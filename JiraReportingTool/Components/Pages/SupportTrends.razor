                        @if (!DisplayedBugs.Any()) { <tr><td colspan="10" class="st-muted-cell">No bugs match this filter.</td></tr> }
                    </tbody>
                </table>
            </div>
        </div>
        }
    }
</div>

@code {
    private List<SprintConfig> _configs = new();
    private List<string> _epicKeys = new();
    private List<string> _failedEpics = new();
    private List<SprintIssue> _allBugsPool = new();   // epic children + JSSUPPORT-linked, unfiltered
    private List<SprintIssue> _bugs = new();          // _allBugsPool after the Product filter
    private bool _linkedFetchFailed;

    // ── Product (JS Project) filter — applies to the entire page ─────────────
    private HashSet<string> _selectedProducts = new();
    private bool _productDdOpen;
    private const string NoProductLabel = "—";

    private static string ProductOf(SprintIssue b) =>
        string.IsNullOrWhiteSpace(b.Product) ? NoProductLabel : b.Product;

    private List<(string Name, int Count)> AllProducts => _allBugsPool
        .GroupBy(ProductOf)
        .Select(g => (Name: g.Key, Count: g.Count()))
        .OrderBy(g => g.Name == NoProductLabel ? 1 : 0)
        .ThenBy(g => g.Name)
        .ToList();

    private void ToggleProduct(string p)
    {
        if (!_selectedProducts.Remove(p)) _selectedProducts.Add(p);
        ApplyPoolFilters();
    }

    private void ClearProducts()
    {
        _selectedProducts.Clear();
        ApplyPoolFilters();
    }

    // ── Sprint filter — applies to the entire page ───────────────────────────
    // A bug belongs to a selected sprint if it's a child of that sprint's planning
    // epic, or its Jira sprint history touches that sprint (covers JSSUPPORT-linked
    // tickets that were pulled into a sprint without living under its epic).
    private HashSet<string> _selectedSprints = new();
    private bool _sprintDdOpen;

    private List<(string Name, int Count)> AllSprintOptions => _configs
        .OrderByDescending(c => c.StartDate)
        .Select(c => (Name: ConfigName(c), Count: _allBugsPool.Count(b => BugInConfigSprint(b, c))))
        .ToList();

    private bool BugInConfigSprint(SprintIssue b, SprintConfig c) =>
        (!string.IsNullOrWhiteSpace(c.EpicKey) &&
         string.Equals(b.EpicKey?.Trim(), c.EpicKey.Trim(), StringComparison.OrdinalIgnoreCase))
        || b.Sprints.Any(js => SprintMatches(js, c));

    private bool MatchesSprintFilter(SprintIssue b) =>
        _selectedSprints.Count == 0
        || _configs.Any(c => _selectedSprints.Contains(ConfigName(c)) && BugInConfigSprint(b, c));

    private void ToggleSprintFilter(string s)
    {
        if (!_selectedSprints.Remove(s)) _selectedSprints.Add(s);
        ApplyPoolFilters();
    }

    private void ClearSprintFilters()
    {
        _selectedSprints.Clear();
        ApplyPoolFilters();
    }

    private bool HasPoolFilter => _selectedProducts.Count > 0 || _selectedSprints.Count > 0;

    private void ApplyPoolFilters()
    {
        _bugs = HasPoolFilter
            ? _allBugsPool.Where(b =>
                (_selectedProducts.Count == 0 || _selectedProducts.Contains(ProductOf(b))) &&
                MatchesSprintFilter(b)).ToList()
            : _allBugsPool;
        _chartsNeedRender = true;
    }

    private DateOnly _fullStart = DateOnly.FromDateTime(DateTime.Today.AddMonths(-6));
    private DateOnly _fullEnd   = DateOnly.FromDateTime(DateTime.Today);
    private DateOnly _rangeStart;
    private DateOnly _rangeEnd;

    private bool _loading;
    private string _error = "";
    private int _epicsTotal;
    private int _epicsLoaded;
    private bool _chartsNeedRender;

    // ── Tabs ──
    private string _tab = "overview";
    private string _bugFilter = "all";
    private record TabDef(string Key, string Label, string Icon);
    private static readonly TabDef[] _tabs =
    {
        new("overview",   "Overview",   "bi-speedometer2"),
        new("metrics",    "Metrics",    "bi-bar-chart-line"),
        new("sprints",    "Sprints",    "bi-calendar3"),
        new("breakdowns", "Breakdowns", "bi-diagram-3"),
        new("bugs",       "Bugs",       "bi-bug"),
    };

    private void SetTab(string t)
    {
        _tab = t;
        _chartsNeedRender = true;   // charts live inside tab panels; re-render when one becomes visible
    }

    private void SetBugFilter(string f) { _bugFilter = f; _chartsNeedRender = true; }

    // ── Bug explorer: customer filter + column sorting ───────────────────────
    private const string NoCustomerLabel = "(none)";
    private HashSet<string> _selectedCustomers = new();
    private bool _showCustomerFilter;
    private string _bugSearch = "";
    private string _bugSortCol = "";
    private bool _bugSortAsc = true;

    private IEnumerable<string> AllBugCustomers =>
        _bugs.Select(b => string.IsNullOrWhiteSpace(b.Customer) ? NoCustomerLabel : b.Customer)
             .Distinct()
             .OrderBy(c => c == NoCustomerLabel ? 1 : 0)
             .ThenBy(c => c);

    private void ToggleCustomer(string customer)
    {
        if (!_selectedCustomers.Remove(customer)) _selectedCustomers.Add(customer);
        _chartsNeedRender = true;
    }
    private void SelectAllCustomers() { _selectedCustomers = new HashSet<string>(AllBugCustomers); _chartsNeedRender = true; }
    private void ClearCustomers() { _selectedCustomers.Clear(); _chartsNeedRender = true; }

    private void BugSort(string col)
    {
        if (_bugSortCol == col) _bugSortAsc = !_bugSortAsc;
        else { _bugSortCol = col; _bugSortAsc = true; }
    }
    private string BugSI(string col) => _bugSortCol == col ? (_bugSortAsc ? "sort-asc" : "sort-desc") : "";

    // ── Lifecycle ───────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        _configs = await SprintConfigService.GetAllAsync();
        _epicKeys = _configs
            .Where(c => !string.IsNullOrWhiteSpace(c.EpicKey))
            .Select(c => c.EpicKey.Trim().ToUpperInvariant())
            .Distinct()
            .ToList();

        if (_configs.Count > 0)
        {
            _fullStart = _configs.Min(c => c.StartDate);
            _fullEnd   = _configs.Max(c => c.EndDate);
            _rangeStart = _fullStart;
            _rangeEnd   = _fullEnd;
        }

        if (_epicKeys.Count > 0) await ReloadAsync();
    }

    private bool _forceReload;
    private DateTime? _oldestSync;

    private Task ReloadAsync() => ReloadCoreAsync(force: false);

    /// <summary>Hard refresh: bypasses the DB cache, re-fetches every epic from Jira, and rebuilds the stored copies.</summary>
    private Task ForceReloadAsync() => ReloadCoreAsync(force: true);

    private async Task ReloadCoreAsync(bool force)
    {
        _forceReload = force;
        _loading = true;
        _error = "";
        _failedEpics = new();
        _epicsTotal = _epicKeys.Count;
        _epicsLoaded = 0;
        _oldestSync = null;
        StateHasChanged();

        try
        {
            // Sequential on purpose: the cached fetches share the circuit's scoped DbContext,
            // which is not thread-safe. Closed sprints come straight from the DB, so only the
            // current sprint's hot window actually hits Jira on a normal reload.
            var results = new List<List<SprintIssue>>();
            foreach (var epicKey in _epicKeys)
                results.Add(await FetchEpicAsync(epicKey));

            // Pool + de-dupe by issue key (an issue could surface under more than one epic).
            var pool = results
                .SelectMany(r => r)
                .GroupBy(b => b.Key)
                .Select(g => g.First())
                .ToList();

            // JSSUPPORT-linked bugs outside the configured epics — same set as the Support
            // Bugs page's "JSSUPPORT Linked" tab: linked to a JSSUPPORT ticket, with worklog
            // activity since the full window start.
            _linkedFetchFailed = false;
            try
            {
                var linked = await JiraService.GetJsSupportLinkedBugsAsync(_fullStart, _fullEnd, _forceReload);
                TrackSync(linked.SyncedAt);
                var known = pool.Select(b => b.Key).ToHashSet(StringComparer.OrdinalIgnoreCase);
                var startAt = _fullStart.ToDateTime(TimeOnly.MinValue);
                var extra = (linked.Issues ?? new())
                    .Where(b => !known.Contains(b.Key))
                    .Where(b => b.LinkedIssueKeys.Any(k => k.StartsWith("JSSUPPORT", StringComparison.OrdinalIgnoreCase)))
                    .Where(b => b.Worklogs.Any(w => w.TimeSpentSeconds > 0 && w.Started >= startAt))
                    .ToList();
                foreach (var b in extra) b.EpicName = "JSSUPPORT Linked";   // origin marker
                pool.AddRange(extra);
            }
            catch { _linkedFetchFailed = true; }

            _allBugsPool = pool;
            ApplyPoolFilters();
        }
        catch (Exception ex)
        {
            _error = $"Failed to load trends: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void TrackSync(DateTime? syncedAt)
    {
        if (syncedAt.HasValue && (_oldestSync is null || syncedAt < _oldestSync))
            _oldestSync = syncedAt;
    }

    private async Task<List<SprintIssue>> FetchEpicAsync(string epicKey)
    {
        try
        {
            // Cached fetch (includes every child type under the epic, so logged hours
            // reconcile with a Jira "parent = EPIC" total). Closed sprints are served from
            // the DB; the current sprint merges a delta of recently-updated issues.
            var sprintEnd = _configs
                .Where(c => string.Equals(c.EpicKey.Trim(), epicKey, StringComparison.OrdinalIgnoreCase))
                .Select(c => (DateOnly?)c.EndDate)
                .DefaultIfEmpty(null)
                .Max();
            var report = await JiraService.GetSupportEpicBugsAsync(epicKey, sprintEnd, _forceReload);
            TrackSync(report.SyncedAt);
            return report.Issues ?? new();
        }
        catch
        {
            _failedEpics.Add(epicKey);
            return new();
        }
        finally
        {
            Interlocked.Increment(ref _epicsLoaded);
            await InvokeAsync(StateHasChanged);
        }
    }

    private void OnRangeChanged()
    {
        if (_rangeEnd < _rangeStart) (_rangeStart, _rangeEnd) = (_rangeEnd, _rangeStart);
        _chartsNeedRender = true;
    }

    private void ResetRange()
    {
        _rangeStart = _fullStart;
        _rangeEnd   = _fullEnd;
        _chartsNeedRender = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_chartsNeedRender && _bugs.Count > 0 && !_loading)
        {
            _chartsNeedRender = false;
            await RenderChartsAsync();
        }
    }

    // ── Window helpers ──────────────────────────────────────────────────────
    private bool InRange(DateTime? d) =>
        d.HasValue && DateOnly.FromDateTime(d.Value) >= _rangeStart && DateOnly.FromDateTime(d.Value) <= _rangeEnd;

    private static bool InWin(DateTime? d, DateOnly s, DateOnly e) =>
        d.HasValue && DateOnly.FromDateTime(d.Value) >= s && DateOnly.FromDateTime(d.Value) <= e;

    private static bool IsDone(SprintIssue b) =>
        b.StatusCategoryKey == "done" || string.Equals(b.Status, "done", StringComparison.OrdinalIgnoreCase);

    private static int GetDaysOpen(SprintIssue b) =>
        b.Created.HasValue ? Math.Max(0, (int)(DateTime.Today - b.Created.Value.Date).TotalDays) : 0;

    private string GetHealth(SprintIssue b)
    {
        if (IsDone(b)) return "done";
        if (!b.DueDate.HasValue) return "no-due-date";
        if (b.DueDate.Value.Date <= DateTime.Today) return "overdue";
        return (b.DueDate.Value.Date - DateTime.Today).Days <= 7 ? "at-risk" : "on-track";
    }

    private static int GetSlaDays(SprintIssue b) => b.Priority?.ToLowerInvariant() switch
    {
        "critical" or "highest" => 1,
        "high"                  => 7,
        "medium"                => 14,
        _                       => 30
    };
    private string GetSlaBucket(SprintIssue b)
    {
        if (IsDone(b)) return "done";
        return GetDaysOpen(b) - GetSlaDays(b) <= 0 ? "inside" : "breached";
    }

    private static double? AvgResolveOf(IEnumerable<SprintIssue> bugs)
    {
        var closed = bugs.Where(b => b.ResolutionDate.HasValue && b.Created.HasValue).ToList();
        if (closed.Count == 0) return null;
        return closed.Average(b => (b.ResolutionDate!.Value.Date - b.Created!.Value.Date).TotalDays);
    }

    // ── Lifecycle metrics (window-scoped flow, all-time state) ───────────────
    private int OpenCount            => _bugs.Count(b => !IsDone(b));
    private int DoneCount            => _bugs.Count(IsDone);
    private int CreatedCount         => _bugs.Count(b => InRange(b.Created));
    private int WorkedOnCount        => _bugs.Count(b => b.Worklogs.Any(w => InRange(w.Started)));
    private int ClosedCount          => _bugs.Count(b => InRange(b.ResolutionDate));
    private int NetFlow              => ClosedCount - CreatedCount;
    private int CarriedOverOpenCount => _bugs.Count(b => !IsDone(b) && b.Created.HasValue && DateOnly.FromDateTime(b.Created.Value) < _rangeStart);
    private int ReopenedCount        => _bugs.Count(b => b.QaRejectedCount > 0);
    private double? AvgResolveDays   => AvgResolveOf(_bugs.Where(b => InRange(b.ResolutionDate)));

    // ── Effort metrics ──────────────────────────────────────────────────────
    private int WindowLoggedSeconds => _bugs.Sum(b => b.Worklogs.Where(w => InRange(w.Started)).Sum(w => w.TimeSpentSeconds));
    private int WindowWorklogCount  => _bugs.Sum(b => b.Worklogs.Count(w => InRange(w.Started)));
    private int TotalLoggedSeconds  => _bugs.Sum(b => b.TimeSpentSeconds);
    private int RemainingSeconds    => _bugs.Where(b => !IsDone(b)).Sum(b => b.ComputedRemainingSeconds);
    private int BugsNoTimeOpen      => _bugs.Count(b => !IsDone(b) && b.TimeSpentSeconds == 0);
    private int AvgLoggedPerBugSeconds
    {
        get { var w = _bugs.Where(b => b.TimeSpentSeconds > 0).ToList(); return w.Count == 0 ? 0 : (int)w.Average(b => b.TimeSpentSeconds); }
    }
    private int WindowWeeks => Math.Max(1, (_rangeEnd.DayNumber - _rangeStart.DayNumber + 1 + 6) / 7);
    private double WeeklyBurnHours => WindowLoggedSeconds / 3600.0 / WindowWeeks;

    // ── Effort & Time, computed for an arbitrary issue subset ─────────────────
    // Overview splits Effort & Time into Bug-type and Redesign-type sections, so
    // the same metric set is derived once per subset instead of only over _bugs.
    private record EffortStats(int Count, int WindowLoggedSeconds, int WindowWorklogCount,
        int TotalLoggedSeconds, int RemainingSeconds, double WeeklyBurnHours, int WindowWeeks,
        int AvgLoggedSeconds, int NoTimeOpen, int Overdue, int SlaBreached, double AvgOpenAgeDays);

    private IEnumerable<SprintIssue> BugTypeIssues =>
        _bugs.Where(b => string.Equals(b.IssueType, "Bug", StringComparison.OrdinalIgnoreCase));
    private IEnumerable<SprintIssue> RedesignTypeIssues =>
        _bugs.Where(b => string.Equals(b.IssueType, "Redesign", StringComparison.OrdinalIgnoreCase));

    private EffortStats EffortStatsFor(IEnumerable<SprintIssue> src)
    {
        var list          = src.ToList();
        var windowLogged  = list.Sum(b => b.Worklogs.Where(w => InRange(w.Started)).Sum(w => w.TimeSpentSeconds));
        var windowLogs    = list.Sum(b => b.Worklogs.Count(w => InRange(w.Started)));
        var withTime      = list.Where(b => b.TimeSpentSeconds > 0).ToList();
        var open          = list.Where(b => !IsDone(b)).ToList();
        return new EffortStats(
            Count:              list.Count,
            WindowLoggedSeconds: windowLogged,
            WindowWorklogCount:  windowLogs,
            TotalLoggedSeconds:  list.Sum(b => b.TimeSpentSeconds),
            RemainingSeconds:    open.Sum(b => b.ComputedRemainingSeconds),
            WeeklyBurnHours:     windowLogged / 3600.0 / WindowWeeks,
            WindowWeeks:         WindowWeeks,
            AvgLoggedSeconds:    withTime.Count == 0 ? 0 : (int)withTime.Average(b => b.TimeSpentSeconds),
            NoTimeOpen:          list.Count(b => !IsDone(b) && b.TimeSpentSeconds == 0),
            Overdue:             list.Count(b => GetHealth(b) == "overdue"),
            SlaBreached:         list.Count(b => GetSlaBucket(b) == "breached"),
            AvgOpenAgeDays:      open.Count == 0 ? 0 : open.Average(GetDaysOpen));
    }

    // ── Health / SLA / aging ────────────────────────────────────────────────
    private int OverdueCount     => _bugs.Count(b => GetHealth(b) == "overdue");
    private int SlaBreachedCount => _bugs.Count(b => GetSlaBucket(b) == "breached");
    private double AvgOpenAgeDays
    {
        get { var open = _bugs.Where(b => !IsDone(b)).ToList(); return open.Count == 0 ? 0 : open.Average(GetDaysOpen); }
    }

    private static readonly string[] PriorityOrder = { "Critical", "Highest", "High", "Medium", "Low", "Lowest" };

    // ── Tickets by priority (all-time counts) ─────────────────────────────────
    private record PriorityCount(string Name, int Total, int Open, int Closed, double? AvgFixHours);
    private IEnumerable<PriorityCount> ByPriority =>
        _bugs.GroupBy(b => string.IsNullOrWhiteSpace(b.Priority) ? "Medium" : b.Priority)
             .Select(g => new PriorityCount(g.Key, g.Count(), g.Count(b => !IsDone(b)), g.Count(IsDone), AvgDevReadyToDoneHoursOf(g)))
             .OrderBy(p => { var i = Array.IndexOf(PriorityOrder, p.Name); return i < 0 ? 99 : i; });

    // Same priority breakdown as ByPriority, but scoped to the tickets that belonged to one
    // sprint — powers the per-sprint "breakdown of the breakdown" on the Sprints tab.
    // Passing an issueType ("Bug" / "Redesign") narrows the set to that type.
    private IEnumerable<PriorityCount> SprintPriorityBreakdown(string sprintName, string? issueType = null)
    {
        var src = BugsInSprint(sprintName);
        if (issueType is not null)
            src = src.Where(b => string.Equals(b.IssueType, issueType, StringComparison.OrdinalIgnoreCase));
        return src
             .GroupBy(b => string.IsNullOrWhiteSpace(b.Priority) ? "Medium" : b.Priority)
             .Select(g => new PriorityCount(g.Key, g.Count(), g.Count(b => !IsDone(b)), g.Count(IsDone), AvgDevReadyToDoneHoursOf(g)))
             .OrderBy(p => { var i = Array.IndexOf(PriorityOrder, p.Name); return i < 0 ? 99 : i; });
    }

    // Avg logged worklog effort (hours) from first "Dev Ready" transition until resolution,
    // across done bugs that have both timestamps. Same approach as the support-bugs dashboard.
    private static int WorklogSecondsBetween(SprintIssue b, DateTime from, DateTime to)
        => b.Worklogs.Where(w => w.Started >= from && w.Started <= to).Sum(w => w.TimeSpentSeconds);

    private static double? AvgDevReadyToDoneHoursOf(IEnumerable<SprintIssue> bugs)
    {
        var list = bugs.Where(b => IsDone(b) && b.DevReadyDate.HasValue && b.ResolutionDate.HasValue
                                && b.ResolutionDate!.Value > b.DevReadyDate!.Value).ToList();
        if (list.Count == 0) return null;
        return list.Average(b => WorklogSecondsBetween(b, b.DevReadyDate!.Value, b.ResolutionDate!.Value) / 3600.0);
    }

    // ── Bug explorer ──────────────────────────────────────────────────────────
    // Slow-lifecycle threshold (calendar days) for the longest phase, Dev Ready → Done.
    private const double SlowLifecycleDays = 10;

    private record BugFlag(string Label, string Cls);

    // Returns the critical flags that apply to a bug (empty = not critical).
    private List<BugFlag> BugFlags(SprintIssue b)
    {
        var flags = new List<BugFlag>();
        var devDone = PhaseDays(b.DevReadyDate, b.ResolutionDate);
        if (devDone.HasValue && devDone.Value >= SlowLifecycleDays) flags.Add(new("Slow lifecycle", "st-flag-slow"));
        if (IsHighPriority(b)) flags.Add(new("High priority", "st-flag-prio"));
        if (b.QaRejectedCount > 0) flags.Add(new("QA bounced", "st-flag-qa"));
        return flags;
    }

    private static bool IsHighPriority(SprintIssue b) =>
        b.Priority?.ToLowerInvariant() is "critical" or "highest";

    private IEnumerable<SprintIssue> CriticalBugs => _bugs.Where(b => BugFlags(b).Count > 0);

    // Bugs shown in the explorer: status filter + customer filter, then sorted.
    private IEnumerable<SprintIssue> DisplayedBugs
    {
        get
        {
            IEnumerable<SprintIssue> src = _bugFilter == "critical" ? CriticalBugs : _bugs;
            if (_selectedCustomers.Count > 0)
                src = src.Where(b => _selectedCustomers.Contains(string.IsNullOrWhiteSpace(b.Customer) ? NoCustomerLabel : b.Customer));

            if (!string.IsNullOrWhiteSpace(_bugSearch))
            {
                var q = _bugSearch.Trim();
                src = src.Where(b => (b.Key?.Contains(q, StringComparison.OrdinalIgnoreCase) ?? false)
                                  || (b.Summary?.Contains(q, StringComparison.OrdinalIgnoreCase) ?? false));
            }

            // No explicit column sort → default worst-first ordering (critical, then longest in-flow).
            if (string.IsNullOrEmpty(_bugSortCol))
                return src.OrderByDescending(b => BugFlags(b).Count)
                          .ThenByDescending(b => PhaseDays(b.DevReadyDate, b.ResolutionDate) ?? -1)
                          .ThenByDescending(b => b.Created ?? DateTime.MinValue);

            return ApplyBugSort(src);
        }
    }

    private IEnumerable<SprintIssue> ApplyBugSort(IEnumerable<SprintIssue> src)
    {
        var asc = _bugSortAsc;
        // Missing phase timings sort last regardless of direction.
        return _bugSortCol switch
        {
            "key"      => asc ? src.OrderBy(b => b.Key)                  : src.OrderByDescending(b => b.Key),
            "summary"  => asc ? src.OrderBy(b => b.Summary)              : src.OrderByDescending(b => b.Summary),
            "customer" => asc ? src.OrderBy(b => CustomerKey(b))         : src.OrderByDescending(b => CustomerKey(b)),
            "priority" => asc ? src.OrderBy(b => PriOrder(b))            : src.OrderByDescending(b => PriOrder(b)),
            "status"   => asc ? src.OrderBy(b => b.Status)               : src.OrderByDescending(b => b.Status),
            "devqa"    => asc ? src.OrderBy(b => PhaseLoggedSeconds(b, b.DevReadyDate, b.QaReadyDate)    ?? int.MaxValue) : src.OrderByDescending(b => PhaseLoggedSeconds(b, b.DevReadyDate, b.QaReadyDate)    ?? int.MinValue),
            "qadone"   => asc ? src.OrderBy(b => PhaseLoggedSeconds(b, b.QaReadyDate, b.ResolutionDate)  ?? int.MaxValue) : src.OrderByDescending(b => PhaseLoggedSeconds(b, b.QaReadyDate, b.ResolutionDate)  ?? int.MinValue),
            "devdone"  => asc ? src.OrderBy(b => PhaseLoggedSeconds(b, b.DevReadyDate, b.ResolutionDate) ?? int.MaxValue) : src.OrderByDescending(b => PhaseLoggedSeconds(b, b.DevReadyDate, b.ResolutionDate) ?? int.MinValue),
            "qarej"    => asc ? src.OrderBy(b => b.QaRejectedCount)      : src.OrderByDescending(b => b.QaRejectedCount),
            "logged"   => asc ? src.OrderBy(b => b.TimeSpentSeconds)     : src.OrderByDescending(b => b.TimeSpentSeconds),
            _          => src
        };
    }

    private static int PriOrder(SprintIssue b)
    {
        var i = Array.IndexOf(PriorityOrder, string.IsNullOrWhiteSpace(b.Priority) ? "Medium" : b.Priority);
        return i < 0 ? 99 : i;
    }

    private static string CustomerKey(SprintIssue b) =>
        string.IsNullOrWhiteSpace(b.Customer) ? NoCustomerLabel : b.Customer;

    // Calendar days between two lifecycle markers; null if either is missing or out of order.
    private static double? PhaseDays(DateTime? from, DateTime? to)
    {
        if (!from.HasValue || !to.HasValue) return null;
        var d = (to.Value - from.Value).TotalDays;
        return d < 0 ? null : d;
    }

    private static string PhaseLabel(double? days) =>
        days.HasValue ? $"{days.Value:0.0}d" : "—";

    // Amber/red emphasis once a phase runs long.
    private static string PhaseCls(double? days, double warnDays)
    {
        if (!days.HasValue) return "";
        if (days.Value >= warnDays * 2) return "v2-text-danger";
        if (days.Value >= warnDays) return "st-text-warn";
        return "";
    }

    // Worklog effort (seconds) logged within a lifecycle phase: the sum of every worklog
    // whose "started" timestamp falls between the two markers. Null when either marker is
    // missing or out of order (so the cell renders "—" rather than a misleading 0h).
    private static int? PhaseLoggedSeconds(SprintIssue b, DateTime? from, DateTime? to)
    {
        if (!from.HasValue || !to.HasValue || to.Value < from.Value) return null;
        return WorklogSecondsBetween(b, from.Value, to.Value);
    }

    private static string PhaseHrsLabel(int? seconds) =>
        seconds.HasValue ? FmtHM(seconds.Value) : "—";

    // Amber/red emphasis once the logged effort in a phase gets heavy.
    private static string PhaseHrsCls(int? seconds, double warnHours)
    {
        if (!seconds.HasValue) return "";
        var h = seconds.Value / 3600.0;
        if (h >= warnHours * 2) return "v2-text-danger";
        if (h >= warnHours) return "st-text-warn";
        return "";
    }

    private string JiraUrl(string key) => $"{Config["Jira:BaseUrl"]?.TrimEnd('/')}/browse/{key}";

    // "% of total bugs" cell content.
    private static string ShareCell(int part, int whole) =>
        whole <= 0 ? "—" : $"{part * 100.0 / whole:0.0}%";

    // ── Breakdowns ──────────────────────────────────────────────────────────
    private record GroupStat(string Name, int Total, int Closed, int Open, int LoggedSeconds, int WindowLoggedSeconds, double? AvgResolve,
        int LoggedDoneSeconds = 0);   // logged (in window) on Done tickets only — filled by the Sprints-tab breakdowns

    private IEnumerable<GroupStat> ByCustomer =>
        _bugs.Where(b => !string.IsNullOrWhiteSpace(b.Customer))
             .GroupBy(b => b.Customer)
             .Select(g => new GroupStat(g.Key, g.Count(), g.Count(IsDone), g.Count(b => !IsDone(b)),
                 g.Sum(b => b.TimeSpentSeconds),
                 g.Sum(b => b.Worklogs.Where(w => InRange(w.Started)).Sum(w => w.TimeSpentSeconds)),
                 AvgResolveOf(g)));

    private IEnumerable<GroupStat> ByLabel =>
        _bugs.SelectMany(b => (b.Labels ?? new()).Select(l => (Label: l, Bug: b)))
             .Where(x => !string.IsNullOrWhiteSpace(x.Label))
             .GroupBy(x => x.Label)
             .Select(g => new GroupStat(g.Key, g.Count(), g.Count(x => IsDone(x.Bug)), g.Count(x => !IsDone(x.Bug)),
                 g.Sum(x => x.Bug.TimeSpentSeconds),
                 g.Sum(x => x.Bug.Worklogs.Where(w => InRange(w.Started)).Sum(w => w.TimeSpentSeconds)),
                 AvgResolveOf(g.Select(x => x.Bug))));

    // Worklog-author breakdown: who actually logged work, regardless of current assignee.
    // Mirrors the Metrics tab "Worklog effort by author" chart (same logged-hours totals),
    // but as a sortable/filterable table with the bugs they touched.
    private IEnumerable<GroupStat> WorkedBy =>
        _bugs.SelectMany(b => b.Worklogs
                 .Where(w => !string.IsNullOrWhiteSpace(w.Author))
                 .Select(w => (Author: w.Author, Bug: b, Sec: w.TimeSpentSeconds,
                               WinSec: InRange(w.Started) ? w.TimeSpentSeconds : 0)))
             .GroupBy(x => x.Author)
             .Select(g =>
             {
                 var bugs = g.Select(x => x.Bug).DistinctBy(b => b.Key).ToList();
                 return new GroupStat(
                     g.Key,
                     bugs.Count,
                     bugs.Count(IsDone),
                     bugs.Count(b => !IsDone(b)),
                     g.Sum(x => x.Sec),
                     g.Sum(x => x.WinSec),
                     AvgResolveOf(bugs));
             });

    // ── Breakdown table sort + filter (Breakdowns tab) ───────────────────────
    private string _custSortCol = "total", _labelSortCol = "total", _workedSortCol = "logged";
    private bool _custAsc = false, _labelAsc = false, _workedAsc = false;
    private string _custFilter = "", _labelFilter = "", _workedFilter = "";

    private void CustSort(string col)   { if (_custSortCol == col) _custAsc = !_custAsc; else { _custSortCol = col; _custAsc = false; } }
    private void LabelSort(string col)  { if (_labelSortCol == col) _labelAsc = !_labelAsc; else { _labelSortCol = col; _labelAsc = false; } }
    private void WorkedSort(string col) { if (_workedSortCol == col) _workedAsc = !_workedAsc; else { _workedSortCol = col; _workedAsc = false; } }
    private string CustSI(string col)   => _custSortCol == col ? (_custAsc ? "sort-asc" : "sort-desc") : "";
    private string LabelSI(string col)  => _labelSortCol == col ? (_labelAsc ? "sort-asc" : "sort-desc") : "";
    private string WorkedSI(string col) => _workedSortCol == col ? (_workedAsc ? "sort-asc" : "sort-desc") : "";

    // Filters a breakdown by name substring, then orders by the chosen column.
    private static IEnumerable<GroupStat> SortFilterGroups(IEnumerable<GroupStat> src, string col, bool asc, string filter)
    {
        if (!string.IsNullOrWhiteSpace(filter))
            src = src.Where(g => g.Name.Contains(filter.Trim(), StringComparison.OrdinalIgnoreCase));
        Func<GroupStat, object> key = col switch
        {
            "name"    => g => g.Name,
            "closed"  => g => g.Closed,
            "open"    => g => g.Open,
            "logged"  => g => g.LoggedSeconds,
            "wlogged" => g => g.WindowLoggedSeconds,
            "resolve" => g => g.AvgResolve ?? double.MaxValue,
            _         => g => g.Total
        };
        return asc ? src.OrderBy(key) : src.OrderByDescending(key);
    }

    // ── Worklog effort breakdown (Metrics tab) ───────────────────────────────
    // Worklog effort by author across EVERY bug (all time — matches the Bugs tab set).
    private record WorklogGroup(string Name, double TotalHours, int Entries, double AvgHours);

    private List<WorklogGroup> WlAuthorAllTime =>
        _bugs.SelectMany(b => b.Worklogs)
             .Select(w => (Key: string.IsNullOrWhiteSpace(w.Author) ? "Unknown" : w.Author, Sec: w.TimeSpentSeconds))
             .GroupBy(x => x.Key)
             .Select(g =>
             {
                 var entries = g.Count();
                 var hours   = g.Sum(x => x.Sec) / 3600.0;
                 return new WorklogGroup(g.Key, hours, entries, entries == 0 ? 0 : hours / entries);
             })
             .OrderByDescending(g => g.TotalHours)
             .ToList();

    // ── Sprint-over-sprint (epic-scoped, with sprint-field carry-over) ─────────
    // Each configured sprint owns one planning epic (e.g. 26.12 → JM-18265), so a
    // sprint's tickets = that epic's children — this reconciles exactly with Jira's
    // `parent = <epic>` count. The Jira sprint field (customfield_10020, captured as
    // issue.Sprints) is then used *only* to detect movement: whether a ticket also
    // lived in an earlier or later configured sprint.

    private string ConfigName(SprintConfig c) => string.IsNullOrWhiteSpace(c.Name) ? c.EpicKey : c.Name;

    // A ticket's Jira sprint entry matches a configured sprint by Sprint ID (exact) —
    // falling back to name-contains ("26.12" ⊆ "Pro 26.12") when no ID is available.
    private static bool SprintMatches(IssueSprint js, SprintConfig cfg) =>
        (cfg.SprintId != 0 && js.Id == cfg.SprintId) ||
        (cfg.SprintId == 0 && js.Id == 0 &&
         !string.IsNullOrWhiteSpace(cfg.Name) && !string.IsNullOrWhiteSpace(js.Name) &&
         js.Name.Contains(cfg.Name.Trim(), StringComparison.OrdinalIgnoreCase));

    // Tickets belonging to a configured sprint = the children of its planning epic.
    private IEnumerable<SprintIssue> EpicBugsFor(SprintConfig c) =>
        _bugs.Where(b => !string.IsNullOrWhiteSpace(c.EpicKey) &&
                         string.Equals(b.EpicKey?.Trim(), c.EpicKey.Trim(), StringComparison.OrdinalIgnoreCase));

    // Ordinals (chronological index) of every configured sprint this ticket's Jira sprint
    // history touches. Used to tell carried-in (was in an earlier sprint) from spilled
    // (also appears in a later sprint).
    private List<int> ConfigSprintOrdinals(SprintIssue b, List<SprintConfig> ordered)
    {
        var set = new HashSet<int>();
        foreach (var js in b.Sprints)
            for (int i = 0; i < ordered.Count; i++)
                if (SprintMatches(js, ordered[i])) { set.Add(i); break; }
        return set.ToList();
    }

    // Bugs of the sprint whose display name is `sprintName` (epic-scoped).
    private IEnumerable<SprintIssue> BugsInSprint(string sprintName)
    {
        var c = _configs.FirstOrDefault(x => ConfigName(x) == sprintName);
        return c == null ? Enumerable.Empty<SprintIssue>() : EpicBugsFor(c);
    }

    private record SprintStat(string Name, DateOnly Start, DateOnly End,
        int InSprint, int New, int CarriedIn, int DoneHere, int SpilledOver,
        int LoggedSeconds, int LoggedDoneSeconds, double CompletionPct, int QaRejected);

    private IEnumerable<SprintStat> SprintStats
    {
        get
        {
            var ordered = _configs.OrderBy(c => c.StartDate).ToList();
            return ordered.Select((c, ord) =>
            {
                var s = c.StartDate; var e = c.EndDate;
                var epicBugs = EpicBugsFor(c).ToList();
                var inSprint = epicBugs.Count;
                var done     = epicBugs.Count(IsDone);
                int isNew = 0, carriedIn = 0, spilled = 0, qa = 0;
                foreach (var b in epicBugs)
                {
                    var ords     = ConfigSprintOrdinals(b, ordered);
                    var earliest = ords.Count > 0 ? ords.Min() : ord;   // no sprint data → treat as new here
                    var latest   = ords.Count > 0 ? ords.Max() : ord;
                    if (earliest < ord) carriedIn++; else isNew++;       // was in an earlier sprint
                    if (latest > ord) spilled++;                          // also appears in a later sprint
                    if (b.QaRejectedCount > 0) qa++;
                }
                var logged = epicBugs.Sum(b => b.Worklogs.Where(w => InWin(w.Started, s, e)).Sum(w => w.TimeSpentSeconds));
                var loggedDone = epicBugs.Where(IsDone).Sum(b => b.Worklogs.Where(w => InWin(w.Started, s, e)).Sum(w => w.TimeSpentSeconds));
                var pct = inSprint == 0 ? 0 : done * 100.0 / inSprint;
                return new SprintStat(ConfigName(c), s, e, inSprint, isNew, carriedIn, done, spilled, logged, loggedDone, pct, qa);
            }).ToList();
        }
    }

    // ── Per-sprint breakdowns (Sprints tab, collapsible) ─────────────────────
    // Same customer / label / worked-by breakdowns as the Breakdowns tab, but scoped
    // to the bugs CREATED inside a given sprint window, with logged hours counted
    // only from worklogs that also fall inside that window.
    private HashSet<string> _expandedSprints = new();
    private void ToggleSprint(string name)
    {
        if (!_expandedSprints.Remove(name)) _expandedSprints.Add(name);
    }

    private List<GroupStat> SprintByCustomer(string sprintName, DateOnly s, DateOnly e) =>
        BugsInSprint(sprintName).Where(b => !string.IsNullOrWhiteSpace(b.Customer))
             .GroupBy(b => b.Customer)
             .Select(g => new GroupStat(g.Key, g.Count(), g.Count(IsDone), g.Count(b => !IsDone(b)),
                 g.Sum(b => b.Worklogs.Where(w => InWin(w.Started, s, e)).Sum(w => w.TimeSpentSeconds)),
                 g.Sum(b => b.Worklogs.Where(w => InWin(w.Started, s, e)).Sum(w => w.TimeSpentSeconds)),
                 AvgResolveOf(g),
                 g.Where(IsDone).Sum(b => b.Worklogs.Where(w => InWin(w.Started, s, e)).Sum(w => w.TimeSpentSeconds))))
             .OrderByDescending(g => g.Total).ThenByDescending(g => g.LoggedSeconds)
             .ToList();

    private List<GroupStat> SprintByLabel(string sprintName, DateOnly s, DateOnly e) =>
        BugsInSprint(sprintName)
             .SelectMany(b => (b.Labels ?? new()).Select(l => (Label: l, Bug: b)))
             .Where(x => !string.IsNullOrWhiteSpace(x.Label))
             .GroupBy(x => x.Label)
             .Select(g => new GroupStat(g.Key, g.Count(), g.Count(x => IsDone(x.Bug)), g.Count(x => !IsDone(x.Bug)),
                 g.Sum(x => x.Bug.Worklogs.Where(w => InWin(w.Started, s, e)).Sum(w => w.TimeSpentSeconds)),
                 g.Sum(x => x.Bug.Worklogs.Where(w => InWin(w.Started, s, e)).Sum(w => w.TimeSpentSeconds)),
                 AvgResolveOf(g.Select(x => x.Bug)),
                 g.Where(x => IsDone(x.Bug)).Sum(x => x.Bug.Worklogs.Where(w => InWin(w.Started, s, e)).Sum(w => w.TimeSpentSeconds))))
             .OrderByDescending(g => g.Total).ThenByDescending(g => g.LoggedSeconds)
             .ToList();

    private List<GroupStat> SprintWorkedBy(string sprintName, DateOnly s, DateOnly e) =>
        BugsInSprint(sprintName)
             .SelectMany(b => b.Worklogs
                 .Where(w => !string.IsNullOrWhiteSpace(w.Author) && InWin(w.Started, s, e))
                 .Select(w => (Author: w.Author, Bug: b, Sec: w.TimeSpentSeconds)))
             .GroupBy(x => x.Author)
             .Select(g =>
             {
                 var bugs = g.Select(x => x.Bug).DistinctBy(b => b.Key).ToList();
                 var sec  = g.Sum(x => x.Sec);
                 var doneSec = g.Where(x => IsDone(x.Bug)).Sum(x => x.Sec);
                 return new GroupStat(g.Key, bugs.Count, bugs.Count(IsDone), bugs.Count(b => !IsDone(b)),
                     sec, sec, AvgResolveOf(bugs), doneSec);
             })
             .OrderByDescending(g => g.LoggedSeconds)
             .ToList();

    // ── Charts ──────────────────────────────────────────────────────────────
    private async Task RenderChartsAsync()
    {
        // Only the active tab's canvases exist in the DOM, so render that tab's charts.
        if (_tab == "overview")
        {
            await JS.InvokeVoidAsync("destroyChart", "st-chart-priority");
            var pr = ByPriority.ToList();
            await JS.InvokeVoidAsync("renderChart", "st-chart-priority", new
            {
                type = "doughnut",
                data = new
                {
                    labels = pr.Select(p => p.Name).ToArray(),
                    datasets = new[] { new
                    {
                        data = pr.Select(p => p.Total).ToArray(),
                        backgroundColor = pr.Select(p => PriorityColor(p.Name)).ToArray(),
                        borderWidth = 0
                    }}
                },
                options = new
                {
                    responsive = true,
                    maintainAspectRatio = false,
                    plugins = new { legend = new { display = true, position = "right" } }
                }
            });
            return;
        }

        if (_tab == "sprints") { await RenderSprintChartsAsync(); return; }

        if (_tab == "bugs") { await RenderBugChartsAsync(); return; }

        if (_tab != "metrics") return;

        foreach (var id in new[] { "st-chart-m-author", "st-chart-m-customer", "st-chart-m-label" })
            await JS.InvokeVoidAsync("destroyChart", id);

        // Worklog effort by author across every bug (all time).
        var auth = WlAuthorAllTime.Take(20).ToList();
        await JS.InvokeVoidAsync("renderChart", "st-chart-m-author", new
        {
            type = "bar",
            data = new
            {
                labels = auth.Select(g => g.Name).ToArray(),
                datasets = new[] { new
                {
                    label = "Hours",
                    data = auth.Select(g => Math.Round(g.TotalHours, 1)).ToArray(),
                    backgroundColor = "#2563eb",
                    borderRadius = 4
                }}
            },
            options = new
            {
                indexAxis = "y",
                responsive = true,
                maintainAspectRatio = false,
                plugins = new { legend = new { display = false } },
                scales = new { x = new { beginAtZero = true } }
            }
        });

        // By customer — bug count (left axis) + logged hours (right axis).
        var cust = ByCustomer.OrderByDescending(c => c.Total).Take(15).ToList();
        await JS.InvokeVoidAsync("renderChart", "st-chart-m-customer", new
        {
            type = "bar",
            data = new
            {
                labels = cust.Select(c => c.Name).ToArray(),
                datasets = new object[]
                {
                    new { label = "Bugs",  data = cust.Select(c => c.Total).ToArray(), backgroundColor = "#2563eb", borderRadius = 3, yAxisID = "y" },
                    new { label = "Hours", data = cust.Select(c => Math.Round(c.LoggedSeconds / 3600.0, 1)).ToArray(), backgroundColor = "#7c3aed", borderRadius = 3, yAxisID = "y1" }
                }
            },
            options = DualAxisOpts()
        });

        // By label — bug count (left axis) + logged hours (right axis).
        var lab = ByLabel.OrderByDescending(l => l.Total).Take(15).ToList();
        await JS.InvokeVoidAsync("renderChart", "st-chart-m-label", new
        {
            type = "bar",
            data = new
            {
                labels = lab.Select(l => l.Name).ToArray(),
                datasets = new object[]
                {
                    new { label = "Bugs",  data = lab.Select(l => l.Total).ToArray(), backgroundColor = "#16a34a", borderRadius = 3, yAxisID = "y" },
                    new { label = "Hours", data = lab.Select(l => Math.Round(l.LoggedSeconds / 3600.0, 1)).ToArray(), backgroundColor = "#b45309", borderRadius = 3, yAxisID = "y1" }
                }
            },
            options = DualAxisOpts()
        });
    }

    // Grouped-bar options with a left axis (counts) and a right axis (hours).
    private static object DualAxisOpts() => new
    {
        responsive = true,
        maintainAspectRatio = false,
        plugins = new { legend = new { display = true, position = "bottom" } },
        scales = new
        {
            y  = new { type = "linear", position = "left",  beginAtZero = true, ticks = new { precision = 0 }, title = new { display = true, text = "Bugs" } },
            y1 = new { type = "linear", position = "right", beginAtZero = true, grid = new { drawOnChartArea = false }, title = new { display = true, text = "Hours" } }
        }
    };

    private async Task RenderSprintChartsAsync()
    {
        foreach (var id in new[] { "st-chart-sprint-flow", "st-chart-sprint-logged" })
            await JS.InvokeVoidAsync("destroyChart", id);

        var sprints = SprintStats.ToList();
        var sLabels = sprints.Select(s => s.Name).ToArray();
        await JS.InvokeVoidAsync("renderChart", "st-chart-sprint-flow", new
        {
            type = "bar",
            data = new
            {
                labels = sLabels,
                datasets = new object[]
                {
                    new { label = "In Sprint", data = sprints.Select(s => s.InSprint).ToArray(), backgroundColor = "#94a3b8", borderRadius = 3 },
                    new { label = "Done",      data = sprints.Select(s => s.DoneHere).ToArray(), backgroundColor = "#16a34a", borderRadius = 3 }
                }
            },
            options = ChartOpts(true)
        });

        await JS.InvokeVoidAsync("renderChart", "st-chart-sprint-logged", new
        {
            type = "bar",
            data = new
            {
                labels = sLabels,
                datasets = new object[]
                {
                    new { label = "Hours", data = sprints.Select(s => Math.Round(s.LoggedSeconds / 3600.0, 1)).ToArray(), backgroundColor = "#2563eb", borderRadius = 3 }
                }
            },
            options = ChartOpts(false)
        });
    }

    // Bug-tab analytics — all driven by the explorer's current Show/Customer filter (DisplayedBugs).
    private async Task RenderBugChartsAsync()
    {
        foreach (var id in new[] { "st-chart-bug-phases", "st-chart-bug-logged", "st-chart-bug-byprio", "st-chart-bug-qarej" })
            await JS.InvokeVoidAsync("destroyChart", id);

        var bugs = DisplayedBugs.ToList();

        // 1. Average phase timing (calendar days) across bugs that reached each marker.
        double AvgPhase(Func<SprintIssue, double?> sel)
        {
            var vals = bugs.Select(sel).Where(v => v.HasValue).Select(v => v!.Value).ToList();
            return vals.Count == 0 ? 0 : Math.Round(vals.Average(), 1);
        }
        await JS.InvokeVoidAsync("renderChart", "st-chart-bug-phases", new
        {
            type = "bar",
            data = new
            {
                labels = new[] { "Dev→QA", "QA→Done", "Dev→Done" },
                datasets = new[] { new
                {
                    label = "Avg days",
                    data = new[]
                    {
                        AvgPhase(b => PhaseDays(b.DevReadyDate, b.QaReadyDate)),
                        AvgPhase(b => PhaseDays(b.QaReadyDate, b.ResolutionDate)),
                        AvgPhase(b => PhaseDays(b.DevReadyDate, b.ResolutionDate))
                    },
                    backgroundColor = new[] { "#2563eb", "#7c3aed", "#b45309" },
                    borderRadius = 4
                }}
            },
            options = ChartOpts(false)
        });

        // 2. Logged-hours distribution — bug count per effort bucket.
        var hrBuckets = new (string Label, Func<double, bool> Test)[]
        {
            ("0h",     h => h == 0),
            ("<2h",    h => h > 0 && h < 2),
            ("2–5h",   h => h >= 2 && h < 5),
            ("5–10h",  h => h >= 5 && h < 10),
            ("10–20h", h => h >= 10 && h < 20),
            ("20h+",   h => h >= 20),
        };
        var hours = bugs.Select(b => b.TimeSpentSeconds / 3600.0).ToList();
        await JS.InvokeVoidAsync("renderChart", "st-chart-bug-logged", new
        {
            type = "bar",
            data = new
            {
                labels = hrBuckets.Select(x => x.Label).ToArray(),
                datasets = new[] { new
                {
                    label = "Bugs",
                    data = hrBuckets.Select(x => hours.Count(x.Test)).ToArray(),
                    backgroundColor = "#2563eb",
                    borderRadius = 4
                }}
            },
            options = ChartOpts(false)
        });

        // 3. Average logged hours per bug, grouped by priority (bugs with time logged).
        var byPrio = PriorityOrder
            .Select(p => new
            {
                Name = p,
                Logged = bugs.Where(b => string.Equals(b.Priority, p, StringComparison.OrdinalIgnoreCase)
                                      && b.TimeSpentSeconds > 0).ToList()
            })
            .Where(g => g.Logged.Count > 0)
            .ToList();
        await JS.InvokeVoidAsync("renderChart", "st-chart-bug-byprio", new
        {
            type = "bar",
            data = new
            {
                labels = byPrio.Select(g => g.Name).ToArray(),
                datasets = new[] { new
                {
                    label = "Avg h / bug",
                    data = byPrio.Select(g => Math.Round(g.Logged.Average(b => b.TimeSpentSeconds) / 3600.0, 1)).ToArray(),
                    backgroundColor = byPrio.Select(g => PriorityColor(g.Name)).ToArray(),
                    borderRadius = 4
                }}
            },
            options = ChartOpts(false)
        });

        // 4. QA bounce-backs — how many times bugs were kicked back from QA.
        var qaBuckets = new (string Label, Func<SprintIssue, bool> Test)[]
        {
            ("0",  b => b.QaRejectedCount == 0),
            ("1",  b => b.QaRejectedCount == 1),
            ("2",  b => b.QaRejectedCount == 2),
            ("3+", b => b.QaRejectedCount >= 3),
        };
        await JS.InvokeVoidAsync("renderChart", "st-chart-bug-qarej", new
        {
            type = "bar",
            data = new
            {
                labels = qaBuckets.Select(x => x.Label).ToArray(),
                datasets = new[] { new
                {
                    label = "Bugs",
                    data = qaBuckets.Select(x => bugs.Count(x.Test)).ToArray(),
                    backgroundColor = new[] { "#16a34a", "#b45309", "#dc2626", "#991b1b" },
                    borderRadius = 4
                }}
            },
            options = ChartOpts(false)
        });
    }

    private static object ChartOpts(bool legend) => new
    {
        responsive = true,
        maintainAspectRatio = false,
        plugins = new { legend = new { display = legend, position = "bottom" } },
        scales = new { y = new { beginAtZero = true, ticks = new { precision = 0 } } }
    };

    // ── Formatting helpers ──────────────────────────────────────────────────
    private static string FmtHM(int seconds)
    {
        if (seconds <= 0) return "0h";
        var h = seconds / 3600; var m = (seconds % 3600) / 60;
        if (h == 0) return $"{m}m";
        return m > 0 ? $"{h}h {m}m" : $"{h}h";
    }

    private static int Pct(int part, int whole) => whole <= 0 ? 0 : Math.Min(100, part * 100 / whole);

    private static string PriorityPill(string? p) => p?.ToLowerInvariant() switch
    {
        "critical" or "highest" => "v2-pill-danger",
        "high"                  => "v2-pill-warn",
        "medium"                => "v2-pill-brand",
        _                       => "v2-pill-neutral"
    };

    private static string PriorityColor(string? p) => p?.ToLowerInvariant() switch
    {
        "critical" or "highest" => "#b91c1c",
        "high"                  => "#b45309",
        "medium"                => "#2563eb",
        "low"                   => "#16a34a",
        _                       => "#94a3b8"
    };

    private static string AvatarGrad(string name) => $"v2-avatar-grad-{1 + (Math.Abs(name.GetHashCode()) % 5)}";
    private static string Initials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0) return "?";
        return parts.Length == 1 ? parts[0][..1].ToUpper() : (parts[0][..1] + parts[^1][..1]).ToUpper();
    }

    // ── Reusable render fragments ─────────────────────────────────────────────
    // Effort & Time KPI grid for one issue subset (Bugs / Redesign on the Overview tab).
    private RenderFragment EffortGrid(EffortStats s, string unit) => @<div class="v2-kpi-grid">
        <div class="v2-kpi v2-kpi-neutral">
            <div class="v2-kpi-head"><i class="bi bi-stopwatch"></i>Logged in Window</div>
            <div class="v2-kpi-value">@FmtHM(s.WindowLoggedSeconds)</div>
            <div class="v2-kpi-sub">across @s.WindowWorklogCount worklog@(s.WindowWorklogCount == 1 ? "" : "s")</div>
        </div>
        <div class="v2-kpi v2-kpi-neutral">
            <div class="v2-kpi-head"><i class="bi bi-clock-history"></i>Total Logged</div>
            <div class="v2-kpi-value">@FmtHM(s.TotalLoggedSeconds)</div>
            <div class="v2-kpi-sub">+ @FmtHM(s.RemainingSeconds) remaining (all time)</div>
        </div>
        <div class="v2-kpi v2-kpi-neutral">
            <div class="v2-kpi-head"><i class="bi bi-speedometer"></i>Weekly Burn</div>
            <div class="v2-kpi-value">@($"{s.WeeklyBurnHours:0.0}")<span class="v2-kpi-of">h / wk</span></div>
            <div class="v2-kpi-sub">@s.WindowWeeks week@(s.WindowWeeks == 1 ? "" : "s") in window</div>
        </div>
        <div class="v2-kpi v2-kpi-neutral">
            <div class="v2-kpi-head"><i class="bi bi-clock"></i>Avg Logged / @unit</div>
            <div class="v2-kpi-value">@FmtHM(s.AvgLoggedSeconds)</div>
            <div class="v2-kpi-sub">@(unit.ToLowerInvariant())s with time logged</div>
        </div>
        <div class="v2-kpi @(s.NoTimeOpen == 0 ? "v2-kpi-success" : "v2-kpi-warn")">
            <div class="v2-kpi-head"><i class="bi bi-slash-circle"></i>Open · No Time</div>
            <div class="v2-kpi-value">@s.NoTimeOpen</div>
            <div class="v2-kpi-sub">open with zero logged</div>
        </div>
        <div class="v2-kpi @(s.Overdue == 0 ? "v2-kpi-success" : "v2-kpi-danger")">
            <div class="v2-kpi-head"><i class="bi bi-exclamation-triangle"></i>Overdue</div>
            <div class="v2-kpi-value">@s.Overdue</div>
            <div class="v2-kpi-sub">@s.SlaBreached past SLA · avg age @($"{s.AvgOpenAgeDays:0}")d</div>
        </div>
    </div>;

    // Per-sprint priority table for one issue type (Bugs / Redesign on the Sprints tab).
    // Share is computed within the subset, so each table reads as 100% of its own type.
    private RenderFragment SprintPriorityTable(IReadOnlyList<PriorityCount> rows, int total, string unitLabel) => @<text>
        @if (total == 0)
        {
            <div class="st-muted-cell" style="padding:6px 2px">No @unitLabel.ToLowerInvariant() belonged to this sprint.</div>
        }
        else
        {
            <div class="v2-table-wrap" style="margin:0">
                <table class="v2-table" style="font-size:12px">
                    <thead><tr>
                        <th>Priority</th><th class="v2-table-num">@unitLabel</th><th class="v2-table-num">Open</th>
                        <th class="v2-table-num">Done</th><th class="v2-table-num" title="Avg logged effort from first Dev Ready → Done">Avg Fix</th><th class="v2-table-num">Share</th>
                    </tr></thead>
                    <tbody>
                        @foreach (var p in rows)
                        {
                            <tr>
                                <td><span class="v2-pill @PriorityPill(p.Name)">@p.Name</span></td>
                                <td class="v2-table-num">@p.Total</td>
                                <td class="v2-table-num">@p.Open</td>
                                <td class="v2-table-num v2-text-success">@p.Closed</td>
                                <td class="v2-table-num">@(p.AvgFixHours.HasValue ? $"{p.AvgFixHours:0.0}h" : "—")</td>
                                <td class="v2-table-num">@ShareCell(p.Total, total)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </text>;

    // Compact per-sprint breakdown table (customer / label / worked-by on the Sprints tab).
    // shareByLogged → the Share column is % of logged hours (worked-by) instead of % of bugs.
    private RenderFragment SprintGroupTable(string nameCol, IReadOnlyList<GroupStat> rows, int shareWhole, bool shareByLogged) => @<text>
        @if (rows.Count == 0)
        {
            <div class="st-muted-cell" style="padding:6px 2px">No data in this window.</div>
        }
        else
        {
            <div class="v2-table-wrap" style="margin:0">
                <table class="v2-table" style="font-size:12px">
                    <thead><tr>
                        <th>@nameCol</th>
                        <th class="v2-table-num">Bugs</th>
                        <th class="v2-table-num">Closed</th>
                        <th class="v2-table-num">Open</th>
                        <th class="v2-table-num">Logged</th>
                        <th class="v2-table-num" title="Hours logged in this sprint's window on tickets that are Done">Logged (Done)</th>
                        <th class="v2-table-num">Avg Resolve</th>
                        <th class="v2-table-num">Share</th>
                    </tr></thead>
                    <tbody>
                        @foreach (var g in rows.Take(15))
                        {
                            <tr>
                                <td class="st-trunc" title="@g.Name">@g.Name</td>
                                <td class="v2-table-num">@g.Total</td>
                                <td class="v2-table-num v2-text-success">@g.Closed</td>
                                <td class="v2-table-num">@g.Open</td>
                                <td class="v2-table-num">@FmtHM(g.LoggedSeconds)</td>
                                <td class="v2-table-num v2-text-success">@FmtHM(g.LoggedDoneSeconds)</td>
                                <td class="v2-table-num">@(g.AvgResolve.HasValue ? $"{g.AvgResolve:0.0}d" : "—")</td>
                                <td class="v2-table-num">@(shareByLogged ? ShareCell(g.LoggedSeconds, shareWhole) : ShareCell(g.Total, shareWhole))</td>
                            </tr>
                        }
                        @if (rows.Count > 15)
                        {
                            <tr><td colspan="8" class="st-muted-cell">+@(rows.Count - 15) more…</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </text>;
}

