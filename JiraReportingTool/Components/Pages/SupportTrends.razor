        <div class="v2-card" style="margin-top:16px">
            <div class="v2-table-wrap" style="margin:0">
                <table class="v2-table st-bug-table">
                    <thead>
                        <tr>
                            <th class="sortable @BugSI("key")" @onclick='() => BugSort("key")'>Key</th>
                            <th class="sortable @BugSI("summary")" @onclick='() => BugSort("summary")'>Summary</th>
                            <th class="sortable @BugSI("customer")" @onclick='() => BugSort("customer")'>Customer</th>
                            <th class="sortable @BugSI("priority")" @onclick='() => BugSort("priority")'>Priority</th>
                            <th class="sortable @BugSI("status")" @onclick='() => BugSort("status")'>Status</th>
                            <th class="v2-table-num sortable @BugSI("devqa")" @onclick='() => BugSort("devqa")' title="Hours logged between first Dev Ready and first QA Ready">Dev→QA</th>
                            <th class="v2-table-num sortable @BugSI("qadone")" @onclick='() => BugSort("qadone")' title="Hours logged between first QA Ready and Done">QA→Done</th>
                            <th class="v2-table-num sortable @BugSI("devdone")" @onclick='() => BugSort("devdone")' title="Hours logged between first Dev Ready and Done">Dev→Done</th>
                            <th class="v2-table-num sortable @BugSI("qarej")" @onclick='() => BugSort("qarej")' title="Times bounced back from QA">QA Rej.</th>
                            <th class="v2-table-num sortable @BugSI("logged")" @onclick='() => BugSort("logged")' title="Total logged">Logged</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var b in DisplayedBugs)
                        {
                            var flags = BugFlags(b);
                            var devQa   = PhaseLoggedSeconds(b, b.DevReadyDate, b.QaReadyDate);
                            var qaDone  = PhaseLoggedSeconds(b, b.QaReadyDate, b.ResolutionDate);
                            var devDone = PhaseLoggedSeconds(b, b.DevReadyDate, b.ResolutionDate);
                            <tr class="@(flags.Any() ? "st-bug-critical" : "")">
                                <td><a class="st-bug-key" href="@JiraUrl(b.Key)" target="_blank" rel="noopener">@b.Key</a></td>
                                <td class="st-trunc" style="max-width:320px" title="@b.Summary">
                                    @b.Summary
                                    @foreach (var f in flags) { <span class="st-flag-dot @f.Cls" title="@f.Label"></span> }
                                </td>
                                <td class="st-trunc" style="max-width:160px" title="@b.Customer">@(string.IsNullOrWhiteSpace(b.Customer) ? "—" : b.Customer)</td>
                                <td><span class="v2-pill @PriorityPill(b.Priority)">@b.Priority</span></td>
                                <td><span class="st-status @(IsDone(b) ? "st-status-done" : "st-status-open")">@b.Status</span></td>
                                <td class="v2-table-num @PhaseHrsCls(devQa, 8)">@PhaseHrsLabel(devQa)</td>
                                <td class="v2-table-num @PhaseHrsCls(qaDone, 8)">@PhaseHrsLabel(qaDone)</td>
                                <td class="v2-table-num @PhaseHrsCls(devDone, 16)">@PhaseHrsLabel(devDone)</td>
                                <td class="v2-table-num @(b.QaRejectedCount > 0 ? "v2-text-danger" : "")">@(b.QaRejectedCount > 0 ? b.QaRejectedCount.ToString() : "—")</td>
                                <td class="v2-table-num">@(b.TimeSpentSeconds > 0 ? FmtHM(b.TimeSpentSeconds) : "—")</td>
                            </tr>
