@page "/support-trends"
@rendermode InteractiveServer
@using JiraReportingTool.Models
@using System.Threading
@inject IJiraService JiraService
@inject SprintConfigService SprintConfigService
@inject IConfiguration Config
@inject IJSRuntime JS

<PageTitle>Support Trends</PageTitle>

<div class="v2-root">

    <!-- ═══ HERO ═══════════════════════════════════════════════════════════════ -->
    <div class="v2-hero">
        <div class="v2-hero-row">
            <div class="v2-hero-icon"><i class="bi bi-graph-up-arrow"></i></div>
            <div class="v2-hero-titles">
                <span class="v2-eyebrow">Reporting</span>
                <h1 class="v2-hero-title">Support Trends</h1>
                <span class="v2-hero-sub">
                    @if (_epicKeys.Count > 0)
                    {
                        <strong>@_bugs.Count bugs</strong>
                        @if (HasPoolFilter)
                        {
                            <span> (of @_allBugsPool.Count)</span>
                        }
                        <span> · @_epicKeys.Count epic@(_epicKeys.Count == 1 ? "" : "s") · @_configs.Count sprint@(_configs.Count == 1 ? "" : "s")</span>
                        <span> · @_fullStart.ToString("MMM yyyy") – @_fullEnd.ToString("MMM yyyy")</span>
                        @if (_oldestSync is not null)
                        {
                            <span> · data as of @_oldestSync.Value.ToLocalTime().ToString("dd-MMM HH:mm")</span>
                        }
                    }
                    else
                    {
                        <span>Long-term bug analytics pooled across every epic in Dashboard Config</span>
                    }
                </span>
            </div>
            <div class="v2-hero-spacer"></div>
            <div class="v2-hero-actions st-controls">
                <button class="v2-btn v2-btn-ghost" @onclick="ReloadAsync" disabled="@(_loading || _epicKeys.Count == 0)" title="Reload — closed sprints from the local cache, only recent changes from Jira">
                    @if (_loading) { <span class="v2-spin"></span> } else { <i class="bi bi-arrow-repeat"></i> }
                </button>
                <button class="v2-btn v2-btn-ghost" @onclick="ForceReloadAsync" disabled="@(_loading || _epicKeys.Count == 0)" title="Force full re-fetch from Jira (rebuilds the cache — slow)">
                    <i class="bi bi-cloud-arrow-down"></i>
                </button>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="st-banner st-banner-danger"><i class="bi bi-exclamation-triangle"></i> @_error</div>
    }
    @if (_failedEpics.Count > 0)
    {
        <div class="st-banner st-banner-warn">
            <i class="bi bi-exclamation-circle"></i>
            Couldn't load @_failedEpics.Count epic@(_failedEpics.Count == 1 ? "" : "s"): @string.Join(", ", _failedEpics)
        </div>
    }
    @if (_linkedFetchFailed)
    {
        <div class="st-banner st-banner-warn">
            <i class="bi bi-exclamation-circle"></i>
            Couldn't load JSSUPPORT-linked bugs — showing epic-scoped data only.
        </div>
    }

    @if (_configs.Count == 0)
    {
        <div class="st-empty">
            <i class="bi bi-sliders2"></i>
            <p>No sprints are configured yet. Add some on the <a href="config">Dashboard Config</a> page.</p>
        </div>
    }
    else if (_epicKeys.Count == 0)
    {
        <div class="st-empty">
            <i class="bi bi-link-45deg"></i>
            <p>None of your configured sprints have an Epic Key. Add epic keys on the <a href="config">Dashboard Config</a> page.</p>
        </div>
    }
    else if (_loading && _allBugsPool.Count == 0)
    {
        <div class="st-empty">
            <span class="v2-spin"></span>
            <p>Loading bugs — @_epicsLoaded of @_epicsTotal epics…</p>
            <div class="st-load-bar"><div class="st-load-fill" style="width:@(_epicsTotal == 0 ? 0 : _epicsLoaded * 100 / _epicsTotal)%"></div></div>
        </div>
    }
    else if (_allBugsPool.Count == 0)
    {
        <div class="st-empty"><i class="bi bi-inbox"></i><p>No bugs found across the configured epics.</p></div>
    }
    else
    {
        <!-- ═══ RANGE ══════════════════════════════════════════════════════════ -->
        <div class="st-toolbar">
            <div class="st-tool-group">
                <span class="st-tool-label">Window</span>
                <span class="st-date-lbl">From</span>
                <InputDate class="st-input" @bind-Value="_rangeStart" @bind-Value:after="OnRangeChanged" />
                <span class="st-date-lbl">To</span>
                <InputDate class="st-input" @bind-Value="_rangeEnd" @bind-Value:after="OnRangeChanged" />
                <button class="st-link" @onclick="ResetRange" disabled="@(_rangeStart == _fullStart && _rangeEnd == _fullEnd)">Full span</button>
            </div>
            <div class="st-tool-group">
                <span class="st-tool-label">Sprint</span>
                <div class="st-dd">
                    <button class="st-dd-btn @(_selectedSprints.Count > 0 ? "active" : "")" @onclick="() => _sprintDdOpen = !_sprintDdOpen">
                        @(_selectedSprints.Count == 0 ? "All sprints" : $"{_selectedSprints.Count} selected")
                        <span class="st-dd-caret">▾</span>
                    </button>
                    @if (_sprintDdOpen)
                    {
                        <div class="st-dd-backdrop" @onclick="() => _sprintDdOpen = false"></div>
                        <div class="st-dd-panel">
                            @if (_selectedSprints.Count > 0)
                            {
                                <button class="st-dd-clear" @onclick="ClearSprintFilters">Clear</button>
                            }
                            @foreach (var s in AllSprintOptions)
                            {
                                var name = s.Name;
                                <label class="st-dd-opt">
                                    <input type="checkbox" checked="@_selectedSprints.Contains(name)" @onchange="() => ToggleSprintFilter(name)" />
                                    <span class="st-dd-opt-name" title="@name">@name</span>
                                    <span class="st-dd-opt-n">@s.Count</span>
                                </label>
                            }
                        </div>
                    }
                </div>
                @foreach (var s in _selectedSprints.OrderBy(x => x))
                {
                    var val = s;
                    <button class="st-prod-chip" @onclick="() => ToggleSprintFilter(val)" title="Remove @val">@val ✕</button>
                }
            </div>
            <div class="st-tool-group">
                <span class="st-tool-label">Product</span>
                <div class="st-dd">
                    <button class="st-dd-btn @(_selectedProducts.Count > 0 ? "active" : "")" @onclick="() => _productDdOpen = !_productDdOpen">
                        @(_selectedProducts.Count == 0 ? "All products" : $"{_selectedProducts.Count} selected")
                        <span class="st-dd-caret">▾</span>
                    </button>
                    @if (_productDdOpen)
                    {
                        <div class="st-dd-backdrop" @onclick="() => _productDdOpen = false"></div>
                        <div class="st-dd-panel">
                            @if (_selectedProducts.Count > 0)
                            {
                                <button class="st-dd-clear" @onclick="ClearProducts">Clear</button>
                            }
                            @foreach (var p in AllProducts)
                            {
                                var name = p.Name;
                                <label class="st-dd-opt">
                                    <input type="checkbox" checked="@_selectedProducts.Contains(name)" @onchange="() => ToggleProduct(name)" />
                                    <span class="st-dd-opt-name" title="@name">@name</span>
                                    <span class="st-dd-opt-n">@p.Count</span>
                                </label>
                            }
                        </div>
                    }
                </div>
                @foreach (var p in _selectedProducts.OrderBy(x => x))
                {
                    var val = p;
                    <button class="st-prod-chip" @onclick="() => ToggleProduct(val)" title="Remove @val">@val ✕</button>
                }
            </div>
            @if (_loading) { <div class="st-tool-group" style="margin-left:auto"><span class="v2-spin" title="Refreshing"></span></div> }
        </div>

        <!-- ═══ TABS ═══════════════════════════════════════════════════════════ -->
        <div class="st-tabs">
            @foreach (var t in _tabs)
            {
                <button class="st-tab @(_tab == t.Key ? "active" : "")" @onclick="() => SetTab(t.Key)">
                    <i class="bi @t.Icon"></i> @t.Label
                    @if (t.Key == "bugs") { <span class="st-tab-count">@_bugs.Count</span> }
                </button>
            }
        </div>

        @if (_tab == "overview")
        {
        <!-- ═══ 1. LIFECYCLE & THROUGHPUT ══════════════════════════════════════ -->
        <div class="v2-section"><span class="v2-section-title"><i class="bi bi-arrow-repeat"></i> Lifecycle &amp; Throughput <span class="st-scope">in window</span></span></div>
        <div class="v2-kpi-grid">

            <div class="v2-kpi v2-kpi-neutral">
                <div class="v2-kpi-head"><i class="bi bi-collection"></i>Total Bugs</div>
                <div class="v2-kpi-value">@_bugs.Count</div>
                <div class="v2-kpi-sub">@OpenCount open · @DoneCount done (all time)</div>
            </div>

            <div class="v2-kpi v2-kpi-neutral">
                <div class="v2-kpi-head"><i class="bi bi-plus-circle"></i>Created</div>
                <div class="v2-kpi-value">@CreatedCount</div>
                <div class="v2-kpi-sub">raised in window</div>
            </div>

            <div class="v2-kpi v2-kpi-neutral">
                <div class="v2-kpi-head"><i class="bi bi-hammer"></i>Worked On</div>
                <div class="v2-kpi-value">@WorkedOnCount</div>
                <div class="v2-kpi-sub">had worklog activity</div>
            </div>

            <div class="v2-kpi v2-kpi-success">
                <div class="v2-kpi-head"><i class="bi bi-check2-circle"></i>Closed</div>
                <div class="v2-kpi-value">@ClosedCount</div>
                <div class="v2-bar" style="margin-top:8px"><div class="v2-bar-fill v2-bar-fill-success" style="width:@Pct(ClosedCount, Math.Max(1, WorkedOnCount))%"></div></div>
                <div class="v2-kpi-sub">resolved in window</div>
            </div>

            <div class="v2-kpi @(CarriedOverOpenCount == 0 ? "v2-kpi-neutral" : "v2-kpi-warn")">
                <div class="v2-kpi-head"><i class="bi bi-arrow-left-right"></i>Open Backlog</div>
                <div class="v2-kpi-value">@OpenCount</div>
                <div class="v2-kpi-sub">@CarriedOverOpenCount opened before window</div>
            </div>

            <div class="v2-kpi @(ReopenedCount == 0 ? "v2-kpi-neutral" : "v2-kpi-danger")">
                <div class="v2-kpi-head"><i class="bi bi-arrow-counterclockwise"></i>QA Rejected</div>
                <div class="v2-kpi-value">@ReopenedCount</div>
                <div class="v2-kpi-sub">bugs bounced back from QA</div>
            </div>

            <div class="v2-kpi v2-kpi-neutral">
                <div class="v2-kpi-head"><i class="bi bi-graph-up"></i>Net Flow</div>
                <div class="v2-kpi-value @(NetFlow >= 0 ? "v2-text-success" : "v2-text-danger")">@(NetFlow >= 0 ? "+" : "")@NetFlow</div>
                <div class="v2-kpi-sub">closed − created</div>
            </div>

            <div class="v2-kpi v2-kpi-neutral">
                <div class="v2-kpi-head"><i class="bi bi-hourglass-split"></i>Avg Time to Resolve</div>
                <div class="v2-kpi-value">@(AvgResolveDays.HasValue ? $"{AvgResolveDays:0.0}" : "—")<span class="v2-kpi-of">days</span></div>
                <div class="v2-kpi-sub">create → resolve (closed in window)</div>
            </div>

        </div>

        <!-- ═══ 2. EFFORT & TIME — BUGS ════════════════════════════════════════ -->
        var bugEffort = EffortStatsFor(BugTypeIssues);
        <div class="v2-section"><span class="v2-section-title"><i class="bi bi-bug"></i> Effort &amp; Time <span class="st-scope">Bug type · @bugEffort.Count</span></span></div>
        @EffortGrid(bugEffort, "Bug")

        <!-- ═══ 2b. EFFORT & TIME — REDESIGN ═══════════════════════════════════ -->
        var redesignEffort = EffortStatsFor(RedesignTypeIssues);
        <div class="v2-section"><span class="v2-section-title"><i class="bi bi-pencil-square"></i> Effort &amp; Time <span class="st-scope">Redesign type · @redesignEffort.Count</span></span></div>
        @EffortGrid(redesignEffort, "Redesign")

        <!-- ═══ TICKETS BY PRIORITY ════════════════════════════════════════════ -->
        <div class="v2-section"><span class="v2-section-title"><i class="bi bi-flag-fill"></i> Tickets by priority <span class="st-scope">all time</span></span></div>
        <div class="v2-grid-2">
            <div class="v2-card">
                <div class="st-card-title"><i class="bi bi-pie-chart"></i> Count by priority</div>
                <div class="st-chart-box"><canvas id="st-chart-priority"></canvas></div>
            </div>
            <div class="v2-card">
                <div class="st-card-title"><i class="bi bi-list-ol"></i> Breakdown</div>
                <div class="v2-table-wrap" style="margin:0">
                    <table class="v2-table" style="font-size:12px">
                        <thead><tr><th>Priority</th><th class="v2-table-num">Bugs</th><th class="v2-table-num">Open</th><th class="v2-table-num">Done</th><th class="v2-table-num" title="Avg logged effort from first Dev Ready → Done">Avg Fix</th><th class="v2-table-num">Share</th></tr></thead>
                        <tbody>
                            @foreach (var p in ByPriority)
                            {
                                <tr>
                                    <td><span class="v2-pill @PriorityPill(p.Name)">@p.Name</span></td>
                                    <td class="v2-table-num">@p.Total</td>
                                    <td class="v2-table-num">@p.Open</td>
                                    <td class="v2-table-num v2-text-success">@p.Closed</td>
                                    <td class="v2-table-num">@(p.AvgFixHours.HasValue ? $"{p.AvgFixHours:0.0}h" : "—")</td>
                                    <td class="v2-table-num">@ShareCell(p.Total, _bugs.Count)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        }

        @if (_tab == "metrics")
        {
        <!-- ═══ 3. METRICS ════════════════════════════════════════════════════ -->
        <div class="v2-section"><span class="v2-section-title"><i class="bi bi-bar-chart-line"></i> Metrics <span class="st-scope">all bugs · all time</span></span></div>

        <!-- Worklog effort by author across every bug -->
        <div class="v2-card">
            <div class="st-card-title"><i class="bi bi-person-workspace"></i> Worklog effort by author <span class="st-scope">hours logged · top 20</span></div>
            <div class="st-chart-box" style="height:420px"><canvas id="st-chart-m-author"></canvas></div>
        </div>

        <div class="v2-grid-2" style="margin-top:16px">
            <!-- By customer -->
            <div class="v2-card">
                <div class="st-card-title"><i class="bi bi-building"></i> By customer <span class="st-scope">bugs &amp; logged hours · top 15</span></div>
                <div class="st-chart-box" style="height:320px"><canvas id="st-chart-m-customer"></canvas></div>
            </div>
            <!-- By label -->
            <div class="v2-card">
                <div class="st-card-title"><i class="bi bi-tags"></i> By label <span class="st-scope">bugs &amp; logged hours · top 15</span></div>
                <div class="st-chart-box" style="height:320px"><canvas id="st-chart-m-label"></canvas></div>
            </div>
        </div>

        }

        @if (_tab == "sprints")
        {
        <!-- ═══ 4. SPRINT-OVER-SPRINT ═════════════════════════════════════════ -->
        <div class="v2-section"><span class="v2-section-title"><i class="bi bi-calendar3"></i> Sprint over Sprint</span></div>
        <div class="v2-grid-2">
            <div class="v2-card">
                <div class="st-card-title"><i class="bi bi-funnel"></i> In sprint vs Done per sprint</div>
                <div class="st-chart-box"><canvas id="st-chart-sprint-flow"></canvas></div>
            </div>
            <div class="v2-card">
                <div class="st-card-title"><i class="bi bi-stopwatch"></i> Hours logged per sprint</div>
                <div class="st-chart-box"><canvas id="st-chart-sprint-logged"></canvas></div>
            </div>
        </div>
        <div class="v2-card" style="margin-top:16px">
            <div class="st-card-title"><i class="bi bi-table"></i> Per-sprint breakdown</div>
            <div class="v2-table-wrap" style="margin:0">
                <table class="v2-table">
                    <thead><tr>
                        <th>Sprint</th><th>Window</th>
                        <th class="v2-table-num" title="All tickets in this sprint's epic (matches Jira parent = epic)">In Sprint</th>
                        <th class="v2-table-num" title="First appeared in this sprint — not carried from an earlier one">New</th>
                        <th class="v2-table-num" title="Also lived in an earlier sprint (per the Jira sprint field)">Carried In</th>
                        <th class="v2-table-num" title="Done tickets in this sprint's epic (matches Jira parent = epic AND status = Done)">Done</th>
                        <th class="v2-table-num" title="Also appears in a later sprint — work continued past this one">Spilled</th>
                        <th class="v2-table-num" title="Done ÷ In Sprint">Compl.</th>
                        <th class="v2-table-num">Logged</th>
                        <th class="v2-table-num" title="Hours logged in the sprint window on tickets that are Done">Logged (Done)</th>
                        <th class="v2-table-num">QA Rej.</th>
                    </tr></thead>
                    <tbody>
                        @foreach (var s in SprintStats)
                        {
                            <tr>
                                <td class="st-trunc" title="@s.Name" style="font-weight:600">@s.Name</td>
                                <td class="st-muted-cell">@s.Start.ToString("dd MMM") – @s.End.ToString("dd MMM yy")</td>
                                <td class="v2-table-num" style="font-weight:600">@s.InSprint</td>
                                <td class="v2-table-num">@s.New</td>
                                <td class="v2-table-num @(s.CarriedIn > 0 ? "v2-text-warn" : "")">@(s.CarriedIn > 0 ? s.CarriedIn.ToString() : "—")</td>
                                <td class="v2-table-num v2-text-success">@s.DoneHere</td>
                                <td class="v2-table-num @(s.SpilledOver > 0 ? "v2-text-danger" : "")">@(s.SpilledOver > 0 ? s.SpilledOver.ToString() : "—")</td>
                                <td class="v2-table-num">@s.CompletionPct.ToString("0")%</td>
                                <td class="v2-table-num">@FmtHM(s.LoggedSeconds)</td>
                                <td class="v2-table-num v2-text-success">@FmtHM(s.LoggedDoneSeconds)</td>
                                <td class="v2-table-num @(s.QaRejected > 0 ? "v2-text-danger" : "")">@(s.QaRejected > 0 ? s.QaRejected.ToString() : "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- ═══ PER-SPRINT BREAKDOWNS (collapsible) ════════════════════════════ -->
        <div class="v2-section" style="margin-top:16px">
            <span class="v2-section-title"><i class="bi bi-diagram-3"></i> Per-sprint breakdowns <span class="st-scope">tickets that belonged to each sprint · click a sprint to expand</span></span>
        </div>
        @foreach (var s in SprintStats)
        {
            var prioBugs      = SprintPriorityBreakdown(s.Name, "Bug").ToList();
            var prioRedesigns = SprintPriorityBreakdown(s.Name, "Redesign").ToList();
            var bugTotal      = prioBugs.Sum(r => r.Total);
            var redesignTotal = prioRedesigns.Sum(r => r.Total);
            var sprintTotal   = BugsInSprint(s.Name).Count();
            var expanded = _expandedSprints.Contains(s.Name);
            <div class="v2-card st-sprint-card">
                <button class="st-sprint-head @(expanded ? "open" : "")" @onclick="() => ToggleSprint(s.Name)">
                    <i class="bi bi-chevron-@(expanded ? "down" : "right") st-sprint-chev"></i>
                    <span class="st-sprint-name"><i class="bi bi-calendar3"></i> @s.Name</span>
                    <span class="st-scope">@s.Start.ToString("dd MMM") – @s.End.ToString("dd MMM yy") · @sprintTotal ticket@(sprintTotal == 1 ? "" : "s") · @bugTotal bug@(bugTotal == 1 ? "" : "s") · @redesignTotal redesign@(redesignTotal == 1 ? "" : "s")</span>
                </button>
                @if (expanded)
                {
                    var custRows    = SprintByCustomer(s.Name, s.Start, s.End);
                    var labelRows   = SprintByLabel(s.Name, s.Start, s.End);
                    var workedRows  = SprintWorkedBy(s.Name, s.Start, s.End);
                    var workedTotal = workedRows.Sum(w => w.LoggedSeconds);
                    <div class="st-sprint-body">
                        <!-- By priority, split by issue type: Bugs vs Redesign -->
                        <div class="v2-grid-2">
                            <div class="st-sprint-sub">
                                <div class="st-card-title"><i class="bi bi-bug"></i> By priority — Bugs <span class="st-scope">@bugTotal ticket@(bugTotal == 1 ? "" : "s")</span></div>
                                @SprintPriorityTable(prioBugs, bugTotal, "Bugs")
                            </div>
                            <div class="st-sprint-sub">
                                <div class="st-card-title"><i class="bi bi-pencil-square"></i> By priority — Redesign <span class="st-scope">@redesignTotal ticket@(redesignTotal == 1 ? "" : "s")</span></div>
                                @SprintPriorityTable(prioRedesigns, redesignTotal, "Redesigns")
                            </div>
                        </div>

                        <div class="v2-grid-2">
                            <div class="st-sprint-sub">
                                <div class="st-card-title"><i class="bi bi-building"></i> By customer</div>
                                @SprintGroupTable("Customer", custRows, sprintTotal, false)
                            </div>
                            <div class="st-sprint-sub">
                                <div class="st-card-title"><i class="bi bi-tags"></i> By label</div>
                                @SprintGroupTable("Label", labelRows, sprintTotal, false)
                            </div>
                        </div>

                        <div class="st-sprint-sub">
                            <div class="st-card-title"><i class="bi bi-person-workspace"></i> Worked by <span class="st-scope">worklog author · in sprint window</span></div>
                            @SprintGroupTable("Member", workedRows, workedTotal, true)
                        </div>
                    </div>
                }
            </div>
        }

        }

        @if (_tab == "breakdowns")
        {
        <!-- ═══ 5. BREAKDOWNS ═════════════════════════════════════════════════ -->
        <div class="v2-section"><span class="v2-section-title"><i class="bi bi-diagram-3"></i> Breakdowns <span class="st-scope">all time</span></span></div>

        <div class="v2-grid-2">
            <!-- By customer -->
            <div class="v2-card">
                <div class="st-card-title st-bk-head">
                    <span><i class="bi bi-building"></i> By customer</span>
                    <input class="st-bk-search" placeholder="Filter customers…" @bind="_custFilter" @bind:event="oninput" />
                </div>
                <div class="v2-table-wrap st-bk-scroll" style="margin:0">
                    <table class="v2-table" style="font-size:12px">
                        <thead><tr>
                            <th class="sortable @CustSI("name")" @onclick='() => CustSort("name")'>Customer</th>
                            <th class="v2-table-num sortable @CustSI("total")" @onclick='() => CustSort("total")'>Bugs</th>
                            <th class="v2-table-num sortable @CustSI("closed")" @onclick='() => CustSort("closed")'>Closed</th>
                            <th class="v2-table-num sortable @CustSI("logged")" @onclick='() => CustSort("logged")'>Logged</th>
                            <th class="v2-table-num sortable @CustSI("resolve")" @onclick='() => CustSort("resolve")'>Avg Resolve</th>
                            <th class="v2-table-num">Share</th>
                        </tr></thead>
                        <tbody>
                            @foreach (var c in SortFilterGroups(ByCustomer, _custSortCol, _custAsc, _custFilter))
                            {
                                <tr>
