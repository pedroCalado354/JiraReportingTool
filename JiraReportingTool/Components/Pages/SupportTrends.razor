                <div class="st-chart-box"><canvas id="st-chart-bug-byprio"></canvas></div>
            </div>
            <div class="v2-card">
                <div class="st-card-title"><i class="bi bi-arrow-counterclockwise"></i> QA bounce-backs <span class="st-scope">times rejected</span></div>
                <div class="st-chart-box"><canvas id="st-chart-bug-qarej"></canvas></div>
            </div>
