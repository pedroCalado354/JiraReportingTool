@page "/epic"
@rendermode InteractiveServer
@inject JiraService JiraService
@using JiraReportingTool.Models

<PageTitle>Epic Report</PageTitle>

<h1 class="mb-4">Epic Report</h1>

<div class="row g-2 mb-4">
    <div class="col-auto">
        <input class="form-control"
               style="width: 260px"
               @bind="EpicKey"
               @onkeyup="HandleKeyUp"
               placeholder="Epic key (e.g. JM-123)" />
    </div>
    <div class="col-auto">
        <button class="btn btn-primary" @onclick="LoadEpic" disabled="@IsLoading">
            @if (IsLoading)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
            }
            Load Epic
        </button>
    </div>
</div>

@if (ErrorMessage != null)
{
    <div class="alert alert-danger">@ErrorMessage</div>
}

@if (Report != null)
{
    <!-- Epic header card -->
    <div class="card mb-3 border-0 shadow-sm">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                <div>
                    <span class="text-muted small fw-semibold">@Report.Key</span>
                    <h4 class="mb-1 mt-1">@Report.Summary</h4>
                    <span class="text-muted"><strong>Assignee:</strong> @Report.Assignee</span>
                </div>
                <span class="badge @StatusBadge(Report.StatusCategoryKey) fs-6 align-self-start">@Report.Status</span>
            </div>
        </div>
    </div>

    <!-- Progress card -->
    @if (Report.TotalIssues > 0)
    {
        <div class="card mb-3 border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="fw-semibold">Progress</span>
                    <span class="text-muted small">@Report.DoneCount / @Report.TotalIssues issues done</span>
                </div>
                <div class="progress mb-3" style="height: 10px; border-radius: 6px;">
                    <div class="progress-bar bg-success"
                         role="progressbar"
                         style="width: @Pct(Report.DoneCount, Report.TotalIssues)%">
                    </div>
                    <div class="progress-bar bg-primary"
                         role="progressbar"
                         style="width: @Pct(Report.InProgressCount, Report.TotalIssues)%">
                    </div>
                    <div class="progress-bar bg-secondary opacity-50"
                         role="progressbar"
                         style="width: @Pct(Report.ToDoCount, Report.TotalIssues)%">
                    </div>
                </div>
                <div class="d-flex flex-wrap gap-3 align-items-center">
                    <span><span class="badge bg-success me-1">@Report.DoneCount</span>Done</span>
                    <span><span class="badge bg-primary me-1">@Report.InProgressCount</span>In Progress</span>
                    <span><span class="badge bg-secondary me-1">@Report.ToDoCount</span>To Do</span>
                    @if (Report.TotalOriginalEstimateSeconds > 0)
                    {
                        <span class="ms-auto text-muted small">
                            <strong>@Fmt(Report.TotalTimeSpentSeconds)</strong> logged
                            / @Fmt(Report.TotalOriginalEstimateSeconds) estimated
                        </span>
                    }
                </div>
            </div>
        </div>
    }

    <!-- Issues table -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <strong>Issues (@Report.TotalIssues)</strong>
            <span class="text-muted small">Click a row to expand worklogs</span>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:100px">Key</th>
                        <th style="width:90px">Type</th>
                        <th>Summary</th>
                        <th style="width:140px">Status</th>
                        <th style="width:150px">Assignee</th>
                        <th style="width:90px">Logged</th>
                        <th style="width:90px">Estimate</th>
                        <th style="width:80px"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var issue in Report.Issues)
                    {
                        <tr class="@(issue.IsExpanded ? "table-active" : "")"
                            style="cursor: pointer;"
                            @onclick="() => issue.IsExpanded = !issue.IsExpanded">
                            <td class="fw-semibold text-nowrap">@issue.Key</td>
                            <td>
                                <span class="badge bg-light text-dark border">@issue.IssueType</span>
                            </td>
                            <td>@issue.Summary</td>
                            <td>
                                <span class="badge @StatusBadge(issue.StatusCategoryKey)">@issue.Status</span>
                            </td>
                            <td class="text-nowrap text-truncate" style="max-width:150px">@issue.Assignee</td>
                            <td class="text-nowrap">@(issue.TimeSpent == "-" ? "—" : issue.TimeSpent)</td>
                            <td class="text-nowrap">@(issue.OriginalEstimate == "-" ? "—" : issue.OriginalEstimate)</td>
                            <td class="text-muted small text-nowrap">
                                @if (issue.Worklogs.Any())
                                {
                                    @(issue.IsExpanded ? "▲" : "▼")
                                    <span class="ms-1">@issue.Worklogs.Count log@(issue.Worklogs.Count != 1 ? "s" : "")</span>
                                }
                            </td>
                        </tr>

                        @if (issue.IsExpanded)
                        {
                            <tr>
                                <td colspan="8" class="p-0 border-0">
                                    <div class="px-4 py-3 bg-light border-start border-3 border-primary">
                                        @if (issue.Worklogs.Any())
                                        {
                                            <table class="table table-sm mb-0">
                                                <thead>
                                                    <tr>
                                                        <th>Author</th>
                                                        <th>Time Spent</th>
                                                        <th>Date</th>
                                                        <th>Comment</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var wl in issue.Worklogs.OrderByDescending(w => w.Started))
                                                    {
                                                        <tr>
                                                            <td class="text-nowrap">@wl.Author</td>
                                                            <td class="text-nowrap">@wl.TimeSpent</td>
                                                            <td class="text-nowrap text-muted">@wl.Started.ToString("dd MMM yyyy")</td>
                                                            <td class="text-muted">@(string.IsNullOrEmpty(wl.Comment) ? "—" : wl.Comment)</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">No worklog entries for this issue.</span>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private string EpicKey = "";
    private bool IsLoading = false;
    private string? ErrorMessage;
    private JiraEpicReport? Report;

    private async Task LoadEpic()
    {
        if (string.IsNullOrWhiteSpace(EpicKey)) return;

        IsLoading = true;
        ErrorMessage = null;
        Report = null;

        try
        {
            Report = await JiraService.GetEpicReportAsync(EpicKey.Trim().ToUpper());
        }
        catch (HttpRequestException ex)
        {
            ErrorMessage = $"Failed to load epic: {ex.Message}";
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Unexpected error: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await LoadEpic();
    }

    private static string StatusBadge(string categoryKey) => categoryKey switch
    {
        "done" => "bg-success",
        "indeterminate" => "bg-primary",
        _ => "bg-secondary"
    };

    private static int Pct(int count, int total) =>
        total == 0 ? 0 : (int)Math.Round((double)count / total * 100);

    private static string Fmt(int seconds)
    {
        if (seconds <= 0) return "—";
        var h = seconds / 3600;
        var m = (seconds % 3600) / 60;
        return h > 0 ? $"{h}h {m}m" : $"{m}m";
    }
}
