@page "/epic"
@rendermode InteractiveServer
@inject IJiraService JiraService
@using JiraReportingTool.Models

<PageTitle>Epic Report</PageTitle>

<h1 class="mb-4">Epic Report</h1>

<div class="row g-2 mb-4">
    <div class="col-auto">
        <input class="form-control"
               style="width: 260px"
               @bind="EpicKey"
               @onkeyup="HandleKeyUp"
               placeholder="Epic key (e.g. JM-123)" />
    </div>
    <div class="col-auto">
        <button class="btn btn-primary" @onclick="LoadEpic" disabled="@IsLoading">
            @if (IsLoading)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
            }
            Load Epic
        </button>
    </div>
</div>

@if (ErrorMessage != null)
{
    <div class="alert alert-danger">@ErrorMessage</div>
}

@if (Report != null)
{
    <!-- Epic header card -->
    <div class="card mb-3 border-0 shadow-sm">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                <div>
                    <span class="text-muted small fw-semibold">@Report.Key</span>
                    <h4 class="mb-1 mt-1">@Report.Summary</h4>
                    <span class="text-muted"><strong>Assignee:</strong> @Report.Assignee</span>
                </div>
                <span class="badge @StatusBadge(Report.StatusCategoryKey) fs-6 align-self-start">@Report.Status</span>
            </div>
        </div>
    </div>

    <!-- Progress card -->
    @if (Report.TotalIssues > 0)
    {
        <div class="card mb-3 border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="fw-semibold">Progress</span>
                    <span class="text-muted small">@Report.DoneCount / @Report.TotalIssues issues done</span>
                </div>
                <div class="progress mb-3" style="height: 10px; border-radius: 6px;">
                    <div class="progress-bar bg-success"
                         role="progressbar"
                         style="width: @Pct(Report.DoneCount, Report.TotalIssues)%">
                    </div>
                    <div class="progress-bar bg-primary"
                         role="progressbar"
                         style="width: @Pct(Report.InProgressCount, Report.TotalIssues)%">
                    </div>
                    <div class="progress-bar bg-secondary opacity-50"
                         role="progressbar"
                         style="width: @Pct(Report.ToDoCount, Report.TotalIssues)%">
                    </div>
                </div>
                <div class="d-flex flex-wrap gap-3 align-items-center">
                    <span><span class="badge bg-success me-1">@Report.DoneCount</span>Done</span>
                    <span><span class="badge bg-primary me-1">@Report.InProgressCount</span>In Progress</span>
                    <span><span class="badge bg-secondary me-1">@Report.ToDoCount</span>To Do</span>
                    @if (Report.TotalOriginalEstimateSeconds > 0)
                    {
                        <span class="ms-auto text-muted small">
                            <strong>@Fmt(Report.TotalTimeSpentSeconds)</strong> logged
                            / @Fmt(Report.TotalOriginalEstimateSeconds) estimated
                        </span>
                    }
                </div>
            </div>
        </div>
    }

    <!-- Filters -->
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <div class="row g-3 align-items-start">

                <!-- Team members multi-select -->
                <div class="col-lg-4">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <span class="small fw-semibold">Team Members</span>
                        <div class="d-flex gap-2 small">
                            <button class="btn btn-link btn-sm p-0 text-decoration-none" @onclick="SelectAllMembers">All</button>
                            <span class="text-muted">/</span>
                            <button class="btn btn-link btn-sm p-0 text-decoration-none" @onclick="ClearMembersFilter">None</button>
                        </div>
                    </div>
                    <div class="border rounded p-2" style="max-height:140px;overflow-y:auto">
                        @foreach (var member in AllMembers)
                        {
                            <div class="form-check mb-0">
                                <input class="form-check-input" type="checkbox" id="er_@member"
                                       checked="@SelectedMembers.Contains(member)"
                                       @onchange="e => ToggleMember(member, (bool)(e.Value ?? false))" />
                                <label class="form-check-label small" for="er_@member">@member</label>
                            </div>
                        }
                    </div>
                    <div class="text-muted small mt-1">@SelectedMembers.Count of @AllMembers.Count selected</div>
                </div>

                <!-- Table filters -->
                <div class="col-lg-8">
                    <span class="form-label small fw-semibold d-block mb-1">Table Filters</span>
                    <div class="row g-2">
                        <div class="col-md-5">
                            <input class="form-control form-control-sm" placeholder="Search key or summary…"
                                   @bind="FilterText" @bind:event="oninput" />
                        </div>
                        <div class="col-md-3">
                            <select class="form-select form-select-sm" @bind="FilterStatus">
                                <option value="">All statuses</option>
                                @foreach (var s in AllStatuses)
                                {
                                    <option value="@s">@s</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <select class="form-select form-select-sm" @bind="FilterType">
                                <option value="">All types</option>
                                @foreach (var t in AllTypes)
                                {
                                    <option value="@t">@t</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-1 d-flex align-items-center">
                            @if (!string.IsNullOrEmpty(FilterText) || !string.IsNullOrEmpty(FilterStatus) || !string.IsNullOrEmpty(FilterType) || SelectedMembers.Count < AllMembers.Count)
                            {
                                <button class="btn btn-sm btn-outline-secondary w-100" @onclick="ClearFilters" title="Clear filters">✕</button>
                            }
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!-- Issues table -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <strong>
                Issues (@FilteredIssues.Count
                @if (FilteredIssues.Count != Report.TotalIssues)
                {
                    <span class="text-muted fw-normal"> of @Report.TotalIssues</span>
                }
                )
            </strong>
            <span class="text-muted small">Click a row to expand worklogs</span>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:100px">Key</th>
                        <th style="width:90px">Type</th>
                        <th>Summary</th>
                        <th style="width:140px">Status</th>
                        <th style="width:150px">Assignee</th>
                        <th style="width:90px">Logged</th>
                        <th style="width:90px">Estimate</th>
                        <th style="width:80px"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var issue in FilteredIssues)
                    {
                        <tr class="@(issue.IsExpanded ? "table-active" : "")"
                            style="cursor: pointer;"
                            @onclick="() => issue.IsExpanded = !issue.IsExpanded">
                            <td class="fw-semibold text-nowrap">@issue.Key</td>
                            <td>
                                <span class="badge bg-light text-dark border">@issue.IssueType</span>
                            </td>
                            <td>@issue.Summary</td>
                            <td>
                                <span class="badge @StatusBadge(issue.StatusCategoryKey)">@issue.Status</span>
                            </td>
                            <td class="text-nowrap text-truncate" style="max-width:150px">@issue.Assignee</td>
                            <td class="text-nowrap">@(issue.TimeSpent == "-" ? "—" : issue.TimeSpent)</td>
                            <td class="text-nowrap">@(issue.OriginalEstimate == "-" ? "—" : issue.OriginalEstimate)</td>
                            <td class="text-muted small text-nowrap">
                                @if (issue.Worklogs.Any())
                                {
                                    @(issue.IsExpanded ? "▲" : "▼")
                                    <span class="ms-1">@issue.Worklogs.Count log@(issue.Worklogs.Count != 1 ? "s" : "")</span>
                                }
                            </td>
                        </tr>

                        @if (issue.IsExpanded)
                        {
                            <tr>
                                <td colspan="8" class="p-0 border-0">
                                    <div class="px-4 py-3 bg-light border-start border-3 border-primary">
                                        @if (issue.Worklogs.Any())
                                        {
                                            <table class="table table-sm mb-0">
                                                <thead>
                                                    <tr>
                                                        <th>Author</th>
                                                        <th>Time Spent</th>
                                                        <th>Date</th>
                                                        <th>Comment</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var wl in issue.Worklogs.OrderByDescending(w => w.Started))
                                                    {
                                                        <tr>
                                                            <td class="text-nowrap">@wl.Author</td>
                                                            <td class="text-nowrap">@wl.TimeSpent</td>
                                                            <td class="text-nowrap text-muted">@wl.Started.ToString("dd MMM yyyy")</td>
                                                            <td class="text-muted">@(string.IsNullOrEmpty(wl.Comment) ? "—" : wl.Comment)</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">No worklog entries for this issue.</span>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    @if (FilteredIssues.Count == 0)
                    {
                        <tr><td colspan="8" class="text-center text-muted py-4">No issues match the selected filters.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private string EpicKey = "";
    private bool IsLoading = false;
    private string? ErrorMessage;
    private JiraEpicReport? Report;

    // ── Filters ───────────────────────────────────────────────────────────────
    private HashSet<string> SelectedMembers = [];
    private string FilterText   = "";
    private string FilterStatus = "";
    private string FilterType   = "";

    // ── Derived ───────────────────────────────────────────────────────────────
    private List<string> AllMembers => Report?.Issues
        .Select(i => i.Assignee)
        .Where(a => !string.IsNullOrEmpty(a))
        .Distinct().Order().ToList() ?? [];

    private List<string> AllStatuses => Report?.Issues
        .Select(i => i.Status)
        .Where(s => !string.IsNullOrEmpty(s))
        .Distinct().Order().ToList() ?? [];

    private List<string> AllTypes => Report?.Issues
        .Select(i => i.IssueType)
        .Where(t => !string.IsNullOrEmpty(t))
        .Distinct().Order().ToList() ?? [];

    private List<JiraIssueModel> FilteredIssues => Report?.Issues
        .Where(i =>
            (SelectedMembers.Count == 0 || SelectedMembers.Contains(i.Assignee)) &&
            (string.IsNullOrEmpty(FilterStatus) || i.Status == FilterStatus) &&
            (string.IsNullOrEmpty(FilterType)   || i.IssueType == FilterType) &&
            (string.IsNullOrEmpty(FilterText)   ||
                i.Key.Contains(FilterText, StringComparison.OrdinalIgnoreCase) ||
                i.Summary.Contains(FilterText, StringComparison.OrdinalIgnoreCase)))
        .ToList() ?? [];

    // ── Load ──────────────────────────────────────────────────────────────────
    private async Task LoadEpic()
    {
        if (string.IsNullOrWhiteSpace(EpicKey)) return;

        IsLoading = true;
        ErrorMessage = null;
        Report = null;
        SelectedMembers.Clear();
        FilterText = FilterStatus = FilterType = "";

        try
        {
            Report = await JiraService.GetEpicReportAsync(EpicKey.Trim().ToUpper());
            SelectedMembers = new HashSet<string>(AllMembers);
        }
        catch (HttpRequestException ex)
        {
            ErrorMessage = $"Failed to load epic: {ex.Message}";
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Unexpected error: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await LoadEpic();
    }

    // ── Filter actions ────────────────────────────────────────────────────────
    private void SelectAllMembers()  => SelectedMembers = new HashSet<string>(AllMembers);
    private void ClearMembersFilter() => SelectedMembers.Clear();

    private void ToggleMember(string member, bool selected)
    {
        if (selected) SelectedMembers.Add(member);
        else          SelectedMembers.Remove(member);
    }

    private void ClearFilters()
    {
        FilterText = FilterStatus = FilterType = "";
        SelectedMembers = new HashSet<string>(AllMembers);
    }

    // ── Helpers ───────────────────────────────────────────────────────────────
    private static string StatusBadge(string categoryKey) => categoryKey switch
    {
        "done"          => "bg-success",
        "indeterminate" => "bg-primary",
        _               => "bg-secondary"
    };

    private static int Pct(int count, int total) =>
        total == 0 ? 0 : (int)Math.Round((double)count / total * 100);

    private static string Fmt(int seconds)
    {
        if (seconds <= 0) return "—";
        var h = seconds / 3600;
        var m = (seconds % 3600) / 60;
        return h > 0 ? $"{h}h {m}m" : $"{m}m";
    }
}
