    private async Task LoadLinkedBugsAsync()
    {
        _linkedBugsLoading = true;
        _linkedBugsError   = "";
        StateHasChanged();
        try
        {
            var report = await JiraService.GetBugsWithLinksAsync(_sprintStart, _sprintEnd);
