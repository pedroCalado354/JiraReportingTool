    // ── Load ───────────────────────────────────────────────────────────────────
    private async Task LoadAsync()
    {
        var key = _epicKeyInput.Trim().ToUpperInvariant();
        if (string.IsNullOrEmpty(key)) return;

        _loading      = true;
        _errorMessage = "";
        _bugs.Clear();
        _priorityBugs.Clear();
        _expandedKeys.Clear();
        _selectedAssignees.Clear();
        _selectedStatuses.Clear();
        _selectedCustomers.Clear();
        _selectedLabels.Clear();
        _healthFilter = "all";
        _dueDateFrom  = null;
        _dueDateTo    = null;
        _activityFrom = null;
        _activityTo   = null;
        CloseFilterDropdowns();
        _linkedBugsLoaded = false; // sprint window may have changed — refetch on next tab open
        StateHasChanged();

        try
        {
            // bugsOnly: false → include every child type (Stories, Tasks, Sub-tasks) under the
            // epic, matching a Jira "parent = EPIC" worklog total so logged hours reconcile.
            var epicTask     = JiraService.GetEpicBugsAsync(key, bugsOnly: false);
            var priorityTask = JiraService.GetPriorityBugsAsync();
            await Task.WhenAll(epicTask, priorityTask);

            _bugs              = epicTask.Result.Issues ?? new();
            _loadedEpicKey     = key;
            _priorityBugs      = priorityTask.Result.Issues ?? new();
            _chartsNeedRender      = true;
            _stripChartsNeedRender = true;
            _breakdownsChartNeedRender = true;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load bugs for {key}: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

