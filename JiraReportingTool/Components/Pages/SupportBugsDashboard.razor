    private static List<string> JsSupportLinksOf(SprintIssue b) => b.LinkedIssueKeys
        .Where(k => k.StartsWith("JSSUPPORT", StringComparison.OrdinalIgnoreCase))
        .Distinct(StringComparer.OrdinalIgnoreCase)
