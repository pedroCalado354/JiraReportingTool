    private static string GetShortName(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length <= 1 ? name : parts[0];
    }

    private static string GetInitials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0) return "?";
        if (parts.Length == 1) return parts[0][0].ToString().ToUpper();
        return $"{parts[0][0]}{parts[^1][0]}".ToUpper();
    }

    private static string GetAvatarColor(string name)
    {
        var palette = new[] { "#6366f1","#8b5cf6","#ec4899","#14b8a6","#f59e0b","#10b981","#3b82f6","#ef4444","#f97316","#84cc16","#06b6d4","#a855f7" };
        var hash = name.ToCharArray().Aggregate(0, (acc, c) => acc + c);
        return palette[Math.Abs(hash) % palette.Length];
    }

    private void ToggleRow(string key)
    {
        if (!_expandedKeys.Remove(key))
        {
            _expandedKeys.Add(key);
            if (!_ghPrs.ContainsKey(key))
                _ = LoadGitHubPRsAsync(key);
        }
    }

    private async Task LoadGitHubPRsAsync(string key)
    {
        _ghPrLoading.Add(key); StateHasChanged();
        try   { _ghPrs[key] = await GitHubService.GetPullRequestsAsync(key); }
        catch { _ghPrs[key] = null; }
        finally { _ghPrLoading.Remove(key); StateHasChanged(); }
    }

    // ── Formatting ─────────────────────────────────────────────────────────────
    private static string FormatSeconds(int s)
    {
        if (s == 0) return "—";
        var abs = Math.Abs(s);
        var h = abs / 3600;
        var m = (abs % 3600) / 60;
        var fmt = h > 0 ? (m > 0 ? $"{h}h {m}m" : $"{h}h") : $"{m}m";
        return s < 0 ? $"-{fmt}" : fmt;
    }

    // ── Excel Export ───────────────────────────────────────────────────────────
    private async Task ExportToExcelAsync()
    {
        using var wb = new XLWorkbook();

        var ws = wb.Worksheets.Add("Support Bugs");
        var headers = new[] { "Key", "Title", "Assignee", "Status", "Priority", "Due Date", "Health", "Forecast",
                               "Original Est", "Logged", "Sprint Logged", "Remaining", "% Done", "Last Activity" };
        for (int c = 0; c < headers.Length; c++)
        {
            ws.Cell(1, c + 1).Value = headers[c];
            ws.Cell(1, c + 1).Style.Font.Bold = true;
        }

        int row = 2;
        foreach (var b in FilteredBugs)
        {
            var lastAct = GetLastActivity(b);
            ws.Cell(row, 1).Value  = b.Key;
            ws.Cell(row, 2).Value  = b.Summary;
            ws.Cell(row, 3).Value  = b.Assignee ?? "";
            ws.Cell(row, 4).Value  = b.Status ?? "";
            ws.Cell(row, 5).Value  = b.Priority ?? "";
            ws.Cell(row, 6).Value  = b.DueDate.HasValue ? b.DueDate.Value.ToString("yyyy-MM-dd") : "";
            ws.Cell(row, 7).Value  = GetHealth(b);
            ws.Cell(row, 8).Value  = GetForecastLabel(GetForecast(b));
            ws.Cell(row, 9).Value  = FormatSeconds(b.OriginalEstimateSeconds);
            ws.Cell(row, 10).Value = FormatSeconds(b.TimeSpentSeconds);
            ws.Cell(row, 11).Value = FormatSeconds(GetSprintTimeSeconds(b));
            ws.Cell(row, 12).Value = FormatSeconds(b.ComputedRemainingSeconds);
            ws.Cell(row, 13).Value = b.OriginalEstimateSeconds > 0 ? $"{Math.Min(100, b.TimeSpentSeconds * 100 / b.OriginalEstimateSeconds)}%" : "";
            ws.Cell(row, 14).Value = lastAct.HasValue ? lastAct.Value.ToString("dd MMM yyyy, HH:mm") : "Never";
            row++;
        }
        ws.Columns().AdjustToContents();

        var wsWl = wb.Worksheets.Add("Worklogs");
        wsWl.Cell(1, 1).Value = "Key";    wsWl.Cell(1, 2).Value = "Date";
        wsWl.Cell(1, 3).Value = "Author"; wsWl.Cell(1, 4).Value = "Time";
        wsWl.Cell(1, 5).Value = "In Sprint"; wsWl.Cell(1, 6).Value = "Comment";
        for (int c = 1; c <= 6; c++) wsWl.Cell(1, c).Style.Font.Bold = true;

        int wlRow = 2;
        foreach (var b in FilteredBugs)
        {
            foreach (var wl in b.Worklogs.OrderByDescending(w => w.Started))
            {
                wsWl.Cell(wlRow, 1).Value = b.Key;
                wsWl.Cell(wlRow, 2).Value = wl.Started.ToString("yyyy-MM-dd HH:mm");
                wsWl.Cell(wlRow, 3).Value = wl.Author;
                wsWl.Cell(wlRow, 4).Value = wl.TimeSpent;
                wsWl.Cell(wlRow, 5).Value = IsInSprintPeriod(wl) ? "Yes" : "";
                wsWl.Cell(wlRow, 6).Value = wl.Comment ?? "";
                wlRow++;
            }
        }
        wsWl.Columns().AdjustToContents();

        if (_jssupportIssues.Count > 0)
        {
            var wsPlanned = wb.Worksheets.Add("Planned Issues");
            var plannedHeaders = new[] { "Key", "Summary", "Status", "Assignee", "Created", "Logged By" };
            for (int c = 0; c < plannedHeaders.Length; c++)
            {
                wsPlanned.Cell(1, c + 1).Value = plannedHeaders[c];
                wsPlanned.Cell(1, c + 1).Style.Font.Bold = true;
            }
            int pRow = 2;
            foreach (var issue in _jssupportIssues)
            {
                var loggers = issue.Worklogs
                    .Select(w => w.Author)
                    .Where(a => !string.IsNullOrEmpty(a))
                    .Distinct()
                    .OrderBy(a => a);
                wsPlanned.Cell(pRow, 1).Value = issue.Key;
                wsPlanned.Cell(pRow, 2).Value = issue.Summary;
                wsPlanned.Cell(pRow, 3).Value = issue.Status ?? "";
                wsPlanned.Cell(pRow, 4).Value = issue.Assignee ?? "";
                wsPlanned.Cell(pRow, 5).Value = issue.Created.HasValue ? issue.Created.Value.ToString("dd MMM yyyy") : "";
                wsPlanned.Cell(pRow, 6).Value = string.Join(", ", loggers);
                pRow++;
            }
            wsPlanned.Columns().AdjustToContents();
        }

        using var ms = new MemoryStream();
        wb.SaveAs(ms);
        var base64   = Convert.ToBase64String(ms.ToArray());
        var fileName = $"SupportBugs_{_loadedEpicKey}{ScopeFileSuffix}_{DateTime.Now:yyyyMMdd}.xlsx";
        const string mime = "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet";
        await JS.InvokeVoidAsync("downloadBase64File", base64, fileName, mime);
    }

    // ── CSV Export ────────────────────────────────────────────────────────────
    private async Task ExportBugsToCsvAsync()
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("Key,Title,Assignee,Status,Priority,Due Date,Health,Forecast,Orig Est (h),Logged (h),Sprint (h),Remaining (h),% Done,Last Activity");
        foreach (var b in FilteredBugs)
        {
            var lastAct = GetLastActivity(b);
            sb.AppendLine(string.Join(",", new[]
            {
                CsvEscape(b.Key),
                CsvEscape(b.Summary),
                CsvEscape(b.Assignee ?? ""),
                CsvEscape(b.Status ?? ""),
                CsvEscape(b.Priority ?? ""),
                b.DueDate.HasValue ? b.DueDate.Value.ToString("yyyy-MM-dd") : "",
                GetHealth(b),
                GetForecastLabel(GetForecast(b)),
                $"{b.OriginalEstimateSeconds / 3600.0:F1}",
                $"{b.TimeSpentSeconds / 3600.0:F1}",
                $"{GetSprintTimeSeconds(b) / 3600.0:F1}",
                b.OriginalEstimateSeconds > 0 ? $"{b.ComputedRemainingSeconds / 3600.0:F1}" : "",
                b.OriginalEstimateSeconds > 0 ? $"{Math.Min(100, b.TimeSpentSeconds * 100 / b.OriginalEstimateSeconds)}" : "",
                lastAct.HasValue ? lastAct.Value.ToString("yyyy-MM-dd HH:mm") : "Never"
            }));
        }
        var bytes  = System.Text.Encoding.UTF8.GetBytes(sb.ToString());
        var base64 = Convert.ToBase64String(bytes);
        var fileName = $"SupportBugs_{_loadedEpicKey}{ScopeFileSuffix}_{DateTime.Now:yyyyMMdd}.csv";
        await JS.InvokeVoidAsync("downloadBase64File", base64, fileName, "text/csv;charset=utf-8");
    }

    private string ScopeFileSuffix => _typeScope switch
    {
        "bug"      => "_Bugs",
        "redesign" => "_Redesign",
        _          => ""
    };

    private static string CsvEscape(string value)
    {
        if (string.IsNullOrEmpty(value)) return "";
        if (value.Contains(',') || value.Contains('"') || value.Contains('\n'))
            return $"\"{value.Replace("\"", "\"\"")}\"";
        return value;
    }

    // ── Charts ────────────────────────────────────────────────────────────────
    private async Task SwitchToChartsTab()
    {
        _activeTab = "charts";
        _chartsNeedRender = true;
    }

    private void SwitchToBreakdownsTab()
    {
        _activeTab = "breakdowns";
        _breakdownsChartNeedRender = true;
    }

    private async Task RenderBreakdownsChartAsync()
    {
        await JS.InvokeVoidAsync("destroyChart", "sb-chart-resolved");

        var days = Enumerable.Range(0, Math.Max(1, _sprintEnd.DayNumber - _sprintStart.DayNumber + 1))
                             .Select(i => _sprintStart.AddDays(i)).ToList();
        var labels   = days.Select(d => d.ToString("MMM d")).ToArray();
        var resolved = days.Select(d => FilteredBugs.Count(b =>
                            b.ResolutionDate.HasValue && DateOnly.FromDateTime(b.ResolutionDate.Value) == d)).ToArray();

        await JS.InvokeVoidAsync("renderChart", "sb-chart-resolved", new
        {
            type = "bar",
            data = new
            {
                labels,
                datasets = new[] { new
                {
                    label = "Resolved",
                    data = resolved,
                    backgroundColor = "#16a34a",
                    borderRadius = 3
                }}
            },
            options = new
            {
                responsive = true,
                maintainAspectRatio = false,
                plugins = new { legend = new { display = false } },
                scales = new { y = new { beginAtZero = true, ticks = new { precision = 0 } } }
            }
        });
    }

    protected override async Task OnInitializedAsync()
    {
        var current = await SprintConfigService.GetCurrentAsync();
        if (current is not null)
        {
            if (string.IsNullOrEmpty(_epicKeyInput))
                _epicKeyInput = current.EpicKey;
            _sprintStart = current.StartDate;
            _sprintEnd   = current.EndDate;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_stripChartsNeedRender && _bugs.Count > 0)
        {
            _stripChartsNeedRender = false;
            await RenderStripChartsAsync();
        }

        if (_chartsNeedRender && _activeTab == "charts" && _bugs.Count > 0)
        {
            _chartsNeedRender = false;
            await RenderChartsAsync();
        }

        if (_breakdownsChartNeedRender && _activeTab == "breakdowns" && _bugs.Count > 0)
        {
            _breakdownsChartNeedRender = false;
            await RenderBreakdownsChartAsync();
        }
    }

