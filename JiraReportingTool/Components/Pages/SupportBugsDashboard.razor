    // ── Worklogs ───────────────────────────────────────────────────────────────
    private int GetSprintTimeSeconds(SprintIssue b)
    {
        return b.Worklogs.Where(w => IsInSprintPeriod(w) && AuthorIncluded(w)).Sum(w => w.TimeSpentSeconds);
    }

    // Total logged scoped to the active person filter: the bug's full logged time when no person is
    // selected, otherwise only the selected people's worklogs (matches Jira's worklogAuthor total).
    private int GetTotalTimeSeconds(SprintIssue b)
    {
        return (!_personFilterByAuthor || _selectedAssignees.Count == 0)
            ? b.TimeSpentSeconds
            : b.Worklogs.Where(AuthorIncluded).Sum(w => w.TimeSpentSeconds);
    }

    private List<WorklogEntry> GetSprintWorklogs(SprintIssue b)
    {
        return b.Worklogs.Where(w => IsInSprintPeriod(w) && AuthorIncluded(w)).OrderByDescending(w => w.Started).ToList();
    }

    private bool IsInSprintPeriod(WorklogEntry w)
    {
        var d = DateOnly.FromDateTime(w.Started);
        return d >= _sprintStart && d <= _sprintEnd;
    }

    // A worklog counts toward logged-time metrics when no person filter is active, or when its author
    // is one of the selected people. Keeps "Sprint Logged"/"Total Logged" aligned with the filter.
    private bool AuthorIncluded(WorklogEntry w) =>
        !_personFilterByAuthor || _selectedAssignees.Count == 0 || _selectedAssignees.Contains(w.Author);

    private static DateTime? GetLastActivity(SprintIssue b) =>
        b.Worklogs.Count > 0 ? b.Worklogs.Max(w => w.Started) : null;

    private bool IsStale(SprintIssue b) =>
        IsInProgress(b) &&
        (GetLastActivity(b) == null || (DateTime.Now - GetLastActivity(b)!.Value).TotalHours > 24);

