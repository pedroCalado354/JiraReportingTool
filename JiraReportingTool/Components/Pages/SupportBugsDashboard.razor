            .ThenByDescending(x => x.Wl.TimeSpentSeconds)
            .ToList();

    private record DashContribRow(string Name, int BugCount, int TotalSeconds, int DaysActive, List<string> BugKeys);

    private List<DashContribRow> DashContribRows(List<SprintIssue> activeBugs) =>
        activeBugs
            .SelectMany(b => GetSprintWorklogs(b).Select(w => (Bug: b, Wl: w)))
            .GroupBy(x => x.Wl.Author)
            .Select(g => new DashContribRow(
                g.Key,
                g.Select(x => x.Bug.Key).Distinct().Count(),
                g.Sum(x => x.Wl.TimeSpentSeconds),
                g.Select(x => DateOnly.FromDateTime(x.Wl.Started)).Distinct().Count(),
                g.Select(x => x.Bug.Key).Distinct().OrderBy(k => k).ToList()
            ))
            .OrderByDescending(r => r.TotalSeconds)
            .ToList();

