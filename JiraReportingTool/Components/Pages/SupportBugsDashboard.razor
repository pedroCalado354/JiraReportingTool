    // JSSUPPORT-linked + outside the epic + either has a worklog logged on/after 00:00 of
    // the sprint start date or was resolved within the sprint window (bugs can be closed
    // without logged time), before the tab's own author/status filters — the base set the
    // dropdown options/counts are built from.
    private List<SprintIssue> LinkedBaseBugs
    {
        get
        {
            var epicKeys = _bugs.Select(b => b.Key).ToHashSet(StringComparer.OrdinalIgnoreCase);
            var sprintStartAt = _sprintStart.ToDateTime(TimeOnly.MinValue);
            var sprintEndAt = _sprintEnd.AddDays(1).ToDateTime(TimeOnly.MinValue);
            return _linkedBugsRaw
                .Where(b => JsSupportLinksOf(b).Count > 0 && !epicKeys.Contains(b.Key))
                .Where(b => b.Worklogs.Any(w => w.TimeSpentSeconds > 0 && w.Started >= sprintStartAt)
                         || (b.ResolutionDate >= sprintStartAt && b.ResolutionDate < sprintEndAt))
                .ToList();
        }
    }

    private List<SprintIssue> LinkedSupportBugs
    {
        get
        {
            var q = LinkedBaseBugs.AsEnumerable();
            if (_lkSelectedAuthors.Count > 0)
                q = q.Where(b => b.Worklogs.Any(w => _lkSelectedAuthors.Contains(w.Author)));
            if (_lkSelectedStatuses.Count > 0)
                q = q.Where(b => _lkSelectedStatuses.Contains(b.Status));
            return (_sortColLk switch
            {
                "pri"      => _sortAscLk ? q.OrderBy(b => PriOrder(b))                          : q.OrderByDescending(b => PriOrder(b)),
                "key"      => _sortAscLk ? q.OrderBy(b => b.Key)                                : q.OrderByDescending(b => b.Key),
                "title"    => _sortAscLk ? q.OrderBy(b => b.Summary)                            : q.OrderByDescending(b => b.Summary),
                "customer" => _sortAscLk ? q.OrderBy(b => b.Customer)                           : q.OrderByDescending(b => b.Customer),
                "status"   => _sortAscLk ? q.OrderBy(b => b.Status)                             : q.OrderByDescending(b => b.Status),
                "created"  => _sortAscLk ? q.OrderBy(b => b.Created ?? DateTime.MaxValue)       : q.OrderByDescending(b => b.Created ?? DateTime.MinValue),
                "age"      => _sortAscLk ? q.OrderBy(b => GetDaysOpen(b))                       : q.OrderByDescending(b => GetDaysOpen(b)),
                "logged"   => _sortAscLk ? q.OrderBy(b => b.TimeSpentSeconds)                   : q.OrderByDescending(b => b.TimeSpentSeconds),
                _          => q.OrderByDescending(b => b.Created ?? DateTime.MinValue)
            }).ToList();
        }
    }

