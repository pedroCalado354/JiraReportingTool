                    backgroundColor = new[] { "#16a34a", "#2563eb", "#b45309", "#9ca3af" },
                    borderWidth = 2,
                    borderColor = "#ffffff"
                }}
            },
            options = new
            {
                responsive = true,
                maintainAspectRatio = false,
                cutout = "68%",
                plugins = new { legend = new { display = false }, tooltip = new { callbacks = new { } } }
            }
        });

        await JS.InvokeVoidAsync("renderChart", "sb-strip-chart-health", new
        {
            type = "doughnut",
            data = new
            {
                labels = new[] { "Overdue", "At Risk", "On Track", "No Due Date", "Done" },
                datasets = new[] { new
                {
                    data = new[] { OverdueCount, AtRiskCount, OnTrackCount, NoDueDateCount, DoneCount },
                    backgroundColor = new[] { "#b91c1c", "#b45309", "#16a34a", "#9ca3af", "#2563eb" },
                    borderWidth = 2,
                    borderColor = "#ffffff"
                }}
            },
            options = new
            {
                responsive = true,
                maintainAspectRatio = false,
                cutout = "68%",
                plugins = new { legend = new { display = false }, tooltip = new { callbacks = new { } } }
            }
        });
    }

    private async Task RenderChartsAsync()
    {
        foreach (var id in new[] { "sb-chart-health", "sb-chart-status", "sb-chart-age", "sb-chart-assignee", "sb-chart-time" })
            await JS.InvokeVoidAsync("destroyChart", id);

        await JS.InvokeVoidAsync("renderChart", "sb-chart-health", new
        {
            type = "doughnut",
            data = new
            {
                labels = new[] { "Overdue", "At Risk", "On Track", "No Due Date", "Done" },
                datasets = new[] { new
                {
                    data = new[] { OverdueCount, AtRiskCount, OnTrackCount, NoDueDateCount, DoneCount },
                    backgroundColor = new[] { "#b91c1c", "#b45309", "#16a34a", "#9ca3af", "#2563eb" },
                    borderWidth = 2,
                    borderColor = "#ffffff"
                }}
            },
            options = new
            {
                responsive = true,
                maintainAspectRatio = false,
                plugins = new { legend = new { position = "bottom", labels = new { font = new { size = 11 } } } }
            }
        });

        var todoCount = FilteredBugs.Count(b => !IsDone(b) && !IsInProgress(b) &&
            !string.Equals(b.Status, "on hold", StringComparison.OrdinalIgnoreCase));
        await JS.InvokeVoidAsync("renderChart", "sb-chart-status", new
        {
            type = "doughnut",
            data = new
            {
                labels = new[] { "Done", "In Progress", "On Hold", "To Do" },
                datasets = new[] { new
                {
                    data = new[] { DoneCount, InProgressCount, OnHoldCount, todoCount },
                    backgroundColor = new[] { "#16a34a", "#2563eb", "#b45309", "#9ca3af" },
                    borderWidth = 2,
                    borderColor = "#ffffff"
                }}
            },
            options = new
            {
                responsive = true,
                maintainAspectRatio = false,
                plugins = new { legend = new { position = "bottom", labels = new { font = new { size = 11 } } } }
            }
        });

        var openBugsForAge = FilteredBugs.Where(b => !IsDone(b)).ToList();
        var ageFreshC  = openBugsForAge.Count(b => GetDaysOpen(b) < 7);
        var ageRecentC = openBugsForAge.Count(b => GetDaysOpen(b) >= 7  && GetDaysOpen(b) < 30);
        var ageAgingC  = openBugsForAge.Count(b => GetDaysOpen(b) >= 30 && GetDaysOpen(b) < 90);
        var ageOldC    = openBugsForAge.Count(b => GetDaysOpen(b) >= 90);
        await JS.InvokeVoidAsync("renderChart", "sb-chart-age", new
        {
            type = "bar",
            data = new
            {
                labels = new[] { "Fresh (<7d)", "Recent (7-30d)", "Aging (30-90d)", "Old (>90d)" },
                datasets = new[] { new
                {
                    label = "Open Bugs",
                    data = new[] { ageFreshC, ageRecentC, ageAgingC, ageOldC },
                    backgroundColor = new[] { "#16a34a", "#2563eb", "#b45309", "#b91c1c" }
                }}
            },
            options = new
            {
                responsive = true,
                maintainAspectRatio = false,
                plugins = new { legend = new { display = false } },
                scales = new { y = new { beginAtZero = true, ticks = new { stepSize = 1 } } }
            }
        });

        var assignees = AssigneeSummaries.ToList();
        await JS.InvokeVoidAsync("renderChart", "sb-chart-assignee", new
        {
            type = "bar",
            data = new
            {
                labels = assignees.Select(a => GetShortName(a.Name)).ToArray(),
                datasets = new object[]
                {
                    new { label = "Open",  data = assignees.Select(a => a.Total - a.Done).ToArray(), backgroundColor = "#3b82f6", stack = "s" },
                    new { label = "Done",  data = assignees.Select(a => a.Done).ToArray(),            backgroundColor = "#16a34a", stack = "s" }
                }
            },
            options = new
            {
                responsive = true,
                maintainAspectRatio = false,
                indexAxis = "y",
                plugins = new { legend = new { position = "bottom" } },
                scales = new { x = new { stacked = true, beginAtZero = true }, y = new { stacked = true } }
            }
        });

        await JS.InvokeVoidAsync("renderChart", "sb-chart-time", new
        {
            type = "bar",
            data = new
            {
                labels = assignees.Select(a => GetShortName(a.Name)).ToArray(),
                datasets = new object[]
                {
                    new { label = "Sprint Logged (h)", data = assignees.Select(a => Math.Round(a.SprintSeconds / 3600.0, 1)).ToArray(), backgroundColor = "#6366f1" },
                    new { label = "Total Logged (h)",  data = assignees.Select(a => Math.Round(a.TotalSeconds  / 3600.0, 1)).ToArray(), backgroundColor = "#a5b4fc" }
                }
            },
            options = new
            {
                responsive = true,
                maintainAspectRatio = false,
                indexAxis = "y",
                plugins = new { legend = new { position = "bottom" } },
                scales = new { x = new { beginAtZero = true } }
            }
        });
    }

    // ── Inner types ────────────────────────────────────────────────────────────
    private record AssigneeSummary
    {
        public string Name          { get; init; } = "";
        public int    Total         { get; init; }
        public int    Done          { get; init; }
        public int    InProgress    { get; init; }
        public int    Overdue       { get; init; }
        public int    AtRisk        { get; init; }
        public int    NoDueDate     { get; init; }
        public int    SprintSeconds { get; init; }
        public int    TotalSeconds  { get; init; }
    }

    private record WorkloadRow
    {
        public string Name             { get; init; } = "";
        public int    Total            { get; init; }
        public int    Open             { get; init; }
        public int    Done             { get; init; }
        public int    Overdue          { get; init; }
        public int    OnHold           { get; init; }
        public int    SprintSeconds    { get; init; }
        public int    TotalSeconds     { get; init; }
        public int    RemainingSeconds { get; init; }
