    private List<(SprintIssue Bug, WorklogEntry Wl)> DashDayWorklogs(List<SprintIssue> activeBugs, DateOnly day) =>
        activeBugs
            .SelectMany(b => GetSprintWorklogs(b)
                .Where(w => DateOnly.FromDateTime(w.Started) == day)
                .Select(w => (Bug: b, Wl: w)))
