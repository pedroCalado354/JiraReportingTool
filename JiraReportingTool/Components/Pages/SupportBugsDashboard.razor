        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
    }
    .sb-scope-dot-bug      { background: var(--danger); }
    .sb-scope-dot-redesign { background: #8b5cf6; }

    .sb-scope-hint { font-size: 12px; color: var(--txt-3); }

    /* ── KPI cards ───────────────────────────────────────────────── */
    .sbk-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
        gap: 12px;
    }

    .sbk-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--r-md);
        padding: 14px 16px 12px;
        box-shadow: var(--sh-xs);
        display: flex;
        flex-direction: column;
        min-width: 0;
        transition: box-shadow .15s, border-color .15s;
    }
    .sbk-card:hover { box-shadow: var(--sh-sm); }

    .sbk-head {
        display: flex;
        align-items: center;
        gap: 7px;
        font-size: 10.5px;
        font-weight: 700;
        color: var(--txt-3);
        text-transform: uppercase;
        letter-spacing: .06em;
        margin-bottom: 8px;
        white-space: nowrap;
        overflow: hidden;
    }
    .sbk-title { overflow: hidden; text-overflow: ellipsis; }

    .sbk-ico {
        width: 22px;
        height: 22px;
        border-radius: 6px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        flex-shrink: 0;
        background: var(--surface-2);
        color: var(--txt-3);
    }

    .sbk-value {
        font-size: 25px;
        font-weight: 750;
        color: var(--txt-1);
        line-height: 1.1;
        letter-spacing: -0.3px;
        display: flex;
        align-items: baseline;
        gap: 6px;
        flex-wrap: wrap;
    }

    .sbk-unit {
        font-size: 12px;
        font-weight: 500;
        color: var(--txt-3);
        letter-spacing: 0;
    }

    .sbk-meter {
        height: 4px;
        background: var(--surface-2);
        border-radius: 2px;
        overflow: hidden;
        margin-top: 9px;
    }
    .sbk-meter-fill {
        height: 100%;
        border-radius: 2px;
        background: var(--primary);
        transition: width .3s ease;
    }

    .sbk-sub {
        font-size: 11px;
        color: var(--txt-3);
        margin-top: 7px;
        line-height: 1.45;
    }

    /* Tone variants: icon tint + meter color */
    .sbk-success .sbk-ico        { background: var(--success-light, #dcfce7); color: var(--success); }
    .sbk-success .sbk-meter-fill { background: var(--success); }
    .sbk-warn .sbk-ico           { background: var(--warning-light, #fef3c7); color: var(--warning); }
    .sbk-warn .sbk-meter-fill    { background: var(--warning); }
    .sbk-danger .sbk-ico         { background: var(--danger-light); color: var(--danger); }
    .sbk-danger .sbk-meter-fill  { background: var(--danger); }
    .sbk-neutral .sbk-ico        { background: var(--primary-light); color: var(--primary); }

    /* ── Metric strip ────────────────────────────────────────────── */
    .sb-metrics {
        display: flex;
        align-items: stretch;
        gap: 10px;
        flex-wrap: wrap;
    }

    .sb-metric {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--r-md);
        padding: 14px 20px;
        min-width: 100px;
        box-shadow: var(--sh-xs);
        border-left-width: 3px;
        flex: 1;
    }

    .sb-metric-neutral { border-left-color: var(--border); }
    .sb-metric-green   { border-left-color: var(--success); }
    .sb-metric-blue    { border-left-color: var(--primary); }
    .sb-metric-red     { border-left-color: var(--danger); }
    .sb-metric-amber   { border-left-color: var(--warning); }
    .sb-metric-time    { border-left-color: #8b5cf6; background: #faf5ff; border-color: #e9d5ff; border-left-color: #8b5cf6; }

    .sb-metric-divider {
        width: 1px;
        background: var(--border);
        margin: 4px 4px;
        flex-shrink: 0;
        align-self: stretch;
    }

    .sb-metric-val {
        font-size: 24px;
        font-weight: 700;
        color: var(--txt-1);
        line-height: 1.15;
    }
    .sb-metric-val-sm { font-size: 18px; }

    .sb-metric-green .sb-metric-val  { color: var(--success); }
    .sb-metric-blue .sb-metric-val   { color: var(--primary); }
    .sb-metric-red .sb-metric-val    { color: var(--danger); }
    .sb-metric-amber .sb-metric-val  { color: var(--warning); }
    .sb-metric-time .sb-metric-val   { color: #7c3aed; }

    .sb-metric-pct {
        font-size: 13px;
        font-weight: 500;
        color: var(--txt-3);
        margin-left: 3px;
    }

    .sb-metric-lbl {
        font-size: 11px;
        color: var(--txt-3);
        margin-top: 3px;
        white-space: nowrap;
        font-weight: 500;
    }

    /* ── Filter panel ────────────────────────────────────────────── */
    .sb-filters-panel {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--r-md);
        overflow: hidden;
        box-shadow: var(--sh-xs);
    }

    /* ── Filter bar (searchable dropdowns + date ranges) ─────────── */
    /* .sb-section sets overflow:hidden later in this sheet — needs the higher
       specificity here so the dropdown panels can overflow the section. */
    .sb-section.sb-filterbar { overflow: visible; }

    .sb-filterbar-row {
        display: flex;
        align-items: flex-end;
        gap: 18px;
        flex-wrap: wrap;
        padding: 12px 16px 14px;
    }

    .sb-fb-group {
        display: flex;
        flex-direction: column;
        gap: 5px;
        min-width: 0;
    }

    .sb-fb-cap {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 10px;
        font-weight: 700;
        color: var(--txt-3);
        text-transform: uppercase;
        letter-spacing: .07em;
        white-space: nowrap;
    }

    .sb-filter-clear-link {
        background: none;
        border: none;
        color: var(--primary);
        font-size: 11px;
        cursor: pointer;
        padding: 0;
        font-weight: 500;
        text-transform: none;
        letter-spacing: 0;
    }
    .sb-filter-clear-link:hover { text-decoration: underline; }

    .sb-section-clear { margin-left: auto; }

    .sb-person-mode {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 11px;
        color: var(--txt-2);
        cursor: pointer;
        padding: 8px 12px 2px;
        user-select: none;
    }
    .sb-person-mode input { cursor: pointer; accent-color: var(--primary); }

    /* Searchable multi-select dropdown (shared pattern with /support-bugs-slas) */
    .sb-dd { position: relative; display: inline-block; }

    .sb-dd-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: 1px solid var(--border);
        background: var(--surface);
        color: var(--txt-2);
        font-family: inherit;
        font-size: 12.5px;
        font-weight: 500;
        padding: 6px 12px;
        border-radius: 8px;
        cursor: pointer;
        transition: border-color .12s, background .12s, color .12s;
        white-space: nowrap;
        min-width: 128px;
        justify-content: space-between;
    }
    .sb-dd-btn:hover:not(:disabled) { border-color: var(--primary-border); color: var(--txt-1); }
    .sb-dd-btn:disabled { opacity: .5; cursor: not-allowed; }
    .sb-dd-btn.active {
        border-color: var(--primary-border);
        background: var(--primary-light);
        color: var(--primary);
        font-weight: 600;
    }
    .sb-dd-caret { font-size: 10px; color: var(--txt-4); }
    .sb-dd-btn.active .sb-dd-caret { color: var(--primary); }

    .sb-dd-backdrop { position: fixed; inset: 0; z-index: 40; }

    .sb-dd-panel {
        position: absolute;
        top: calc(100% + 5px);
        left: 0;
        z-index: 41;
        width: 280px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 10px;
        box-shadow: var(--sh-md);
        overflow: hidden;
    }

    .sb-dd-head {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 9px 10px;
        border-bottom: 1px solid var(--border);
        background: var(--surface-2);
    }

    .sb-dd-search {
        flex: 1;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: var(--surface);
        color: var(--txt-1);
        font-family: inherit;
        font-size: 12px;
        padding: 5px 9px;
        outline: none;
        min-width: 0;
    }
    .sb-dd-search:focus { border-color: var(--primary); }

    .sb-dd-clear {
        background: none;
        border: none;
        color: var(--primary);
        font-size: 11.5px;
        font-weight: 600;
        cursor: pointer;
        padding: 2px 4px;
        white-space: nowrap;
    }
    .sb-dd-clear:hover { text-decoration: underline; }

    .sb-dd-list { max-height: 280px; overflow-y: auto; padding: 4px 0; }

    .sb-dd-opt {
        display: flex;
        align-items: center;
        gap: 9px;
        padding: 6px 12px;
        font-size: 12.5px;
        color: var(--txt-2);
        cursor: pointer;
        user-select: none;
        transition: background .1s;
    }
    .sb-dd-opt:hover { background: var(--surface-2); color: var(--txt-1); }
    .sb-dd-opt input { cursor: pointer; accent-color: var(--primary); flex-shrink: 0; }

    .sb-dd-opt-name {
        flex: 1;
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .sb-dd-opt-n {
        font-size: 10.5px;
        font-weight: 700;
        color: var(--txt-4);
        background: var(--surface-2);
        border-radius: 9px;
        padding: 1px 7px;
        flex-shrink: 0;
    }

    /* Selected-filter chips echoed under the dropdown row */
    .sb-fb-chips {
        display: flex;
        align-items: center;
        gap: 6px;
        flex-wrap: wrap;
        padding: 0 16px 12px;
    }

    .sb-fb-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        border: 1px solid var(--primary-border);
        background: var(--primary-light);
        color: var(--primary);
        font-family: inherit;
        font-size: 11.5px;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 20px;
        cursor: pointer;
        transition: opacity .12s;
        line-height: 1.5;
    }
    .sb-fb-chip:hover { opacity: .75; }

    .sb-fb-chip-cap {
        font-size: 9.5px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .05em;
        opacity: .65;
    }

    .sb-date-range {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .sb-date-range-lbl {
        font-size: 11px;
        color: var(--txt-4);
        flex-shrink: 0;
    }

    .sb-filter-date {
        font-size: 12px;
        padding: 4px 8px;
        height: 30px;
        width: 124px;
    }

    /* ── Chip-filter row (bottom row) ────────────────────────────── */
    .sb-filter-row {
        display: flex;
        align-items: flex-start;
        gap: 14px;
        padding: 10px 16px;
    }

    .sb-filter-row-inline {
        align-items: center;
        background: var(--surface-2);
    }

    .sb-filter-sep {
        height: 1px;
        background: var(--border);
    }

    .sb-filter-inline-sep {
        width: 1px;
        background: var(--border);
        align-self: stretch;
        margin: 0 4px;
    }

    .sb-filter-inline-group {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .sb-filter-label {
        font-size: 10px;
        font-weight: 700;
        color: var(--txt-3);
        text-transform: uppercase;
        letter-spacing: .07em;
        white-space: nowrap;
    }

    .sb-filter-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 5px;
    }

    .sb-chip-btn {
        display: inline-flex;
        align-items: center;
        padding: 3px 10px;
        border-radius: 20px;
        border: 1px solid var(--border);
        background: var(--surface);
        color: var(--txt-2);
        font-size: 12px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.12s;
        line-height: 1.5;
    }
    .sb-chip-btn:hover {
        border-color: var(--primary-border);
        background: var(--primary-light);
        color: var(--primary);
    }
    .sb-chip-btn.active {
        background: var(--primary);
        border-color: var(--primary);
        color: #fff;
        font-weight: 600;
    }

    /* Health chip colour overrides when active */
    .sb-chip-health-overdue.active    { background: var(--danger);  border-color: var(--danger); }
    .sb-chip-health-at-risk.active    { background: var(--warning); border-color: var(--warning); }
    .sb-chip-health-on-track.active   { background: var(--success); border-color: var(--success); }
    .sb-chip-health-no-due-date.active { background: #6b7280; border-color: #6b7280; }
    .sb-chip-health-done.active       { background: var(--success); border-color: var(--success); }

    /* ── Sections ────────────────────────────────────────────────── */
    .sb-section {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--r-md);
        overflow: hidden;
        box-shadow: var(--sh-xs);
    }

    .sb-section-header {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 11px 16px;
        cursor: pointer;
        user-select: none;
        background: var(--surface-2);
        border-bottom: 1px solid var(--border);
        transition: background 0.1s;
    }
    .sb-section-header:hover { filter: brightness(0.98); }
    .sb-filterbar > .sb-section-header { border-radius: var(--r-md) var(--r-md) 0 0; }

    .sb-section-toggle { font-size: 11px; color: var(--txt-4); }

    .sb-section-title {
        font-size: 13px;
        font-weight: 600;
        color: var(--txt-1);
    }

    .sb-section-sub {
        font-size: 12px;
        color: var(--txt-3);
    }

    /* ── Assignee Cards ──────────────────────────────────────────── */
    .sb-assignee-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 12px;
        padding: 16px;
    }

    .sb-assignee-card {
        border: 1px solid var(--border);
        border-radius: var(--r-md);
        padding: 14px 16px;
        background: var(--surface);
        transition: box-shadow 0.15s, border-color 0.15s;
    }
    .sb-assignee-card:hover {
        box-shadow: var(--sh-sm);
        border-color: #d1d5db;
    }

    .sb-ac-head {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 10px;
    }

    .sb-ac-avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 12px;
        font-weight: 700;
        flex-shrink: 0;
        letter-spacing: 0.5px;
    }

    .sb-ac-head-info { min-width: 0; }

    .sb-ac-name {
        font-size: 13px;
        font-weight: 600;
        color: var(--txt-1);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .sb-ac-pct-label {
        font-size: 11px;
        color: var(--txt-3);
        margin-top: 1px;
    }

    .sb-ac-progress {
        height: 4px;
        background: var(--border);
        border-radius: 2px;
        overflow: hidden;
        margin-bottom: 10px;
    }

    .sb-ac-progress-fill {
        height: 100%;
        background: var(--success);
        border-radius: 2px;
        transition: width 0.3s;
    }

    .sb-ac-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
        margin-bottom: 10px;
    }

    .ac-chip {
        display: inline-block;
        padding: 2px 7px;
        border-radius: 10px;
        font-size: 11px;
        font-weight: 600;
        white-space: nowrap;
    }
    .ac-chip-red   { background: #fee2e2; color: #b91c1c; }
    .ac-chip-amber { background: #fef3c7; color: #92400e; }
    .ac-chip-blue  { background: #dbeafe; color: #1e40af; }
    .ac-chip-green { background: #dcfce7; color: #15803d; }
    .ac-chip-gray  { background: #f3f4f6; color: #4b5563; }

    .sb-ac-time {
        display: flex;
        gap: 14px;
        font-size: 12px;
        color: var(--txt-2);
        font-weight: 600;
    }

    .sb-ac-time-lbl {
        font-size: 10px;
        font-weight: 600;
        color: var(--txt-4);
        text-transform: uppercase;
        letter-spacing: .05em;
        margin-right: 2px;
    }

    /* ── Main Table ──────────────────────────────────────────────── */
    .sb-table-wrap { overflow-x: auto; }

    .sb-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

    .sb-th {
        padding: 9px 10px;
        text-align: left;
        font-size: 10px;
        font-weight: 700;
        color: var(--txt-3);
        text-transform: uppercase;
        letter-spacing: .06em;
        background: var(--surface-2);
        border-bottom: 2px solid var(--border);
        white-space: nowrap;
        position: sticky;
        top: 0;
        z-index: 2;
    }

    .sb-th-pri      { width: 28px; text-align: center; }
    .sb-th-key      { width: 90px; }
    .sb-th-title    { min-width: 220px; max-width: 320px; }
    .sb-th-customer { width: 110px; }
    .sb-th-assignee { width: 120px; }
    .sb-th-labels   { width: 160px; }
    .sb-td-customer { font-size: 12px; color: var(--txt-2); white-space: nowrap; }
    .sb-th-status   { width: 110px; }
    .sb-th-due      { width: 130px; }
    .sb-th-forecast { width: 110px; }
    .sb-th-est      { width: 80px; text-align: right; }
    .sb-th-pct      { width: 90px; text-align: center; }
    .sb-th-activity { width: 130px; }
    .sb-th-expand   { width: 60px; text-align: center; }

    .sb-td {
        padding: 9px 10px;
        border-bottom: 1px solid var(--border);
        vertical-align: middle;
        color: var(--txt-2);
    }

    .sb-row:hover .sb-td { background: var(--surface-2); }
    .sb-row-expanded .sb-td { background: var(--primary-light); }

    .sb-td-key { font-family: monospace; font-size: 12px; }
    .sb-td-title { max-width: 320px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .sb-td-assignee { font-size: 12px; }
    .sb-td-labels   { font-size: 11px; }
    .sb-label-chip  { display: inline-block; padding: 1px 6px; margin: 1px 2px; border-radius: 10px; background: var(--surface-2); border: 1px solid var(--border); color: var(--txt-2); white-space: nowrap; }
    .sb-lk-chip     { display: inline-block; padding: 1px 8px; margin: 1px 2px; border-radius: 10px; background: var(--primary-light); border: 1px solid var(--primary-border); color: var(--primary); font-size: 11px; font-weight: 600; white-space: nowrap; text-decoration: none; }
    .sb-lk-chip:hover { filter: brightness(0.96); text-decoration: none; }
    /* JSSUPPORT Linked tab — dropdown panel must overflow the section (same trick as the filter bar) */
    .sb-section.sb-lk-section { overflow: visible; }
    .sb-section.sb-lk-section > .sb-section-header { border-radius: var(--r-md) var(--r-md) 0 0; }
    .sb-lk-toolbar {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
        padding: 10px 16px;
        border-bottom: 1px solid var(--border);
    }
    .sb-lk-toolbar-count { margin-left: auto; font-size: 12px; color: var(--txt-3); white-space: nowrap; }

    .sb-lk-author-row  { display: flex; flex-wrap: wrap; gap: 6px; padding: 8px 0 10px; }
    .sb-lk-author-chip { display: inline-flex; align-items: center; gap: 6px; padding: 3px 10px 3px 4px; border-radius: 20px; background: var(--surface-2); border: 1px solid var(--border); color: var(--txt-2); font-size: 11.5px; white-space: nowrap; }
    .sb-td-est { text-align: right; font-size: 12px; color: var(--txt-3); white-space: nowrap; }
    .sb-td-pct { text-align: center; }
    .sb-td-activity { font-size: 12px; color: var(--txt-2); white-space: nowrap; }
    .sb-td-stale { font-size: 12px; background: var(--danger-light) !important; color: var(--danger); white-space: nowrap; }
    .sb-td-expand { text-align: center; }

    .sb-sprint-time { color: var(--primary); font-weight: 600; }

    .sb-key-link {
        color: var(--primary);
        text-decoration: none;
        font-weight: 600;
        font-size: 12px;
    }
    .sb-key-link:hover { text-decoration: underline; }

    .sb-never { color: var(--txt-4); font-style: italic; }
    .sb-no-due { color: var(--txt-4); }

    /* ── Priority dot ────────────────────────────────────────────── */
    .sb-td-pri { text-align: center; }

    .sb-pri-dot {
        display: inline-block;
        width: 10px;
        height: 10px;
        border-radius: 50%;
    }

    .pri-critical { background: #dc2626; }
    .pri-high     { background: #f97316; }
    .pri-medium   { background: #eab308; }
    .pri-low      { background: #22c55e; }
    .pri-lowest   { background: #94a3b8; }

    /* ── Due date cell ───────────────────────────────────────────── */
    .sb-due-date  { font-size: 12px; font-weight: 600; color: var(--txt-1); display: block; }
    .sb-due-delta { font-size: 11px; display: block; margin-top: 1px; }

    .sb-delta-red   { color: var(--danger); font-weight: 600; }
    .sb-delta-amber { color: var(--warning); font-weight: 600; }
    .sb-delta-green { color: var(--success); }

    .sb-due-overdue { background: #fff1f2 !important; }
    .sb-due-at-risk { background: #fffbeb !important; }

    /* ── Forecast badge ──────────────────────────────────────────── */
    .sb-forecast-badge {
        display: inline-block;
        padding: 2px 8px;
        border-radius: 10px;
        font-size: 11px;
        font-weight: 700;
        white-space: nowrap;
    }

    .fc-done    { background: #dcfce7; color: #15803d; }
    .fc-meet    { background: #dbeafe; color: #1d4ed8; }
    .fc-miss    { background: #fee2e2; color: #b91c1c; }
    .fc-blocked { background: #f3f4f6; color: #374151; }
    .fc-noest   { background: #fef9c3; color: #854d0e; }
    .fc-nodue   { background: #f3f4f6; color: #6b7280; }

    /* ── % Bar ───────────────────────────────────────────────────── */
    .sb-pct-bar-wrap {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .sb-pct-bar {
        display: inline-block;
        height: 5px;
        background: var(--primary);
        border-radius: 3px;
        min-width: 2px;
        max-width: 50px;
    }

    .sb-pct-label { font-size: 11px; color: var(--txt-3); }

    /* ── Expand button ───────────────────────────────────────────── */
    .sb-expand-btn { font-size: 11px; padding: 2px 6px; }

    /* ── Worklog section ─────────────────────────────────────────── */
    .sb-worklog-row .sb-worklog-cell {
        padding: 0;
        background: #f8fafc;
        border-bottom: 2px solid var(--primary);
    }

    /* ── Expanded row panels ─────────────────────────────────────── */
    .sb-expanded-panels {
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .sb-worklog-wrap { padding: 12px 24px 14px; }
    .sb-dev-panel { padding: 12px 24px 14px; border-top: 1px dashed var(--border); }

    .sb-worklog-header {
        font-size: 12px;
        font-weight: 600;
        color: var(--txt-2);
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .sb-wl-sprint-note {
        background: #dbeafe;
        color: #1d4ed8;
        padding: 2px 8px;
        border-radius: 10px;
        font-size: 11px;
        font-weight: 600;
    }

    .sb-wl-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 12px;
    }

    .sb-wl-table th {
        padding: 5px 10px;
        background: #e2e8f0;
        text-align: left;
        font-weight: 600;
        color: var(--txt-3);
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: .04em;
    }

    .sb-wl-table td {
        padding: 5px 10px;
        border-bottom: 1px solid #e2e8f0;
        color: var(--txt-2);
    }

    .sb-wl-in-sprint { background: #eff6ff; }
    .sb-wl-time  { font-weight: 600; white-space: nowrap; }
    .sb-wl-comment { max-width: 400px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: var(--txt-3); }
    .sb-wl-sprint-flag { text-align: center; color: var(--primary); font-weight: 700; }

    /* ── Dashboard Control ──────────────────────────────────────── */
    .sb-dash-kpis {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .sb-dash-kpi {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--r-md);
        padding: 12px 18px;
        flex: 1;
        min-width: 110px;
        box-shadow: var(--sh-xs);
    }

    .sb-dash-kpi-warn { border-color: #fbbf24; background: #fffbeb; }

    .sb-dash-kpi-val {
        font-size: 22px;
        font-weight: 700;
        color: var(--txt-1);
        line-height: 1.2;
    }

    .sb-dash-kpi-lbl {
        font-size: 11px;
        color: var(--txt-3);
        margin-top: 3px;
        font-weight: 500;
    }

    .sb-dash-legend {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 10px;
        padding: 8px 14px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--r-md);
    }

    .sb-dash-legend-title {
        font-size: 10px;
        font-weight: 700;
        color: var(--txt-4);
        text-transform: uppercase;
        letter-spacing: .06em;
        margin-right: 4px;
    }

    .sb-dash-legend-item {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 12px;
        color: var(--txt-2);
        font-weight: 500;
    }

    /* Swimlane */
    .sb-swimlane-outer {
        overflow-x: auto;
        padding-bottom: 6px;
    }

    .sb-swimlane-table {
        border-collapse: collapse;
        min-width: max-content;
    }

    .sb-sw-sticky-l {
        position: sticky;
        left: 0;
        z-index: 2;
        box-shadow: 2px 0 6px rgba(0,0,0,.07);
    }

    .sb-sw-info {
        min-width: 230px;
        max-width: 230px;
        padding: 6px 12px;
        border-right: 2px solid var(--border);
        vertical-align: middle;
        background: inherit;
    }

    .sb-swimlane-table thead .sb-sw-info {
        font-size: 10px;
        font-weight: 700;
        color: var(--txt-3);
        text-transform: uppercase;
        letter-spacing: .06em;
    }

    .sb-sw-bug-key { font-size: 12px; font-weight: 700; }
    .sb-sw-bug-key a { color: var(--primary); text-decoration: none; }
    .sb-sw-bug-key a:hover { text-decoration: underline; }

    .sb-sw-bug-sum {
        font-size: 11px;
        color: var(--txt-3);
        margin-top: 2px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 206px;
    }

    .sb-sw-day-th {
        min-width: 38px;
        width: 38px;
        text-align: center;
        padding: 4px 2px;
        border-right: 1px solid #efefef;
        cursor: pointer;
        user-select: none;
        transition: filter .1s;
        vertical-align: middle;
    }

    .sb-sw-day-th:hover { filter: brightness(.94); }

    .sb-sw-day-hdr {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 3px;
    }

    .sb-sw-day-name {
        font-size: 9px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .04em;
    }

    .sb-sw-day-num {
        font-size: 11px;
        font-weight: 700;
        color: var(--txt-2);
        width: 22px;
        height: 22px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
    }

    .sb-sw-today-num { background: var(--primary) !important; color: #fff !important; }

    .sb-sw-cell {
        min-width: 38px;
        width: 38px;
        text-align: center;
        padding: 3px 2px;
        border-right: 1px solid #f2f2f2;
        border-bottom: 1px solid #f8f8f8;
        vertical-align: middle;
        cursor: pointer;
        transition: filter .1s;
    }

    .sb-sw-cell:hover { filter: brightness(.93); }

    .sb-sw-row:hover .sb-sw-info { background: #f9fafb; }

    .sb-sw-end-th {
        min-width: 100px;
        padding: 5px 10px;
        border-left: 2px solid var(--border);
        vertical-align: middle;
        font-size: 10px;
        font-weight: 700;
        color: var(--txt-3);
        text-transform: uppercase;
        letter-spacing: .05em;
        white-space: nowrap;
    }

    .sb-sw-end-status { min-width: 120px; }

    .sb-sw-dot {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        color: #fff;
        font-size: 7.5px;
        font-weight: 800;
        cursor: default;
        flex-shrink: 0;
        margin: 1px;
        vertical-align: middle;
    }

    .sb-sw-dot-more {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background: #d1d5db;
        color: var(--txt-3);
        font-size: 8px;
        font-weight: 700;
        margin: 1px;
        vertical-align: middle;
    }

    /* Day detail panel */
    .sb-dash-day-panel {
        border: 1px solid #93c5fd;
        border-radius: 6px;
        margin: 10px 0 0;
        overflow: hidden;
    }

    .sb-dash-day-panel-hdr {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 9px 14px;
        background: #dbeafe;
        border-bottom: 1px solid #bfdbfe;
        flex-wrap: wrap;
    }

    .sb-dash-day-panel-title { font-weight: 700; font-size: 13px; color: var(--txt-1); }
    .sb-dash-day-panel-sub   { font-size: 12px; color: #1e40af; }

    /* Untouched banner */
    .sb-dash-untouched-banner {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 16px;
        background: #fffbeb;
        border: 1px solid #fbbf24;
        border-radius: var(--r-md);
        font-size: 13px;
        color: #92400e;
    }

    /* Contributor cards */
    .sb-dash-contrib-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
        gap: 12px;
        padding: 14px;
    }

    .sb-dash-contrib-card {
        background: var(--surface-2);
        border-radius: 8px;
        padding: 12px 14px;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .sb-dash-contrib-head { display: flex; align-items: center; gap: 10px; }

    .sb-dash-contrib-bugs {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
    }

    /* ── Development panel ───────────────────────────────────────── */
    .sb-dev-loading { font-size: 12px; color: var(--txt-3); display: flex; align-items: center; gap: 6px; padding: 4px 0; }
    .sb-dev-empty   { font-size: 12px; color: var(--txt-4); font-style: italic; padding: 4px 0; }

    .sb-dev-summary-row { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 10px; }
    .sb-dev-badge {
        display: inline-flex; align-items: center; gap: 4px;
        padding: 3px 9px; border-radius: 10px; font-size: 11px; font-weight: 600;
    }
    .sb-dev-badge-branch  { background: #f0fdf4; color: #15803d; border: 1px solid #bbf7d0; }
    .sb-dev-badge-commit  { background: #f5f3ff; color: #6d28d9; border: 1px solid #ddd6fe; }
    .sb-dev-badge-build-ok   { background: #f0fdf4; color: #15803d; border: 1px solid #bbf7d0; }
    .sb-dev-badge-build-fail { background: #fef2f2; color: #b91c1c; border: 1px solid #fecaca; }

    .sb-dev-table { margin-top: 2px; }
    .sb-dev-pr-status {
        display: inline-block; padding: 1px 7px; border-radius: 8px;
        font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .03em;
    }
    .sb-dev-pr-open    { background: #dbeafe; color: #1d4ed8; }
    .sb-dev-pr-merged  { background: #ede9fe; color: #6d28d9; }
    .sb-dev-pr-declined { background: #fee2e2; color: #b91c1c; }
    .sb-dev-pr-link {
        color: var(--primary); font-weight: 600; font-size: 11px;
        text-decoration: none; white-space: nowrap;
    }
    .sb-dev-pr-link:hover { text-decoration: underline; }

    /* ── Empty states ────────────────────────────────────────────── */
    .sb-empty-state {
        text-align: center;
        padding: 56px 24px;
        color: var(--txt-3);
        font-size: 14px;
        background: var(--surface);
        border: 1px dashed var(--border);
        border-radius: var(--r-md);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
    }

    .sb-empty-state-ico {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        background: var(--primary-light);
        color: var(--primary);
        margin-bottom: 6px;
    }

    .sb-empty-state-title { font-size: 15px; font-weight: 600; color: var(--txt-1); }
    .sb-empty-state-hint  { font-size: 13px; color: var(--txt-3); max-width: 460px; }

    .sb-empty {
        text-align: center;
        padding: 24px;
        color: var(--txt-3);
        font-style: italic;
    }

    /* ── Tabs ────────────────────────────────────────────────────── */
    .sb-tabs {
        display: flex;
        border-bottom: 2px solid var(--border);
        gap: 0;
        background: var(--surface);
        border-radius: var(--r-md) var(--r-md) 0 0;
        border: 1px solid var(--border);
        border-bottom: 2px solid var(--border);
        padding: 0 4px;
    }

    .sb-tab {
        padding: 10px 20px;
        font-size: 13px;
        font-weight: 500;
        font-family: inherit;
        background: none;
        border: none;
        border-bottom: 2px solid transparent;
        color: var(--txt-3);
        cursor: pointer;
        margin-bottom: -2px;
        transition: color .15s, border-color .15s;
        display: flex;
        align-items: center;
        gap: 6px;
    }
    .sb-tab:hover { color: var(--txt-1); }
    .sb-tab-active { color: var(--primary); border-bottom-color: var(--primary); font-weight: 600; }

    .sb-tab-badge {
        background: var(--danger);
        color: #fff;
        border-radius: 10px;
        padding: 1px 7px;
        font-size: 11px;
        font-weight: 600;
    }
    .sb-tab-badge-neutral { background: var(--txt-4); }

    /* ── Bug Master Dashboard ────────────────────────────────────── */
    .sb-master-kpi-row  { display: flex; flex-wrap: wrap; gap: 10px; padding: 14px 16px; background: var(--surface-2); border-bottom: 1px solid var(--border); align-items: stretch; }
    .sb-master-kpi      { display: flex; flex-direction: column; gap: 4px; padding: 10px 16px; border-radius: 8px; border: 1px solid var(--border); background: var(--surface); min-width: 150px; flex: 1; }
    .sb-master-kpi-label { font-size: 11px; font-weight: 600; color: var(--txt-2); }
    .sb-master-kpi-count { font-size: 28px; font-weight: 700; line-height: 1; }
    .sb-master-kpi-p0   { border-left: 4px solid var(--danger); }
    .sb-master-kpi-p0 .sb-master-kpi-count { color: var(--danger); }
    .sb-master-kpi-p1   { border-left: 4px solid var(--warning); }
    .sb-master-kpi-p1 .sb-master-kpi-count { color: var(--warning); }
    .sb-master-kpi-p2   { border-left: 4px solid var(--primary); }
    .sb-master-kpi-p2 .sb-master-kpi-count { color: var(--primary); }
    .sb-master-kpi-p3   { border-left: 4px solid #6366f1; }
    .sb-master-kpi-p3 .sb-master-kpi-count { color: #6366f1; }
    .sb-master-kpi-watch { border-left: 4px solid var(--txt-3); }
    .sb-master-kpi-watch .sb-master-kpi-count { color: var(--txt-2); }
    .sb-master-section  { margin-bottom: 0; border-bottom: 1px solid var(--border); }
    .sb-master-section:last-child { border-bottom: none; }
    .sb-master-badge    { display: inline-flex; align-items: center; justify-content: center; width: 28px; height: 20px; border-radius: 4px; font-size: 11px; font-weight: 700; color: #fff; margin-right: 6px; flex-shrink: 0; }
    .sb-badge-p0        { background: var(--danger); }
    .sb-badge-p1        { background: var(--warning); }
    .sb-badge-p2        { background: var(--primary); }
    .sb-badge-p3        { background: #6366f1; }
    .sb-badge-watch     { background: var(--txt-3); }
    .sb-master-p0 .sb-section-header { background: #fef2f2; border-left: 4px solid var(--danger); }
    .sb-master-p1 .sb-section-header { background: #fffbeb; border-left: 4px solid var(--warning); }
    .sb-master-p2 .sb-section-header { background: #eff6ff; border-left: 4px solid var(--primary); }
    .sb-master-p3 .sb-section-header { background: #eef2ff; border-left: 4px solid #6366f1; }
    .sb-master-watch .sb-section-header { background: var(--surface-2); border-left: 4px solid var(--txt-3); }

    /* ── Calendar ────────────────────────────────────────────────── */
    .sb-cal-root        { padding: 16px; }
    .sb-cal-header      { display: flex; align-items: center; gap: 8px; margin-bottom: 14px; flex-wrap: wrap; }
    .sb-cal-month-label { font-size: 15px; font-weight: 700; color: var(--txt-1); min-width: 155px; text-align: center; }
    .sb-cal-nav         { font-size: 22px; font-weight: 400; line-height: 1; padding: 2px 12px !important; }
    .sb-cal-badge       { background: var(--primary-light); color: var(--primary); border: 1px solid var(--primary-border); border-radius: 12px; padding: 2px 10px; font-size: 12px; font-weight: 600; margin-left: 4px; }
    .sb-cal-empty-month { font-size: 12px; color: var(--txt-3); margin-left: 4px; }
    .sb-cal-grid-wrap   { overflow-x: auto; }

    .sb-cal-table       { width: 100%; border-collapse: collapse; table-layout: fixed; min-width: 700px; }
    .sb-cal-th          { padding: 7px 4px; text-align: center; font-size: 11px; font-weight: 700; color: var(--txt-3); text-transform: uppercase; letter-spacing: .05em; border-bottom: 2px solid var(--border); background: var(--surface-2); }
    .sb-cal-cell        { vertical-align: top; height: 120px; border: 1px solid var(--border); padding: 6px 5px 4px; background: var(--surface); }
    .sb-cal-blank       { background: #f7f7f9; }
    .sb-cal-weekend     { background: #fafafa; }
    .sb-cal-today       { background: #eff6ff !important; outline: 2px solid var(--primary); outline-offset: -2px; }
    .sb-cal-daynum      { font-size: 11px; font-weight: 600; color: var(--txt-3); margin-bottom: 5px; }
    .sb-cal-daynum-today {
        display: inline-flex; align-items: center; justify-content: center;
        background: var(--primary); color: #fff;
        width: 20px; height: 20px; border-radius: 50%; font-size: 11px;
    }

    .sb-cal-chip {
        display: flex;
        flex-direction: column;
        padding: 2px 5px 3px;
        border-radius: 4px;
        margin-bottom: 3px;
        font-size: 10.5px;
        border-left: 3px solid transparent;
        overflow: hidden;
        cursor: pointer;
        text-decoration: none;
    }
    .sb-cal-chip:hover { filter: brightness(0.93); text-decoration: none; }
    .sb-cal-chip-key { font-weight: 700; font-size: 10px; white-space: nowrap; }
    .sb-cal-chip-sum { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; opacity: .85; }

    .sb-cal-chip-done          { background: #dcfce7; border-left-color: #16a34a; color: #14532d; opacity: .65; }
    .sb-cal-chip-indeterminate { background: #dbeafe; border-left-color: var(--primary); color: #1e3a8a; }
    .sb-cal-chip-new           { background: #fef9c3; border-left-color: #eab308; color: #713f12; }

    /* ── Filter active bar ───────────────────────────────────────── */
    /* ── Metric label inline ─────────────────────────────────────── */
    .sb-metric-lbl-inline { font-size: 14px; font-weight: 400; color: var(--txt-3); margin-left: 1px; }

    /* ── Age buckets ─────────────────────────────────────────────── */
    .sb-age-buckets { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
    .sb-age-bucket  {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--r-md);
        padding: 20px;
        box-shadow: var(--sh-xs);
        border-left-width: 4px;
        text-align: center;
    }
    .sb-age-bucket-val   { font-size: 36px; font-weight: 700; line-height: 1; }
    .sb-age-bucket-lbl   { font-size: 13px; font-weight: 700; color: var(--txt-2); margin-top: 4px; }
    .sb-age-bucket-range { font-size: 11px; color: var(--txt-4); margin-top: 2px; }

    .sb-age-fresh  { border-left-color: var(--success); }
    .sb-age-fresh  .sb-age-bucket-val { color: var(--success); }
    .sb-age-recent { border-left-color: var(--primary); }
    .sb-age-recent .sb-age-bucket-val { color: var(--primary); }
    .sb-age-aging  { border-left-color: var(--warning); }
    .sb-age-aging  .sb-age-bucket-val { color: var(--warning); }
    .sb-age-old    { border-left-color: #9ca3af; }
    .sb-age-old    .sb-age-bucket-val { color: #6b7280; }
    .sb-age-old-alert { border-left-color: var(--danger); }
    .sb-age-old-alert .sb-age-bucket-val { color: var(--danger); }

    .sb-age-badge          { display: inline-block; padding: 2px 8px; border-radius: 10px; font-size: 11px; font-weight: 700; }
    .sb-age-badge-fresh    { background: #dcfce7; color: #15803d; }
    .sb-age-badge-recent   { background: #dbeafe; color: #1d4ed8; }
    .sb-age-badge-aging    { background: #fef3c7; color: #92400e; }
    .sb-age-badge-old      { background: #fee2e2; color: #b91c1c; }

    /* ── KPI colour helpers (kept for table cells) ───────────────── */
    .kpi-green  { color: var(--success); }
    .kpi-amber  { color: var(--warning); }
    .kpi-red    { color: var(--danger); }
    .kpi-blue   { color: var(--primary); }
    .kpi-neutral { color: var(--txt-2); }

    /* ── Status chips ────────────────────────────────────────────── */
    .rpt-status-chip {
        display: inline-block;
        padding: 2px 8px;
        border-radius: 10px;
        font-size: 11px;
        font-weight: 600;
        white-space: nowrap;
    }

    .status-dev-ready   { background: #e0f2fe; color: #0369a1; }
    .status-in-progress { background: #fef3c7; color: #b45309; }
    .status-in-review   { background: #ede9fe; color: #6d28d9; }
    .status-qa-ready    { background: #f0fdf4; color: #166534; }
    .status-done        { background: #f0fdf4; color: #047857; }
    .status-on-hold     { background: #fdf4ff; color: #7e22ce; border: 1px solid #e9d5ff; }
