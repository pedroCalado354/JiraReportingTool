    private List<SprintIssue> TasksTabIssues
    {
        get
        {
            var q = ActiveIssues.AsEnumerable();
            if (!string.IsNullOrWhiteSpace(_tskSearch))
            {
                var s = _tskSearch.Trim();
                q = q.Where(i => i.Key.Contains(s, StringComparison.OrdinalIgnoreCase)
                              || i.Summary.Contains(s, StringComparison.OrdinalIgnoreCase));
            }
            if (!string.IsNullOrEmpty(_tskFilterStatus))   q = q.Where(i => i.StatusCategoryKey == _tskFilterStatus);
            if (!string.IsNullOrEmpty(_tskFilterType))     q = q.Where(i => i.IssueType == _tskFilterType);
            if (!string.IsNullOrEmpty(_tskFilterPriority)) q = q.Where(i => i.Priority == _tskFilterPriority);
            if (!string.IsNullOrEmpty(_tskFilterAssignee)) q = q.Where(i => i.Assignee == _tskFilterAssignee);
            if (!string.IsNullOrEmpty(_tskFilterEpic))     q = q.Where(i => i.EpicKey == _tskFilterEpic);
            return q.ToList();
        }
    }

    private IEnumerable<SprintIssue> ApplySortTSK(IEnumerable<SprintIssue> src) => _sortTSK switch
    {
        "Key"      => _ascTSK ? src.OrderBy(i => i.Key)                        : src.OrderByDescending(i => i.Key),
        "Summary"  => _ascTSK ? src.OrderBy(i => i.Summary)                    : src.OrderByDescending(i => i.Summary),
        "Type"     => _ascTSK ? src.OrderBy(i => i.IssueType)                  : src.OrderByDescending(i => i.IssueType),
        "Priority" => _ascTSK ? src.OrderBy(i => TskPriorityOrder(i.Priority)) : src.OrderByDescending(i => TskPriorityOrder(i.Priority)),
        "Status"   => _ascTSK ? src.OrderBy(i => i.StatusCategoryKey)          : src.OrderByDescending(i => i.StatusCategoryKey),
        "Assignee" => _ascTSK ? src.OrderBy(i => i.Assignee)                   : src.OrderByDescending(i => i.Assignee),
        "Epic"     => _ascTSK ? src.OrderBy(i => i.EpicKey)                    : src.OrderByDescending(i => i.EpicKey),
        "Est"      => _ascTSK ? src.OrderBy(i => i.OriginalEstimateSeconds)    : src.OrderByDescending(i => i.OriginalEstimateSeconds),
        "Log"      => _ascTSK ? src.OrderBy(i => i.TimeSpentSeconds)           : src.OrderByDescending(i => i.TimeSpentSeconds),
        "Rem"      => _ascTSK ? src.OrderBy(i => i.ComputedRemainingSeconds)   : src.OrderByDescending(i => i.ComputedRemainingSeconds),
        "Pct"      => _ascTSK ? src.OrderBy(i => IssuePercentDone(i) ?? -1)    : src.OrderByDescending(i => IssuePercentDone(i) ?? -1),
        "Last"     => _ascTSK ? src.OrderBy(i => i.Worklogs.Any() ? i.Worklogs.Max(w => w.Started) : DateTime.MinValue)
                              : src.OrderByDescending(i => i.Worklogs.Any() ? i.Worklogs.Max(w => w.Started) : DateTime.MinValue),
        _          => src.OrderBy(i => i.StatusCategoryKey switch { "indeterminate" => 0, "new" => 1, _ => 2 })
                         .ThenByDescending(i => i.ComputedRemainingSeconds),
    };

    private static int TskPriorityOrder(string p) => p switch
    {
        "Highest" or "Critical" => 5,
        "High"    => 4,
        "Medium"  => 3,
        "Low"     => 2,
        "Lowest"  => 1,
        _         => 0
    };

    private static string FmtH(int seconds)
    {
        if (seconds == 0) return "—";
        var abs = Math.Abs(seconds);
        var h = abs / 3600; var m = (abs % 3600) / 60;
        var s = m == 0 ? $"{h}h" : $"{h}h {m}m";
        return seconds < 0 ? $"-{s}" : s;
    }

    private static string Initials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}".ToUpper()
            : name.Length >= 2 ? name[..2].ToUpper() : name.ToUpper();
    }

    private static string RiskReason(SprintIssue i)
    {
        if (i.StatusCategoryKey == "new") return "Not started past 50% mark";
        if (i.DaysSinceLastWorklog >= 2 && i.StatusCategoryKey == "indeterminate") return $"No worklog in {i.DaysSinceLastWorklog}d";
        if (i.ComputedRemainingSeconds > 0) return "Remaining > capacity";
        return "Flagged";
    }

    // ── SVG charts (MarkupString) ────────────────────────────────────────────
    private static System.Globalization.CultureInfo Inv => System.Globalization.CultureInfo.InvariantCulture;

    private MarkupString SparklineSvg(List<double> values, string color)
    {
        if (values.Count < 2) return new MarkupString("");
        var max = values.Max();
        var min = values.Min();
        var range = Math.Max(0.001, max - min);
        const double w = 200, h = 36;
        var step = w / (values.Count - 1);
        var pts = string.Join(" ", values.Select((v, i) =>
            $"{(i * step).ToString("F1", Inv)},{(h - (v - min) / range * h).ToString("F1", Inv)}"));
        return new MarkupString(
            $"<svg class=\"v2-spark\" viewBox=\"0 0 {w} {h}\" preserveAspectRatio=\"none\">" +
            $"<polyline fill=\"none\" stroke=\"{color}\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" points=\"{pts}\"/>" +
            $"<polyline fill=\"{color}\" fill-opacity=\"0.10\" stroke=\"none\" points=\"0,{h} {pts} {w},{h}\"/>" +
            $"</svg>");
    }

    private MarkupString BurndownSvg()
    {
        if (Report == null) return new MarkupString("");
        var actual = DailyBurndownHours;
        if (actual.Count < 2)
            return new MarkupString("<div class='v2-empty' style='padding:24px'>Not enough data yet for burndown.</div>");

        var totalDays  = Math.Max(2, Report.TotalSprintDays);
        var totalHours = Math.Max(0.001, actual[0]);
        const double w = 600, h = 220;
        var step = w / (totalDays - 1);

        // Ideal: from (0, totalHours) to (totalDays-1, 0)
        var ideal = new List<string>();
        for (int i = 0; i < totalDays; i++)
        {
            var rem = totalHours - i * (totalHours / (totalDays - 1));
            var y   = h - rem / totalHours * h;
            ideal.Add($"{(i * step).ToString("F1", Inv)},{y.ToString("F1", Inv)}");
        }
        var idealPath = string.Join(" ", ideal);

        // Actual
        var act = new List<string>();
        for (int i = 0; i < actual.Count; i++)
        {
            var y = h - actual[i] / totalHours * h;
            act.Add($"{(i * step).ToString("F1", Inv)},{y.ToString("F1", Inv)}");
        }
        var actPath = string.Join(" ", act);

        // Projection from current pace
        var projPath = "";
        if (actual.Count >= 2 && actual.Count < totalDays)
        {
            var last = actual[^1];
            var rate = (actual[0] - last) / (actual.Count - 1);
            var proj = new List<string> { act[^1] };
            for (int i = actual.Count; i < totalDays; i++)
            {
                var rem = Math.Max(0, last - rate * (i - (actual.Count - 1)));
                var y = h - rem / totalHours * h;
                proj.Add($"{(i * step).ToString("F1", Inv)},{y.ToString("F1", Inv)}");
            }
            projPath = string.Join(" ", proj);
        }

        var lastX = ((actual.Count - 1) * step).ToString("F1", Inv);
        var sb = new System.Text.StringBuilder();
        sb.Append($"<svg viewBox=\"0 0 {w.ToString("F0", Inv)} {h.ToString("F0", Inv)}\" style=\"width:100%;height:220px\" preserveAspectRatio=\"none\">");
        sb.Append("<defs><linearGradient id=\"actualGrad\" x1=\"0\" x2=\"0\" y1=\"0\" y2=\"1\">");
        sb.Append("<stop offset=\"0\" stop-color=\"#6366f1\" stop-opacity=\"0.18\"/>");
        sb.Append("<stop offset=\"1\" stop-color=\"#6366f1\" stop-opacity=\"0\"/>");
        sb.Append("</linearGradient></defs>");
        // Subtle grid
        for (int i = 1; i < 4; i++)
        {
            var y = (h * i / 4).ToString("F1", Inv);
            sb.Append($"<line x1=\"0\" y1=\"{y}\" x2=\"{w.ToString("F0", Inv)}\" y2=\"{y}\" stroke=\"#eef0f6\" stroke-width=\"1\"/>");
        }
        sb.Append($"<polyline fill=\"url(#actualGrad)\" stroke=\"none\" points=\"0,{h.ToString("F1", Inv)} {actPath} {lastX},{h.ToString("F1", Inv)}\"/>");
        sb.Append($"<polyline fill=\"none\" stroke=\"#94a3b8\" stroke-width=\"1.5\" stroke-dasharray=\"5,4\" points=\"{idealPath}\"/>");
        if (!string.IsNullOrEmpty(projPath))
            sb.Append($"<polyline fill=\"none\" stroke=\"#10b981\" stroke-width=\"1.5\" stroke-dasharray=\"3,3\" points=\"{projPath}\"/>");
        sb.Append($"<polyline fill=\"none\" stroke=\"#6366f1\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" points=\"{actPath}\"/>");
        sb.Append("</svg>");
        return new MarkupString(sb.ToString());
    }

    // ── Non-bug burndown (Task 2) ────────────────────────────────────────────
    private List<double> DailyBurndownHoursNonBug
    {
        get
        {
            if (Report == null) return new();
            var nonBugs = ActiveIssues
                .Where(i => !string.Equals(i.IssueType, "Bug", StringComparison.OrdinalIgnoreCase))
                .ToList();
            var start = Report.StartDate?.Date ?? DateTime.Today.AddDays(-13);
            var end   = Report.EndDate?.Date ?? DateTime.Today;
            var totalHours = nonBugs.Sum(i => i.OriginalEstimateSeconds) / 3600.0;
            if (totalHours == 0) totalHours = nonBugs.Count;
            var loggedByDay = new Dictionary<DateTime, double>();
            foreach (var w in nonBugs.SelectMany(i => i.Worklogs))
            {
                var d = w.Started.Date;
                loggedByDay[d] = (loggedByDay.ContainsKey(d) ? loggedByDay[d] : 0) + w.TimeSpentSeconds / 3600.0;
            }
            var points    = new List<double>();
            var remaining = totalHours;
            for (var d = start; d <= end; d = d.AddDays(1))
            {
                if (loggedByDay.TryGetValue(d, out var logged)) remaining -= logged;
                if (d <= DateTime.Today) points.Add(Math.Max(0, remaining));
            }
            return points;
        }
    }

