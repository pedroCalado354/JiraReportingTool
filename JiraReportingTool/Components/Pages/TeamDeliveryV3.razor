    private static readonly string[] TeamTimeTeams = { "Backend", "Frontend", "QA" };
    private static string? CanonTeam(string? team)
    {
        if (string.IsNullOrWhiteSpace(team)) return null;
        var t = team.Trim();
        return TeamTimeTeams.FirstOrDefault(x => string.Equals(x, t, StringComparison.OrdinalIgnoreCase));
    }

    private static bool WorklogByMember(WorklogEntry w, RosterMember m)
    {
        if (!string.IsNullOrWhiteSpace(m.JiraAccountId) && !string.IsNullOrWhiteSpace(w.AuthorAccountId))
            return string.Equals(w.AuthorAccountId, m.JiraAccountId, StringComparison.OrdinalIgnoreCase);
        if (!string.IsNullOrWhiteSpace(m.JiraEmail) && !string.IsNullOrWhiteSpace(w.AuthorEmail))
            return string.Equals(w.AuthorEmail, m.JiraEmail, StringComparison.OrdinalIgnoreCase);
        return !string.IsNullOrWhiteSpace(m.Name) && string.Equals(w.Author, m.Name, StringComparison.OrdinalIgnoreCase);
    }

    private record TeamTimeRow(string Name, string Team, double LoggedSprint, double Capacity,
                               double AvgPerDay, int Tasks, int Done, double RemainingHours,
                               double PlannedHours, double FullCapacity, double LoggedOnDone);

    private List<TeamTimeRow> TeamTimeRows
    {
        get
        {
            var days        = EffectiveDaysRemaining;
            var totalDays   = Report?.TotalSprintDays ?? 10;
            var elapsed     = Math.Max(1, Report?.ElapsedDays ?? 1);
            var start       = Report?.StartDate?.Date;
            var end         = Report?.EndDate?.Date;
            var scopedIssues = TeamTimeScopedIssues;
            var allWorklogs = scopedIssues.SelectMany(i => i.Worklogs).ToList();
            var doneWorklogs = scopedIssues
                .Where(i => i.StatusCategoryKey == "done")
                .SelectMany(i => i.Worklogs)
                .ToList();

            bool InWindow(DateTime d) =>
                (start == null || d.Date >= start) && (end == null || d.Date <= end);

            return _roster.Select(m =>
            {
                var logged = allWorklogs
                    .Where(w => WorklogByMember(w, m) && InWindow(w.Started))
                    .Sum(w => (long)w.TimeSpentSeconds) / 3600.0;
                var loggedOnDone = doneWorklogs
                    .Where(w => WorklogByMember(w, m) && InWindow(w.Started))
                    .Sum(w => (long)w.TimeSpentSeconds) / 3600.0;
                var assigned = scopedIssues
                    .Where(i => string.Equals(i.Assignee, m.Name, StringComparison.OrdinalIgnoreCase))
                    .ToList();
                return new TeamTimeRow(
                    Name:           m.Name,
                    Team:           m.Team ?? "",
                    LoggedSprint:   logged,
                    Capacity:       (double)m.HoursPerDay * days,
                    AvgPerDay:      logged / elapsed,
                    Tasks:          assigned.Count,
                    Done:           assigned.Count(i => i.StatusCategoryKey == "done"),
                    RemainingHours: assigned.Where(i => i.StatusCategoryKey != "done").Sum(i => i.ComputedRemainingSeconds) / 3600.0,
                    PlannedHours:   assigned.Sum(i => i.OriginalEstimateSeconds) / 3600.0,
                    FullCapacity:   (double)m.HoursPerDay * totalDays,
                    LoggedOnDone:   loggedOnDone);
            })
            .OrderByDescending(r => r.LoggedSprint)
            .ToList();
        }
    }

