        .Where(i => i.StatusCategoryKey == "done"
                 && i.Worklogs.Any(w => w.Started.Date >= DateTime.Today.AddDays(-1)))
        .ToList();

    private List<SprintIssue> StandupWorkedToday => ActiveIssues
        .Where(i => i.Worklogs.Any(w => w.Started.Date == DateTime.Today))
        .OrderByDescending(i => i.Worklogs.Where(w => w.Started.Date == DateTime.Today).Sum(w => w.TimeSpentSeconds))
        .ToList();

    private List<SprintIssue> StandupStuckToday => ActiveIssues
        .Where(i => i.StatusCategoryKey == "indeterminate" && i.DaysSinceLastWorklog >= 1)
        .OrderByDescending(i => i.DaysSinceLastWorklog)
        .ToList();

