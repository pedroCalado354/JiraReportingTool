    private static string TeamMembersJqlClause =>
        "assignee in (" + string.Join(", ", TeamMemberAccountIds.Select(id => $"\"{id}\"")) + ")";

    // Splits a JQL string around its trailing ORDER BY so we can inject extra
    // clauses before the sort. Returns (whereClause, orderByOrEmpty).
    private static (string where, string order) SplitJqlOrderBy(string jql)
    {
        var idx = jql.LastIndexOf("ORDER BY", StringComparison.OrdinalIgnoreCase);
        return idx > 0
            ? (jql[..idx].Trim(), " " + jql[idx..].Trim())
            : (jql.Trim(), "");
    }

    private async Task LoadData(bool forceRefresh = false)
    {
        var useFilter = !string.IsNullOrEmpty(SelectedFilterId) && !string.IsNullOrEmpty(SelectedFilterJql);
        var useSprint = !useFilter && int.TryParse(SprintId.Trim(), out _);
        if (!useFilter && !useSprint) return;

        IsLoading = true; ErrorMessage = null; Report = null;
        _fullEpicStats.Clear();
        _loadingFullEpics.Clear();
        _epicMeta.Clear();
        _epicLoadProgress = 0;
        _epicLoadTotal    = 0;
        try
        {
            // Cached sprint path is only safe when no extra filter is applied —
            // otherwise the cache key (sprint ID) wouldn't reflect the assignee filter.
            if (useSprint && !OnlyTeamMembers)
            {
                Report = await JiraService.GetDeliveryDataAsync(int.Parse(SprintId.Trim()), bypassCache: forceRefresh);
            }
            else
            {
                var baseJql = useFilter
                    ? SelectedFilterJql
                    : $"sprint = {SprintId.Trim()} ORDER BY status ASC, priority DESC";

                if (OnlyTeamMembers)
                {
                    var (where, order) = SplitJqlOrderBy(baseJql);
                    baseJql = $"({where}) AND {TeamMembersJqlClause}{order}";
                }

                Report = await JiraService.GetDeliveryDataByFilterAsync(baseJql);
            }
        }
        catch (Exception ex) { ErrorMessage = $"Failed to load: {ex.Message}"; }

        // Fetch full-epic details sequentially; IsLoading stays true so the button
        // and progress bar remain visible until everything is ready.
        if (Report != null)
        {
            var epicKeys = Report.EpicSummaries
                .Select(e => e.Key)
                .Where(k => !string.IsNullOrEmpty(k))
                .ToList();
            try { _epicMeta = await JiraService.FetchEpicMetaAsync(epicKeys); }
            catch { /* non-fatal: metadata is decorative */ }

            try { await LoadAllFullEpicsAsync(); }
            catch { /* individual failures handled inside LoadFullEpicAsync */ }
        }
        IsLoading = false;
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await LoadData();
    }

    // Hard refresh — re-fetch the currently loaded sprint/filter fresh from Jira, bypassing
    // the DB cache (JiraCacheService). LoadData() rebuilds the whole report (issues, epic
    // metadata, full-epic stats) and the bypass forces a live fetch + cache upsert, so the
    // stored copy is brought up to date too.
    private async Task HardRefresh()
    {
        if (IsLoading) return;
        await LoadData(forceRefresh: true);
    }

