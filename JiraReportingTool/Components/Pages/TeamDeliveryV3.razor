    private record EpicSdRow(string EpicKey, string EpicName,
        int Total, int Done, int YesterdaySeconds,
        List<SprintIssue> CompletedYesterday, List<SprintIssue> WorkedYesterday,
        List<SprintIssue> InProgress, List<SprintIssue> Stuck);

    private record MemberSdRow(string Name, int YesterdaySeconds,
        List<SprintIssue> Concluded, List<SprintIssue> WorkedYesterday,
        List<SprintIssue> InProgress);

    private HashSet<string> _epicSdExpanded   = [];
    private HashSet<string> _memberSdExpanded = [];
    private void ToggleEpicSd(string key)    { if (!_epicSdExpanded.Remove(key))   _epicSdExpanded.Add(key); }
    private void ToggleMemberSd(string name) { if (!_memberSdExpanded.Remove(name)) _memberSdExpanded.Add(name); }

    private static string FirstName(string fullName) =>
        fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? fullName;

    private List<EpicSdRow> EpicStandupRows
    {
        get
        {
            var cutoff = DateTime.Today.AddDays(-1);
            return ActiveIssues
                .Where(i => !string.IsNullOrEmpty(i.EpicKey))
                .GroupBy(i => new { i.EpicKey, i.EpicName })
                .Select(g =>
                {
                    var issues = g.ToList();
                    var completedYesterday = issues
                        .Where(i => i.StatusCategoryKey == "done" && i.Worklogs.Any(w => w.Started.Date >= cutoff))
                        .ToList();
                    var workedYesterday = issues
                        .Where(i => i.StatusCategoryKey != "done" && i.Worklogs.Any(w => w.Started.Date >= cutoff))
                        .ToList();
                    var inProgress = issues
                        .Where(i => i.StatusCategoryKey == "indeterminate")
                        .OrderBy(i => i.DaysSinceLastWorklog)
                        .ToList();
                    var stuck = inProgress.Where(i => i.DaysSinceLastWorklog >= 1).ToList();
                    var yesterdaySec = issues.SelectMany(i => i.Worklogs)
                        .Where(w => w.Started.Date >= cutoff)
                        .Sum(w => w.TimeSpentSeconds);
                    return new EpicSdRow(
                        g.Key.EpicKey, g.Key.EpicName ?? g.Key.EpicKey,
                        issues.Count, issues.Count(i => i.StatusCategoryKey == "done"),
                        yesterdaySec, completedYesterday, workedYesterday, inProgress, stuck);
                })
                .OrderByDescending(r => r.YesterdaySeconds)
                .ThenBy(r => r.EpicName)
                .ToList();
        }
    }

    private List<MemberSdRow> MemberStandupRows
    {
        get
        {
            var cutoff = DateTime.Today.AddDays(-1);
            return ActiveIssues
                .Where(i => !string.IsNullOrWhiteSpace(i.Assignee) && i.Assignee != "Unassigned")
                .Select(i => i.Assignee)
                .Distinct()
                .OrderBy(n => n)
                .Select(person =>
                {
                    var mine = ActiveIssues.Where(i => i.Assignee == person).ToList();
                    var concluded = mine
                        .Where(i => i.StatusCategoryKey == "done" && i.Worklogs.Any(w => w.Started.Date >= cutoff))
                        .ToList();
                    var worked = mine
                        .Where(i => i.StatusCategoryKey != "done" && i.Worklogs.Any(w => w.Started.Date >= cutoff))
                        .ToList();
                    var inProgress = mine
                        .Where(i => i.StatusCategoryKey == "indeterminate")
                        .OrderBy(i => i.DaysSinceLastWorklog)
                        .ToList();
                    var yesterdaySec = mine.SelectMany(i => i.Worklogs)
                        .Where(w => w.Started.Date >= cutoff)
                        .Sum(w => w.TimeSpentSeconds);
                    return new MemberSdRow(person, yesterdaySec, concluded, worked, inProgress);
                })
                .OrderByDescending(r => r.YesterdaySeconds)
                .ThenBy(r => r.Name)
                .ToList();
        }
    }

