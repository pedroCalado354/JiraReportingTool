    // ── Daily activity (worklog hours per day, last 14 days) ─────────────────
    private Dictionary<DateTime, int> DailyActivity
    {
        get
        {
            if (Report == null) return new();
            var start = Report.StartDate?.Date ?? DateTime.Today.AddDays(-13);
            var end   = (Report.EndDate?.Date ?? DateTime.Today) > DateTime.Today ? DateTime.Today : Report.EndDate?.Date ?? DateTime.Today;
            var days = new Dictionary<DateTime, int>();
            for (var d = start; d <= end; d = d.AddDays(1))
                if (d.DayOfWeek != DayOfWeek.Saturday && d.DayOfWeek != DayOfWeek.Sunday)
                    days[d] = 0;
            foreach (var w in ActiveIssues.SelectMany(i => i.Worklogs))
            {
                var key = w.Started.Date;
                if (days.ContainsKey(key)) days[key] += w.TimeSpentSeconds;
            }
            return days;
        }
    }

    // ── Burndown points (cumulative remaining hours per day) ─────────────────
    private List<double> DailyBurndownHours
    {
        get
        {
            if (Report == null) return new();
            var start = Report.StartDate?.Date ?? DateTime.Today.AddDays(-13);
            var end = Report.EndDate?.Date ?? DateTime.Today;
            var totalHours = ActiveIssues.Sum(i => i.OriginalEstimateSeconds) / 3600.0;
            if (totalHours == 0) totalHours = ActiveIssues.Count;
            var loggedByDay = new Dictionary<DateTime, double>();
            foreach (var w in ActiveIssues.SelectMany(i => i.Worklogs))
            {
                var d = w.Started.Date;
                loggedByDay[d] = (loggedByDay.ContainsKey(d) ? loggedByDay[d] : 0) + w.TimeSpentSeconds / 3600.0;
            }
            var points = new List<double>();
            var remaining = totalHours;
            for (var d = start; d <= end; d = d.AddDays(1))
            {
                if (loggedByDay.TryGetValue(d, out var logged)) remaining -= logged;
                if (d <= DateTime.Today) points.Add(Math.Max(0, remaining));
            }
            return points;
        }
    }

