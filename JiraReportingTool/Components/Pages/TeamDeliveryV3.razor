    // ── Full-epic stats (all sprints, auto-loaded per epic after LoadData) ───
    private record EpicFullStats(int Total, int Done, double EstimateHours, double LoggedHours, double RemainingHours);
    private Dictionary<string, EpicFullStats> _fullEpicStats = new();
    private HashSet<string> _loadingFullEpics = new();

    // ── Epic metadata (Committed Date + Customers, fetched once per load) ────
    private Dictionary<string, EpicMeta> _epicMeta = new();

    // Run sequentially — the shared scoped EF DbContext can't handle concurrent operations,
    // and JiraCacheService funnels every call through the same repo.
    private async Task LoadAllFullEpicsAsync()
    {
        var epicKeys = EpicRows
            .Select(e => e.Key)
            .Where(k => !string.IsNullOrEmpty(k) && k != "—")
            .Distinct()
            .ToList();

        _epicLoadTotal    = epicKeys.Count;
        _epicLoadProgress = 0;

        foreach (var k in epicKeys)
        {
            if (_fullEpicStats.ContainsKey(k)) { _epicLoadProgress++; continue; }
            await LoadFullEpicAsync(k);
            _epicLoadProgress++;
            // StateHasChanged already called inside LoadFullEpicAsync
        }
    }

    private async Task LoadFullEpicAsync(string epicKey)
    {
        if (string.IsNullOrEmpty(epicKey) || epicKey == "—") return;
        if (_fullEpicStats.ContainsKey(epicKey) || _loadingFullEpics.Contains(epicKey)) return;
        _loadingFullEpics.Add(epicKey);
        await InvokeAsync(StateHasChanged);
        try
        {
            var report = await JiraService.GetAllEpicIssuesAsync(epicKey);
            var issues = report.Issues
                .Where(i => !string.Equals(i.IssueType, "Epic", StringComparison.OrdinalIgnoreCase))
                .ToList();
            _fullEpicStats[epicKey] = new EpicFullStats(
                Total:          issues.Count,
                Done:           issues.Count(i => i.StatusCategoryKey == "done"),
                EstimateHours:  issues.Sum(i => i.OriginalEstimateSeconds) / 3600.0,
                LoggedHours:    issues.Sum(i => i.TimeSpentSeconds) / 3600.0,
                RemainingHours: issues.Where(i => i.StatusCategoryKey != "done").Sum(i => i.ComputedRemainingSeconds) / 3600.0);
        }
        catch (Exception ex)
        {
            // Stash an empty record so the placeholder clears; log to console for diagnostics.
            Console.Error.WriteLine($"Full-epic load failed for {epicKey}: {ex.Message}");
            _fullEpicStats[epicKey] = new EpicFullStats(0, 0, 0, 0, 0);
        }
        finally
        {
            _loadingFullEpics.Remove(epicKey);
            await InvokeAsync(StateHasChanged);
        }
    }

    // ── Per-member workload for one epic ─────────────────────────────────────
    private record EpicMemberRow(string Name, int Tasks, int Done,
                                 double Logged, double EpicRemaining,
                                 double TotalRemaining, double Capacity);

    private List<EpicMemberRow> EpicMembers(EpicRow ep)
    {
        var capacity    = CapacityPerMemberHours;
        var sprintStart = Report?.StartDate?.Date;
        var sprintEnd   = Report?.EndDate?.Date;

        // Each member's total remaining work across ALL their open tasks in this sprint
        var totalRemainingByMember = ActiveIssues
            .Where(i => !string.IsNullOrWhiteSpace(i.Assignee) && i.Assignee != "Unassigned"
                     && i.StatusCategoryKey != "done")
            .GroupBy(i => i.Assignee)
            .ToDictionary(g => g.Key, g => g.Sum(i => i.ComputedRemainingSeconds) / 3600.0);

        // Logged hours by worklog *author* (matches Jira's worklog report attribution)
        var loggedByAuthor = ep.Issues
            .SelectMany(i => i.Worklogs)
            .Where(w => sprintStart == null || w.Started.Date >= sprintStart)
            .Where(w => sprintEnd   == null || w.Started.Date <= sprintEnd)
            .GroupBy(w => w.Author, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(g => g.Key, g => g.Sum(w => (long)w.TimeSpentSeconds) / 3600.0,
                          StringComparer.OrdinalIgnoreCase);

        // Task/remaining data is still by assignee
        var byAssignee = ep.Issues
            .Where(i => !string.IsNullOrWhiteSpace(i.Assignee) && i.Assignee != "Unassigned")
            .GroupBy(i => i.Assignee, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(g => g.Key, g => g.ToList(), StringComparer.OrdinalIgnoreCase);

        return byAssignee.Keys
            .Union(loggedByAuthor.Keys, StringComparer.OrdinalIgnoreCase)
            .Select(name =>
            {
                var tasks = byAssignee.TryGetValue(name, out var tl) ? tl : new List<SprintIssue>();
                return new EpicMemberRow(
                    Name:           name,
                    Tasks:          tasks.Count,
                    Done:           tasks.Count(i => i.StatusCategoryKey == "done"),
                    Logged:         loggedByAuthor.TryGetValue(name, out var lh) ? lh : 0,
                    EpicRemaining:  tasks.Where(i => i.StatusCategoryKey != "done").Sum(i => i.ComputedRemainingSeconds) / 3600.0,
                    TotalRemaining: totalRemainingByMember.TryGetValue(name, out var tr) ? tr : 0,
                    Capacity:       capacity);
            })
            .Where(r => r.Tasks > 0 || r.Logged > 0)
            .OrderByDescending(r => r.EpicRemaining)
            .ThenByDescending(r => r.Tasks)
            .ToList();
    }

    // ── Status → row color mapping (tinted background + accent border) ───────
    private static (string bg, string border) StatusColor(SprintIssue i)
    {
        var s = (i.Status ?? "").ToLowerInvariant();
        if (i.StatusCategoryKey == "done")                          return ("#ecfdf5", "#10b981"); // green
        if (s.Contains("hold") || s.Contains("block"))              return ("#fef2f2", "#ef4444"); // red
        if (s.Contains("review"))                                    return ("#faf5ff", "#a855f7"); // purple
        if (s.Contains("qa") || s.Contains("test"))                 return ("#ecfeff", "#06b6d4"); // cyan
        if (s.Contains("ready"))                                     return ("#fffbeb", "#f59e0b"); // amber
        if (i.StatusCategoryKey == "indeterminate")                 return ("#eff6ff", "#3b82f6"); // blue (In Progress)
        return ("#f9fafb", "#94a3b8");                                                              // gray (To Do)
    }

