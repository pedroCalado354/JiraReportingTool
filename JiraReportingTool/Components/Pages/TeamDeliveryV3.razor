    // ── Epics Progress tab — one compact, risk-scored row per epic ───────────
    private record EpicProgRow(
        EpicRow Epic, int DonePct,
        int TaskDone, int TaskActive, int TaskToDo,
        int BugOpen, int BugTotal,
        int Stale, int Blocked, int Unest,
        double EstH, double LoggedH, double RemH,
        bool OverBudget, bool WillFinish, double ShortfallH, double ProjectedDonePct,
        DateTime? CommittedDate, bool Overdue,
        int RiskLevel,
        string ForecastLabel, string ForecastPill,
        string StatusLabel, string StatusPill,
        List<string> Reasons, EpicForecast Forecast);

    private List<EpicProgRow> EpicProgressRows => FilteredEpicRows
        .Select(ep =>
        {
            var taskList = ep.Issues.Where(i => !string.Equals(i.IssueType, "Bug", StringComparison.OrdinalIgnoreCase)).ToList();
            var bugList  = ep.Issues.Where(i =>  string.Equals(i.IssueType, "Bug", StringComparison.OrdinalIgnoreCase)).ToList();
            var donePct  = ep.Total > 0 ? ep.Done * 100 / ep.Total : 0;

            var taskDone   = taskList.Count(i => i.StatusCategoryKey == "done");
            var taskActive = taskList.Count(i => i.StatusCategoryKey == "indeterminate");
            var taskToDo   = taskList.Count(i => i.StatusCategoryKey == "new");
            var bugOpen    = bugList.Count(i => i.StatusCategoryKey != "done");

            var stale   = ep.Issues.Count(i => i.StatusCategoryKey == "indeterminate" && i.DaysSinceLastWorklog >= 2);
            var blocked = ep.Issues.Count(IsBlocked);
            var unest   = ep.Issues.Count(i => i.OriginalEstimateSeconds == 0 && i.StatusCategoryKey != "done");

            var overBudget = ep.EstimateHours > 0 && ep.LoggedHours > ep.EstimateHours;
            var fc         = BuildForecast(ep);

            var overdue = ep.Key != "—" && _epicMeta.TryGetValue(ep.Key, out var m)
                       && m.CommittedDate.HasValue && m.CommittedDate.Value.Date < DateTime.Today
                       && ep.Done < ep.Total;
            DateTime? committed = ep.Key != "—" && _epicMeta.TryGetValue(ep.Key, out var m2) ? m2.CommittedDate : null;

            // Forecast verdict (sprint scope) — capacity-driven headline. Blockers /
            // unestimated / unassigned only downgrade to "Tight", never force "Won't finish".
            string fLabel, fPill;
            if (ep.RemainingHours <= 0 && ep.Done >= ep.Total) { fLabel = "Complete";     fPill = "v2-pill-success"; }
            else if (!fc.WillFinish && ep.RemainingHours > 0) { fLabel = $"Won't finish · −{fc.ShortfallH:F0}h"; fPill = "v2-pill-danger"; }
            else if ((fc.ProjectedDonePct < 95 || fc.Findings.Count > 0) && ep.RemainingHours > 0) { fLabel = "Tight"; fPill = "v2-pill-warn"; }
            else { fLabel = "On track"; fPill = "v2-pill-success"; }

            // Overall status (health)
            string sLabel, sPill;
            if (overdue)            { sLabel = "Overdue";     sPill = "v2-pill-danger"; }
            else if (overBudget)    { sLabel = "Over budget"; sPill = "v2-pill-danger"; }
            else if (stale > 0 || blocked > 0 || bugOpen > 0) { sLabel = "Watch"; sPill = "v2-pill-warn"; }
            else                    { sLabel = "Healthy";     sPill = "v2-pill-success"; }

            // Reasons + composite risk level
            var reasons = new List<string>();
            if (overBudget)                          reasons.Add($"Over budget +{(ep.LoggedHours - ep.EstimateHours):F0}h");
            if (!fc.WillFinish && ep.RemainingHours > 0) reasons.Add($"Short {fc.ShortfallH:F0}h to finish");
            if (overdue)                             reasons.Add("Committed date overdue");
            if (blocked > 0)                         reasons.Add($"{blocked} blocked");
            if (stale > 0)                           reasons.Add($"{stale} stale 2d+");
            if (bugOpen > 0)                         reasons.Add($"{bugOpen} open bugs");
            if (unest > 0)                           reasons.Add($"{unest} unestimated");

            var riskLevel =
                (overBudget || (!fc.WillFinish && ep.RemainingHours > 0) || overdue) ? 2
                : (stale > 0 || blocked > 0 || bugOpen > 0 || (fc.ProjectedDonePct < 95 && ep.RemainingHours > 0)) ? 1
                : 0;

            return new EpicProgRow(ep, donePct, taskDone, taskActive, taskToDo, bugOpen, bugList.Count,
                stale, blocked, unest, ep.EstimateHours, ep.LoggedHours, ep.RemainingHours,
                overBudget, fc.WillFinish, fc.ShortfallH, fc.ProjectedDonePct,
                committed, overdue, riskLevel, fLabel, fPill, sLabel, sPill, reasons, fc);
        })
        .ToList();

    private string _sortEP = "Risk"; private bool _ascEP = false;
    private void SortEP(string c) { if (_sortEP == c) _ascEP = !_ascEP; else { _sortEP = c; _ascEP = c == "Epic"; } }

    // Which epic-progress rows have their forecast-detail section expanded.
    private HashSet<string> _epForecastExpanded = new();
    private void ToggleEpForecast(string key) { if (!_epForecastExpanded.Remove(key)) _epForecastExpanded.Add(key); }

    private IEnumerable<EpicProgRow> ApplySortEP(IEnumerable<EpicProgRow> src) => _sortEP switch
    {
        "Epic"      => _ascEP ? src.OrderBy(r => r.Epic.Name)        : src.OrderByDescending(r => r.Epic.Name),
        "Progress"  => _ascEP ? src.OrderBy(r => r.DonePct)          : src.OrderByDescending(r => r.DonePct),
        "Bugs"      => _ascEP ? src.OrderBy(r => r.BugOpen)          : src.OrderByDescending(r => r.BugOpen),
        "Logged"    => _ascEP ? src.OrderBy(r => r.LoggedH)          : src.OrderByDescending(r => r.LoggedH),
        "Remaining" => _ascEP ? src.OrderBy(r => r.RemH)             : src.OrderByDescending(r => r.RemH),
        "Forecast"  => _ascEP ? src.OrderBy(r => r.WillFinish).ThenByDescending(r => r.ShortfallH)
                              : src.OrderByDescending(r => r.WillFinish).ThenBy(r => r.ShortfallH),
        _           => _ascEP ? src.OrderBy(r => r.RiskLevel).ThenBy(r => r.RemH)
                              : src.OrderByDescending(r => r.RiskLevel).ThenByDescending(r => r.RemH),
    };

    // ── Epics → Excel export (all sprint epics) ──────────────────────────────
    private async Task ExportEpicsToXlsxAsync()
    {
        var rows = EpicRows
            .Where(e => e.Key != "—")
            .OrderBy(e => e.Name)
            .ToList();
        if (rows.Count == 0) return;

        using var wb = new XLWorkbook();
        var ws = wb.Worksheets.Add("Epics");

        string[] headers =
        [
            "Epic Key", "Epic Name", "Committed Date", "Committed Customers",
            "Total", "Done", "In Progress", "To Do", "Completion %",
            "Estimate (h)", "Logged (h)", "Remaining (h)"
        ];

        for (int i = 0; i < headers.Length; i++)
        {
            var hc = ws.Cell(1, i + 1);
            hc.Value = headers[i];
            hc.Style.Font.Bold = true;
            hc.Style.Font.FontColor = XLColor.White;
            hc.Style.Fill.BackgroundColor = XLColor.FromHtml("#4f46e5");
            hc.Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;
            hc.Style.Alignment.Vertical   = XLAlignmentVerticalValues.Center;
        }
        ws.Row(1).Height = 22;
        ws.SheetView.FreezeRows(1);

        int row = 2;
        foreach (var e in rows)
        {
            _epicMeta.TryGetValue(e.Key, out var meta);
            var donePct = e.Total > 0 ? Math.Round(e.Done * 100.0 / e.Total, 1) : 0;

            int col = 1;
            var keyCell = ws.Cell(row, col++);
            keyCell.Value = e.Key;
            keyCell.SetHyperlink(new XLHyperlink($"{JiraBase}/browse/{e.Key}"));
            keyCell.Style.Font.FontColor = XLColor.FromHtml("#4f46e5");
            keyCell.Style.Font.Underline = XLFontUnderlineValues.Single;

            ws.Cell(row, col++).Value = e.Name;

            var dateCell = ws.Cell(row, col++);
            if (meta?.CommittedDate is { } cd)
            {
                dateCell.Value = cd;
                dateCell.Style.DateFormat.Format = "yyyy-mm-dd";
                if (cd.Date < DateTime.Today && e.Done < e.Total)
                    dateCell.Style.Font.FontColor = XLColor.FromHtml("#dc2626");
            }
            else dateCell.Value = "—";

            ws.Cell(row, col++).Value = string.IsNullOrEmpty(meta?.CommittedCustomers) ? "—" : meta!.CommittedCustomers;
            ws.Cell(row, col++).Value = e.Total;
            ws.Cell(row, col++).Value = e.Done;
            ws.Cell(row, col++).Value = e.InProgress;
            ws.Cell(row, col++).Value = e.ToDo;

            var pctCell = ws.Cell(row, col++);
            pctCell.Value = donePct / 100.0;
            pctCell.Style.NumberFormat.Format = "0%";

            ws.Cell(row, col++).Value = Math.Round(e.EstimateHours, 1);
            ws.Cell(row, col++).Value = Math.Round(e.LoggedHours, 1);
            ws.Cell(row, col++).Value = Math.Round(e.RemainingHours, 1);

            row++;
        }

        // Totals
        var totRange = ws.Range(row, 1, row, headers.Length);
        totRange.Style.Fill.BackgroundColor = XLColor.FromHtml("#eef2ff");
        totRange.Style.Font.Bold = true;
        ws.Cell(row, 1).Value = "TOTAL";
        ws.Cell(row, 5).Value = rows.Sum(e => e.Total);
        ws.Cell(row, 6).Value = rows.Sum(e => e.Done);
        ws.Cell(row, 7).Value = rows.Sum(e => e.InProgress);
        ws.Cell(row, 8).Value = rows.Sum(e => e.ToDo);
        ws.Cell(row, 10).Value = Math.Round(rows.Sum(e => e.EstimateHours), 1);
        ws.Cell(row, 11).Value = Math.Round(rows.Sum(e => e.LoggedHours), 1);
        ws.Cell(row, 12).Value = Math.Round(rows.Sum(e => e.RemainingHours), 1);

        ws.Column(1).Width = 14;
        ws.Column(2).Width = 42;
        ws.Column(3).Width = 15;
        ws.Column(4).Width = 30;
        for (int c = 5; c <= 12; c++) ws.Column(c).Width = 12;
        ws.Range(1, 1, row, headers.Length).Style.Border.OutsideBorder = XLBorderStyleValues.Medium;

        using var ms = new MemoryStream();
        wb.SaveAs(ms);
        var b64 = Convert.ToBase64String(ms.ToArray());
        const string mime = "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet";
        await JS.InvokeVoidAsync("downloadBase64File", b64,
            $"SprintEpics_{DateTime.Today:yyyyMMdd}.xlsx", mime);
    }

    // ── Capacity-aware epic forecast ─────────────────────────────────────────
    // Instead of extrapolating the epic's own burn rate (which makes barely-started
    // epics look doomed), this asks: does the remaining work fit the assignees'
    // realistic available capacity for the rest of the sprint? Capacity comes from
    // each member's roster Hours/day × days left, and is shared proportionally
    // across ALL their remaining sprint work so a person spread over several epics
    // isn't assumed fully available to this one.
    private const double ForecastDailyCapH = 6.0;   // fallback when a member isn't on the roster

    private double HoursPerDayFor(string name) =>
        (double)(_roster.FirstOrDefault(m => string.Equals(m.Name, name, StringComparison.OrdinalIgnoreCase))?.HoursPerDay
                 ?? (decimal)ForecastDailyCapH);

    private record MemberForecast(string Name, double AssignedRemainingH, double CapacityLeftH,
                                  double TotalRemainingH, double CoveredH, double ShortfallH, bool Overloaded);

    // Severity: "danger" | "warn" | "info". Key is the Jira issue key (nullable for aggregate findings).
    private record ForecastFinding(string Icon, string Severity, string Message, string? Key, string? Summary);

    private record EpicForecast(bool WillFinish, double ShortfallH, double ProjectedDonePct,
                                List<MemberForecast> Members, double UnassignedRemainingH,
                                List<ForecastFinding> Findings, string Rationale);

    private EpicForecast BuildForecast(EpicRow ep)
    {
        var daysLeft = (double)EffectiveDaysRemaining;

        // Remaining hours on THIS epic, per assignee (their own plate).
        var epicRemByAssignee = ep.Issues
            .Where(i => i.StatusCategoryKey != "done"
                     && !string.IsNullOrWhiteSpace(i.Assignee)
                     && i.Assignee != "Unassigned")
            .GroupBy(i => i.Assignee, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(g => g.Key, g => g.Sum(x => x.ComputedRemainingSeconds) / 3600.0,
                          StringComparer.OrdinalIgnoreCase);

        // Remaining hours across the WHOLE sprint, per assignee (cross-epic contention).
        var sprintRemByAssignee = ActiveIssues
            .Where(i => i.StatusCategoryKey != "done"
                     && !string.IsNullOrWhiteSpace(i.Assignee)
                     && i.Assignee != "Unassigned")
            .GroupBy(i => i.Assignee, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(g => g.Key, g => g.Sum(x => x.ComputedRemainingSeconds) / 3600.0,
                          StringComparer.OrdinalIgnoreCase);

        var members = epicRemByAssignee
            .Select(kv =>
            {
                var name       = kv.Key;
                var epicRem    = kv.Value;
                var totalRem   = sprintRemByAssignee.TryGetValue(name, out var t) ? t : epicRem;
                var capLeft    = HoursPerDayFor(name) * daysLeft;

                // If everything on their plate fits their capacity, this epic is fully covered.
                // Otherwise share the capacity they DO have proportionally to this epic's slice.
                double covered = totalRem <= capLeft || totalRem <= 0
                    ? epicRem
                    : capLeft * (epicRem / totalRem);
                covered = Math.Min(covered, epicRem);

                var shortfall = Math.Max(0, epicRem - covered);
                return new MemberForecast(name, epicRem, capLeft, totalRem, covered, shortfall,
                                          Overloaded: totalRem > capLeft);
            })
            .OrderByDescending(x => x.ShortfallH)
            .ThenByDescending(x => x.AssignedRemainingH)
            .ToList();

        // Remaining work nobody is assigned to → no capacity to cover it.
        var unassignedRem = ep.Issues
            .Where(i => i.StatusCategoryKey != "done"
                     && (string.IsNullOrWhiteSpace(i.Assignee) || i.Assignee == "Unassigned"))
            .Sum(i => i.ComputedRemainingSeconds) / 3600.0;

        var shortfallH = members.Sum(m => m.ShortfallH) + unassignedRem;
        var willFinish = ep.RemainingHours <= 0 || shortfallH <= 1.0;   // sub-hour rounding tolerance

        // Projected % done = current + share of remaining hours the capacity can cover.
        var alreadyDonePct = ep.Total > 0 ? ep.Done * 100.0 / ep.Total : 0;
        var projectedDonePct = alreadyDonePct;
        if (ep.RemainingHours > 0)
        {
            var coverage = Math.Clamp((ep.RemainingHours - shortfallH) / ep.RemainingHours, 0, 1);
            var remainingTaskShare = ep.Total > 0 ? (ep.Total - ep.Done) * 100.0 / ep.Total : 0;
            projectedDonePct += coverage * remainingTaskShare;
        }
        projectedDonePct = Math.Clamp(projectedDonePct, 0, 100);

        // ── Findings: the specific tickets that gate the forecast ──
        var findings = new List<ForecastFinding>();
        foreach (var i in ep.Issues.Where(IsBlocked))
            findings.Add(new("bi-slash-circle", "danger", "Blocked — unblock to progress", i.Key, i.Summary));
        foreach (var i in ep.Issues.Where(i => i.StatusCategoryKey != "done"
                                            && (string.IsNullOrWhiteSpace(i.Assignee) || i.Assignee == "Unassigned")))
            findings.Add(new("bi-person-dash", "warn", "Unassigned — needs an owner", i.Key, i.Summary));
        foreach (var i in ep.Issues.Where(i => i.StatusCategoryKey != "done" && i.OriginalEstimateSeconds == 0))
            findings.Add(new("bi-question-circle", "warn", "Unestimated — hidden work not in the forecast", i.Key, i.Summary));
        foreach (var i in ep.Issues.Where(i => i.StatusCategoryKey == "indeterminate" && i.DaysSinceLastWorklog >= 2))
            findings.Add(new("bi-hourglass-split", "info", $"Idle {i.DaysSinceLastWorklog}d — in progress but no recent log", i.Key, i.Summary));
        foreach (var m in members.Where(m => m.Overloaded))
            findings.Add(new("bi-exclamation-triangle", "warn",
                $"{m.Name} is overloaded — {m.TotalRemainingH:F0}h across the sprint vs {m.CapacityLeftH:F0}h capacity", null, null));

        // ── Human-readable rationale ──
        string rationale;
        if (ep.RemainingHours <= 0 && ep.Done >= ep.Total)
            rationale = "All work complete.";
        else if (shortfallH > 1.0)
        {
            var worst = members.FirstOrDefault(m => m.ShortfallH > 0);
            rationale = worst != null
                ? $"{worst.Name} holds {worst.AssignedRemainingH:F0}h but has ~{worst.CapacityLeftH:F0}h capacity left"
                  + (members.Count(m => m.ShortfallH > 0) > 1 ? $" (+{members.Count(m => m.ShortfallH > 0) - 1} more)" : "")
                  + $" → {shortfallH:F0}h short over {daysLeft:F0} day{(daysLeft == 1 ? "" : "s")} left."
                : $"{unassignedRem:F0}h of unassigned work with no owner → {shortfallH:F0}h short.";
        }
        else if (projectedDonePct < 95 || findings.Count > 0)
            rationale = $"Work fits the {daysLeft:F0} day{(daysLeft == 1 ? "" : "s")} left, but "
                      + string.Join(", ", new[]
                        {
                            findings.Any(f => f.Icon == "bi-slash-circle") ? "blockers" : null,
                            findings.Any(f => f.Icon == "bi-person-dash")  ? "unassigned work" : null,
                            findings.Any(f => f.Icon == "bi-question-circle") ? "unestimated tickets" : null,
                            findings.Any(f => f.Icon == "bi-hourglass-split") ? "idle tickets" : null,
                        }.Where(s => s != null).DefaultIfEmpty("tight coverage"))
                      + " need attention.";
        else
            rationale = $"Remaining {ep.RemainingHours:F0}h fits the team's ~{members.Sum(m => m.CapacityLeftH):F0}h capacity over {daysLeft:F0} day{(daysLeft == 1 ? "" : "s")} left.";

        return new EpicForecast(willFinish, shortfallH, projectedDonePct, members, unassignedRem, findings, rationale);
    }

    // ── Member tracking ──────────────────────────────────────────────────────
    private string MembersSearch       = "";
    private string MembersFilterStatus = "";
    private string MembersFilterEpic   = "";
    private string MembersFilterType   = "";
    private string MembersFilterHealth = "";
    private bool   MembersHideEmpty    = false;

    private bool HasMemberFilters =>
        !string.IsNullOrEmpty(MembersSearch) ||
        !string.IsNullOrEmpty(MembersFilterStatus) ||
        !string.IsNullOrEmpty(MembersFilterEpic) ||
        !string.IsNullOrEmpty(MembersFilterType) ||
        !string.IsNullOrEmpty(MembersFilterHealth) ||
        MembersHideEmpty;

    private void ClearMemberFilters()
    {
        MembersSearch = ""; MembersFilterStatus = ""; MembersFilterEpic = "";
        MembersFilterType = ""; MembersFilterHealth = ""; MembersHideEmpty = false;
    }

    private List<SprintIssue> FilteredTasksFor(MemberRow m) => m.Tasks
        .Where(i =>
            (string.IsNullOrEmpty(MembersFilterStatus) || i.Status == MembersFilterStatus) &&
            (string.IsNullOrEmpty(MembersFilterEpic)   || (string.IsNullOrEmpty(i.EpicKey) ? "—" : i.EpicKey) == MembersFilterEpic) &&
            (string.IsNullOrEmpty(MembersFilterType)   || i.IssueType == MembersFilterType))
        .ToList();

    private record MemberRow(string Name, int Total, int Done, int InProgress, int ToDo,
                             double CompletionPct, double HoursLogged, double RemainingHours,
                             double HoursLogged7d, int BlockedCount, int IdleActiveCount,
                             int InfeasibleCount, int UnestimatedCount,
                             List<SprintIssue> Tasks, List<double> DailyHours, string HealthBand);

    // Seconds a specific member logged on one issue (their own worklog entries only).
    private static int MemberLoggedSeconds(string member, SprintIssue i) =>
        i.Worklogs.Where(w => w.Author == member).Sum(w => w.TimeSpentSeconds);

    // ── Epics Worked by Member (worklog-authorship based) ────────────────────
    // Credits each member for the epics they ACTUALLY logged work on, regardless of who
    // the task is assigned to now — so work done before a task was reassigned still counts.
    private record EpicWorkedEpic(string Key, string Name, int Tasks, int Done);
    private record EpicWorkedRow(string Name, List<EpicWorkedEpic> Epics);

    private List<EpicWorkedRow> EpicsWorkedByMember
    {
        get
        {
            // One (member, issue) pair per worklog author who logged time on an epic-linked issue.
            var pairs = ActiveIssues
                .Where(i => !string.IsNullOrEmpty(i.EpicKey))
                .SelectMany(i => i.Worklogs
                    .Select(w => w.Author)
                    .Where(a => !string.IsNullOrWhiteSpace(a) && a != "Unassigned")
                    .Distinct()
                    .Select(author => (Author: author, Issue: i)));

            return pairs
                .GroupBy(p => p.Author)
                .Select(mg => new EpicWorkedRow(
                    mg.Key,
                    mg.GroupBy(p => p.Issue.EpicKey)
                      .Select(eg => new EpicWorkedEpic(
                          eg.Key,
                          eg.First().Issue.EpicName is { Length: > 0 } en && en != "No Epic" ? en : eg.Key,
                          eg.Count(),
                          eg.Count(p => p.Issue.StatusCategoryKey == "done")))
                      .OrderByDescending(e => e.Tasks)
                      .ToList()))
                .Where(r => r.Epics.Count > 0)
                .OrderByDescending(r => r.Epics.Count)
                .ThenBy(r => r.Name)
                .ToList();
        }
    }

    private double CapacityPerMemberHours => Math.Max(0, EffectiveDaysRemaining * 6.0);

    private List<MemberRow> MemberRows
    {
        get
        {
            var sevenDaysAgo = DateTime.Today.AddDays(-7);
            var fourteenDaysAgo = DateTime.Today.AddDays(-14);

            // Credit each member for every issue they ACTUALLY logged work on (worklog author),
            // regardless of who it's assigned to right now — so handed-off / reassigned work still
            // shows up under the person who did it. Mirrors the "Epics Worked by Member" view.
            return ActiveIssues
                .SelectMany(i => i.Worklogs
                    .Select(w => w.Author)
                    .Where(a => !string.IsNullOrWhiteSpace(a) && a != "Unassigned")
                    .Distinct()
                    .Select(author => (Author: author, Issue: i)))
                .GroupBy(p => p.Author)
                .Select(g =>
                {
                    var member      = g.Key;
                    var tasks       = g.Select(p => p.Issue).ToList();
                    var done        = tasks.Count(i => i.StatusCategoryKey == "done");
                    var active      = tasks.Count(i => i.StatusCategoryKey == "indeterminate");
                    var todo        = tasks.Count(i => i.StatusCategoryKey == "new");
                    var compl       = tasks.Count == 0 ? 0 : done * 100.0 / tasks.Count;
                    // Logged figures = this member's OWN worklog contribution (the work they did),
                    // not the task totals (which may bundle other people's time on the same task).
                    var logged      = tasks.SelectMany(i => i.Worklogs).Where(w => w.Author == member).Sum(w => w.TimeSpentSeconds) / 3600.0;
                    var remaining   = tasks.Where(i => i.StatusCategoryKey != "done").Sum(i => i.ComputedRemainingSeconds) / 3600.0;
                    var logged7d    = tasks.SelectMany(i => i.Worklogs).Where(w => w.Author == member && w.Started.Date >= sevenDaysAgo).Sum(w => w.TimeSpentSeconds) / 3600.0;
                    var blocked     = tasks.Count(IsBlocked);
                    var idleActive  = tasks.Count(i => i.StatusCategoryKey == "indeterminate" && i.DaysSinceLastWorklog >= 1);
                    var infeasible  = tasks.Count(i => i.StatusCategoryKey != "done" && TaskFeasibility(i).band == "danger");
                    var unest       = tasks.Count(i => i.StatusCategoryKey != "done" && i.OriginalEstimateSeconds == 0);

                    // Daily hours last 14d — this member's own worklogs only
                    var daily = new List<double>();
                    for (var d = fourteenDaysAgo; d <= DateTime.Today; d = d.AddDays(1))
                    {
                        var h = tasks.SelectMany(i => i.Worklogs).Where(w => w.Author == member && w.Started.Date == d).Sum(w => w.TimeSpentSeconds) / 3600.0;
                        daily.Add(h);
                    }

                    var capPerMember = CapacityPerMemberHours;
                    var overCap      = capPerMember > 0 && remaining > capPerMember;
                    var sprintBehind = Report != null && Report.SprintProgressPct - compl > 20;

                    string health;
                    if (overCap || blocked > 0 || infeasible > 0) health = "danger";
                    else if (sprintBehind || idleActive > 0 || (capPerMember > 0 && remaining > capPerMember * 0.8)) health = "warn";
                    else health = "success";

                    return new MemberRow(
                        Name: member,
                        Total: tasks.Count,
                        Done: done,
                        InProgress: active,
                        ToDo: todo,
                        CompletionPct: compl,
                        HoursLogged: logged,
                        RemainingHours: remaining,
                        HoursLogged7d: logged7d,
                        BlockedCount: blocked,
                        IdleActiveCount: idleActive,
                        InfeasibleCount: infeasible,
                        UnestimatedCount: unest,
                        Tasks: tasks,
                        DailyHours: daily,
                        HealthBand: health);
                })
                .OrderBy(m => m.HealthBand switch { "danger" => 0, "warn" => 1, _ => 2 })
                .ThenByDescending(m => m.RemainingHours)
                .ToList();
        }
    }

    private List<MemberRow> FilteredMemberRows => MemberRows
        .Where(m =>
            (string.IsNullOrWhiteSpace(MembersSearch) || m.Name.Contains(MembersSearch, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrEmpty(MembersFilterHealth) || m.HealthBand == MembersFilterHealth) &&
            (!MembersHideEmpty || FilteredTasksFor(m).Count > 0))
        .ToList();

    private static bool IsBlocked(SprintIssue i) =>
        i.StatusCategoryKey != "done" &&
        ((i.Status?.Contains("Block", StringComparison.OrdinalIgnoreCase) ?? false) ||
         (i.Labels?.Any(l => l.Contains("block", StringComparison.OrdinalIgnoreCase)) ?? false));

    private static int? IssuePercentDone(SprintIssue i)
    {
        if (i.StatusCategoryKey == "done") return 100;
        var spent = i.TimeSpentSeconds;
        var rem   = i.ComputedRemainingSeconds;
        var orig  = i.OriginalEstimateSeconds;

        // No estimate of any kind → can't compute progress
        if (orig == 0 && rem == 0)
            return spent > 0 ? (int?)null : 0;

        var denom = Math.Max(orig, spent + rem);
        if (denom == 0) return 0;

        var pct = (int)Math.Round(spent * 100.0 / denom);
        return Math.Clamp(pct, 0, 99); // not done → never 100
    }

    private (string label, string band, string reason) TaskFeasibility(SprintIssue i)
    {
        if (i.StatusCategoryKey == "done") return ("Done", "success", "Completed");
        var days = EffectiveDaysRemaining;
        if (days <= 0) return ("Overdue", "danger", "Sprint already ended — task not done");
        var remH = i.ComputedRemainingSeconds / 3600.0;
        if (remH == 0 && i.OriginalEstimateSeconds == 0) return ("?", "warn", "No estimate");
        var capacity = days * 6.0;
        if (remH > capacity) return ("No", "danger", $"{remH:F0}h needed > {capacity:F0}h capacity");
        if (remH > capacity * 0.8) return ("Tight", "warn", $"{remH:F0}h vs {capacity:F0}h capacity");
        return ("Yes", "success", $"{remH:F0}h fits in {capacity:F0}h");
    }

    // ── Scope Changes state ──────────────────────────────────────────────────
    private HashSet<string> _excludedScopeEpics = new();
    private string _scopeSearch         = "";
    private string _scopeFilterStatus   = "";
    private string _scopeFilterType     = "";
    private string _scopeFilterAssignee = "";

    private List<SprintIssue> ScopeChangedIssues => Report?.StartDate == null ? new()
        : ActiveIssues
            .Where(i => i.Created.HasValue && i.Created.Value >= Report.StartDate.Value.Date)
            .OrderBy(i => i.EpicKey).ThenBy(i => i.Created)
            .ToList();

    private List<SprintIssue> ScopeActiveIssues => _excludedScopeEpics.Count == 0
        ? ScopeChangedIssues
        : ScopeChangedIssues
            .Where(i => !_excludedScopeEpics.Contains(string.IsNullOrEmpty(i.EpicKey) ? "No Epic" : i.EpicKey))
            .ToList();

    private List<SprintIssue> ScopeFilteredIssues => ScopeActiveIssues
        .Where(i =>
            (string.IsNullOrEmpty(_scopeSearch) ||
             i.Key.Contains(_scopeSearch, StringComparison.OrdinalIgnoreCase) ||
             i.Summary.Contains(_scopeSearch, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrEmpty(_scopeFilterStatus)   || i.Status    == _scopeFilterStatus) &&
            (string.IsNullOrEmpty(_scopeFilterType)     || i.IssueType == _scopeFilterType) &&
            (string.IsNullOrEmpty(_scopeFilterAssignee) || i.Assignee  == _scopeFilterAssignee))
        .ToList();

    private int    ScopeEstimateSec  => ScopeActiveIssues.Sum(i => i.OriginalEstimateSeconds);
    private int    ScopeLoggedSec    => ScopeActiveIssues.Sum(i => i.TimeSpentSeconds);
    private double ScopePctDisplay   => ActiveIssues.Count == 0 ? 0 : Math.Round((double)ScopeActiveIssues.Count / ActiveIssues.Count * 100, 1);
    private int    ScopeUnestimated  => ScopeActiveIssues.Count(i => i.OriginalEstimateSeconds == 0);

    private record ScopeEpicGroup(string EpicKey, string EpicName, int Count, int EstSec, int LoggedSec, int Done, List<SprintIssue> Issues);

    private List<ScopeEpicGroup> GetScopeByEpic() =>
        ScopeChangedIssues
            .GroupBy(i => string.IsNullOrEmpty(i.EpicKey) ? "No Epic" : i.EpicKey)
            .Select(g => new ScopeEpicGroup(
                g.Key,
                g.First().EpicName,
                g.Count(),
                g.Sum(i => i.OriginalEstimateSeconds),
                g.Sum(i => i.TimeSpentSeconds),
                g.Count(i => i.StatusCategoryKey == "done"),
                g.OrderBy(i => i.Key).ToList()))
            .OrderByDescending(e => e.Count)
            .ToList();

    private List<(string Member, int LoggedSec)> GetScopeByMember() =>
        ScopeActiveIssues
            .SelectMany(i => i.Worklogs.Select(w => (w.Author, w.TimeSpentSeconds)))
            .GroupBy(x => x.Author, StringComparer.OrdinalIgnoreCase)
            .Select(g => (Member: g.Key, LoggedSec: g.Sum(x => x.TimeSpentSeconds)))
            .OrderByDescending(x => x.LoggedSec)
            .ToList();

