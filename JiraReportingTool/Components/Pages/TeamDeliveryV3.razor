    private IEnumerable<ContribRow> ApplySortTM(IEnumerable<ContribRow> src) => _sortTM switch
    {
        "Name"   => _ascTM ? src.OrderBy(c => c.Name)              : src.OrderByDescending(c => c.Name),
        "Tasks"  => _ascTM ? src.OrderBy(c => c.Total)             : src.OrderByDescending(c => c.Total),
        "Done"   => _ascTM ? src.OrderBy(c => c.Done)              : src.OrderByDescending(c => c.Done),
        "Active" => _ascTM ? src.OrderBy(c => c.InProgress)        : src.OrderByDescending(c => c.InProgress),
        "ToDo"   => _ascTM ? src.OrderBy(c => c.ToDo)              : src.OrderByDescending(c => c.ToDo),
        "Compl"  => _ascTM ? src.OrderBy(c => c.CompletionPct)     : src.OrderByDescending(c => c.CompletionPct),
        "Logged" => _ascTM ? src.OrderBy(c => c.HoursLoggedSprint) : src.OrderByDescending(c => c.HoursLoggedSprint),
        "Rem"    => _ascTM ? src.OrderBy(c => c.RemainingHours)    : src.OrderByDescending(c => c.RemainingHours),
        _        => src.OrderByDescending(c => c.HoursLoggedSprint),
