    // At-Risk issues after the Risks-tab filter bar is applied (sorting happens separately via ApplySortRI).
    private IEnumerable<SprintIssue> FilteredAtRiskIssues
    {
        get
        {
            if (Report == null) return Enumerable.Empty<SprintIssue>();
            IEnumerable<SprintIssue> q = AtRiskIssuesScoped;
            if (!string.IsNullOrWhiteSpace(_riSearch))
            {
                var s = _riSearch.Trim();
                q = q.Where(i => (i.Key?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false)
                              || (i.Summary?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false));
            }
            if (!string.IsNullOrEmpty(_riFilterType))     q = q.Where(i => i.IssueType == _riFilterType);
            if (!string.IsNullOrEmpty(_riFilterAssignee)) q = q.Where(i => i.Assignee == _riFilterAssignee);
            if (!string.IsNullOrEmpty(_riFilterStatus))   q = q.Where(i => i.Status == _riFilterStatus);
            if (!string.IsNullOrEmpty(_riFilterReason))   q = q.Where(i => RiskReasonKey(i) == _riFilterReason);
            return q;
        }
    }

    // Stable bucket key for the risk reason (RiskReason() text varies, e.g. "No worklog in 6d").
    private static string RiskReasonKey(SprintIssue i)
    {
        if (i.StatusCategoryKey == "new") return "notstarted";
        if (i.DaysSinceLastWorklog >= 2 && i.StatusCategoryKey == "indeterminate") return "stale";
        if (i.ComputedRemainingSeconds > 0) return "overcapacity";
        return "flagged";
    }
    private static string RiskReasonLabel(string key) => key switch
    {
        "notstarted"   => "Not started",
        "stale"        => "No recent worklog",
        "overcapacity" => "Remaining > capacity",
        _              => "Flagged",
    };

