    // ── Daily Standup tables ─────────────────────────────────────────────────
    private record EpicSdRow(string EpicKey, string EpicName,
        int Total, int Done, int YesterdaySeconds,
        List<SprintIssue> CompletedYesterday, List<SprintIssue> WorkedYesterday,
        List<SprintIssue> InProgress, List<SprintIssue> Stuck);

    private record MemberSdRow(string Name, int YesterdaySeconds,
        List<SprintIssue> Concluded, List<SprintIssue> WorkedYesterday,
        List<SprintIssue> InProgress);

    private HashSet<string> _epicSdExpanded   = [];
    private HashSet<string> _memberSdExpanded = [];
    private void ToggleEpicSd(string key)    { if (!_epicSdExpanded.Remove(key))   _epicSdExpanded.Add(key); }
    private void ToggleMemberSd(string name) { if (!_memberSdExpanded.Remove(name)) _memberSdExpanded.Add(name); }

    private static string FirstName(string fullName) =>
        fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? fullName;

    private List<EpicSdRow> EpicStandupRows
    {
        get
        {
            var cutoff = DateTime.Today.AddDays(-1);
            return ActiveIssues
                .Where(i => !string.IsNullOrEmpty(i.EpicKey))
                .GroupBy(i => new { i.EpicKey, i.EpicName })
                .Select(g =>
                {
                    var issues = g.ToList();
                    var completedYesterday = issues
                        .Where(i => i.StatusCategoryKey == "done" && i.Worklogs.Any(w => w.Started.Date >= cutoff))
                        .ToList();
                    var workedYesterday = issues
                        .Where(i => i.StatusCategoryKey != "done" && i.Worklogs.Any(w => w.Started.Date >= cutoff))
                        .ToList();
                    var inProgress = issues
                        .Where(i => i.StatusCategoryKey == "indeterminate")
                        .OrderBy(i => i.DaysSinceLastWorklog)
                        .ToList();
                    var stuck = inProgress.Where(i => i.DaysSinceLastWorklog >= 1).ToList();
                    var yesterdaySec = issues.SelectMany(i => i.Worklogs)
                        .Where(w => w.Started.Date >= cutoff)
                        .Sum(w => w.TimeSpentSeconds);
                    return new EpicSdRow(
                        g.Key.EpicKey, g.Key.EpicName ?? g.Key.EpicKey,
                        issues.Count, issues.Count(i => i.StatusCategoryKey == "done"),
                        yesterdaySec, completedYesterday, workedYesterday, inProgress, stuck);
                })
                .OrderByDescending(r => r.YesterdaySeconds)
                .ThenBy(r => r.EpicName)
                .ToList();
        }
    }

    private List<MemberSdRow> MemberStandupRows
    {
        get
        {
            var cutoff = DateTime.Today.AddDays(-1);
            return ActiveIssues
                .Where(i => !string.IsNullOrWhiteSpace(i.Assignee) && i.Assignee != "Unassigned")
                .Select(i => i.Assignee)
                .Distinct()
                .OrderBy(n => n)
                .Select(person =>
                {
                    var mine = ActiveIssues.Where(i => i.Assignee == person).ToList();
                    var concluded = mine
                        .Where(i => i.StatusCategoryKey == "done" && i.Worklogs.Any(w => w.Started.Date >= cutoff))
                        .ToList();
                    var worked = mine
                        .Where(i => i.StatusCategoryKey != "done" && i.Worklogs.Any(w => w.Started.Date >= cutoff))
                        .ToList();
                    var inProgress = mine
                        .Where(i => i.StatusCategoryKey == "indeterminate")
                        .OrderBy(i => i.DaysSinceLastWorklog)
                        .ToList();
                    var yesterdaySec = mine.SelectMany(i => i.Worklogs)
                        .Where(w => w.Started.Date >= cutoff)
                        .Sum(w => w.TimeSpentSeconds);
                    return new MemberSdRow(person, yesterdaySec, concluded, worked, inProgress);
                })
                .OrderByDescending(r => r.YesterdaySeconds)
                .ThenBy(r => r.Name)
                .ToList();
        }
    }

    // ── On Hold issues (Task 4) ──────────────────────────────────────────────
    private List<SprintIssue> OnHoldIssues => ActiveIssues
        .Where(i => i.StatusCategoryKey != "done"
                 && (i.Status?.Contains("Hold", StringComparison.OrdinalIgnoreCase) == true
                  || i.Status?.Contains("Block", StringComparison.OrdinalIgnoreCase) == true))
        .ToList();

    // ── Team Tracking (Task 1) ───────────────────────────────────────────────
    private HashSet<string> _trackingExpanded = [];
    private string _sortColTRK = ""; private bool _sortAscTRK = true;

    private void ToggleTracking(string name)
    {
        if (!_trackingExpanded.Remove(name)) _trackingExpanded.Add(name);
    }

    private void SortTRK(string c)
    {
        if (_sortColTRK == c) _sortAscTRK = !_sortAscTRK; else { _sortColTRK = c; _sortAscTRK = true; }
    }

    private record TrkRow(string Person, List<SprintIssue> AllActive, List<SprintIssue> Effective,
                          int TotalRem, int NonBugRem, bool HasBug, int DaysIdle, string Signal);

    private List<string> TrackingPeople => ActiveIssues
        .Where(i => !string.IsNullOrWhiteSpace(i.Assignee) && i.Assignee != "Unassigned")
        .Select(i => i.Assignee)
        .Distinct()
        .OrderBy(n => n)
        .ToList();

    private List<TrkRow> BuildTrackingRows() => TrackingPeople.Select(person =>
    {
        var allActive = ActiveIssues
            .Where(i => i.Assignee.Equals(person, StringComparison.OrdinalIgnoreCase)
                     && i.StatusCategoryKey == "indeterminate")
            .OrderBy(i => i.ComputedRemainingSeconds)
            .ToList();
        var effective   = allActive.Where(i => !(i.Status?.Contains("Hold", StringComparison.OrdinalIgnoreCase) ?? false)).ToList();
        var hasBug      = effective.Any(i => i.IssueType.Equals("Bug", StringComparison.OrdinalIgnoreCase));
        var nonBugRem   = effective.Where(i => !i.IssueType.Equals("Bug", StringComparison.OrdinalIgnoreCase))
                                   .Sum(i => i.ComputedRemainingSeconds);
        var nonBugCount = effective.Count(i => !i.IssueType.Equals("Bug", StringComparison.OrdinalIgnoreCase));
        var totalRem    = effective.Sum(i => i.ComputedRemainingSeconds);
        var lastLog     = ActiveIssues
            .Where(i => i.Assignee.Equals(person, StringComparison.OrdinalIgnoreCase))
            .SelectMany(i => i.Worklogs)
            .Select(w => w.Started)
            .DefaultIfEmpty()
            .Max();
        var daysIdle = lastLog == default ? 999 : (int)(DateTime.Today - lastLog.Date).TotalDays;
        var signal   = hasBug                                    ? "busy"
                     : effective.Count == 0 || nonBugCount == 0 ? "needs"
                     : nonBugRem < 6 * 3600                     ? "low"
                     : nonBugRem < 12 * 3600                    ? "soon"
                     : "busy";
        return new TrkRow(person, allActive, effective, totalRem, nonBugRem, hasBug, daysIdle, signal);
    }).ToList();

    private int TrackingNeedsCount => TrackingPeople.Count(p =>
    {
        var effective = ActiveIssues
            .Where(i => i.Assignee.Equals(p, StringComparison.OrdinalIgnoreCase)
                     && i.StatusCategoryKey == "indeterminate"
                     && !(i.Status?.Contains("Hold", StringComparison.OrdinalIgnoreCase) ?? false))
            .ToList();
        if (effective.Any(i => i.IssueType.Equals("Bug", StringComparison.OrdinalIgnoreCase))) return false;
        return !effective.Any(i => !i.IssueType.Equals("Bug", StringComparison.OrdinalIgnoreCase));
    });

    private int TrackingLowCount => TrackingPeople.Count(p =>
    {
        var effective = ActiveIssues
            .Where(i => i.Assignee.Equals(p, StringComparison.OrdinalIgnoreCase)
                     && i.StatusCategoryKey == "indeterminate"
                     && !(i.Status?.Contains("Hold", StringComparison.OrdinalIgnoreCase) ?? false))
            .ToList();
        if (effective.Any(i => i.IssueType.Equals("Bug", StringComparison.OrdinalIgnoreCase))) return false;
        var rem = effective.Sum(i => i.ComputedRemainingSeconds);
        return rem > 0 && rem < 6 * 3600;
    });

    private IEnumerable<TrkRow> ApplySortTRK(IEnumerable<TrkRow> rows) => _sortColTRK switch
    {
        "TRKMember" => _sortAscTRK ? rows.OrderBy(r => r.Person)          : rows.OrderByDescending(r => r.Person),
        "TRKActive" => _sortAscTRK ? rows.OrderBy(r => r.Effective.Count) : rows.OrderByDescending(r => r.Effective.Count),
        "TRKRem"    => _sortAscTRK ? rows.OrderBy(r => r.TotalRem)        : rows.OrderByDescending(r => r.TotalRem),
        "TRKIdle"   => _sortAscTRK ? rows.OrderBy(r => r.DaysIdle)        : rows.OrderByDescending(r => r.DaysIdle),
        "TRKSignal" => _sortAscTRK ? rows.OrderBy(r => TrkSignalOrder(r.Signal)) : rows.OrderByDescending(r => TrkSignalOrder(r.Signal)),
        _           => rows.OrderBy(r => TrkSignalOrder(r.Signal)).ThenBy(r => r.Person),
    };

    private static int TrkSignalOrder(string s) => s switch { "needs" => 0, "low" => 1, "soon" => 2, _ => 3 };
}
