        "Key"      => _ascSC ? src.OrderBy(i => i.Key)                       : src.OrderByDescending(i => i.Key),
        "Summary"  => _ascSC ? src.OrderBy(i => i.Summary)                   : src.OrderByDescending(i => i.Summary),
        "Type"     => _ascSC ? src.OrderBy(i => i.IssueType)                 : src.OrderByDescending(i => i.IssueType),
        "Assignee" => _ascSC ? src.OrderBy(i => i.Assignee)                  : src.OrderByDescending(i => i.Assignee),
        "Status"   => _ascSC ? src.OrderBy(i => i.Status)                    : src.OrderByDescending(i => i.Status),
        "Created"  => _ascSC ? src.OrderBy(i => i.Created ?? DateTime.MinValue) : src.OrderByDescending(i => i.Created ?? DateTime.MinValue),
        "Est"      => _ascSC ? src.OrderBy(i => i.OriginalEstimateSeconds)   : src.OrderByDescending(i => i.OriginalEstimateSeconds),
        "Log"      => _ascSC ? src.OrderBy(i => i.TimeSpentSeconds)          : src.OrderByDescending(i => i.TimeSpentSeconds),
        "Rem"      => _ascSC ? src.OrderBy(i => i.ComputedRemainingSeconds)  : src.OrderByDescending(i => i.ComputedRemainingSeconds),
        _          => src.OrderBy(i => i.EpicKey).ThenBy(i => i.Created),
    };

