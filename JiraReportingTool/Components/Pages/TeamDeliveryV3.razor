    // ── Calendar tab (epics plotted on their committed date) ─────────────────
    private int _calYear  = DateTime.Today.Year;
    private int _calMonth = DateTime.Today.Month;
    private void CalPrevMonth() { if (_calMonth == 1) { _calMonth = 12; _calYear--; } else _calMonth--; }
    private void CalNextMonth() { if (_calMonth == 12) { _calMonth = 1; _calYear++; } else _calMonth++; }

    private record EpicCalItem(string Key, string Name, DateTime Committed, int Done, int Total);

    private List<EpicCalItem> EpicsWithCommittedDate => EpicRows
        .Where(e => e.Key != "—" && _epicMeta.TryGetValue(e.Key, out var m) && m.CommittedDate.HasValue)
        .Select(e => new EpicCalItem(e.Key, e.Name, _epicMeta[e.Key].CommittedDate!.Value.Date, e.Done, e.Total))
        .ToList();

    private static string EpicCalState(EpicCalItem e) =>
