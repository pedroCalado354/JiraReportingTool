    private record TrkRow(string Person, List<SprintIssue> AllActive, List<SprintIssue> Effective,
                          int TotalRem, int NonBugRem, bool HasBug, int DaysIdle, string Signal);

    private List<string> TrackingPeople => ActiveIssues
        .Where(i => !string.IsNullOrWhiteSpace(i.Assignee) && i.Assignee != "Unassigned")
        .Select(i => i.Assignee)
        .Distinct()
        .OrderBy(n => n)
        .ToList();

    private List<TrkRow> BuildTrackingRows() => TrackingPeople.Select(person =>
    {
        var allActive = ActiveIssues
            .Where(i => i.Assignee.Equals(person, StringComparison.OrdinalIgnoreCase)
                     && i.StatusCategoryKey == "indeterminate")
            .OrderBy(i => i.ComputedRemainingSeconds)
            .ToList();
        var effective   = allActive.Where(i => !(i.Status?.Contains("Hold", StringComparison.OrdinalIgnoreCase) ?? false)).ToList();
        var hasBug      = effective.Any(i => i.IssueType.Equals("Bug", StringComparison.OrdinalIgnoreCase));
        var nonBugRem   = effective.Where(i => !i.IssueType.Equals("Bug", StringComparison.OrdinalIgnoreCase))
                                   .Sum(i => i.ComputedRemainingSeconds);
        var nonBugCount = effective.Count(i => !i.IssueType.Equals("Bug", StringComparison.OrdinalIgnoreCase));
        var totalRem    = effective.Sum(i => i.ComputedRemainingSeconds);
        var lastLog     = ActiveIssues
            .Where(i => i.Assignee.Equals(person, StringComparison.OrdinalIgnoreCase))
            .SelectMany(i => i.Worklogs)
            .Select(w => w.Started)
            .DefaultIfEmpty()
            .Max();
        var daysIdle = lastLog == default ? 999 : (int)(DateTime.Today - lastLog.Date).TotalDays;
        var signal   = hasBug                                    ? "busy"
                     : effective.Count == 0 || nonBugCount == 0 ? "needs"
                     : nonBugRem < 6 * 3600                     ? "low"
                     : nonBugRem < 12 * 3600                    ? "soon"
                     : "busy";
        return new TrkRow(person, allActive, effective, totalRem, nonBugRem, hasBug, daysIdle, signal);
    }).ToList();

    private int TrackingNeedsCount => TrackingPeople.Count(p =>
    {
        var effective = ActiveIssues
            .Where(i => i.Assignee.Equals(p, StringComparison.OrdinalIgnoreCase)
                     && i.StatusCategoryKey == "indeterminate"
                     && !(i.Status?.Contains("Hold", StringComparison.OrdinalIgnoreCase) ?? false))
            .ToList();
        if (effective.Any(i => i.IssueType.Equals("Bug", StringComparison.OrdinalIgnoreCase))) return false;
        return !effective.Any(i => !i.IssueType.Equals("Bug", StringComparison.OrdinalIgnoreCase));
    });

    private int TrackingLowCount => TrackingPeople.Count(p =>
    {
        var effective = ActiveIssues
            .Where(i => i.Assignee.Equals(p, StringComparison.OrdinalIgnoreCase)
                     && i.StatusCategoryKey == "indeterminate"
                     && !(i.Status?.Contains("Hold", StringComparison.OrdinalIgnoreCase) ?? false))
            .ToList();
        if (effective.Any(i => i.IssueType.Equals("Bug", StringComparison.OrdinalIgnoreCase))) return false;
        var rem = effective.Sum(i => i.ComputedRemainingSeconds);
        return rem > 0 && rem < 6 * 3600;
    });

    private IEnumerable<TrkRow> ApplySortTRK(IEnumerable<TrkRow> rows) => _sortColTRK switch
    {
        "TRKMember" => _sortAscTRK ? rows.OrderBy(r => r.Person)          : rows.OrderByDescending(r => r.Person),
        "TRKActive" => _sortAscTRK ? rows.OrderBy(r => r.Effective.Count) : rows.OrderByDescending(r => r.Effective.Count),
        "TRKRem"    => _sortAscTRK ? rows.OrderBy(r => r.TotalRem)        : rows.OrderByDescending(r => r.TotalRem),
        "TRKIdle"   => _sortAscTRK ? rows.OrderBy(r => r.DaysIdle)        : rows.OrderByDescending(r => r.DaysIdle),
        "TRKSignal" => _sortAscTRK ? rows.OrderBy(r => TrkSignalOrder(r.Signal)) : rows.OrderByDescending(r => TrkSignalOrder(r.Signal)),
        _           => rows.OrderBy(r => TrkSignalOrder(r.Signal)).ThenBy(r => r.Person),
    };

    private static int TrkSignalOrder(string s) => s switch { "needs" => 0, "low" => 1, "soon" => 2, _ => 3 };
}
