@page "/delivery-v3"
@rendermode InteractiveServer
@inject IJiraService JiraService
@inject IConfiguration Config
@inject SprintConfigService SprintConfigService
@inject IJSRuntime JS
@using JiraReportingTool.Models
@using ClosedXML.Excel

<PageTitle>Team Delivery — Command Center</PageTitle>

<div class="v2-root">

    <!-- ═══ HERO ═════════════════════════════════════════════════════════════ -->
    <div class="v2-hero">
        <div class="v2-hero-row">
            <div class="v2-hero-icon"><i class="bi bi-speedometer2"></i></div>
            <div class="v2-hero-titles">
                <span class="v2-eyebrow">Sprint Command Center</span>
                <h1 class="v2-hero-title">Team Delivery</h1>
                <span class="v2-hero-sub">
                    @if (Report is not null)
                    {
                        <strong>@(Report.SprintName is { Length: > 0 } sn ? sn : "Sprint")</strong>
                        @if (Report.StartDate.HasValue && Report.EndDate.HasValue)
                        {
                            <span> · @Report.StartDate.Value.ToString("MMM d") – @Report.EndDate.Value.ToString("MMM d, yyyy")</span>
                        }
                    }
                    else
                    {
                        <span>Real-time delivery health · velocity · capacity · risk</span>
                    }
                </span>
            </div>
            <div class="v2-hero-spacer"></div>
            @if (Report is not null)
            {
                <div class="v2-hero-actions">
                    <button class="v2-btn v2-btn-ghost" @onclick="HardRefresh"
                            disabled="@IsLoading"
                            title="Re-fetch this sprint's data fresh from Jira">
                        @if (IsLoading) { <span class="v2-spin"></span> }
                        else { <i class="bi bi-arrow-repeat"></i> }
                        <span>Refresh</span>
                    </button>
                    <span class="v2-rag @RagClass">@RagText</span>
                    <span class="v2-pill v2-pill-neutral"><i class="bi bi-calendar3"></i> @Report.DaysRemaining d left</span>
                </div>
            }
        </div>
    </div>

    <!-- ═══ LOAD CONTROL BAR ════════════════════════════════════════════════ -->
    <div class="v2-control-bar">
        <div class="v2-field" style="min-width:260px">
            <label class="v2-label">Jira Saved Filter</label>
            <select class="v2-select" @bind="SelectedFilterId"
                    disabled="@(FiltersLoading || !string.IsNullOrEmpty(SprintId))">
                <option value="">— select a filter —</option>
                @foreach (var f in MyFilters)
                {
                    <option value="@f.Id" title="@f.Jql">@f.Name</option>
                }
            </select>
        </div>

        <div class="v2-or">or</div>

        <div class="v2-field" style="min-width:140px">
            <label class="v2-label">Sprint ID</label>
            <input class="v2-input" @bind="SprintId" @onkeyup="HandleKeyUp"
                   placeholder="e.g. 6690"
                   disabled="@(!string.IsNullOrEmpty(SelectedFilterId))" />
        </div>

        <div class="v2-field">
            <label class="v2-label">Days override</label>
            <input type="number" class="v2-input v2-input-sm" style="width:90px"
                   @bind="OverrideDaysLeftInput"
                   placeholder="@(Report != null ? Report.DaysRemaining.ToString() : "auto")"
                   min="0" max="99" />
        </div>

        <button class="v2-btn v2-btn-primary" @onclick="() => LoadData()"
                disabled="@(IsLoading || (string.IsNullOrEmpty(SprintId) && string.IsNullOrEmpty(SelectedFilterId)))">
            @if (IsLoading) { <span class="v2-spin"></span> }
            else { <i class="bi bi-lightning-charge-fill"></i> }
            <span>@(IsLoading ? (_epicLoadTotal > 0 ? $"Epics {_epicLoadProgress}/{_epicLoadTotal}" : "Loading…") : "Load delivery")</span>
        </button>

        <label style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--v2-ink-2);cursor:pointer"
               title="Restrict the query to a fixed list of engineering team member account IDs">
            <input type="checkbox" @bind="OnlyTeamMembers" />
            <i class="bi bi-people-fill" style="color:var(--v2-brand)"></i>
            Engineering team only
        </label>

        @if (Report is not null)
        {
            <span class="v2-hint" style="margin-left:auto">@Report.TotalIssues issues · @Report.Issues.Select(i => i.Assignee).Distinct().Count() contributors</span>
        }
    </div>

    @if (IsLoading && _epicLoadTotal > 0)
    {
        <div class="v2-epic-load-bar">
            <div class="v2-epic-load-track">
                <div class="v2-epic-load-fill" style="width:@(_epicLoadProgress * 100 / _epicLoadTotal)%"></div>
            </div>
            <span class="v2-hint" style="white-space:nowrap">Fetching epic details @_epicLoadProgress / @_epicLoadTotal</span>
        </div>
    }

    @if (ErrorMessage != null)
    {
        <div class="v2-alert v2-alert-error"><i class="bi bi-exclamation-triangle-fill"></i> @ErrorMessage</div>
    }

    @if (Report is null)
    {
        <div class="v2-empty">
            <div class="v2-empty-icon"><i class="bi bi-rocket-takeoff"></i></div>
            <div class="v2-empty-title">Pick a sprint or filter to begin</div>
            <div>Load real-time delivery telemetry to see velocity, capacity, risks and contributors at a glance.</div>
        </div>
    }
    else
    {
        <!-- ═══ SPRINT INFO ════════════════════════════════════════════════ -->
        <div class="v2-card" style="display:flex;flex-wrap:wrap;align-items:center;gap:14px 22px;margin-bottom:14px;padding:14px 18px">
            <div style="display:flex;align-items:center;gap:8px">
                <i class="bi bi-flag-fill" style="color:var(--v2-brand)"></i>
                <strong>@(string.IsNullOrEmpty(Report.SprintName) ? "Sprint" : Report.SprintName)</strong>
                @if (!string.IsNullOrEmpty(Report.ProjectKey))
                {
                    <span class="v2-pill v2-pill-neutral" style="font-size:10px;padding:1px 6px">@Report.ProjectKey</span>
                }
            </div>

            <div style="display:flex;align-items:center;gap:6px" title="Sprint start">
                <i class="bi bi-calendar-event" style="color:var(--v2-ink-3)"></i>
                <span class="v2-hint">Start</span>
                <strong>@(Report.StartDate.HasValue ? Report.StartDate.Value.ToString("ddd, dd MMM yyyy") : "—")</strong>
            </div>

            <div style="display:flex;align-items:center;gap:6px" title="Sprint end">
                <i class="bi bi-calendar-check" style="color:var(--v2-ink-3)"></i>
                <span class="v2-hint">End</span>
                <strong>@(Report.EndDate.HasValue ? Report.EndDate.Value.ToString("ddd, dd MMM yyyy") : "—")</strong>
            </div>

            <div style="display:flex;align-items:center;gap:6px" title="Working days in sprint">
                <i class="bi bi-calendar-range" style="color:var(--v2-ink-3)"></i>
                <span class="v2-hint">Length</span>
                <strong>@Report.TotalSprintDays workday@(Report.TotalSprintDays == 1 ? "" : "s")</strong>
            </div>

            <div style="display:flex;align-items:center;gap:6px" title="Working days elapsed (excludes today)">
                <i class="bi bi-hourglass-split" style="color:var(--v2-ink-3)"></i>
                <span class="v2-hint">Elapsed</span>
                <strong>@Report.ElapsedDays / @Report.TotalSprintDays</strong>
                <span class="v2-hint">(@((int)Report.SprintProgressPct)%)</span>
            </div>

            <div style="display:flex;align-items:center;gap:6px" title="Working days remaining (today through end)">
                <i class="bi bi-clock-history" style="color:var(--v2-ink-3)"></i>
                <span class="v2-hint">Remaining</span>
                <strong class="@(Report.DaysRemaining == 0 ? "v2-text-danger" : "")">@Report.DaysRemaining workday@(Report.DaysRemaining == 1 ? "" : "s")</strong>
            </div>

            @if (Report.StartDate.HasValue && Report.EndDate.HasValue && DateTime.Today > Report.EndDate.Value.Date)
            {
                <span class="v2-pill v2-pill-danger">Sprint ended @((DateTime.Today - Report.EndDate.Value.Date).Days)d ago</span>
            }
            else if (Report.StartDate.HasValue && DateTime.Today < Report.StartDate.Value.Date)
            {
                <span class="v2-pill v2-pill-warn">Sprint hasn't started — opens in @((Report.StartDate.Value.Date - DateTime.Today).Days)d</span>
            }

            @if (!Report.StartDate.HasValue || !Report.EndDate.HasValue)
            {
                <div style="flex-basis:100%;display:flex;align-items:center;gap:8px;color:var(--v2-warn-2);font-size:12px;padding-top:4px;border-top:1px dashed var(--v2-border)">
                    <i class="bi bi-exclamation-triangle"></i>
                    Sprint @(Report.StartDate.HasValue ? "end" : Report.EndDate.HasValue ? "start" : "start &amp; end") date is missing — load via <strong>Sprint ID</strong> (rather than a saved filter) to populate dates, or set a <strong>Days override</strong> above to drive capacity calculations.
                </div>
            }
        </div>

        <!-- ═══ HEALTH GAUGE ════════════════════════════════════════════════ -->
        <div class="v2-gauge">
            <div class="v2-gauge-score @($"v2-gauge-score-{HealthBand}")">@HealthScore</div>
            <div class="v2-gauge-mid">
                <div class="v2-gauge-label">Sprint Health Score</div>
                <div class="v2-gauge-track">
                    <div class="v2-gauge-marker" style="left:@HealthScore%;"></div>
                </div>
                <div class="v2-gauge-desc">
                    @HealthMessage
                </div>
            </div>
            <div class="v2-gauge-side">
                <div class="v2-gauge-side-stat">
                    <div class="v2-gauge-side-val">@((int)Report.SprintProgressPct)%</div>
                    <div class="v2-gauge-side-lbl">Time elapsed</div>
                </div>
                <div class="v2-gauge-side-stat">
                    <div class="v2-gauge-side-val @(CompletionBehind ? "v2-text-danger" : "v2-text-success")">
                        @((int)CompletionPct)%
                    </div>
                    <div class="v2-gauge-side-lbl">Work done</div>
                </div>
                <div class="v2-gauge-side-stat">
                    <div class="v2-gauge-side-val @(IsOverCapacity ? "v2-text-danger" : "")">@($"{TotalRemainingHours:F0}h")</div>
                    <div class="v2-gauge-side-lbl">Remaining</div>
                </div>
                <div class="v2-gauge-side-stat">
                    <div class="v2-gauge-side-val">@($"{CapacityHours:F0}h")</div>
                    <div class="v2-gauge-side-lbl">Capacity</div>
                </div>
            </div>
        </div>

        <!-- ═══ KPI GRID ════════════════════════════════════════════════════ -->
        <div class="v2-kpi-grid">
            <!-- Completion -->
            <div class="v2-kpi @(CompletionBehind ? "v2-kpi-warn" : "v2-kpi-success")">
                <div class="v2-kpi-head"><i class="bi bi-check2-circle"></i>Completion</div>
                <div class="v2-kpi-value">@((int)CompletionPct)%</div>
                <div class="v2-bar" style="margin-top:8px">
                    <div class="v2-bar-fill @(CompletionBehind ? "v2-bar-fill-warn" : "v2-bar-fill-success")"
                         style="width:@Math.Min((int)CompletionPct,100)%"></div>
                </div>
                <div class="v2-kpi-sub">@DoneCount of @ActiveIssues.Count done · @InProgressCount active · @ToDoCount pending</div>
                <div class="v2-kpi-sub" style="margin-top:4px">@($"{DoneHours:F0}h") logged on done · @($"{DoneAndInReviewHours:F0}h") proj. incl. in review</div>
            </div>

            <!-- Task Completion (issue type Task & Sub-task only) -->
            <div class="v2-kpi @(TaskCompletionBehind ? "v2-kpi-warn" : "v2-kpi-success")">
                <div class="v2-kpi-head"><i class="bi bi-check2-all"></i>Task Completion</div>
                <div class="v2-kpi-value">@((int)TaskCompletionPct)%</div>
                <div class="v2-bar" style="margin-top:8px">
                    <div class="v2-bar-fill @(TaskCompletionBehind ? "v2-bar-fill-warn" : "v2-bar-fill-success")"
                         style="width:@Math.Min((int)TaskCompletionPct,100)%"></div>
                </div>
                <div class="v2-kpi-sub">@TaskDoneCount of @TaskOnlyIssues.Count done · @TaskInProgressCount active · tasks & sub-tasks only</div>
            </div>

            <!-- Sprint Health Score (tasks & sub-tasks only) -->
            <div class="v2-kpi v2-kpi-@TaskHealthBand">
                <div class="v2-kpi-head"><i class="bi bi-heart-pulse"></i>Sprint Health (Tasks)</div>
                <div class="v2-kpi-value @(TaskHealthBand == "success" ? "v2-text-success" : TaskHealthBand == "danger" ? "v2-text-danger" : "")">@TaskHealthScore<span class="v2-kpi-of">/ 100</span></div>
                <div class="v2-bar" style="margin-top:8px">
                    <div class="v2-bar-fill v2-bar-fill-@TaskHealthBand" style="width:@TaskHealthScore%"></div>
                </div>
                <div class="v2-kpi-sub">@TaskHealthMessage</div>
                <div class="v2-kpi-sub" style="margin-top:4px">tasks &amp; sub-tasks only</div>
            </div>

            <!-- Story Points -->
            @if (Report.HasStoryPoints)
            {
                <div class="v2-kpi">
                    <div class="v2-kpi-head"><i class="bi bi-stars"></i>Story Points</div>
                    <div class="v2-kpi-value">@Report.DoneStoryPoints<span class="v2-kpi-of">/ @Report.TotalStoryPoints SP</span></div>
                    <div class="v2-bar" style="margin-top:8px">
                        <div class="v2-bar-fill" style="width:@(Report.TotalStoryPoints > 0 ? Math.Min(Report.DoneStoryPoints * 100 / Report.TotalStoryPoints, 100) : 0)%"></div>
                    </div>
                    <div class="v2-kpi-sub">@(Report.TotalStoryPoints > 0 ? (Report.DoneStoryPoints * 100 / Report.TotalStoryPoints) : 0)% velocity · @VelocityPerDay.ToString("F1") SP/day pace</div>
                </div>
            }

            <!-- Hours (tasks & sub-tasks only) -->
            <div class="v2-kpi @(TaskOverCapacity ? "v2-kpi-danger" : "")">
                <div class="v2-kpi-head"><i class="bi bi-clock-history"></i>Capacity</div>
                <div class="v2-kpi-value @(TaskOverCapacity ? "v2-text-danger" : "")">@($"{TaskCapacityHours:F0}h")<span class="v2-kpi-of">vs @($"{TaskRemainingHours:F0}h")</span></div>
                <div class="v2-bar" style="margin-top:8px">
                    <div class="v2-bar-fill @(TaskOverCapacity ? "v2-bar-fill-danger" : "v2-bar-fill-success")"
                         style="width:@(TaskCapacityHours > 0 ? Math.Min(TaskRemainingHours / TaskCapacityHours * 100, 100) : 0)%"></div>
                </div>
                <div class="v2-kpi-sub">@(TaskOverCapacity ? $"⚠ {(TaskRemainingHours - TaskCapacityHours):F0}h over capacity" : $"+{(TaskCapacityHours - TaskRemainingHours):F0}h buffer")</div>
                <div class="v2-kpi-sub" style="margin-top:4px">tasks &amp; sub-tasks only</div>
            </div>

            <!-- Velocity / Burn rate -->
            <div class="v2-kpi v2-kpi-neutral">
                <div class="v2-kpi-head"><i class="bi bi-graph-up-arrow"></i>Burn Rate</div>
                <div class="v2-kpi-value">@($"{HoursLoggedPerWorkday:F1}h")<span class="v2-kpi-of">/ workday</span></div>
                @if (DailyBurndownHours.Count > 1)
                {
                    @SparklineSvg(DailyBurndownHours, "#6366f1")
                }
                <div class="v2-kpi-sub">@($"{TotalLoggedHours:F0}h logged") · projected @ProjectedFinishHours.ToString("F0")h by end</div>
            </div>

            <!-- Idle Tasks (tasks & sub-tasks only) -->
            <div class="v2-kpi @(TaskIdleActiveCount == 0 ? "v2-kpi-success" : TaskIdleActiveCount > TaskInProgressCount * 0.5 ? "v2-kpi-danger" : "v2-kpi-warn")">
                <div class="v2-kpi-head"><i class="bi bi-hourglass-split"></i>Idle Tasks</div>
                <div class="v2-kpi-value">@TaskIdleActiveCount<span class="v2-kpi-of">of @TaskInProgressCount active</span></div>
                <div class="v2-bar" style="margin-top:8px">
                    <div class="v2-bar-fill @(TaskIdleActiveCount == 0 ? "v2-bar-fill-success" : TaskIdleActiveCount > TaskInProgressCount * 0.5 ? "v2-bar-fill-danger" : "v2-bar-fill-warn")"
                         style="width:@(TaskInProgressCount > 0 ? Math.Min(TaskIdleActiveCount * 100 / Math.Max(1, TaskInProgressCount), 100) : 0)%"></div>
                </div>
                <div class="v2-kpi-sub">@TaskStaleCount stuck 2d+ · in-progress without log 24h+ · tasks &amp; sub-tasks only</div>
            </div>

            <!-- Throughput (tasks & sub-tasks only) -->
            <div class="v2-kpi @(TaskThroughputBehind ? "v2-kpi-warn" : "v2-kpi-success")">
                <div class="v2-kpi-head"><i class="bi bi-speedometer2"></i>Throughput</div>
                <div class="v2-kpi-value">@TaskThroughputPerDay.ToString("F1")<span class="v2-kpi-of">tasks / day</span></div>
                <div class="v2-bar" style="margin-top:8px">
                    <div class="v2-bar-fill @(TaskThroughputBehind ? "v2-bar-fill-warn" : "v2-bar-fill-success")"
                         style="width:@(TaskNeededThroughputPerDay > 0 ? Math.Min(TaskThroughputPerDay / TaskNeededThroughputPerDay * 100, 100) : 100)%"></div>
                </div>
                <div class="v2-kpi-sub">need @TaskNeededThroughputPerDay.ToString("F1")/day · @(TaskOnlyIssues.Count - TaskDoneCount) to go · tasks &amp; sub-tasks only</div>
            </div>

            <!-- Workload Balance -->
            <div class="v2-kpi @(WorkloadImbalancePct > 100 ? "v2-kpi-danger" : WorkloadImbalancePct > 50 ? "v2-kpi-warn" : "v2-kpi-success")">
                <div class="v2-kpi-head"><i class="bi bi-bar-chart-steps"></i>Workload Balance</div>
                <div class="v2-kpi-value">+@($"{WorkloadImbalancePct:F0}")%<span class="v2-kpi-of">peak vs avg</span></div>
                <div class="v2-bar" style="margin-top:8px">
                    <div class="v2-bar-fill @(WorkloadImbalancePct > 100 ? "v2-bar-fill-danger" : WorkloadImbalancePct > 50 ? "v2-bar-fill-warn" : "v2-bar-fill-success")"
                         style="width:@Math.Min((int)WorkloadImbalancePct, 100)%"></div>
                </div>
                <div class="v2-kpi-sub">
                    @if (HeaviestMember != null)
                    {
                        <span>@HeaviestMember.Name carrying @($"{HeaviestMember.RemainingHours:F0}h") · avg @($"{AvgRemainingPerMember:F0}h")</span>
                    }
                    else
                    {
                        <span>no remaining work assigned</span>
                    }
                </div>
            </div>

            <!-- Estimation Quality -->
            <div class="v2-kpi @(EstimationCoveragePct >= 90 ? "v2-kpi-success" : EstimationCoveragePct >= 70 ? "v2-kpi-warn" : "v2-kpi-danger")">
                <div class="v2-kpi-head"><i class="bi bi-rulers"></i>Estimation Quality</div>
                <div class="v2-kpi-value">@($"{EstimationCoveragePct:F0}%")<span class="v2-kpi-of">tasks estimated</span></div>
                <div class="v2-bar" style="margin-top:8px">
                    <div class="v2-bar-fill @(EstimationCoveragePct >= 90 ? "v2-bar-fill-success" : EstimationCoveragePct >= 70 ? "v2-bar-fill-warn" : "v2-bar-fill-danger")"
                         style="width:@Math.Min((int)EstimationCoveragePct, 100)%"></div>
                </div>
                <div class="v2-kpi-sub">@UnestimatedCount unestimated · @UnassignedCount unassigned</div>
            </div>
        </div>

        <!-- ═══ KEY INSIGHTS ════════════════════════════════════════════════ -->
        <div class="v2-grid-2">
            <!-- Pacing -->
            <div class="v2-card">
                <div class="v2-section-title"><i class="bi bi-speedometer @(CompletionBehind ? "" : "")" style="color:@(CompletionBehind ? "#dc2626" : "#059669")"></i> Pacing</div>
                <div class="v2-stat-row">
                    <span class="v2-num-lg @(CompletionBehind ? "v2-text-danger" : "v2-text-success")">@(CompletionPct - Report.SprintProgressPct >= 0 ? "+" : "")@($"{CompletionPct - Report.SprintProgressPct:F0}")</span>
                    <span class="v2-num-suffix">pp vs ideal</span>
                </div>
                <div class="v2-hint" style="margin-bottom:10px">@(CompletionBehind ? "Behind schedule" : "On or ahead of schedule")</div>
                <div class="v2-row">
                    <span class="v2-row-label">Time elapsed</span>
                    <span class="v2-row-value">@((int)Report.SprintProgressPct)%</span>
                </div>
                <div class="v2-bar" style="margin:4px 0 8px">
                    <div class="v2-bar-fill v2-bar-fill-neutral" style="width:@Math.Min((int)Report.SprintProgressPct,100)%"></div>
                </div>
                <div class="v2-row">
                    <span class="v2-row-label">Work completed</span>
                    <span class="v2-row-value">@((int)CompletionPct)%</span>
                </div>
                <div class="v2-bar" style="margin-top:4px">
                    <div class="v2-bar-fill @(CompletionBehind ? "v2-bar-fill-danger" : "v2-bar-fill-success")"
                         style="width:@Math.Min((int)CompletionPct,100)%"></div>
                </div>
            </div>

            <!-- Forecast -->
            <div class="v2-card">
                <div class="v2-section-title"><i class="bi bi-flag-fill" style="color:@(IsOverCapacity ? "#dc2626" : "#059669")"></i> End-of-Sprint Forecast</div>
                <div class="v2-stat-row">
                    <span class="v2-num-lg @(IsOverCapacity ? "v2-text-danger" : "v2-text-success")">@ForecastVerdict</span>
                </div>
                <div class="v2-hint" style="margin-bottom:10px">@ForecastMessage</div>
                <div class="v2-row"><span class="v2-row-label">Daily capacity needed</span><span class="v2-row-value">@($"{NeededDailyHours:F1}h")</span></div>
                <div class="v2-row"><span class="v2-row-label">Current daily burn</span><span class="v2-row-value">@($"{HoursLoggedPerWorkday:F1}h")</span></div>
                <div class="v2-row"><span class="v2-row-label">Projected completion</span><span class="v2-row-value">@($"{ProjectedCompletionPct:F0}%")</span></div>
            </div>
        </div>

        <!-- ═══ NON-BUG BURNDOWN ═══════════════════════════════════════════════ -->
        <div class="v2-card v2-mt-lg">
            <div class="v2-section-title">
                <i class="bi bi-graph-down-arrow" style="color:#7c3aed"></i>
                Non-Bug Task Burndown
                <span class="v2-section-note">ideal line vs actual remaining work — bugs excluded</span>
            </div>
            @NonBugBurndownSvg()
            <div style="display:flex;gap:14px;margin-top:10px;font-size:11px;color:var(--v2-ink-3)">
                <span><span class="v2-dot v2-dot-brand" style="margin-right:4px"></span>Actual</span>
                <span><span class="v2-dot v2-dot-neutral" style="margin-right:4px"></span>Ideal</span>
                <span><span class="v2-dot v2-dot-success" style="margin-right:4px"></span>Projected</span>
            </div>
        </div>

        <!-- ═══ TABS ════════════════════════════════════════════════════════ -->
        <div class="v2-section v2-mt-lg">
            <div class="v2-tabs">
                <button class="v2-tab @(ActiveTab=="overview" ? "is-active" : "")" @onclick='() => ActiveTab="overview"'>
                    <i class="bi bi-grid-1x2"></i>Overview
                </button>
                <button class="v2-tab @(ActiveTab=="team" ? "is-active" : "")" @onclick='() => ActiveTab="team"'>
                    <i class="bi bi-people"></i>Team
                </button>
                <button class="v2-tab @(ActiveTab=="members" ? "is-active" : "")" @onclick='() => ActiveTab="members"'>
                    <i class="bi bi-person-lines-fill"></i>Members
                    @if (MemberRows.Any(m => m.HealthBand == "danger")) { <span class="v2-tab-badge">@MemberRows.Count(m => m.HealthBand == "danger")</span> }
                </button>
                <button class="v2-tab @(ActiveTab=="epics" ? "is-active" : "")" @onclick='() => ActiveTab="epics"'>
                    <i class="bi bi-collection"></i>Epics
                </button>
                <button class="v2-tab @(ActiveTab=="calendar" ? "is-active" : "")" @onclick='() => ActiveTab="calendar"'>
                    <i class="bi bi-calendar3"></i>Calendar
                    @if (EpicsWithCommittedDate.Count > 0) { <span class="v2-tab-badge">@EpicsWithCommittedDate.Count</span> }
                </button>
                <button class="v2-tab @(ActiveTab=="tasks" ? "is-active" : "")" @onclick='() => ActiveTab="tasks"'>
                    <i class="bi bi-list-task"></i>Tasks
                </button>
                <button class="v2-tab @(ActiveTab=="scope" ? "is-active" : "")" @onclick='() => ActiveTab="scope"'>
                    <i class="bi bi-arrows-expand"></i>Scope Changes
                    @if (ScopeChangedIssues.Count > 0) { <span class="v2-tab-badge">@ScopeChangedIssues.Count</span> }
                </button>
                <button class="v2-tab @(ActiveTab=="risks" ? "is-active" : "")" @onclick='() => ActiveTab="risks"'>
                    <i class="bi bi-shield-exclamation"></i>Risks
                    @if (AtRiskCount > 0) { <span class="v2-tab-badge">@AtRiskCount</span> }
                </button>
                <button class="v2-tab @(ActiveTab=="activity" ? "is-active" : "")" @onclick='() => ActiveTab="activity"'>
                    <i class="bi bi-activity"></i>Activity
                </button>
                <button class="v2-tab @(ActiveTab=="tracking" ? "is-active" : "")" @onclick='() => ActiveTab="tracking"'>
                    <i class="bi bi-person-check"></i>Team Tracking
                    @if (TrackingNeedsCount > 0 || TrackingLowCount > 0) { <span class="v2-tab-badge">@(TrackingNeedsCount + TrackingLowCount)</span> }
                </button>
            </div>
        </div>

        @if (ActiveTab == "overview")
        {
            <div class="v2-grid-2">
                <!-- Burndown -->
                <div class="v2-card v2-card-lg">
                    <div class="v2-section-title">
                        <i class="bi bi-graph-down" style="color:#6366f1"></i>
                        Burndown
                        <span class="v2-section-note">remaining work over time vs ideal trajectory</span>
                    </div>
                    @BurndownSvg()
                    <div style="display:flex;gap:14px;margin-top:10px;font-size:11px;color:var(--v2-ink-3)">
                        <span><span class="v2-dot v2-dot-brand" style="margin-right:4px"></span>Actual</span>
                        <span><span class="v2-dot v2-dot-neutral" style="margin-right:4px"></span>Ideal</span>
                        <span><span class="v2-dot v2-dot-success" style="margin-right:4px"></span>Projected</span>
                    </div>
                </div>

                <!-- Status & Type breakdown -->
                <div class="v2-card v2-card-lg">
                    <div class="v2-section-title">
                        <i class="bi bi-pie-chart" style="color:#7c3aed"></i>
                        Status & Type Breakdown
                    </div>
                    <div style="font-size:11px;font-weight:600;color:var(--v2-ink-3);margin-bottom:6px">By Status</div>
                    <div class="v2-bar-stack v2-tall-bar">
                        <span style="width:@(Pct(DoneCount, ActiveIssues.Count))%; background: linear-gradient(90deg,#10b981,#059669)" title="Done @DoneCount"></span>
                        <span style="width:@(Pct(InProgressCount, ActiveIssues.Count))%; background: linear-gradient(90deg,#6366f1,#4f46e5)" title="In Progress @InProgressCount"></span>
                        <span style="width:@(Pct(ToDoCount, ActiveIssues.Count))%; background: linear-gradient(90deg,#94a3b8,#64748b)" title="To Do @ToDoCount"></span>
                    </div>
                    <div style="display:flex;gap:14px;margin:8px 0 18px;font-size:11px;color:var(--v2-ink-3)">
                        <span><span class="v2-dot v2-dot-success"></span> Done @DoneCount</span>
                        <span><span class="v2-dot v2-dot-brand"></span> In Progress @InProgressCount</span>
                        <span><span class="v2-dot v2-dot-neutral"></span> To Do @ToDoCount</span>
                    </div>

                    <div style="font-size:11px;font-weight:600;color:var(--v2-ink-3);margin-bottom:6px">By Type</div>
                    @foreach (var t in TypeBreakdown)
                    {
                        <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px">
                            <span class="v2-chip v2-chip-@(t.Key.ToLower())">@t.Key</span>
                            <div class="v2-bar" style="flex:1">
                                <div class="v2-bar-fill" style="width:@(Pct(t.Value, ActiveIssues.Count))%"></div>
                            </div>
                            <span class="v2-row-value" style="width:42px;text-align:right">@t.Value</span>
                        </div>
                    }
                </div>
            </div>

            <!-- Task Completion by Scope: initial vs added during sprint -->
            <div class="v2-card v2-card-lg v2-mt-lg">
                <div class="v2-section-title">
                    <i class="bi bi-arrows-collapse" style="color:#0ea5e9"></i>
                    Task Completion by Scope
                    <span class="v2-section-note">issue tasks &amp; sub-tasks · initial sprint scope vs work added after start</span>
                </div>
                @{
                    var initStat = StatFor(TaskInitialIssues);
                    var addStat  = StatFor(TaskAddedIssues);
                    var totTasks = TaskOnlyIssues.Count;
                    int sharePct(int n) => totTasks == 0 ? 0 : (int)Math.Round(n * 100.0 / totTasks);
                }
                <div class="v2-grid-2" style="gap:16px;margin-top:6px">
                    <div class="v2-scope-panel">
                        <div class="v2-scope-head">
                            <div>
                                <div class="v2-scope-title">Initial Scope</div>
                                <div class="v2-scope-sub">planned at sprint start</div>
                            </div>
                            <div class="v2-scope-pct" style="color:var(--v2-success)">@((int)initStat.Pct)%</div>
                        </div>
                        <div class="v2-bar"><div class="v2-bar-fill v2-bar-fill-success" style="width:@Math.Min((int)initStat.Pct,100)%"></div></div>
                        <div class="v2-scope-stats">
                            <span><strong>@initStat.Done</strong> done</span>
                            <span><strong>@initStat.Active</strong> active</span>
                            <span><strong>@initStat.ToDo</strong> to do</span>
                            <span class="v2-scope-total">@initStat.Total tasks · @sharePct(initStat.Total)% of all</span>
                        </div>
                    </div>
                    <div class="v2-scope-panel">
                        <div class="v2-scope-head">
                            <div>
                                <div class="v2-scope-title">Added During Sprint</div>
                                <div class="v2-scope-sub">scope changes after start</div>
                            </div>
                            <div class="v2-scope-pct" style="color:var(--v2-brand)">@((int)addStat.Pct)%</div>
                        </div>
                        <div class="v2-bar"><div class="v2-bar-fill" style="width:@Math.Min((int)addStat.Pct,100)%"></div></div>
                        <div class="v2-scope-stats">
                            <span><strong>@addStat.Done</strong> done</span>
                            <span><strong>@addStat.Active</strong> active</span>
                            <span><strong>@addStat.ToDo</strong> to do</span>
                            <span class="v2-scope-total">@addStat.Total tasks · @sharePct(addStat.Total)% of all</span>
                        </div>
                    </div>
                </div>
                <div class="v2-scope-compare">
                    <span><strong>@totTasks</strong> total tasks</span>
                    <span class="v2-scope-dot">·</span>
                    <span>Initial completion <strong style="color:var(--v2-success)">@((int)initStat.Pct)%</strong></span>
                    <span class="v2-scope-dot">vs</span>
                    <span>Added completion <strong style="color:var(--v2-brand)">@((int)addStat.Pct)%</strong></span>
                    @{ var gap = (int)Math.Round(initStat.Pct - addStat.Pct); }
                    <span class="v2-scope-dot">·</span>
                    <span>@(gap == 0 ? "even" : gap > 0 ? $"initial ahead by {gap} pts" : $"added ahead by {-gap} pts")</span>
                </div>
            </div>

            <!-- Contributor leaderboard -->
            <div class="v2-section v2-mt-lg">
                <div class="v2-section-title"><i class="bi bi-bar-chart-line"></i>Contributor Leaderboard</div>
                <div class="v2-table-wrap">
                    <table class="v2-table">
                        <thead>
                            <tr>
                                <th style="width:32px">#</th>
                                <th class="@SI("Name", _sortOV, _ascOV)" @onclick='() => SortOV("Name")'>Contributor</th>
                                <th class="v2-table-num @SI("Done", _sortOV, _ascOV)" @onclick='() => SortOV("Done")'>Done</th>
                                <th class="v2-table-num @SI("Active", _sortOV, _ascOV)" @onclick='() => SortOV("Active")'>Active</th>
                                <th class="v2-table-num @SI("ToDo", _sortOV, _ascOV)" @onclick='() => SortOV("ToDo")'>To Do</th>
                                <th class="@SI("Pct", _sortOV, _ascOV)" @onclick='() => SortOV("Pct")'>Completion</th>
                                <th class="v2-table-num @SI("Logged", _sortOV, _ascOV)" @onclick='() => SortOV("Logged")'>Logged</th>
                                <th class="v2-table-num @SI("Remaining", _sortOV, _ascOV)" @onclick='() => SortOV("Remaining")'>Remaining</th>
                                <th>Capacity</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ var rank = 1; }
                            @foreach (var r in ApplySortOV(ContributorRows))
                            {
                                var capPct = CapacityHours > 0 ? Math.Min(r.RemainingHours / CapacityHours * 100, 100) : 0;
                                var capOver = r.RemainingHours > CapacityHours;
                                <tr>
                                    <td style="color:var(--v2-ink-4);font-weight:700">@rank</td>
                                    <td>
                                        <div style="display:flex;align-items:center;gap:8px">
                                            <span class="v2-avatar @($"v2-avatar-grad-{1 + (rank % 5)}")">@Initials(r.Name)</span>
                                            <span style="font-weight:600">@r.Name</span>
                                        </div>
                                    </td>
                                    <td class="v2-table-num"><strong>@r.Done</strong></td>
                                    <td class="v2-table-num">@r.InProgress</td>
                                    <td class="v2-table-num">@r.ToDo</td>
                                    <td style="min-width:120px">
                                        <div style="display:flex;align-items:center;gap:6px">
                                            <div class="v2-bar" style="flex:1;height:6px">
                                                <div class="v2-bar-fill v2-bar-fill-success" style="width:@($"{r.CompletionPct:F0}")%"></div>
                                            </div>
                                            <span class="v2-row-value" style="font-size:11px">@($"{r.CompletionPct:F0}%")</span>
                                        </div>
                                    </td>
                                    <td class="v2-table-num">@($"{r.HoursLogged:F0}h")</td>
                                    <td class="v2-table-num @(capOver ? "v2-text-danger" : "")">@($"{r.RemainingHours:F0}h")</td>
                                    <td style="min-width:130px">
                                        <div style="display:flex;align-items:center;gap:6px">
                                            <div class="v2-bar" style="flex:1;height:6px">
                                                <div class="v2-bar-fill @(capOver ? "v2-bar-fill-danger" : "v2-bar-fill-success")"
                                                     style="width:@($"{capPct:F0}")%"></div>
                                            </div>
                                            @if (capOver)
                                            {
                                                <span class="v2-pill v2-pill-danger" style="font-size:10px;padding:1px 6px">Over</span>
                                            }
                                        </div>
                                    </td>
                                </tr>
                                rank++;
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else if (ActiveTab == "team")
        {
            <div class="v2-section">
                <div class="v2-section-title">
                    <i class="bi bi-people" style="color:var(--v2-brand)"></i>Team — logged hours this sprint
                    <span class="v2-hint" style="margin-left:8px;font-weight:400">hours each member logged inside the sprint window · capacity @($"{CapacityPerMemberHours:F0}h") each (6h/day × @EffectiveDaysRemaining day@(EffectiveDaysRemaining == 1 ? "" : "s") left)</span>
                </div>
                <div class="v2-table-wrap">
                    <table class="v2-table">
                        <thead>
                            <tr>
                                <th class="@SI("Name", _sortTM, _ascTM)" @onclick='() => SortTM("Name")'>Member</th>
                                <th class="v2-table-num @SI("Tasks", _sortTM, _ascTM)" @onclick='() => SortTM("Tasks")'>Tasks</th>
                                <th class="v2-table-num @SI("Done", _sortTM, _ascTM)" @onclick='() => SortTM("Done")'>Done</th>
                                <th class="v2-table-num @SI("Active", _sortTM, _ascTM)" @onclick='() => SortTM("Active")'>Active</th>
                                <th class="v2-table-num @SI("ToDo", _sortTM, _ascTM)" @onclick='() => SortTM("ToDo")'>To Do</th>
                                <th class="v2-table-num @SI("Compl", _sortTM, _ascTM)" @onclick='() => SortTM("Compl")'>Completion</th>
                                <th class="v2-table-num @SI("Logged", _sortTM, _ascTM)" @onclick='() => SortTM("Logged")'>Logged (sprint)</th>
                                <th class="v2-table-num @SI("Rem", _sortTM, _ascTM)" @onclick='() => SortTM("Rem")'>Remaining</th>
                                <th>Capacity</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in ApplySortTM(ContributorRows))
                            {
                                var capPct = CapacityPerMemberHours > 0 ? Math.Min(r.RemainingHours / CapacityPerMemberHours * 100, 100) : 0;
                                var capOver = CapacityPerMemberHours > 0 && r.RemainingHours > CapacityPerMemberHours;
                                var status = capOver ? "danger" : (r.RemainingHours > CapacityPerMemberHours * 0.8 ? "warn" : "success");
                                <tr>
                                    <td>
                                        <div style="display:flex;align-items:center;gap:8px">
                                            <span class="v2-avatar v2-avatar-sm @($"v2-avatar-grad-{1 + (Math.Abs(r.Name.GetHashCode()) % 5)}")">@Initials(r.Name)</span>
                                            <span style="font-weight:600" class="v2-truncate">@r.Name</span>
                                            @if (capOver) { <span class="v2-pill v2-pill-danger" style="font-size:10px;padding:1px 6px">over capacity</span> }
                                        </div>
                                    </td>
                                    <td class="v2-table-num">@r.Total</td>
                                    <td class="v2-table-num" style="color:var(--v2-success)">@r.Done</td>
                                    <td class="v2-table-num" style="color:var(--v2-brand)">@r.InProgress</td>
                                    <td class="v2-table-num">@r.ToDo</td>
                                    <td class="v2-table-num">@($"{r.CompletionPct:F0}%")</td>
                                    <td class="v2-table-num" style="font-weight:700">@($"{r.HoursLoggedSprint:F1}h")</td>
                                    <td class="v2-table-num">@($"{r.RemainingHours:F0}h")</td>
                                    <td>
                                        <div style="display:flex;align-items:center;gap:8px;min-width:170px">
                                            <div class="v2-bar" style="flex:1;height:6px">
                                                <div class="v2-bar-fill v2-bar-fill-@status" style="width:@($"{capPct:F0}")%"></div>
                                            </div>
                                            <span class="v2-hint" style="white-space:nowrap;@(capOver ? "color:var(--v2-danger)" : "")">@($"{r.RemainingHours:F0}/{CapacityPerMemberHours:F0}h")</span>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else if (ActiveTab == "epics")
        {
            <!-- ── Filters ─────────────────────────────────────────────────────── -->
            <div class="v2-section" style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:14px">
                <select class="v2-select" style="min-width:240px" @bind="_epicsFilterKey">
                    <option value="">All Epics</option>
                    @foreach (var e in EpicRows.OrderBy(e => e.Name))
                    {
                        <option value="@e.Key">@(e.Name == "No Epic" ? e.Key : $"{e.Key} — {e.Name}")</option>
                    }
                </select>
                <select class="v2-select" style="min-width:200px" @bind="_epicsFilterMember">
                    <option value="">All Team Members</option>
                    @foreach (var m in EpicRows.SelectMany(e => e.Issues)
                                               .Where(i => !string.IsNullOrWhiteSpace(i.Assignee) && i.Assignee != "Unassigned")
                                               .Select(i => i.Assignee)
                                               .Distinct()
                                               .OrderBy(n => n))
                    {
                        <option value="@m">@m</option>
                    }
                </select>
                @if (!string.IsNullOrEmpty(_epicsFilterKey) || !string.IsNullOrEmpty(_epicsFilterMember))
                {
                    <button class="v2-btn v2-btn-ghost" @onclick="ClearEpicsFilters">Clear</button>
                }
                <span class="v2-hint" style="margin-left:auto">
                    @FilteredEpicRows.Count of @EpicRows.Count epic@(EpicRows.Count == 1 ? "" : "s")
                </span>
                <button class="v2-btn v2-btn-ghost" @onclick="ExportEpicsToXlsxAsync"
                        disabled="@(EpicRows.Count == 0)" title="Export all sprint epics to Excel">
                    <i class="bi bi-file-earmark-spreadsheet"></i> Export .xlsx
                </button>
            </div>

            @if (!FilteredEpicRows.Any())
            {
                <div class="v2-empty">
                    <div class="v2-empty-icon"><i class="bi bi-funnel"></i></div>
                    <div class="v2-empty-title">No epics match the current filters</div>
                    <div>Try clearing them to see all epics.</div>
                </div>
            }
            <div style="display:flex;flex-direction:column;gap:16px">
                @foreach (var ep in FilteredEpicRows.OrderByDescending(e => e.InProgress + e.ToDo).ThenByDescending(e => e.Total))
                {
                    var donePct        = ep.Total > 0 ? ep.Done * 100 / ep.Total : 0;
                    var taskList       = ep.Issues.Where(i => !string.Equals(i.IssueType, "Bug", StringComparison.OrdinalIgnoreCase)).ToList();
                    var bugList        = ep.Issues.Where(i =>  string.Equals(i.IssueType, "Bug", StringComparison.OrdinalIgnoreCase)).ToList();
                    var bugTotal       = bugList.Count;
                    var bugOpen        = bugList.Count(i => i.StatusCategoryKey != "done");
                    var staleCnt       = ep.Issues.Count(i => i.StatusCategoryKey == "indeterminate" && i.DaysSinceLastWorklog >= 2);
                    var blockedCnt     = ep.Issues.Count(i => IsBlocked(i));
                    var unestCnt       = ep.Issues.Count(i => i.OriginalEstimateSeconds == 0 && i.StatusCategoryKey != "done");

                    // Per-type breakdown
                    var taskDone    = taskList.Count(i => i.StatusCategoryKey == "done");
                    var taskActive  = taskList.Count(i => i.StatusCategoryKey == "indeterminate");
                    var taskToDo    = taskList.Count(i => i.StatusCategoryKey == "new");
                    var taskStale   = taskList.Count(i => i.StatusCategoryKey == "indeterminate" && i.DaysSinceLastWorklog >= 2);
                    var taskUnest   = taskList.Count(i => i.OriginalEstimateSeconds == 0 && i.StatusCategoryKey != "done");
                    var taskBlocked = taskList.Count(IsBlocked);
                    var bugDone     = bugList.Count(i => i.StatusCategoryKey == "done");
                    var bugActive   = bugList.Count(i => i.StatusCategoryKey == "indeterminate");
                    var bugToDo     = bugList.Count(i => i.StatusCategoryKey == "new");
                    var bugStale    = bugList.Count(i => i.StatusCategoryKey == "indeterminate" && i.DaysSinceLastWorklog >= 2);
                    var bugUnest    = bugList.Count(i => i.OriginalEstimateSeconds == 0 && i.StatusCategoryKey != "done");
                    var bugBlocked  = bugList.Count(IsBlocked);
                    var burnPct        = ep.EstimateHours > 0 ? Math.Min(100, (int)Math.Round(ep.LoggedHours / ep.EstimateHours * 100)) : 0;
                    var overBudget     = ep.EstimateHours > 0 && ep.LoggedHours > ep.EstimateHours;
                    var topAssignees   = ep.Issues.Where(i => !string.IsNullOrWhiteSpace(i.Assignee) && i.Assignee != "Unassigned")
                                                  .GroupBy(i => i.Assignee).OrderByDescending(g => g.Count()).Take(3).ToList();
                    var epicHealth     = bugOpen > 0 ? "warn" : (staleCnt > 0 || blockedCnt > 0 ? "warn" : "success");
                    var donutColor     = epicHealth == "warn" ? "#f59e0b" : "#10b981";
                    var isExpanded     = ExpandedEpics.Contains(ep.Key);
                    var hasFullEpic    = ep.Key != "—" && !string.IsNullOrEmpty(ep.Key);
                    <div class="v2-card v2-card-epic">
                        <div style="display:flex;align-items:flex-start;gap:12px;margin-bottom:8px">
                            <div class="v2-donut" style="--p:@donePct;--c1:@donutColor">
                                <span>@donePct%</span>
                            </div>
                            <div style="flex:1;min-width:0">
                                <div style="display:flex;align-items:center;gap:8px;margin-bottom:2px">
                                    <div style="font-weight:700;font-size:14px" class="v2-truncate">@ep.Name</div>
                                    @if (overBudget) { <span class="v2-pill v2-pill-danger" style="font-size:10px;padding:1px 6px">Over budget</span> }
                                    else if (epicHealth == "warn") { <span class="v2-pill v2-pill-warn" style="font-size:10px;padding:1px 6px">Watch</span> }
                                    else { <span class="v2-pill v2-pill-success" style="font-size:10px;padding:1px 6px">Healthy</span> }
                                </div>
                                <div class="v2-hint">@ep.Key · @ep.Total task@(ep.Total == 1 ? "" : "s")</div>

                                <!-- TASKS row -->
                                <div style="margin-top:10px">
                                    <div style="font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--v2-ink-3);margin-bottom:4px">
                                        <i class="bi bi-list-check" style="margin-right:3px"></i>Tasks · @taskList.Count
                                    </div>
                                    <div style="display:flex;gap:6px;flex-wrap:wrap">
                                        <span class="v2-pill v2-pill-success">@taskDone done</span>
                                        <span class="v2-pill v2-pill-brand">@taskActive active</span>
                                        <span class="v2-pill v2-pill-neutral">@taskToDo to do</span>
                                        @if (taskBlocked > 0)
                                        {
                                            <span class="v2-pill v2-pill-danger" title="blocked tasks"><i class="bi bi-slash-circle" style="margin-right:3px"></i>@taskBlocked blocked</span>
                                        }
                                        @if (taskStale > 0)
                                        {
                                            <span class="v2-pill v2-pill-warn" title="active tasks with no log 2d+"><i class="bi bi-hourglass-split" style="margin-right:3px"></i>@taskStale stale</span>
                                        }
                                        @if (taskUnest > 0)
                                        {
                                            <span class="v2-pill v2-pill-warn" title="unestimated tasks"><i class="bi bi-question-circle" style="margin-right:3px"></i>@taskUnest unest.</span>
                                        }
                                    </div>
                                </div>

                                <!-- BUGS row -->
                                @if (bugTotal > 0)
                                {
                                    <div style="margin-top:8px">
                                        <div style="font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--v2-danger);margin-bottom:4px">
                                            <i class="bi bi-bug" style="margin-right:3px"></i>Bugs · @bugTotal @(bugOpen > 0 ? $"({bugOpen} open)" : "")
                                        </div>
                                        <div style="display:flex;gap:6px;flex-wrap:wrap">
                                            <span class="v2-pill v2-pill-success">@bugDone done</span>
                                            <span class="v2-pill v2-pill-brand">@bugActive active</span>
                                            <span class="v2-pill v2-pill-neutral">@bugToDo to do</span>
                                            @if (bugBlocked > 0)
                                            {
                                                <span class="v2-pill v2-pill-danger" title="blocked bugs"><i class="bi bi-slash-circle" style="margin-right:3px"></i>@bugBlocked blocked</span>
                                            }
                                            @if (bugStale > 0)
                                            {
                                                <span class="v2-pill v2-pill-warn" title="active bugs with no log 2d+"><i class="bi bi-hourglass-split" style="margin-right:3px"></i>@bugStale stale</span>
                                            }
                                            @if (bugUnest > 0)
                                            {
                                                <span class="v2-pill v2-pill-warn" title="unestimated bugs"><i class="bi bi-question-circle" style="margin-right:3px"></i>@bugUnest unest.</span>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                            <!-- Full Epic donut (right side) -->
                            @if (ep.Key != "—" && !string.IsNullOrEmpty(ep.Key))
                            {
                                <div style="display:flex;flex-direction:column;align-items:center;gap:3px;flex-shrink:0">
                                    @if (_fullEpicStats.TryGetValue(ep.Key, out var fullRight))
                                    {
                                        var fullRightPct = fullRight.Total > 0 ? fullRight.Done * 100 / fullRight.Total : 0;
                                        <div class="v2-donut" style="--p:@fullRightPct;--c1:#6366f1" title="Full Epic: @fullRight.Done / @fullRight.Total tasks done">
                                            <span>@fullRightPct%</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="v2-donut" style="--p:0;--c1:#6366f1;opacity:0.3">
                                            <span style="opacity:0.5">…</span>
                                        </div>
                                    }
                                    <span style="font-size:9px;font-weight:600;letter-spacing:.05em;text-transform:uppercase;color:var(--v2-ink-3)">Full Epic</span>
                                </div>
                            }
                        </div>

                        <!-- Status mix bar -->
                        <div class="v2-bar-stack" style="height:8px">
                            <span style="width:@(ep.Total > 0 ? ep.Done * 100 / ep.Total : 0)%; background:var(--v2-success-grad)" title="Done @ep.Done"></span>
                            <span style="width:@(ep.Total > 0 ? ep.InProgress * 100 / ep.Total : 0)%; background:var(--v2-brand-grad)" title="Active @ep.InProgress"></span>
                            <span style="width:@(ep.Total > 0 ? ep.ToDo * 100 / ep.Total : 0)%; background: linear-gradient(90deg,#94a3b8,#64748b)" title="To do @ep.ToDo"></span>
                        </div>

                        <!-- Committed Date & Customers -->
                        @if (ep.Key != "—" && !string.IsNullOrEmpty(ep.Key) && _epicMeta.TryGetValue(ep.Key, out var meta))
                        {
                            @if (meta.CommittedDate.HasValue || !string.IsNullOrEmpty(meta.CommittedCustomers))
                            {
                                <div style="display:flex;flex-wrap:wrap;gap:6px 16px;margin-top:8px;font-size:11px">
                                    @if (meta.CommittedDate.HasValue)
                                    {
                                        var isOverdue = meta.CommittedDate.Value.Date < DateTime.Today;
                                        <div style="display:flex;align-items:center;gap:5px">
                                            <i class="bi bi-calendar-check" style="color:var(--v2-ink-3)"></i>
                                            <span class="v2-hint">Committed</span>
                                            <span style="font-weight:600;color:@(isOverdue ? "var(--v2-danger)" : "var(--v2-ink-1)")">
                                                @meta.CommittedDate.Value.ToString("d MMM yyyy")
                                            </span>
                                            @if (isOverdue)
                                            {
                                                <span class="v2-pill v2-pill-danger" style="font-size:9px;padding:1px 5px">overdue</span>
                                            }
                                        </div>
                                    }
                                    @if (!string.IsNullOrEmpty(meta.CommittedCustomers))
                                    {
                                        <div style="display:flex;align-items:center;gap:5px;flex-wrap:wrap">
                                            <i class="bi bi-person-check" style="color:var(--v2-ink-3)"></i>
                                            @foreach (var cust in meta.CommittedCustomers.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                                            {
                                                <span class="v2-pill v2-pill-neutral" style="font-size:10px">@cust</span>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        }

                        <div class="v2-divider" style="margin:8px 0"></div>

                        <!-- Hours blocks — Sprint & Full Epic side by side -->
                        <div class="@(hasFullEpic ? "v2-hours-grid" : "")">
                            <!-- Sprint slice -->
                            <div>
                                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px">
                                    <div style="font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--v2-brand)">
                                        <i class="bi bi-flag-fill" style="margin-right:3px"></i>Sprint
                                    </div>
                                    <span class="v2-hint" style="font-size:10px">@ep.Total task@(ep.Total == 1 ? "" : "s") in scope</span>
                                </div>
                                <div class="v2-row"><span class="v2-row-label">Estimated</span><span class="v2-row-value">@($"{ep.EstimateHours:F0}h")</span></div>
                                <div class="v2-row"><span class="v2-row-label">Logged</span><span class="v2-row-value">@($"{ep.LoggedHours:F0}h")</span></div>
                                <div class="v2-bar" style="margin:3px 0 5px;height:6px">
                                    <div class="v2-bar-fill @(overBudget ? "v2-bar-fill-danger" : "v2-bar-fill-neutral")" style="width:@burnPct%"></div>
                                </div>
                                <div class="v2-row"><span class="v2-row-label">Remaining</span><span class="v2-row-value">@($"{ep.RemainingHours:F0}h")</span></div>
                            </div>

                            <!-- Full Epic (all sprints, auto-loaded) -->
                            @if (hasFullEpic)
                            {
                                <div>
                                    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px">
                                        <div style="font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--v2-ink-3)">
                                            <i class="bi bi-collection" style="margin-right:3px"></i>Full Epic
                                        </div>
                                        @if (_fullEpicStats.TryGetValue(ep.Key, out var fullForLabel))
                                        {
                                            <span class="v2-hint" style="font-size:10px">@fullForLabel.Total task@(fullForLabel.Total == 1 ? "" : "s") · all sprints</span>
                                        }
                                    </div>
                                    @if (_fullEpicStats.TryGetValue(ep.Key, out var full))
                                    {
                                        var fullBurn       = full.EstimateHours > 0 ? Math.Min(100, (int)Math.Round(full.LoggedHours / full.EstimateHours * 100)) : 0;
                                        var fullOverBudget = full.EstimateHours > 0 && full.LoggedHours > full.EstimateHours;
                                        var fullDonePct    = full.Total > 0 ? full.Done * 100 / full.Total : 0;
                                        <div class="v2-row"><span class="v2-row-label">Estimated</span><span class="v2-row-value">@($"{full.EstimateHours:F0}h")</span></div>
                                        <div class="v2-row"><span class="v2-row-label">Logged</span><span class="v2-row-value">@($"{full.LoggedHours:F0}h")</span></div>
                                        <div class="v2-bar" style="margin:3px 0 5px;height:6px">
                                            <div class="v2-bar-fill @(fullOverBudget ? "v2-bar-fill-danger" : "v2-bar-fill-neutral")" style="width:@fullBurn%"></div>
                                        </div>
                                        <div class="v2-row"><span class="v2-row-label">Remaining</span><span class="v2-row-value">@($"{full.RemainingHours:F0}h")</span></div>
                                        <div class="v2-row"><span class="v2-row-label">Completion</span><span class="v2-row-value">@full.Done / @full.Total (@fullDonePct%)</span></div>
                                    }
                                    else
                                    {
                                        <div class="v2-hint" style="padding:8px 0;text-align:center"><span class="v2-spin"></span> Loading…</div>
                                    }
                                </div>
                            }
                        </div>

                        <!-- Workload by member on this epic -->
                        @{
                            var epicMembers = EpicMembers(ep);
                        }
                        @if (epicMembers.Count > 0)
                        {
                            <div class="v2-divider"></div>
                            <div style="font-size:11px;font-weight:600;color:var(--v2-ink-3);margin-bottom:6px">
                                <i class="bi bi-people"></i> Workload by member
                                <span style="font-weight:400;opacity:.7">— logged & remaining on this epic, plus whether their total sprint workload fits the @($"{CapacityPerMemberHours:F0}h") of capacity left</span>
                            </div>
                            <div class="v2-table-wrap" style="margin:0">
                                <table class="v2-table" style="font-size:11.5px">
                                    <thead>
                                        <tr>
                                            <th>Member</th>
                                            <th class="v2-table-num">Tasks</th>
                                            <th class="v2-table-num" title="Hours logged on this epic">Logged</th>
                                            <th class="v2-table-num" title="Hours remaining on this epic">Remaining</th>
                                            <th class="v2-table-num" title="Their total remaining work (all epics) ÷ sprint capacity left">Workload</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var r in epicMembers)
                                        {
                                            var loadPct = r.Capacity > 0 ? r.TotalRemaining / r.Capacity * 100 : 0;
                                            string verdict;
                                            string pillClass;
                                            if (r.EpicRemaining == 0 && r.Done == r.Tasks)     { verdict = "Complete";  pillClass = "v2-pill-success"; }
                                            else if (r.Capacity <= 0)                          { verdict = "No time left"; pillClass = "v2-pill-danger"; }
                                            else if (r.TotalRemaining > r.Capacity * 1.2)      { verdict = "Won't fit";  pillClass = "v2-pill-danger"; }
                                            else if (r.TotalRemaining > r.Capacity)            { verdict = "At risk";    pillClass = "v2-pill-warn";    }
                                            else                                                { verdict = "On track";   pillClass = "v2-pill-success"; }
                                            <tr>
                                                <td>
                                                    <div style="display:flex;align-items:center;gap:6px">
                                                        <span class="v2-avatar v2-avatar-sm @($"v2-avatar-grad-{1 + (Math.Abs(r.Name.GetHashCode()) % 5)}")">@Initials(r.Name)</span>
                                                        <span class="v2-truncate" style="max-width:120px;font-weight:600" title="@r.Name">@r.Name</span>
                                                    </div>
                                                </td>
                                                <td class="v2-table-num">@r.Done/@r.Tasks</td>
                                                <td class="v2-table-num">@($"{r.Logged:F1}h")</td>
                                                <td class="v2-table-num">@($"{r.EpicRemaining:F1}h")</td>
                                                <td class="v2-table-num">
                                                    <div style="display:flex;align-items:center;gap:6px;justify-content:flex-end" title="@($"{r.TotalRemaining:F1}h") remaining across all epics / @($"{r.Capacity:F0}h") capacity left in sprint">
                                                        <div class="v2-bar" style="width:60px;height:5px">
                                                            <div class="v2-bar-fill @(loadPct > 120 ? "v2-bar-fill-danger" : loadPct > 100 ? "v2-bar-fill-warn" : "v2-bar-fill-success")"
                                                                 style="width:@Math.Min(loadPct, 100)%"></div>
                                                        </div>
                                                        <span style="min-width:42px;text-align:right">@($"{loadPct:F0}%")</span>
                                                    </div>
                                                </td>
                                                <td><span class="v2-pill @pillClass" style="font-size:10px;padding:1px 6px">@verdict</span></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }

                        <!-- Tasks toggle -->
                        <button class="v2-btn v2-btn-ghost" style="margin-top:10px;width:100%;justify-content:center" @onclick="() => ToggleEpic(ep.Key)">
                            <i class="bi @(isExpanded ? "bi-chevron-up" : "bi-chevron-down")"></i>
                            <span>@(isExpanded ? "Hide" : "Show") @ep.Total task@(ep.Total == 1 ? "" : "s")</span>
                        </button>

                        @if (isExpanded)
                        {
                            <div class="v2-table-wrap" style="margin-top:8px">
                                <table class="v2-table">
                                    <thead>
                                        <tr>
                                            <th class="@SI("Key", _sortET, _ascET)" @onclick='() => SortET("Key")'>Key</th>
                                            @* <th class="@SI("Summary", _sortET, _ascET)" @onclick='() => SortET("Summary")'>Summary</th> *@
                                            <th class="@SI("Type", _sortET, _ascET)" @onclick='() => SortET("Type")'>Type</th>
                                            <th class="@SI("Status", _sortET, _ascET)" @onclick='() => SortET("Status")'>Status</th>
                                            <th class="@SI("Assignee", _sortET, _ascET)" @onclick='() => SortET("Assignee")'>Assignee</th>
                                            <th class="v2-table-num @SI("Rem", _sortET, _ascET)" @onclick='() => SortET("Rem")'>Rem.</th>
                                            <th class="v2-table-num @SI("Pct", _sortET, _ascET)" @onclick='() => SortET("Pct")'>% Done</th>
                                            <th class="@SI("Last", _sortET, _ascET)" @onclick='() => SortET("Last")'>Last log</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var i in ApplySortET(ep.Issues))
                                        {
                                            var pct = IssuePercentDone(i);
                                            var lastLog = i.Worklogs.Any() ? i.Worklogs.Max(w => w.Started) : (DateTime?)null;
                                            var sc = StatusColor(i);
                                            <tr class="@(i.StatusCategoryKey == "done" ? "is-done" : "")"
                                                style="background:@sc.bg;border-left:3px solid @sc.border">
                                                <td class="v2-table-key"><a href="@JiraBase/browse/@i.Key" target="_blank" title="@i.Summary" class="v2-key-link">@i.Key</a></td>
                                                @* <td class="v2-truncate" style="max-width:340px" title="@i.Summary">@i.Summary</td> *@
                                                <td><span class="v2-chip v2-chip-@i.IssueType.ToLower()">@i.IssueType</span></td>
                                                <td><span class="v2-pill" style="font-size:10px;padding:1px 6px;background:@sc.bg;color:@sc.border;border:1px solid @sc.border">@i.Status</span></td>
                                                <td class="v2-truncate" style="max-width:140px">@i.Assignee</td>
                                                <td class="v2-table-num">@(i.OriginalEstimateSeconds == 0 ? "—" : FmtH(i.ComputedRemainingSeconds))</td>
                                                <td class="v2-table-num">@(pct.HasValue ? $"{pct.Value}%" : "—")</td>
                                                <td class="v2-hint">@(lastLog.HasValue ? lastLog.Value.ToString("MMM d") : "—")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                }
            </div>
        }
        else if (ActiveTab == "calendar")
        {
            var firstDay    = new DateTime(_calYear, _calMonth, 1);
            var daysInMonth = DateTime.DaysInMonth(_calYear, _calMonth);
            var startOffset = ((int)firstDay.DayOfWeek + 6) % 7;
            var totalCells  = startOffset + daysInMonth;
            var calRows     = (int)Math.Ceiling(totalCells / 7.0);
            var isCurMonth  = _calYear == DateTime.Today.Year && _calMonth == DateTime.Today.Month;
            var epicsByDay  = EpicsWithCommittedDate
                .Where(e => e.Committed.Year == _calYear && e.Committed.Month == _calMonth)
                .GroupBy(e => e.Committed.Day)
                .ToDictionary(g => g.Key, g => g.ToList());
            var monthTotal  = epicsByDay.Values.Sum(l => l.Count);

            <div class="v2-card v2-card-lg v2-cal-root">
                <div class="v2-section-title">
                    <i class="bi bi-calendar3" style="color:var(--v2-brand)"></i>
                    Epic Committed Dates
                    <span class="v2-section-note">epics plotted on their committed delivery date</span>
                </div>
                <div class="v2-cal-header">
                    <button class="v2-btn v2-btn-ghost v2-cal-nav" @onclick="CalPrevMonth">&#8249;</button>
                    <span class="v2-cal-month-label">@firstDay.ToString("MMMM yyyy")</span>
                    <button class="v2-btn v2-btn-ghost v2-cal-nav" @onclick="CalNextMonth">&#8250;</button>
                    @if (monthTotal > 0)
                    {
                        <span class="v2-cal-badge">@monthTotal epic@(monthTotal == 1 ? "" : "s") committed</span>
                    }
                    else
                    {
                        <span class="v2-cal-empty-month">No epics committed in this month</span>
                    }
                    <span class="v2-hint" style="margin-left:auto">@EpicsWithCommittedDate.Count with a committed date</span>
                </div>
                <div class="v2-cal-grid-wrap">
                    <table class="v2-cal-table">
                        <thead>
                            <tr>
                                @foreach (var dow in new[] { "Mon","Tue","Wed","Thu","Fri","Sat","Sun" })
                                {
                                    <th class="v2-cal-th">@dow</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @for (int r = 0; r < calRows; r++)
                            {
                                <tr>
                                    @for (int c = 0; c < 7; c++)
                                    {
                                        var idx       = r * 7 + c;
                                        var dayNum    = idx - startOffset + 1;
                                        var isValid   = dayNum >= 1 && dayNum <= daysInMonth;
                                        var isToday   = isValid && isCurMonth && dayNum == DateTime.Today.Day;
                                        var isWeekend = c >= 5;
                                        var dayEpics  = isValid && epicsByDay.TryGetValue(dayNum, out var de) ? de : new List<EpicCalItem>();

                                        <td class="v2-cal-cell @(!isValid ? "v2-cal-blank" : "") @(isWeekend ? "v2-cal-weekend" : "") @(isToday ? "v2-cal-today" : "")">
                                            @if (isValid)
                                            {
                                                <div class="v2-cal-daynum @(isToday ? "v2-cal-daynum-today" : "")">@dayNum</div>
                                                @foreach (var ep in dayEpics.OrderBy(e => EpicCalState(e)).ThenBy(e => e.Key))
                                                {
                                                    var state = EpicCalState(ep);
                                                    var pct   = ep.Total > 0 ? ep.Done * 100 / ep.Total : 0;
                                                    var committedStr = ep.Committed.ToString("d MMM yyyy");
                                                    <a class="v2-cal-chip v2-cal-chip-@state"
                                                       href="@JiraBase/browse/@ep.Key" target="_blank" rel="noopener noreferrer"
                                                       title="@ep.Key — @ep.Name&#10;@ep.Done/@ep.Total done (@pct%)&#10;Committed: @committedStr">
                                                        <span class="v2-cal-chip-key">@ep.Key</span>
                                                        <span class="v2-cal-chip-sum">@(ep.Name.Length > 28 ? ep.Name[..28] + "…" : ep.Name)</span>
                                                    </a>
                                                }
                                            }
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div style="display:flex;gap:16px;margin-top:12px;font-size:11px;color:var(--v2-ink-3)">
                    <span><span class="v2-dot" style="background:#16a34a;margin-right:4px"></span>Complete</span>
                    <span><span class="v2-dot" style="background:var(--v2-brand);margin-right:4px"></span>Upcoming / in progress</span>
                    <span><span class="v2-dot" style="background:var(--v2-danger);margin-right:4px"></span>Past committed date, not done</span>
                </div>
            </div>
        }
        else if (ActiveTab == "members")
        {
            <!-- Member-level tracking: grouped by member, then by epic -->

            <!-- Risk metric strip (ticket-focused) -->
            <div class="v2-grid-4">
                <div class="v2-risk-card @(OnHoldTicketsCount > 0 ? "v2-risk-card-warn" : "v2-risk-card-success")">
                    <div class="v2-risk-num">@OnHoldTicketsCount</div>
                    <div class="v2-risk-lbl">On Hold</div>
                    <div class="v2-hint" style="margin-top:2px">tickets paused / blocked</div>
                </div>
                <div class="v2-risk-card @(IdleActiveCount > 0 ? "v2-risk-card-warn" : "v2-risk-card-success")">
                    <div class="v2-risk-num">@IdleActiveCount</div>
                    <div class="v2-risk-lbl">In progress, idle 24h+</div>
                    <div class="v2-hint" style="margin-top:2px">@StaleCount stuck 2d+</div>
                </div>
                <div class="v2-risk-card @(NeverLoggedCount > 0 ? "v2-risk-card-danger" : "v2-risk-card-success")">
                    <div class="v2-risk-num">@NeverLoggedCount</div>
                    <div class="v2-risk-lbl">Never logged</div>
                    <div class="v2-hint" style="margin-top:2px">no worklog entries at all</div>
                </div>
                <div class="v2-risk-card @(MemberRows.Count(m => m.HealthBand == "danger") > 0 ? "v2-risk-card-danger" : "v2-risk-card-success")">
                    <div class="v2-risk-num">@MemberRows.Count(m => m.HealthBand == "danger")</div>
                    <div class="v2-risk-lbl">Compromised members</div>
                    <div class="v2-hint" style="margin-top:2px">@MemberRows.Count(m => m.HealthBand == "warn") at risk · @MemberRows.Count(m => m.HealthBand == "success") healthy</div>
                </div>
            </div>

            <!-- ── Epics Worked per Member chart ─────────────────────────────── -->
            <div class="v2-section v2-mt-lg">
                <div class="v2-section-title">
                    <i class="bi bi-collection" style="color:var(--v2-brand)"></i>Epics Worked by Member
                    <span class="v2-hint" style="margin-left:8px;font-weight:400">distinct epics each member actually logged work on — by worklog author, not current assignee</span>
                </div>
                <div class="v2-card v2-card-lg">
                    @{
                        var epicsByMember = EpicsWorkedByMember;
                        var maxEpics = epicsByMember.Select(x => x.Epics.Count).DefaultIfEmpty(1).Max();
                        if (maxEpics < 1) maxEpics = 1;
                    }
                    @if (!epicsByMember.Any())
                    {
                        <div class="v2-text-muted" style="padding:24px 0;text-align:center">
                            No members have logged work on epic-linked tasks in this sprint.
                        </div>
                    }
                    else
                    {
                        @foreach (var r in epicsByMember)
                        {
                            var tooltip = string.Join(" · ",
                                r.Epics.Select(e => $"{e.Key} — {e.Name} ({e.Done}/{e.Tasks})"));
                            var fillClass = r.Epics.Count >= 5 ? "v2-bar-fill-warn"
                                          : r.Epics.Count >= 3 ? "v2-bar-fill"
                                          : "v2-bar-fill-success";
                            <div style="display:flex;align-items:center;gap:12px;margin-bottom:10px" title="@tooltip">
                                <div style="display:flex;align-items:center;gap:8px;min-width:200px;max-width:200px">
                                    <span class="v2-avatar v2-avatar-sm @($"v2-avatar-grad-{1 + (Math.Abs(r.Name.GetHashCode()) % 5)}")">@Initials(r.Name)</span>
                                    <span style="font-weight:600;font-size:13px" class="v2-truncate">@r.Name</span>
                                </div>
                                <div class="v2-bar" style="flex:1;height:16px">
                                    <div class="v2-bar-fill @fillClass" style="width:@((double)r.Epics.Count / maxEpics * 100)%"></div>
                                </div>
                                <div style="min-width:90px;text-align:right">
                                    <strong style="font-size:16px">@r.Epics.Count</strong>
                                    <span class="v2-hint" style="margin-left:2px">epic@(r.Epics.Count == 1 ? "" : "s")</span>
                                </div>
                            </div>
                            <!-- Epic chips -->
                            <div style="display:flex;flex-wrap:wrap;gap:4px;margin:-4px 0 14px 212px">
                                @foreach (var e in r.Epics)
                                {
                                    var donePct = e.Tasks > 0 ? (int)Math.Round(e.Done * 100.0 / e.Tasks) : 0;
                                    var pillClass = donePct == 100 ? "v2-pill-success"
                                                  : donePct >= 50  ? "v2-pill-brand"
                                                  : "v2-pill-neutral";
                                    <span class="v2-pill @pillClass" style="font-size:10px;padding:1px 6px"
                                          title="@e.Key — @e.Name · @e.Done of @e.Tasks done">
                                        @(e.Name.Length > 28 ? e.Name[..28] + "…" : e.Name) · @e.Done/@e.Tasks
                                    </span>
                                }
                            </div>
                        }
                    }
                </div>
            </div>

            <div class="v2-section v2-mt-lg" style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
                <input class="v2-input" style="max-width:240px" placeholder="Filter members…" @bind="MembersSearch" @bind:event="oninput" />
                <select class="v2-select" @bind="MembersFilterStatus">
                    <option value="">All Statuses</option>
                    @foreach (var s in ActiveIssues.Select(i => i.Status).Where(s => !string.IsNullOrEmpty(s)).Distinct().OrderBy(s => s))
                    {
                        <option value="@s">@s</option>
                    }
                </select>
                <select class="v2-select" @bind="MembersFilterEpic">
                    <option value="">All Epics</option>
                    @foreach (var e in ActiveIssues.GroupBy(i => string.IsNullOrEmpty(i.EpicKey) ? "—" : i.EpicKey)
                                                    .OrderBy(g => g.Key))
                    {
                        var name = e.First().EpicName;
                        <option value="@e.Key">@(string.IsNullOrEmpty(name) || name == "No Epic" ? e.Key : $"{e.Key} — {name}")</option>
                    }
                </select>
                <select class="v2-select" @bind="MembersFilterType">
                    <option value="">All Types</option>
                    @foreach (var t in ActiveIssues.Select(i => i.IssueType).Where(t => !string.IsNullOrEmpty(t)).Distinct().OrderBy(t => t))
                    {
                        <option value="@t">@t</option>
                    }
                </select>
                <select class="v2-select" @bind="MembersFilterHealth">
                    <option value="">All Health</option>
                    <option value="danger">Compromised</option>
                    <option value="warn">At Risk</option>
                    <option value="success">On Track</option>
                </select>
                <label style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--v2-ink-3)">
                    <input type="checkbox" @bind="MembersHideEmpty" /> Hide empty members
                </label>
                @if (HasMemberFilters)
                {
                    <button class="v2-btn v2-btn-ghost" @onclick="ClearMemberFilters">Clear</button>
                }
                <span class="v2-hint" style="margin-left:auto">
                    @FilteredMemberRows.Count of @MemberRows.Count member@(MemberRows.Count == 1 ? "" : "s") · sprint capacity @($"{CapacityPerMemberHours:F0}h") each
                </span>
            </div>

            <!-- Per-member cards -->
            @foreach (var m in FilteredMemberRows)
            {
                var capPct = CapacityPerMemberHours > 0 ? Math.Min(m.RemainingHours / CapacityPerMemberHours * 100, 100) : 0;
                var capOver = m.RemainingHours > CapacityPerMemberHours;
                var verdict = m.HealthBand switch { "success" => "On Track", "warn" => "At Risk", _ => "Compromised" };
                <div class="v2-card v2-card-lg v2-mt-lg">
                    <div style="display:flex;align-items:center;gap:14px;margin-bottom:14px;flex-wrap:wrap">
                        <div class="v2-avatar v2-avatar-lg @($"v2-avatar-grad-{1 + (Math.Abs(m.Name.GetHashCode()) % 5)}")">@Initials(m.Name)</div>
                        <div style="flex:1;min-width:200px">
                            <div style="font-weight:700;font-size:16px">@m.Name</div>
                            <div class="v2-hint">@m.Total task@(m.Total == 1 ? "" : "s") · @m.Done done · @m.InProgress active · @m.ToDo pending</div>
                        </div>
                        <span class="v2-pill v2-pill-@m.HealthBand" style="font-weight:700">@verdict</span>
                    </div>

                    <!-- Member KPI row -->
                    <div class="v2-grid-4" style="gap:10px;margin-bottom:14px">
                        <div class="v2-row" style="flex-direction:column;align-items:flex-start;padding:8px 12px;background:var(--v2-surface-2);border-radius:8px">
                            <span class="v2-row-label">Completion</span>
                            <span class="v2-num-lg" style="font-size:20px;color:var(--v2-success)">@($"{m.CompletionPct:F0}%")</span>
                            <div class="v2-bar" style="height:5px;width:100%;margin-top:4px">
                                <div class="v2-bar-fill v2-bar-fill-success" style="width:@($"{m.CompletionPct:F0}")%"></div>
                            </div>
                        </div>
                        <div class="v2-row" style="flex-direction:column;align-items:flex-start;padding:8px 12px;background:var(--v2-surface-2);border-radius:8px">
                            <span class="v2-row-label">Capacity</span>
                            <span class="v2-num-lg @(capOver ? "v2-text-danger" : "")" style="font-size:20px">@($"{m.RemainingHours:F0}h / {CapacityPerMemberHours:F0}h")</span>
                            <div class="v2-bar" style="height:5px;width:100%;margin-top:4px">
                                <div class="v2-bar-fill @(capOver ? "v2-bar-fill-danger" : capPct > 80 ? "v2-bar-fill-warn" : "v2-bar-fill-success")"
                                     style="width:@($"{capPct:F0}")%"></div>
                            </div>
                        </div>
                        <div class="v2-row" style="flex-direction:column;align-items:flex-start;padding:8px 12px;background:var(--v2-surface-2);border-radius:8px">
                            <span class="v2-row-label">Logged (sprint / 7d)</span>
                            <span class="v2-num-lg" style="font-size:20px">@($"{m.HoursLogged:F0}h")</span>
                            <span class="v2-hint">@($"{m.HoursLogged7d:F0}h") last 7d</span>
                        </div>
                        <div class="v2-row" style="flex-direction:column;align-items:flex-start;padding:8px 12px;background:var(--v2-surface-2);border-radius:8px">
                            <span class="v2-row-label">Risk signals</span>
                            <div style="display:flex;flex-wrap:wrap;gap:4px;margin-top:4px">
                                @if (m.BlockedCount > 0) { <span class="v2-pill v2-pill-danger" style="font-size:10px;padding:1px 6px">@m.BlockedCount blocked</span> }
                                @if (m.IdleActiveCount > 0) { <span class="v2-pill v2-pill-warn" style="font-size:10px;padding:1px 6px">@m.IdleActiveCount idle 24h+</span> }
                                @if (m.InfeasibleCount > 0) { <span class="v2-pill v2-pill-danger" style="font-size:10px;padding:1px 6px">@m.InfeasibleCount won't fit</span> }
                                @if (m.UnestimatedCount > 0) { <span class="v2-pill v2-pill-warn" style="font-size:10px;padding:1px 6px">@m.UnestimatedCount unestimated</span> }
                                @if (m.BlockedCount == 0 && m.IdleActiveCount == 0 && m.InfeasibleCount == 0 && m.UnestimatedCount == 0)
                                {
                                    <span class="v2-pill v2-pill-success" style="font-size:10px;padding:1px 6px">Clean</span>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Burn sparkline (last 14d hours/day) -->
                    @if (m.DailyHours.Count > 1)
                    {
                        <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px">
                            <span class="v2-hint" style="min-width:120px">Burn (last 14d)</span>
                            <div style="flex:1">@SparklineSvg(m.DailyHours, "#6366f1")</div>
                            <span class="v2-hint">avg @($"{(m.DailyHours.Count > 0 ? m.DailyHours.Average() : 0):F1}h/day")</span>
                        </div>
                    }

                    <!-- Tasks grouped by epic -->
                    @{
                        var memberTasks = FilteredTasksFor(m);
                    }
                    @if (memberTasks.Count == 0 && HasMemberFilters)
                    {
                        <div class="v2-hint" style="font-style:italic;padding:8px 0">No tasks match the active filters.</div>
                    }
                    @foreach (var grp in memberTasks
                        .GroupBy(i => string.IsNullOrEmpty(i.EpicKey) ? "—" : i.EpicKey)
                        .OrderByDescending(g => g.Sum(i => i.ComputedRemainingSeconds)))
                    {
                        var epicName = grp.First().EpicName;
                        var grpRem   = grp.Where(i => i.StatusCategoryKey != "done").Sum(i => i.ComputedRemainingSeconds);
                        var grpLog   = grp.Sum(i => MemberLoggedSeconds(m.Name, i));
                        <div style="margin-top:14px">
                            <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;padding:6px 10px;background:var(--v2-surface-2);border-radius:6px">
                                <i class="bi bi-collection" style="color:var(--v2-brand)"></i>
                                <span style="font-weight:700;font-size:13px">@(string.IsNullOrEmpty(epicName) || epicName == "No Epic" ? grp.Key : epicName)</span>
                                <span class="v2-hint">@grp.Key</span>
                                <span style="margin-left:auto" class="v2-hint">@grp.Count() task@(grp.Count() == 1 ? "" : "s") · @FmtH(grpLog) logged · @FmtH(grpRem) remaining</span>
                            </div>
                            <div class="v2-table-wrap">
                                <table class="v2-table">
                                    <thead>
                                        <tr>
                                            <th class="@SI("Key", _sortMT, _ascMT)" @onclick='() => SortMT("Key")'>Key</th>
                                            <th class="@SI("Summary", _sortMT, _ascMT)" @onclick='() => SortMT("Summary")'>Title</th>
                                            <th class="@SI("Status", _sortMT, _ascMT)" @onclick='() => SortMT("Status")'>Status</th>
                                            <th class="v2-table-num @SI("Orig", _sortMT, _ascMT)" @onclick='() => SortMT("Orig")'>Orig. Est.</th>
                                            <th class="v2-table-num @SI("Rem", _sortMT, _ascMT)" @onclick='() => SortMT("Rem")'>Remaining</th>
                                            <th class="v2-table-num @SI("Logged", _sortMT, _ascMT)" @onclick='() => SortMT("Logged")'>Time Logged</th>
                                            <th class="v2-table-num @SI("Pct", _sortMT, _ascMT)" @onclick='() => SortMT("Pct")'>% Done</th>
                                            <th>Feasible</th>
                                            <th class="@SI("Last", _sortMT, _ascMT)" @onclick='() => SortMT("Last")'>Last Activity</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var i in ApplySortMT(grp, m.Name))
                                        {
                                            var pct      = IssuePercentDone(i);
                                            var feasible = TaskFeasibility(i);
                                            var lastLog  = i.Worklogs.Any() ? i.Worklogs.Max(w => w.Started) : (DateTime?)null;
                                            var idle24   = i.StatusCategoryKey == "indeterminate" && i.DaysSinceLastWorklog >= 1;
                                            <tr class="@(i.StatusCategoryKey == "done" ? "is-done" : "")">
                                                <td class="v2-table-key"><a href="@JiraBase/browse/@i.Key" target="_blank" title="@i.Summary" class="v2-key-link">@i.Key</a></td>
                                                <td class="v2-truncate" style="max-width:280px" title="@i.Summary">@i.Summary</td>
                                                <td>
                                                    <span class="v2-pill v2-pill-@(i.StatusCategoryKey == "done" ? "success" : i.StatusCategoryKey == "indeterminate" ? "brand" : "neutral")" style="font-size:10px;padding:1px 6px">@i.Status</span>
                                                    @if (IsBlocked(i)) { <span class="v2-pill v2-pill-danger" style="font-size:10px;padding:1px 6px;margin-left:4px">blocked</span> }
                                                </td>
                                                <td class="v2-table-num">@FmtH(i.OriginalEstimateSeconds)</td>
                                                <td class="v2-table-num">@FmtH(i.ComputedRemainingSeconds)</td>
                                                <td class="v2-table-num" title="task total: @FmtH(i.TimeSpentSeconds)">@FmtH(MemberLoggedSeconds(m.Name, i))</td>
                                                <td class="v2-table-num">
                                                    <div style="display:flex;align-items:center;gap:6px;justify-content:flex-end">
                                                        <div class="v2-bar" style="width:60px;height:5px">
                                                            <div class="v2-bar-fill v2-bar-fill-success" style="width:@(pct ?? 0)%"></div>
                                                        </div>
                                                        <span style="min-width:34px;text-align:right">@(pct.HasValue ? $"{pct.Value}%" : "—")</span>
                                                    </div>
                                                </td>
                                                <td>
                                                    <span class="v2-pill v2-pill-@(feasible.band)" style="font-size:10px;padding:1px 6px" title="@feasible.reason">@feasible.label</span>
                                                </td>
                                                <td class="v2-hint">
                                                    @if (lastLog.HasValue)
                                                    {
                                                        <span class="@(idle24 ? "v2-text-danger" : "")">@lastLog.Value.ToString("MMM d, HH:mm") <span style="opacity:.7">(@i.DaysSinceLastWorklog d)</span></span>
                                                    }
                                                    else
                                                    {
                                                        <span class="v2-text-danger">never</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }
                </div>
            }
        }
        else if (ActiveTab == "scope")
        {
            @if (Report.StartDate == null)
            {
                <div class="v2-empty">
                    <div class="v2-empty-icon"><i class="bi bi-calendar-x"></i></div>
                    <div class="v2-empty-title">Sprint start date unknown</div>
                    <div>Scope churn requires a sprint start date — load via sprint ID for full data.</div>
                </div>
            }
            else
            {
                <!-- KPI strip -->
                <div class="v2-grid-4">
                    <div class="v2-risk-card v2-risk-card-warn">
                        <div class="v2-risk-num">@ScopeActiveIssues.Count</div>
                        <div class="v2-risk-lbl">Tasks Added</div>
                        <div class="v2-hint" style="margin-top:2px">@($"{ScopePctDisplay:F0}")% of sprint scope</div>
                        @if (_excludedScopeEpics.Count > 0)
                        {
                            <div class="v2-hint" style="opacity:.7">@_excludedScopeEpics.Count epic(s) excluded</div>
                        }
                        @if (ScopeActiveIssues.Count > 0)
                        {
                            <div style="margin-top:8px;display:flex;flex-wrap:wrap;gap:4px">
                                @foreach (var tg in ScopeActiveIssues
                                                        .GroupBy(i => string.IsNullOrEmpty(i.IssueType) ? "Unknown" : i.IssueType)
                                                        .OrderByDescending(g => g.Count()))
                                {
                                    var isBug = string.Equals(tg.Key, "Bug", StringComparison.OrdinalIgnoreCase);
                                    <span class="v2-pill @(isBug ? "v2-pill-danger" : "v2-pill-neutral")"
                                          style="font-size:10px;padding:1px 6px"
                                          title="@tg.Key: @tg.Count() of @ScopeActiveIssues.Count added">
                                        @tg.Key @tg.Count()
                                    </span>
                                }
                            </div>
                        }
                    </div>
                    <div class="v2-risk-card">
                        <div class="v2-risk-num">@FmtH(ScopeEstimateSec)</div>
                        <div class="v2-risk-lbl">Added Scope</div>
                        <div class="v2-hint" style="margin-top:2px">original estimate total</div>
                    </div>
                    <div class="v2-risk-card v2-risk-card-success">
                        <div class="v2-risk-num">@FmtH(ScopeLoggedSec)</div>
                        <div class="v2-risk-lbl">Time Logged</div>
                        <div class="v2-hint" style="margin-top:2px">on scope-added tasks</div>
                    </div>
                    <div class="v2-risk-card @(ScopeUnestimated > 0 ? "v2-risk-card-danger" : "v2-risk-card-success")">
                        <div class="v2-risk-num">@ScopeUnestimated</div>
                        <div class="v2-risk-lbl">Unestimated</div>
                        <div class="v2-hint" style="margin-top:2px">added with no estimate</div>
                    </div>
                </div>

                @if (!ScopeChangedIssues.Any())
                {
                    <div class="v2-empty v2-mt-lg">
                        <div class="v2-empty-icon" style="color:var(--v2-success)"><i class="bi bi-shield-check"></i></div>
                        <div class="v2-empty-title">No scope changes</div>
                        <div>No tasks were added after sprint start (@Report.StartDate.Value.ToString("dd MMM yyyy")) — scope is clean.</div>
                    </div>
                }
                else
                {
                    <!-- By Epic breakdown -->
                    <div class="v2-section v2-mt-lg">
                        <div class="v2-section-title"><i class="bi bi-collection"></i>Added Tasks by Epic</div>
                        <div class="v2-table-wrap">
                            <table class="v2-table">
                                <thead>
                                    <tr>
                                        <th style="width:36px"></th>
                                        <th class="@SI("Epic", _sortSCE, _ascSCE)" @onclick='() => SortSCE("Epic")'>Epic</th>
                                        <th class="v2-table-num @SI("Count", _sortSCE, _ascSCE)" @onclick='() => SortSCE("Count")'>Added</th>
                                        <th class="v2-table-num @SI("Done", _sortSCE, _ascSCE)" @onclick='() => SortSCE("Done")'>Done</th>
                                        <th class="v2-table-num @SI("Est", _sortSCE, _ascSCE)" @onclick='() => SortSCE("Est")'>Estimate</th>
                                        <th class="v2-table-num @SI("Log", _sortSCE, _ascSCE)" @onclick='() => SortSCE("Log")'>Logged</th>
                                        <th class="@SI("Added", _sortSCE, _ascSCE)" @onclick='() => SortSCE("Added")'>Added On</th>
                                        <th>Status Mix</th>
                                        <th>Type Mix</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var epic in ApplySortSCE(GetScopeByEpic()))
                                    {
                                        <tr style="@(_excludedScopeEpics.Contains(epic.EpicKey) ? "opacity:0.45" : "")">
                                            <td style="text-align:center;vertical-align:middle">
                                                <input type="checkbox"
                                                       checked="@(!_excludedScopeEpics.Contains(epic.EpicKey))"
                                                       @onchange="e => ToggleScopeEpic(epic.EpicKey, (bool)(e.Value ?? true))" />
                                            </td>
                                            <td>
                                                <div style="font-weight:700">@(epic.EpicName == "No Epic" || string.IsNullOrEmpty(epic.EpicName) ? epic.EpicKey : epic.EpicName)</div>
                                                <div class="v2-hint">@epic.EpicKey</div>
                                            </td>
                                            <td class="v2-table-num"><strong>@epic.Count</strong></td>
                                            <td class="v2-table-num">
                                                <span class="v2-pill @(epic.Done == epic.Count ? "v2-pill-success" : "v2-pill-neutral")" style="font-size:10px;padding:1px 6px">@epic.Done/@epic.Count</span>
                                            </td>
                                            <td class="v2-table-num v2-hint">@FmtH(epic.EstSec)</td>
                                            <td class="v2-table-num v2-hint">@FmtH(epic.LoggedSec)</td>
                                            <td class="v2-hint" style="white-space:nowrap">
                                                @{
                                                    var addedDates = epic.Issues.Where(i => i.Created.HasValue).Select(i => i.Created!.Value.Date).ToList();
                                                }
                                                @if (addedDates.Count == 0)
                                                {
                                                    <span>—</span>
                                                }
                                                else
                                                {
                                                    var first = addedDates.Min();
                                                    var last  = addedDates.Max();
                                                    if (first == last)
                                                    {
                                                        <span title="All @epic.Count task(s) added on @first.ToString("dd MMM yyyy")">@first.ToString("dd MMM")</span>
                                                    }
                                                    else
                                                    {
                                                        <span title="First: @first.ToString("dd MMM yyyy") · Last: @last.ToString("dd MMM yyyy")">
                                                            @first.ToString("dd MMM") → @last.ToString("dd MMM")
                                                        </span>
                                                    }
                                                }
                                            </td>
                                            <td>
                                                @foreach (var sg in epic.Issues.GroupBy(i => i.Status).OrderByDescending(g => g.Count()))
                                                {
                                                    <span class="v2-pill v2-pill-neutral" style="font-size:10px;padding:1px 6px;margin-right:3px">@sg.Key (@sg.Count())</span>
                                                }
                                            </td>
                                            <td>
                                                @foreach (var tg in epic.Issues.GroupBy(i => i.IssueType).OrderByDescending(g => g.Count()))
                                                {
                                                    var isBug = string.Equals(tg.Key, "Bug", StringComparison.OrdinalIgnoreCase);
                                                    var typePct = epic.Count > 0 ? (int)Math.Round((double)tg.Count() / epic.Count * 100) : 0;
                                                    <span class="v2-pill @(isBug ? "v2-pill-danger" : "v2-pill-neutral")" style="font-size:10px;padding:1px 6px;margin-right:3px">@tg.Key @tg.Count() (@typePct%)</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Task Detail -->
                    <div class="v2-section v2-mt-lg">
                        <div class="v2-section-title">
                            <i class="bi bi-list-ul"></i>Task Detail
                            <span class="v2-tab-badge" style="background:var(--v2-ink-3);position:static;margin-left:6px">@ScopeFilteredIssues.Count</span>
                        </div>
                        <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px">
                            <input class="v2-input" style="max-width:220px" placeholder="Search key / summary…"
                                   @bind="_scopeSearch" @bind:event="oninput" />
                            <select class="v2-select" @bind="_scopeFilterStatus">
                                <option value="">All Statuses</option>
                                @foreach (var s in ScopeChangedIssues.Select(i => i.Status).Where(s => !string.IsNullOrEmpty(s)).Distinct().Order())
                                {
                                    <option value="@s">@s</option>
                                }
                            </select>
                            <select class="v2-select" @bind="_scopeFilterType">
                                <option value="">All Types</option>
                                @foreach (var t in ScopeChangedIssues.Select(i => i.IssueType).Where(t => !string.IsNullOrEmpty(t)).Distinct().Order())
                                {
                                    <option value="@t">@t</option>
                                }
                            </select>
                            <select class="v2-select" @bind="_scopeFilterAssignee">
                                <option value="">All Assignees</option>
                                @foreach (var a in ScopeChangedIssues.Select(i => i.Assignee).Where(a => !string.IsNullOrEmpty(a)).Distinct().Order())
                                {
                                    <option value="@a">@a</option>
                                }
                            </select>
                            @if (!string.IsNullOrEmpty(_scopeSearch) || !string.IsNullOrEmpty(_scopeFilterStatus) || !string.IsNullOrEmpty(_scopeFilterType) || !string.IsNullOrEmpty(_scopeFilterAssignee))
                            {
                                <button class="v2-btn v2-btn-ghost" @onclick="ClearScopeFilters">Clear</button>
                            }
                        </div>
                        <div class="v2-table-wrap">
                            <table class="v2-table">
                                <thead>
                                    <tr>
                                        <th class="@SI("Key", _sortSC, _ascSC)" @onclick='() => SortSC("Key")'>Key</th>
                                        <th class="@SI("Summary", _sortSC, _ascSC)" @onclick='() => SortSC("Summary")'>Summary</th>
                                        <th class="@SI("Type", _sortSC, _ascSC)" @onclick='() => SortSC("Type")'>Type</th>
                                        <th class="@SI("Assignee", _sortSC, _ascSC)" @onclick='() => SortSC("Assignee")'>Assignee</th>
                                        <th class="@SI("Status", _sortSC, _ascSC)" @onclick='() => SortSC("Status")'>Status</th>
                                        <th class="@SI("Created", _sortSC, _ascSC)" @onclick='() => SortSC("Created")'>Added On</th>
                                        <th class="v2-table-num @SI("Est", _sortSC, _ascSC)" @onclick='() => SortSC("Est")'>Estimate</th>
                                        <th class="v2-table-num @SI("Log", _sortSC, _ascSC)" @onclick='() => SortSC("Log")'>Logged</th>
                                        <th class="v2-table-num @SI("Rem", _sortSC, _ascSC)" @onclick='() => SortSC("Rem")'>Remaining</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var issue in ApplySortSC(ScopeFilteredIssues))
                                    {
                                        <tr class="@(issue.StatusCategoryKey == "done" ? "is-done" : "")">
                                            <td class="v2-table-key"><a href="@JiraBase/browse/@issue.Key" target="_blank" title="@issue.Summary" class="v2-key-link">@issue.Key</a></td>
                                            <td class="v2-truncate" style="max-width:280px">@issue.Summary</td>
                                            <td><span class="v2-chip v2-chip-@issue.IssueType.ToLower()">@issue.IssueType</span></td>
                                            <td>@issue.Assignee</td>
                                            <td><span class="v2-pill v2-pill-@(issue.StatusCategoryKey == "done" ? "success" : issue.StatusCategoryKey == "indeterminate" ? "brand" : "neutral")" style="font-size:10px;padding:1px 6px">@issue.Status</span></td>
                                            <td class="v2-hint">@(issue.Created.HasValue ? issue.Created.Value.ToString("dd MMM HH:mm") : "—")</td>
                                            <td class="v2-table-num">@FmtH(issue.OriginalEstimateSeconds)</td>
                                            <td class="v2-table-num">@FmtH(issue.TimeSpentSeconds)</td>
                                            <td class="v2-table-num">@FmtH(issue.ComputedRemainingSeconds)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Effort by Member -->
                    @if (GetScopeByMember().Any())
                    {
                        <div class="v2-section v2-mt-lg">
                            <div class="v2-section-title"><i class="bi bi-people-fill"></i>Effort on Added Tasks — by Member</div>
                            @{
                                var maxSec = GetScopeByMember().Max(x => x.LoggedSec);
                            }
                            @foreach (var (member, loggedSec) in GetScopeByMember())
                            {
                                var barPct = maxSec > 0 ? (int)((double)loggedSec / maxSec * 100) : 0;
                                <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px">
                                    <span class="v2-avatar v2-avatar-sm">@Initials(member)</span>
                                    <span style="flex:1;font-weight:600;font-size:12px" class="v2-truncate">@member</span>
                                    <div class="v2-bar" style="width:240px;height:6px">
                                        <div class="v2-bar-fill v2-bar-fill-warn" style="width:@barPct%"></div>
                                    </div>
                                    <span style="width:60px;text-align:right;font-size:12px;font-variant-numeric:tabular-nums">@FmtH(loggedSec)</span>
                                </div>
                            }
                        </div>
                    }
                }
            }
        }
        else if (ActiveTab == "risks")
        {
            <div class="v2-grid-4">
                <div class="v2-risk-card @(StaleCount > 0 ? "v2-risk-card-warn" : "v2-risk-card-success")">
                    <div class="v2-risk-num">@StaleCount</div>
                    <div class="v2-risk-lbl">Stale (no log 2d+)</div>
                </div>
                <div class="v2-risk-card @(UnassignedCount > 0 ? "v2-risk-card-warn" : "v2-risk-card-success")">
                    <div class="v2-risk-num">@UnassignedCount</div>
                    <div class="v2-risk-lbl">Unassigned</div>
                </div>
                <div class="v2-risk-card @(OverloggedCount > 0 ? "v2-risk-card-warn" : "v2-risk-card-success")">
                    <div class="v2-risk-num">@OverloggedCount</div>
                    <div class="v2-risk-lbl">Overlogged</div>
                </div>
                <div class="v2-risk-card @(UnestimatedCount > 0 ? "v2-risk-card-warn" : "v2-risk-card-success")">
                    <div class="v2-risk-num">@UnestimatedCount</div>
                    <div class="v2-risk-lbl">Unestimated</div>
                </div>
            </div>

            <div class="v2-section v2-mt-lg">
                <div class="v2-section-title"><i class="bi bi-exclamation-octagon"></i>At-Risk Issues <span class="v2-section-note">prioritised by likelihood of slip</span></div>
                @if (AtRiskIssuesScoped.Count == 0)
                {
                    <div class="v2-empty">
                        <div class="v2-empty-icon" style="color:var(--v2-success)"><i class="bi bi-shield-check"></i></div>
                        <div class="v2-empty-title">No issues currently flagged at risk</div>
                        <div>Sprint health looks clean — keep it up.</div>
                    </div>
                }
                else
                {
                    var riFiltered  = FilteredAtRiskIssues.ToList();
                    var anyRiFilter = !string.IsNullOrWhiteSpace(_riSearch)     || !string.IsNullOrEmpty(_riFilterType)
                                   || !string.IsNullOrEmpty(_riFilterAssignee)  || !string.IsNullOrEmpty(_riFilterStatus)
                                   || !string.IsNullOrEmpty(_riFilterReason);

                    <!-- ── Filter bar ─────────────────────────────────────────────────── -->
                    <div class="v2-filter-bar" style="margin-bottom:12px;flex-wrap:wrap;row-gap:8px">
                        <div class="v2-filter-group">
                            <i class="bi bi-search" style="font-size:12px;color:var(--v2-ink-3)"></i>
                            <input class="v2-input v2-input-sm" style="min-width:180px" placeholder="Search key or summary…"
                                   @bind="_riSearch" @bind:event="oninput" />
                        </div>
                        <div class="v2-filter-sep"></div>
                        <div class="v2-filter-group">
                            <span class="v2-label">Type</span>
                            <select class="v2-select v2-input-sm" @bind="_riFilterType">
                                <option value="">All</option>
                                @foreach (var t in AtRiskIssuesScoped.Select(i => i.IssueType).Where(t => !string.IsNullOrEmpty(t)).Distinct().Order())
                                {
                                    <option value="@t">@t</option>
                                }
                            </select>
                        </div>
                        <div class="v2-filter-sep"></div>
                        <div class="v2-filter-group">
                            <span class="v2-label">Assignee</span>
                            <select class="v2-select v2-input-sm" @bind="_riFilterAssignee">
                                <option value="">All</option>
                                @foreach (var a in AtRiskIssuesScoped.Select(i => i.Assignee).Where(a => !string.IsNullOrEmpty(a)).Distinct().Order())
                                {
                                    <option value="@a">@a</option>
                                }
                            </select>
                        </div>
                        <div class="v2-filter-sep"></div>
                        <div class="v2-filter-group">
                            <span class="v2-label">Status</span>
                            <select class="v2-select v2-input-sm" @bind="_riFilterStatus">
                                <option value="">All</option>
                                @foreach (var s in AtRiskIssuesScoped.Select(i => i.Status).Where(s => !string.IsNullOrEmpty(s)).Distinct().Order())
                                {
                                    <option value="@s">@s</option>
                                }
                            </select>
                        </div>
                        <div class="v2-filter-sep"></div>
                        <div class="v2-filter-group">
                            <span class="v2-label">Risk reason</span>
                            <select class="v2-select v2-input-sm" @bind="_riFilterReason">
                                <option value="">All</option>
                                @foreach (var rk in AtRiskIssuesScoped.Select(RiskReasonKey).Distinct().OrderBy(k => k))
                                {
                                    <option value="@rk">@RiskReasonLabel(rk)</option>
                                }
                            </select>
                        </div>
                        <span class="v2-filter-count">@riFiltered.Count of @AtRiskIssuesScoped.Count</span>
                        @if (anyRiFilter)
                        {
                            <button class="v2-btn v2-btn-ghost" style="padding:4px 10px;font-size:12px" @onclick="ClearRiskFilters">
                                <i class="bi bi-x-lg"></i> Clear
                            </button>
                        }
                    </div>

                    <div class="v2-table-wrap">
                        <table class="v2-table">
                            <thead>
                                <tr>
                                    <th class="@SI("Key", _sortRI, _ascRI)" @onclick='() => SortRI("Key")'>Key</th>
                                    <th class="@SI("Summary", _sortRI, _ascRI)" @onclick='() => SortRI("Summary")'>Summary</th>
                                    <th class="@SI("Type", _sortRI, _ascRI)" @onclick='() => SortRI("Type")'>Type</th>
                                    <th class="@SI("Assignee", _sortRI, _ascRI)" @onclick='() => SortRI("Assignee")'>Assignee</th>
                                    <th class="@SI("Status", _sortRI, _ascRI)" @onclick='() => SortRI("Status")'>Status</th>
                                    <th class="v2-table-num @SI("Rem", _sortRI, _ascRI)" @onclick='() => SortRI("Rem")'>Remaining</th>
                                    <th class="@SI("Reason", _sortRI, _ascRI)" @onclick='() => SortRI("Reason")'>Risk reason</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (riFiltered.Count == 0)
                                {
                                    <tr><td colspan="7" class="v2-hint" style="text-align:center;padding:18px">No at-risk issues match these filters.</td></tr>
                                }
                                @foreach (var i in ApplySortRI(riFiltered))
                                {
                                    <tr>
                                        <td class="v2-table-key"><a href="@JiraBase/browse/@i.Key" target="_blank" title="@i.Summary" class="v2-key-link">@i.Key</a></td>
                                        <td class="v2-truncate" style="max-width:340px">@i.Summary</td>
                                        <td><span class="v2-chip v2-chip-@(i.IssueType.ToLower())">@i.IssueType</span></td>
                                        <td>@i.Assignee</td>
                                        <td><span class="v2-pill v2-pill-@(i.StatusCategoryKey == "indeterminate" ? "brand" : "neutral")">@i.Status</span></td>
                                        <td class="v2-table-num">@FmtH(i.ComputedRemainingSeconds)</td>
                                        <td><span class="v2-hint">@RiskReason(i)</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            <!-- On Hold by Epic -->
            @if (OnHoldIssues.Count == 0)
            {
                <div class="v2-empty v2-mt-lg">
                    <div class="v2-empty-icon" style="color:var(--v2-success)"><i class="bi bi-pause-circle"></i></div>
                    <div class="v2-empty-title">No tasks on hold</div>
                    <div>Nothing is blocked or paused right now.</div>
                </div>
            }
            else
            {
                var onHoldGroups = OnHoldIssues
                    .GroupBy(i => new { EpicKey = string.IsNullOrEmpty(i.EpicKey) ? "—" : i.EpicKey, EpicName = string.IsNullOrEmpty(i.EpicName) || i.EpicName == "No Epic" ? "No Epic" : i.EpicName })
                    .OrderByDescending(g => g.Count())
                    .ToList();
                <div class="v2-section v2-mt-lg">
                    <div class="v2-section-title">
                        <i class="bi bi-pause-circle" style="color:var(--v2-danger)"></i>
                        On Hold — by Epic
                        <span class="v2-tab-badge" style="background:var(--v2-ink-3);position:static;margin-left:6px">@OnHoldIssues.Count</span>
                    </div>
                    @foreach (var grp in onHoldGroups)
                    {
                        <div style="margin-bottom:16px">
                            <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;padding:6px 10px;background:var(--v2-surface-2);border-radius:6px">
                                <i class="bi bi-collection" style="color:var(--v2-brand)"></i>
                                <span style="font-weight:700;font-size:13px">@grp.Key.EpicName</span>
                                <span class="v2-hint">@grp.Key.EpicKey</span>
                                <span class="v2-pill v2-pill-danger" style="margin-left:auto;font-size:10px;padding:1px 6px">@grp.Count() on hold</span>
                            </div>
                            <div class="v2-table-wrap">
                                <table class="v2-table">
                                    <thead>
                                        <tr>
                                            <th>Key</th>
                                            <th>Summary</th>
                                            <th>Type</th>
                                            <th>Assignee</th>
                                            <th>Status</th>
                                            <th class="v2-table-num">Remaining</th>
                                            <th>Last Log</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var i in grp.OrderByDescending(i => i.ComputedRemainingSeconds))
                                        {
                                            var lastLog = i.Worklogs.Any() ? i.Worklogs.Max(w => w.Started) : (DateTime?)null;
                                            <tr>
                                                <td class="v2-table-key"><a href="@JiraBase/browse/@i.Key" target="_blank" title="@i.Summary" class="v2-key-link">@i.Key</a></td>
                                                <td class="v2-truncate" style="max-width:300px" title="@i.Summary">@i.Summary</td>
                                                <td><span class="v2-chip v2-chip-@i.IssueType.ToLower()">@i.IssueType</span></td>
                                                <td>@i.Assignee</td>
                                                <td><span class="v2-pill v2-pill-danger" style="font-size:10px;padding:1px 6px">@i.Status</span></td>
                                                <td class="v2-table-num">@FmtH(i.ComputedRemainingSeconds)</td>
                                                <td class="v2-hint">@(lastLog.HasValue ? lastLog.Value.ToString("MMM d") : "—")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }
                </div>
            }
        }
        else if (ActiveTab == "activity")
        {
            var cutoff       = DateTime.Today.AddDays(-1);
            var epicSdRows   = EpicStandupRows;
            var memberSdRows = MemberStandupRows;

            <!-- ── Epic Daily Standup ─────────────────────────────────────────── -->
            <div class="v2-card" style="margin-bottom:16px">
                <div class="v2-section-title">
                    <i class="bi bi-collection" style="color:#6366f1"></i>
                    Epic Standup
                    <span class="v2-section-note">yesterday's progress &amp; today's focus, by epic</span>
                </div>
                @if (!epicSdRows.Any())
                {
                    <div class="v2-hint" style="padding:16px;font-style:italic">No epic data loaded.</div>
                }
                else
                {
                    <div class="v2-table-wrap">
                        <table class="v2-table">
                            <thead>
                                <tr>
                                    <th>Epic</th>
                                    <th>Progress</th>
                                    <th class="v2-table-num">Hrs Yesterday</th>
                                    <th class="v2-table-num">Completed ✓</th>
                                    <th class="v2-table-num">In Progress</th>
                                    <th class="v2-table-num">Stuck</th>
                                    <th style="width:24px"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var erow in epicSdRows)
                                {
                                    var epicExp  = _epicSdExpanded.Contains(erow.EpicKey);
                                    var donePct  = erow.Total > 0 ? erow.Done * 100 / erow.Total : 0;
                                    <tr style="cursor:pointer" @onclick="() => ToggleEpicSd(erow.EpicKey)">
                                        <td>
                                            <div style="display:flex;flex-direction:column;gap:2px">
                                                <a class="v2-key-link v2-table-key" href="@JiraBase/browse/@erow.EpicKey" target="_blank" @onclick:stopPropagation>@erow.EpicKey</a>
                                                <span class="v2-hint" style="font-size:11px;max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="@erow.EpicName">@erow.EpicName</span>
                                            </div>
                                        </td>
                                        <td>
                                            <div style="display:flex;align-items:center;gap:8px">
                                                <div class="v2-bar" style="width:80px"><div class="v2-bar-fill" style="width:@donePct%"></div></div>
                                                <span class="v2-hint" style="font-size:11px;white-space:nowrap">@erow.Done / @erow.Total</span>
                                            </div>
                                        </td>
                                        <td class="v2-table-num @(erow.YesterdaySeconds == 0 ? "v2-hint" : "")">
                                            @(erow.YesterdaySeconds > 0 ? FmtH(erow.YesterdaySeconds) : "—")
                                        </td>
                                        <td class="v2-table-num @(erow.CompletedYesterday.Count > 0 ? "v2-text-success" : "v2-hint")">
                                            @(erow.CompletedYesterday.Count > 0 ? erow.CompletedYesterday.Count.ToString() : "—")
                                        </td>
                                        <td class="v2-table-num @(erow.InProgress.Count == 0 ? "v2-hint" : "")">
                                            @(erow.InProgress.Count > 0 ? erow.InProgress.Count.ToString() : "—")
                                        </td>
                                        <td class="v2-table-num @(erow.Stuck.Count > 0 ? "v2-text-danger" : "v2-hint")">
                                            @(erow.Stuck.Count > 0 ? erow.Stuck.Count.ToString() : "—")
                                        </td>
                                        <td class="v2-hint" style="text-align:center">@(epicExp ? "▲" : "▼")</td>
                                    </tr>
                                    @if (epicExp)
                                    {
                                        <tr>
                                            <td colspan="7" style="padding:12px 16px 16px 32px;background:var(--v2-surface-2)">
                                                <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:16px">
                                                    @if (erow.CompletedYesterday.Count > 0)
                                                    {
                                                        <div>
                                                            <div style="font-size:11px;font-weight:700;color:var(--v2-success);margin-bottom:6px;display:flex;align-items:center;gap:4px">
                                                                <i class="bi bi-check2-circle"></i> Completed Yesterday
                                                            </div>
                                                            @foreach (var ci in erow.CompletedYesterday)
                                                            {
                                                                <div style="display:flex;align-items:center;gap:6px;padding:3px 0;font-size:12px;flex-wrap:wrap">
                                                                    <a class="v2-key-link v2-table-key" href="@JiraBase/browse/@ci.Key" target="_blank" style="font-size:11px">@ci.Key</a>
                                                                    <span class="v2-truncate" style="color:var(--v2-ink-2);max-width:180px" title="@ci.Summary">@(ci.Summary.Length > 50 ? ci.Summary[..50] + "…" : ci.Summary)</span>
                                                                    @if (!string.IsNullOrEmpty(ci.Assignee)) { <span class="v2-hint" style="font-size:10px;white-space:nowrap">@FirstName(ci.Assignee)</span> }
                                                                </div>
                                                            }
                                                        </div>
                                                    }
                                                    @if (erow.WorkedYesterday.Count > 0)
                                                    {
                                                        <div>
                                                            <div style="font-size:11px;font-weight:700;color:var(--v2-brand);margin-bottom:6px;display:flex;align-items:center;gap:4px">
                                                                <i class="bi bi-play-circle"></i> Worked On Yesterday
                                                            </div>
                                                            @foreach (var wi in erow.WorkedYesterday)
                                                            {
                                                                var wHrs = wi.Worklogs.Where(w => w.Started.Date >= cutoff).Sum(w => w.TimeSpentSeconds);
                                                                <div style="display:flex;align-items:center;gap:6px;padding:3px 0;font-size:12px;flex-wrap:wrap">
                                                                    <a class="v2-key-link v2-table-key" href="@JiraBase/browse/@wi.Key" target="_blank" style="font-size:11px">@wi.Key</a>
                                                                    <span class="v2-truncate" style="color:var(--v2-ink-2);max-width:160px" title="@wi.Summary">@(wi.Summary.Length > 44 ? wi.Summary[..44] + "…" : wi.Summary)</span>
                                                                    <span class="v2-pill v2-pill-neutral" style="font-size:10px;padding:0 5px;flex-shrink:0">@FmtH(wHrs)</span>
                                                                    @if (!string.IsNullOrEmpty(wi.Assignee)) { <span class="v2-hint" style="font-size:10px;white-space:nowrap">@FirstName(wi.Assignee)</span> }
                                                                </div>
                                                            }
                                                        </div>
                                                    }
                                                    @if (erow.InProgress.Any(i => i.DaysSinceLastWorklog == 0))
                                                    {
                                                        <div>
                                                            <div style="font-size:11px;font-weight:700;color:#0284c7;margin-bottom:6px;display:flex;align-items:center;gap:4px">
                                                                <i class="bi bi-arrow-right-circle"></i> Active Today
                                                            </div>
                                                            @foreach (var ai in erow.InProgress.Where(i => i.DaysSinceLastWorklog == 0))
                                                            {
                                                                <div style="display:flex;align-items:center;gap:6px;padding:3px 0;font-size:12px;flex-wrap:wrap">
                                                                    <a class="v2-key-link v2-table-key" href="@JiraBase/browse/@ai.Key" target="_blank" style="font-size:11px">@ai.Key</a>
                                                                    <span class="v2-truncate" style="color:var(--v2-ink-2);max-width:180px" title="@ai.Summary">@(ai.Summary.Length > 50 ? ai.Summary[..50] + "…" : ai.Summary)</span>
                                                                    @if (!string.IsNullOrEmpty(ai.Assignee)) { <span class="v2-hint" style="font-size:10px;white-space:nowrap">@FirstName(ai.Assignee)</span> }
                                                                </div>
                                                            }
                                                        </div>
                                                    }
                                                    @if (erow.Stuck.Count > 0)
                                                    {
                                                        <div>
                                                            <div style="font-size:11px;font-weight:700;color:var(--v2-danger);margin-bottom:6px;display:flex;align-items:center;gap:4px">
                                                                <i class="bi bi-hourglass-split"></i> Stuck / Idle
                                                            </div>
                                                            @foreach (var si in erow.Stuck)
                                                            {
                                                                <div style="display:flex;align-items:center;gap:6px;padding:3px 0;font-size:12px;flex-wrap:wrap">
                                                                    <a class="v2-key-link v2-table-key" href="@JiraBase/browse/@si.Key" target="_blank" style="font-size:11px">@si.Key</a>
                                                                    <span class="v2-truncate" style="color:var(--v2-ink-2);max-width:160px" title="@si.Summary">@(si.Summary.Length > 44 ? si.Summary[..44] + "…" : si.Summary)</span>
                                                                    <span class="v2-pill v2-pill-danger" style="font-size:10px;padding:0 5px;flex-shrink:0">@si.DaysSinceLastWorklog d idle</span>
                                                                </div>
                                                            }
                                                        </div>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            <!-- ── Team Member Daily Standup ────────────────────────────────────── -->
            <div class="v2-card" style="margin-bottom:16px">
                <div class="v2-section-title">
                    <i class="bi bi-people" style="color:#6366f1"></i>
                    Team Standup
                    <span class="v2-section-note">each member's yesterday &amp; today</span>
                </div>
                @if (!memberSdRows.Any())
                {
                    <div class="v2-hint" style="padding:16px;font-style:italic">No assignee data found.</div>
                }
                else
                {
                    <div class="v2-table-wrap">
                        <table class="v2-table">
                            <thead>
                                <tr>
                                    <th>Member</th>
                                    <th class="v2-table-num">Hrs Yesterday</th>
                                    <th class="v2-table-num">Concluded</th>
                                    <th class="v2-table-num">Worked Yesterday</th>
                                    <th class="v2-table-num">In Progress</th>
                                    <th style="width:24px"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var mrow in memberSdRows)
                                {
                                    var memExp    = _memberSdExpanded.Contains(mrow.Name);
                                    var avatarIdx = 1 + (Math.Abs(mrow.Name.GetHashCode()) % 5);
                                    <tr style="cursor:pointer" @onclick="() => ToggleMemberSd(mrow.Name)">
                                        <td>
                                            <div style="display:flex;align-items:center;gap:8px">
                                                <span class="v2-avatar v2-avatar-sm v2-avatar-grad-@avatarIdx">@Initials(mrow.Name)</span>
                                                <span style="font-weight:600">@mrow.Name</span>
                                            </div>
                                        </td>
                                        <td class="v2-table-num @(mrow.YesterdaySeconds == 0 ? "v2-hint" : "")">
                                            @(mrow.YesterdaySeconds > 0 ? FmtH(mrow.YesterdaySeconds) : "—")
                                        </td>
                                        <td class="v2-table-num @(mrow.Concluded.Count > 0 ? "v2-text-success" : "v2-hint")">
                                            @(mrow.Concluded.Count > 0 ? mrow.Concluded.Count.ToString() : "—")
                                        </td>
                                        <td class="v2-table-num @(mrow.WorkedYesterday.Count == 0 ? "v2-hint" : "")">
                                            @(mrow.WorkedYesterday.Count > 0 ? mrow.WorkedYesterday.Count.ToString() : "—")
                                        </td>
                                        <td class="v2-table-num @(mrow.InProgress.Count == 0 ? "v2-hint" : "")">
                                            @(mrow.InProgress.Count > 0 ? mrow.InProgress.Count.ToString() : "—")
                                        </td>
                                        <td class="v2-hint" style="text-align:center">@(memExp ? "▲" : "▼")</td>
                                    </tr>
                                    @if (memExp)
                                    {
                                        <tr>
                                            <td colspan="6" style="padding:12px 16px 16px 32px;background:var(--v2-surface-2)">
                                                <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:16px">
                                                    @if (mrow.Concluded.Count > 0)
                                                    {
                                                        <div>
                                                            <div style="font-size:11px;font-weight:700;color:var(--v2-success);margin-bottom:6px;display:flex;align-items:center;gap:4px">
                                                                <i class="bi bi-check2-circle"></i> Concluded Yesterday
                                                            </div>
                                                            @foreach (var ci in mrow.Concluded)
                                                            {
                                                                <div style="display:flex;align-items:center;gap:6px;padding:3px 0;font-size:12px;flex-wrap:wrap">
                                                                    <a class="v2-key-link v2-table-key" href="@JiraBase/browse/@ci.Key" target="_blank" style="font-size:11px">@ci.Key</a>
                                                                    <span class="v2-truncate" style="color:var(--v2-ink-2);max-width:220px" title="@ci.Summary">@(ci.Summary.Length > 60 ? ci.Summary[..60] + "…" : ci.Summary)</span>
                                                                    <span class="v2-pill v2-pill-success" style="font-size:10px;padding:0 5px;flex-shrink:0">done</span>
                                                                </div>
                                                            }
                                                        </div>
                                                    }
                                                    @if (mrow.WorkedYesterday.Count > 0)
                                                    {
                                                        <div>
                                                            <div style="font-size:11px;font-weight:700;color:var(--v2-brand);margin-bottom:6px;display:flex;align-items:center;gap:4px">
                                                                <i class="bi bi-play-circle"></i> Worked On Yesterday
                                                            </div>
                                                            @foreach (var wi in mrow.WorkedYesterday)
                                                            {
                                                                var wHrs = wi.Worklogs.Where(w => w.Started.Date >= cutoff).Sum(w => w.TimeSpentSeconds);
                                                                <div style="display:flex;align-items:center;gap:6px;padding:3px 0;font-size:12px;flex-wrap:wrap">
                                                                    <a class="v2-key-link v2-table-key" href="@JiraBase/browse/@wi.Key" target="_blank" style="font-size:11px">@wi.Key</a>
                                                                    <span class="v2-truncate" style="color:var(--v2-ink-2);max-width:200px" title="@wi.Summary">@(wi.Summary.Length > 55 ? wi.Summary[..55] + "…" : wi.Summary)</span>
                                                                    <span class="v2-pill v2-pill-neutral" style="font-size:10px;padding:0 5px;flex-shrink:0">@FmtH(wHrs)</span>
                                                                </div>
                                                            }
                                                        </div>
                                                    }
                                                    @if (mrow.InProgress.Count > 0)
                                                    {
                                                        <div>
                                                            <div style="font-size:11px;font-weight:700;color:#0284c7;margin-bottom:6px;display:flex;align-items:center;gap:4px">
                                                                <i class="bi bi-arrow-right-circle"></i> In Progress
                                                            </div>
                                                            @foreach (var ip in mrow.InProgress)
                                                            {
                                                                <div style="display:flex;align-items:center;gap:6px;padding:3px 0;font-size:12px;flex-wrap:wrap">
                                                                    <a class="v2-key-link v2-table-key" href="@JiraBase/browse/@ip.Key" target="_blank" style="font-size:11px">@ip.Key</a>
                                                                    <span class="v2-truncate" style="color:var(--v2-ink-2);max-width:200px" title="@ip.Summary">@(ip.Summary.Length > 55 ? ip.Summary[..55] + "…" : ip.Summary)</span>
                                                                    @if (ip.DaysSinceLastWorklog >= 1)
                                                                    {
                                                                        <span class="v2-pill @(ip.DaysSinceLastWorklog >= 2 ? "v2-pill-danger" : "v2-pill-warn")" style="font-size:10px;padding:0 5px;flex-shrink:0">@ip.DaysSinceLastWorklog d idle</span>
                                                                    }
                                                                </div>
                                                            }
                                                        </div>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            <!-- Daily Standup Delta -->
            <div class="v2-card" style="margin-bottom:16px">
                <div class="v2-section-title">
                    <i class="bi bi-arrow-left-right" style="color:#6366f1"></i>
                    Daily Standup Delta
                    <span class="v2-section-note">what changed since yesterday</span>
                </div>
                <div class="v2-kpi-grid" style="margin-bottom:16px">
                    <div class="v2-kpi @(StandupDoneToday.Count > 0 ? "v2-kpi-success" : "v2-kpi-neutral")">
                        <div class="v2-kpi-head"><i class="bi bi-check2-circle"></i>Completed</div>
                        <div class="v2-kpi-value">@StandupDoneToday.Count</div>
                        <div class="v2-kpi-sub">done since yesterday</div>
                    </div>
                    <div class="v2-kpi v2-kpi-neutral">
                        <div class="v2-kpi-head"><i class="bi bi-play-circle"></i>Logged Today</div>
                        <div class="v2-kpi-value">@StandupWorkedToday.Count</div>
                        <div class="v2-kpi-sub">tasks with work logged</div>
                    </div>
                    <div class="v2-kpi @(StandupStuckToday.Count > 0 ? "v2-kpi-warn" : "v2-kpi-success")">
                        <div class="v2-kpi-head"><i class="bi bi-hourglass-split"></i>Stuck</div>
                        <div class="v2-kpi-value">@StandupStuckToday.Count</div>
                        <div class="v2-kpi-sub">in progress, no log today</div>
                    </div>
                    <div class="v2-kpi @(StandupAddedToday.Count > 0 ? "v2-kpi-warn" : "v2-kpi-neutral")">
                        <div class="v2-kpi-head"><i class="bi bi-plus-circle"></i>Added</div>
                        <div class="v2-kpi-value">@StandupAddedToday.Count</div>
                        <div class="v2-kpi-sub">new issues since yesterday</div>
                    </div>
                </div>

                @if (!StandupDoneToday.Any() && !StandupWorkedToday.Any() && !StandupStuckToday.Any() && !StandupAddedToday.Any())
                {
                    <div class="v2-hint" style="padding:8px 0;font-style:italic;text-align:center">No delta data available yet — worklogs and timestamps populate this as the sprint progresses.</div>
                }
                else
                {
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
                        @if (StandupDoneToday.Any())
                        {
                            <div>
                                <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--v2-success);margin-bottom:6px">
                                    <i class="bi bi-check2-circle"></i> Done since yesterday
                                </div>
                                @foreach (var i in StandupDoneToday)
                                {
                                    <div style="display:flex;align-items:center;gap:8px;padding:4px 0;border-bottom:1px solid var(--v2-border)">
                                        <span class="v2-chip v2-chip-@i.IssueType.ToLower()" style="flex-shrink:0">@i.IssueType</span>
                                        <span class="v2-table-key" style="flex-shrink:0;font-size:11px">@i.Key</span>
                                        <span class="v2-truncate v2-hint" style="flex:1;font-size:11px" title="@i.Summary">@i.Summary</span>
                                        <span class="v2-hint" style="flex-shrink:0;font-size:11px">@(i.Assignee?.Split(' ').FirstOrDefault() ?? "—")</span>
                                    </div>
                                }
                            </div>
                        }
                        @if (StandupStuckToday.Any())
                        {
                            <div>
                                <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--v2-warning);margin-bottom:6px">
                                    <i class="bi bi-hourglass-split"></i> Stuck — no log today
                                </div>
                                @foreach (var i in StandupStuckToday.Take(8))
                                {
                                    <div style="display:flex;align-items:center;gap:8px;padding:4px 0;border-bottom:1px solid var(--v2-border)">
                                        <span class="v2-chip v2-chip-@i.IssueType.ToLower()" style="flex-shrink:0">@i.IssueType</span>
                                        <span class="v2-table-key" style="flex-shrink:0;font-size:11px">@i.Key</span>
                                        <span class="v2-truncate v2-hint" style="flex:1;font-size:11px" title="@i.Summary">@i.Summary</span>
                                        <span class="v2-hint @(i.DaysSinceLastWorklog >= 2 ? "v2-text-danger" : "")" style="flex-shrink:0;font-size:11px">@i.DaysSinceLastWorklog d idle</span>
                                    </div>
                                }
                                @if (StandupStuckToday.Count > 8) { <div class="v2-hint" style="padding-top:4px">+@(StandupStuckToday.Count - 8) more…</div> }
                            </div>
                        }
                        @if (StandupAddedToday.Any())
                        {
                            <div>
                                <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--v2-brand);margin-bottom:6px">
                                    <i class="bi bi-plus-circle"></i> Added since yesterday
                                </div>
                                @foreach (var i in StandupAddedToday)
                                {
                                    <div style="display:flex;align-items:center;gap:8px;padding:4px 0;border-bottom:1px solid var(--v2-border)">
                                        <span class="v2-chip v2-chip-@i.IssueType.ToLower()" style="flex-shrink:0">@i.IssueType</span>
                                        <span class="v2-table-key" style="flex-shrink:0;font-size:11px">@i.Key</span>
                                        <span class="v2-truncate v2-hint" style="flex:1;font-size:11px" title="@i.Summary">@i.Summary</span>
                                        <span class="v2-hint" style="flex-shrink:0;font-size:11px">@(i.Created.HasValue ? i.Created.Value.ToString("HH:mm") : "—")</span>
                                    </div>
                                }
                            </div>
                        }
                        @if (StandupWorkedToday.Any())
                        {
                            <div>
                                <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--v2-ink-2);margin-bottom:6px">
                                    <i class="bi bi-play-circle"></i> Worked on today
                                </div>
                                @foreach (var i in StandupWorkedToday.Take(8))
                                {
                                    var todayH = i.Worklogs.Where(w => w.Started.Date == DateTime.Today).Sum(w => w.TimeSpentSeconds);
                                    <div style="display:flex;align-items:center;gap:8px;padding:4px 0;border-bottom:1px solid var(--v2-border)">
                                        <span class="v2-chip v2-chip-@i.IssueType.ToLower()" style="flex-shrink:0">@i.IssueType</span>
                                        <span class="v2-table-key" style="flex-shrink:0;font-size:11px">@i.Key</span>
                                        <span class="v2-truncate v2-hint" style="flex:1;font-size:11px" title="@i.Summary">@i.Summary</span>
                                        <span class="v2-hint" style="flex-shrink:0;font-size:11px">@FmtH(todayH)</span>
                                    </div>
                                }
                                @if (StandupWorkedToday.Count > 8) { <div class="v2-hint" style="padding-top:4px">+@(StandupWorkedToday.Count - 8) more…</div> }
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="v2-grid-2">
                <!-- Daily worklog heatmap -->
                <div class="v2-card v2-card-lg">
                    <div class="v2-section-title"><i class="bi bi-calendar-heart"></i>Daily Activity</div>
                    @{
                        var maxDay = DailyActivity.Values.DefaultIfEmpty(0).Max();
                    }
                    <div style="display:flex;flex-direction:column;gap:6px">
                        @foreach (var (day, hours) in DailyActivity.OrderBy(kv => kv.Key))
                        {
                            var pct = maxDay > 0 ? (int)(hours / (double)maxDay * 100) : 0;
                            <div style="display:flex;align-items:center;gap:8px">
                                <span style="width:88px;font-size:11px;color:var(--v2-ink-3)">@day.ToString("ddd MMM d")</span>
                                <div class="v2-bar" style="flex:1">
                                    <div class="v2-bar-fill" style="width:@pct%"></div>
                                </div>
                                <span style="width:54px;text-align:right;font-size:12px;font-variant-numeric:tabular-nums">@($"{hours/3600.0:F1}h")</span>
                            </div>
                        }
                    </div>
                </div>

                <!-- Top contributors by activity -->
                <div class="v2-card v2-card-lg">
                    <div class="v2-section-title"><i class="bi bi-fire"></i>Most Active Contributors (last 7d)</div>
                    @{
                        var sevenDayActivity = ContributorRows
                            .OrderByDescending(c => c.HoursLogged7d)
                            .Take(8)
                            .ToList();
                        var maxAct = sevenDayActivity.Select(c => c.HoursLogged7d).DefaultIfEmpty(0).Max();
                    }
                    @foreach (var c in sevenDayActivity)
                    {
                        var pct = maxAct > 0 ? (int)(c.HoursLogged7d / maxAct * 100) : 0;
                        <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px">
                            <span class="v2-avatar v2-avatar-sm">@Initials(c.Name)</span>
                            <span style="flex:1;font-size:12px;font-weight:600" class="v2-truncate">@c.Name</span>
                            <div class="v2-bar" style="width:140px">
                                <div class="v2-bar-fill" style="width:@pct%"></div>
                            </div>
                            <span style="width:50px;text-align:right;font-size:12px;font-variant-numeric:tabular-nums">@($"{c.HoursLogged7d:F0}h")</span>
                        </div>
                    }
                </div>
            </div>

            <!-- Recent worklog feed -->
            <div class="v2-section v2-mt-lg">
                <div class="v2-section-title"><i class="bi bi-clock-history"></i>Recent worklog activity</div>
                <div class="v2-table-wrap">
                    <table class="v2-table">
                        <thead>
                            <tr>
                                <th class="@SI("When", _sortAC, _ascAC)" @onclick='() => SortAC("When")'>When</th>
                                <th class="@SI("Author", _sortAC, _ascAC)" @onclick='() => SortAC("Author")'>Author</th>
                                <th class="@SI("Issue", _sortAC, _ascAC)" @onclick='() => SortAC("Issue")'>Issue</th>
                                <th>Comment</th>
                                <th class="v2-table-num @SI("Time", _sortAC, _ascAC)" @onclick='() => SortAC("Time")'>Time</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var w in ApplySortAC(RecentWorklogs).Take(25))
                            {
                                <tr>
                                    <td class="v2-hint">@w.Started.ToString("ddd MMM d, HH:mm")</td>
                                    <td>@w.Author</td>
                                    <td class="v2-table-key">@w.IssueKey</td>
                                    <td class="v2-truncate" style="max-width:340px">@(string.IsNullOrEmpty(w.Comment) ? "—" : w.Comment)</td>
                                    <td class="v2-table-num">@FmtH(w.TimeSpentSeconds)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else if (ActiveTab == "tracking")
        {
            var trkRows = ApplySortTRK(BuildTrackingRows());
            var trkStatusGroups = ActiveIssues
                .GroupBy(i => new { i.Status, i.StatusCategoryKey })
                .OrderBy(g => g.Key.StatusCategoryKey switch { "new" => 0, "indeterminate" => 1, "done" => 2, _ => 3 })
                .ThenBy(g => g.Key.Status)
                .Select(g => (Status: g.Key.Status, Cat: g.Key.StatusCategoryKey, Count: g.Count()))
                .ToList();

            @if (TrackingNeedsCount > 0 || TrackingLowCount > 0)
            {
                <div style="display:flex;align-items:center;gap:10px;padding:10px 14px;background:#fffbeb;border:1px solid #f59e0b;border-radius:8px;margin-bottom:14px">
                    <i class="bi bi-exclamation-triangle-fill" style="color:#b45309"></i>
                    @if (TrackingNeedsCount > 0)
                    {
                        <span><span class="v2-pill v2-pill-danger">@TrackingNeedsCount</span> member@(TrackingNeedsCount == 1 ? "" : "s") need new tasks</span>
                    }
                    @if (TrackingNeedsCount > 0 && TrackingLowCount > 0)
                    {
                        <span class="v2-hint">·</span>
                    }
                    @if (TrackingLowCount > 0)
                    {
                        <span><span class="v2-pill v2-pill-warn">@TrackingLowCount</span> running low (&lt;6h remaining)</span>
                    }
                </div>
            }

            <div style="display:flex;align-items:center;flex-wrap:wrap;gap:6px;margin-bottom:14px">
                <span class="v2-hint">@ActiveIssues.Count tickets</span>
                @foreach (var sg in trkStatusGroups)
                {
                    var chipClass = sg.Status.Contains("Hold", StringComparison.OrdinalIgnoreCase)
                        ? "v2-pill-danger"
                        : sg.Cat == "done" ? "v2-pill-success" : sg.Cat == "indeterminate" ? "v2-pill-brand" : "v2-pill-neutral";
                    <span class="v2-pill @chipClass" style="font-size:10px;padding:1px 6px">@sg.Status <strong>@sg.Count</strong></span>
                }
            </div>

            <div class="v2-section-title" style="margin-bottom:8px"><i class="bi bi-people"></i>Active Work — @trkRows.Count() members</div>
            <div class="v2-table-wrap">
                <table class="v2-table">
                    <thead>
                        <tr>
                            <th class="@SI("TRKMember", _sortColTRK, _sortAscTRK)" @onclick='() => SortTRK("TRKMember")'>Member</th>
                            <th class="@SI("TRKActive", _sortColTRK, _sortAscTRK)" @onclick='() => SortTRK("TRKActive")'>Active Tasks</th>
                            <th class="v2-table-num @SI("TRKRem", _sortColTRK, _sortAscTRK)" @onclick='() => SortTRK("TRKRem")'>Remaining</th>
                            <th class="@SI("TRKIdle", _sortColTRK, _sortAscTRK)" @onclick='() => SortTRK("TRKIdle")'>Last Active</th>
                            <th class="@SI("TRKSignal", _sortColTRK, _sortAscTRK)" @onclick='() => SortTRK("TRKSignal")'>Signal</th>
                            <th style="width:20px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in trkRows)
                        {
                            var tkExp = _trackingExpanded.Contains(row.Person);
                            var avatarIdx = row.Signal == "needs" ? 5 : row.Signal == "low" ? 4 : 1 + (Math.Abs(row.Person.GetHashCode()) % 5);
                            <tr style="cursor:pointer" @onclick="() => ToggleTracking(row.Person)">
                                <td>
                                    <div style="display:flex;align-items:center;gap:8px">
                                        <span class="v2-avatar v2-avatar-sm v2-avatar-grad-@avatarIdx">@Initials(row.Person)</span>
                                        <span style="font-weight:600">@row.Person</span>
                                    </div>
                                </td>
                                <td>
                                    @if (!row.AllActive.Any())
                                    {
                                        <span class="v2-hint">No active tasks</span>
                                    }
                                    else
                                    {
                                        <div style="display:flex;flex-wrap:wrap;gap:4px">
                                            @foreach (var ai in row.AllActive.Take(3))
                                            {
                                                var isOnHold = ai.Status?.Contains("Hold", StringComparison.OrdinalIgnoreCase) ?? false;
                                                <span class="v2-pill @(isOnHold ? "v2-pill-danger" : "v2-pill-brand")" style="font-size:10px;padding:1px 6px">
                                                    <span class="v2-chip v2-chip-@(ai.IssueType.ToLower())" style="font-size:9px;padding:0 3px;margin-right:2px">@(ai.IssueType.Length > 0 ? ai.IssueType[..1] : "?")</span>@ai.Key
                                                </span>
                                            }
                                            @if (row.AllActive.Count > 3)
                                            {
                                                <span class="v2-hint" style="font-size:11px">+@(row.AllActive.Count - 3)</span>
                                            }
                                        </div>
                                    }
                                </td>
                                <td class="v2-table-num @(row.Signal == "needs" || row.Signal == "low" ? "v2-text-danger" : "")">
                                    @FmtH(row.TotalRem)
                                </td>
                                <td style="white-space:nowrap">
                                    @if (row.DaysIdle == 999)   { <span class="v2-hint">—</span> }
                                    else if (row.DaysIdle == 0) { <span style="color:var(--v2-success);font-weight:600">Today</span> }
                                    else if (row.DaysIdle == 1) { <span class="v2-hint">Yesterday</span> }
                                    else                        { <span class="@(row.DaysIdle >= 3 ? "v2-text-danger" : "")" style="@(row.DaysIdle >= 3 ? "" : "color:#b45309")">@row.DaysIdle d ago</span> }
                                </td>
                                <td>
                                    @if (row.Signal == "needs")    { <span class="v2-pill v2-pill-danger">Needs Tasks</span> }
                                    else if (row.Signal == "low")  { <span class="v2-pill v2-pill-warn">Running Low</span> }
                                    else if (row.Signal == "soon") { <span class="v2-pill v2-pill-neutral">Available Soon</span> }
                                    else                           { <span class="v2-pill v2-pill-success">Busy</span> }
                                </td>
                                <td class="v2-hint" style="text-align:center">@(tkExp ? "▲" : "▼")</td>
                            </tr>

                            @if (tkExp)
                            {
                                <tr>
                                    <td colspan="6" style="padding:0 0 8px 36px;background:var(--v2-surface-2)">
                                        @if (!row.AllActive.Any())
                                        {
                                            <div class="v2-hint" style="padding:8px 0;font-style:italic">No active tasks assigned.</div>
                                        }
                                        else
                                        {
                                            <div class="v2-table-wrap" style="margin:8px 0">
                                                <table class="v2-table" style="font-size:11.5px">
                                                    <thead>
                                                        <tr>
                                                            <th>Key</th>
                                                            <th>Type</th>
                                                            <th>Summary</th>
                                                            <th>Status</th>
                                                            <th class="v2-table-num">Remaining</th>
                                                            <th>Progress</th>
                                                            <th>Last Log</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var ai in row.AllActive)
                                                        {
                                                            var pct = IssuePercentDone(ai) ?? 0;
                                                            var isOnHold = ai.Status?.Contains("Hold", StringComparison.OrdinalIgnoreCase) ?? false;
                                                            <tr style="@(isOnHold ? "opacity:0.75;background:#fef2f2" : "")">
                                                                <td class="v2-table-key" style="white-space:nowrap"><a href="@JiraBase/browse/@ai.Key" target="_blank" title="@ai.Summary" class="v2-key-link">@ai.Key</a></td>
                                                                <td><span class="v2-chip v2-chip-@ai.IssueType.ToLower()">@ai.IssueType</span></td>
                                                                <td class="v2-truncate" style="max-width:280px" title="@ai.Summary">
                                                                    @ai.Summary
                                                                    @if (isOnHold) { <span class="v2-pill v2-pill-danger" style="font-size:10px;padding:1px 6px;margin-left:4px">On Hold</span> }
                                                                </td>
                                                                <td>
                                                                    <span class="v2-pill v2-pill-@(ai.StatusCategoryKey == "done" ? "success" : ai.StatusCategoryKey == "indeterminate" ? "brand" : "neutral")" style="font-size:10px;padding:1px 6px">@ai.Status</span>
                                                                </td>
                                                                <td class="v2-table-num">@FmtH(ai.ComputedRemainingSeconds)</td>
                                                                <td style="min-width:100px">
                                                                    <div style="display:flex;align-items:center;gap:6px">
                                                                        <div class="v2-bar" style="flex:1;height:6px">
                                                                            <div class="v2-bar-fill @(pct >= 100 ? "v2-bar-fill-success" : "v2-bar-fill")" style="width:@Math.Min(pct, 100)%"></div>
                                                                        </div>
                                                                        <span style="font-size:11px;min-width:30px;text-align:right">@pct%</span>
                                                                    </div>
                                                                </td>
                                                                <td class="v2-hint" style="white-space:nowrap">
                                                                    @if (ai.DaysSinceLastWorklog == 0)      { <span style="color:var(--v2-success)">Today</span> }
                                                                    else if (ai.DaysSinceLastWorklog < 999) { <span class="@(ai.DaysSinceLastWorklog >= 2 ? "v2-text-danger" : "")">@ai.DaysSinceLastWorklog d ago</span> }
                                                                    else                                    { <span>—</span> }
                                                                </td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            <div class="v2-hint" style="margin-top:8px;font-size:11px">
                Signal · <strong>Busy</strong>: any bug in progress or 12h+ non-bug remaining · <strong>Available Soon</strong>: &lt;12h · <strong>Running Low</strong>: &lt;6h · <strong>Needs Tasks</strong>: no non-bug/non-held work · On Hold tasks shown but excluded from signals
            </div>
        }
        else if (ActiveTab == "tasks")
        {
            var tskFiltered  = TasksTabIssues;
            var anyTskFilter = !string.IsNullOrWhiteSpace(_tskSearch)      || !string.IsNullOrEmpty(_tskFilterStatus)
                            || !string.IsNullOrEmpty(_tskFilterType)       || !string.IsNullOrEmpty(_tskFilterPriority)
                            || !string.IsNullOrEmpty(_tskFilterAssignee)   || !string.IsNullOrEmpty(_tskFilterEpic);

            <!-- ── Summary pills ─────────────────────────────────────────────── -->
            <div style="display:flex;align-items:center;flex-wrap:wrap;gap:8px;margin-bottom:14px">
                <span class="v2-pill v2-pill-neutral">@ActiveIssues.Count total</span>
                <span class="v2-pill v2-pill-success">@DoneCount done</span>
                <span class="v2-pill v2-pill-brand">@InProgressCount in progress</span>
                <span class="v2-pill v2-pill-warn">@ToDoCount to do</span>
                @if (UnestimatedCount > 0)
                {
                    <span class="v2-pill v2-pill-danger" title="Tasks with no original estimate">@UnestimatedCount unestimated</span>
                }
                @if (NeverLoggedCount > 0)
                {
                    <span class="v2-pill v2-pill-danger" title="Tasks with zero worklogs">@NeverLoggedCount never logged</span>
                }
            </div>

            <!-- ── Filter bar ─────────────────────────────────────────────────── -->
            <div class="v2-filter-bar" style="margin-bottom:12px;flex-wrap:wrap;row-gap:8px">
                <div class="v2-filter-group">
                    <i class="bi bi-search" style="font-size:12px;color:var(--v2-ink-3)"></i>
                    <input class="v2-input v2-input-sm" style="min-width:180px" placeholder="Search key or summary…"
                           @bind="_tskSearch" @bind:event="oninput" />
                </div>
                <div class="v2-filter-sep"></div>
                <div class="v2-filter-group">
                    <span class="v2-label">Status</span>
                    <select class="v2-select v2-input-sm" @bind="_tskFilterStatus">
                        <option value="">All</option>
                        <option value="indeterminate">In Progress</option>
                        <option value="new">To Do</option>
                        <option value="done">Done</option>
                    </select>
                </div>
                <div class="v2-filter-sep"></div>
                <div class="v2-filter-group">
                    <span class="v2-label">Type</span>
                    <select class="v2-select v2-input-sm" @bind="_tskFilterType">
                        <option value="">All</option>
                        @foreach (var t in ActiveIssues.Select(i => i.IssueType).Where(t => !string.IsNullOrEmpty(t)).Distinct().Order())
                        {
                            <option value="@t">@t</option>
                        }
                    </select>
                </div>
                <div class="v2-filter-sep"></div>
                <div class="v2-filter-group">
                    <span class="v2-label">Priority</span>
                    <select class="v2-select v2-input-sm" @bind="_tskFilterPriority">
                        <option value="">All</option>
                        @foreach (var p in new[] { "Highest", "Critical", "High", "Medium", "Low", "Lowest" }
                                              .Where(p => ActiveIssues.Any(i => i.Priority == p)))
                        {
                            <option value="@p">@p</option>
                        }
                    </select>
                </div>
                <div class="v2-filter-sep"></div>
                <div class="v2-filter-group">
                    <span class="v2-label">Assignee</span>
                    <select class="v2-select v2-input-sm" @bind="_tskFilterAssignee">
                        <option value="">All</option>
                        @foreach (var a in ActiveIssues.Select(i => i.Assignee).Where(a => !string.IsNullOrEmpty(a)).Distinct().Order())
                        {
                            <option value="@a">@a</option>
                        }
                    </select>
                </div>
                <div class="v2-filter-sep"></div>
                <div class="v2-filter-group">
                    <span class="v2-label">Epic</span>
                    <select class="v2-select v2-input-sm" style="max-width:180px" @bind="_tskFilterEpic">
                        <option value="">All</option>
                        @foreach (var e in ActiveIssues
                                            .Where(i => !string.IsNullOrEmpty(i.EpicKey))
                                            .GroupBy(i => i.EpicKey)
                                            .Select(g => new { Key = g.Key, Label = g.First().EpicName is { Length: > 0 } n && n != "No Epic" ? n : g.Key })
                                            .OrderBy(e => e.Label))
                        {
                            <option value="@e.Key" title="@e.Key">@e.Label</option>
                        }
                    </select>
                </div>
                <span class="v2-filter-count">@tskFiltered.Count of @ActiveIssues.Count</span>
                @if (anyTskFilter)
                {
                    <button class="v2-btn v2-btn-ghost" style="padding:4px 10px;font-size:12px" @onclick="ClearTaskFilters">
                        <i class="bi bi-x-circle"></i> Clear filters
                    </button>
                }
            </div>

            <!-- ── Table ──────────────────────────────────────────────────────── -->
            <div class="v2-table-wrap">
                <table class="v2-table">
                    <thead>
                        <tr>
                            <th class="@SI("Key", _sortTSK, _ascTSK)" @onclick='() => SortTSK("Key")'>Key</th>
                            <th class="@SI("Summary", _sortTSK, _ascTSK)" @onclick='() => SortTSK("Summary")'>Summary</th>
                            <th class="@SI("Type", _sortTSK, _ascTSK)" @onclick='() => SortTSK("Type")'>Type</th>
                            <th class="@SI("Priority", _sortTSK, _ascTSK)" @onclick='() => SortTSK("Priority")'>Priority</th>
                            <th class="@SI("Status", _sortTSK, _ascTSK)" @onclick='() => SortTSK("Status")'>Status</th>
                            <th class="@SI("Assignee", _sortTSK, _ascTSK)" @onclick='() => SortTSK("Assignee")'>Assignee</th>
                            <th class="@SI("Epic", _sortTSK, _ascTSK)" @onclick='() => SortTSK("Epic")'>Epic</th>
                            <th class="v2-table-num @SI("Est", _sortTSK, _ascTSK)" @onclick='() => SortTSK("Est")'>Estimate</th>
                            <th class="v2-table-num @SI("Log", _sortTSK, _ascTSK)" @onclick='() => SortTSK("Log")'>Logged</th>
                            <th class="v2-table-num @SI("Rem", _sortTSK, _ascTSK)" @onclick='() => SortTSK("Rem")'>Remaining</th>
                            <th class="@SI("Pct", _sortTSK, _ascTSK)" style="min-width:120px" @onclick='() => SortTSK("Pct")'>Progress</th>
                            <th class="@SI("Last", _sortTSK, _ascTSK)" @onclick='() => SortTSK("Last")'>Last log</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!tskFiltered.Any())
                        {
                            <tr><td colspan="12" style="text-align:center;padding:28px" class="v2-text-muted">No tasks match the current filters.</td></tr>
                        }
                        @foreach (var i in ApplySortTSK(tskFiltered))
                        {
                            var pct      = IssuePercentDone(i) ?? 0;
                            var lastLog  = i.Worklogs.Any() ? i.Worklogs.Max(w => w.Started) : (DateTime?)null;
                            var sc       = StatusColor(i);
                            var epicLbl  = i.EpicName is { Length: > 0 } en && en != "No Epic" ? en : i.EpicKey;
                            <tr class="@(i.StatusCategoryKey == "done" ? "is-done" : "")"
                                style="background:@sc.bg;border-left:3px solid @sc.border">
                                <td class="v2-table-key"><a href="@JiraBase/browse/@i.Key" target="_blank" title="@i.Summary" class="v2-key-link">@i.Key</a></td>
                                <td class="v2-truncate" style="max-width:320px" title="@i.Summary">@i.Summary</td>
                                <td><span class="v2-chip v2-chip-@i.IssueType.ToLower()">@i.IssueType</span></td>
                                <td>
                                    @if (!string.IsNullOrEmpty(i.Priority))
                                    {
                                        <span class="v2-chip v2-chip-pri-@i.Priority.ToLower()">@i.Priority</span>
                                    }
                                    else { <span class="v2-text-muted">—</span> }
                                </td>
                                <td>
                                    <span class="v2-pill" style="font-size:10px;padding:1px 6px;background:@sc.bg;color:@sc.border;border:1px solid @sc.border">@i.Status</span>
                                </td>
                                <td>
                                    <div style="display:flex;align-items:center;gap:6px">
                                        <span class="v2-avatar v2-avatar-grad-2" style="width:22px;height:22px;font-size:9px">@Initials(i.Assignee)</span>
                                        <span class="v2-truncate" style="max-width:110px">@(string.IsNullOrEmpty(i.Assignee) ? "Unassigned" : i.Assignee)</span>
                                    </div>
                                </td>
                                <td class="v2-truncate" style="max-width:140px;font-size:11px;color:var(--v2-ink-3)" title="@epicLbl">
                                    @(string.IsNullOrEmpty(epicLbl) ? "—" : epicLbl)
                                </td>
                                <td class="v2-table-num">@(i.OriginalEstimateSeconds > 0 ? FmtH(i.OriginalEstimateSeconds) : "—")</td>
                                <td class="v2-table-num">@(i.TimeSpentSeconds > 0 ? FmtH(i.TimeSpentSeconds) : "—")</td>
                                <td class="v2-table-num">@(i.OriginalEstimateSeconds == 0 ? "—" : FmtH(i.ComputedRemainingSeconds))</td>
                                <td style="min-width:120px">
                                    <div style="display:flex;align-items:center;gap:6px">
                                        <div class="v2-bar" style="flex:1;height:5px">
                                            <div class="v2-bar-fill @(pct >= 100 ? "v2-bar-fill-success" : "")"
                                                 style="width:@Math.Min(pct, 100)%"></div>
                                        </div>
                                        <span style="font-size:11px;min-width:32px;text-align:right">@pct%</span>
                                    </div>
                                </td>
                                <td class="v2-hint" style="white-space:nowrap">
                                    @if (lastLog.HasValue)
                                    {
                                        var daysAgo = (DateTime.Today - lastLog.Value.Date).Days;
                                        <span class="@(daysAgo >= 2 && i.StatusCategoryKey == "indeterminate" ? "v2-text-danger" : daysAgo >= 1 && i.StatusCategoryKey == "indeterminate" ? "v2-text-warn" : "")">
                                            @(daysAgo == 0 ? "Today" : daysAgo == 1 ? "Yesterday" : $"{daysAgo}d ago")
                                        </span>
                                    }
                                    else { <span class="@(i.StatusCategoryKey == "indeterminate" ? "v2-text-danger" : "")">—</span> }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
</div>

@code {
    private string JiraBase => Config["Jira:BaseUrl"]?.TrimEnd('/') ?? "#";

    // ── State ────────────────────────────────────────────────────────────────
    private string SprintId = "";
    private string SelectedFilterId = "";
    private string OverrideDaysLeftInput = "";
    private bool   IsLoading;
    private int    _epicLoadProgress;
    private int    _epicLoadTotal;
    private bool   FiltersLoading = true;
    private string? ErrorMessage;
    private SprintReport? Report;
    private List<JiraFilter> MyFilters = [];
    private string ActiveTab = "overview";

    private string SelectedFilterJql =>
        MyFilters.FirstOrDefault(f => f.Id == SelectedFilterId)?.Jql ?? "";

    // Issues excluded from every metric on this page: the "Product" issue type and the
    // "Documentation" / "Discovery" workflow statuses don't represent delivery work.
    private static bool IsExcludedFromMetrics(SprintIssue i) =>
        string.Equals(i.IssueType, "Product",       StringComparison.OrdinalIgnoreCase) ||
        string.Equals(i.Status,    "Documentation", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(i.Status,    "Discovery",     StringComparison.OrdinalIgnoreCase);

    // ── Derived: counts (excluding epics, support tickets, Product & Doc/Discovery) ──
    private List<SprintIssue> ActiveIssues => Report?.Issues
        .Where(i => !string.Equals(i.IssueType, "Epic", StringComparison.OrdinalIgnoreCase)
                 && !i.Key.Contains("JSSUPPORT", StringComparison.OrdinalIgnoreCase)
                 && !IsExcludedFromMetrics(i))
        .ToList() ?? [];

    // At-risk issues are computed server-side over the raw report, so apply the same exclusion.
    private List<SprintIssue> AtRiskIssuesScoped =>
        Report?.AtRiskIssues.Where(i => !IsExcludedFromMetrics(i)).ToList() ?? [];

    private int DoneCount       => ActiveIssues.Count(i => i.StatusCategoryKey == "done");
    private int InProgressCount => ActiveIssues.Count(i => i.StatusCategoryKey == "indeterminate");
    private int ToDoCount       => ActiveIssues.Count(i => i.StatusCategoryKey == "new");

    private double CompletionPct => ActiveIssues.Count == 0 ? 0
        : DoneCount * 100.0 / ActiveIssues.Count;
    private bool   CompletionBehind => Report != null && Report.SprintProgressPct - CompletionPct > 12;

    // ── Task completion (issue type Task & Sub-task only) ────────────────────
    private static bool IsTaskType(SprintIssue i) =>
        string.Equals(i.IssueType, "Task",     StringComparison.OrdinalIgnoreCase) ||
        string.Equals(i.IssueType, "Sub-task", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(i.IssueType, "Subtask",  StringComparison.OrdinalIgnoreCase);

    private List<SprintIssue> TaskOnlyIssues => ActiveIssues.Where(IsTaskType).ToList();
    private int    TaskDoneCount       => TaskOnlyIssues.Count(i => i.StatusCategoryKey == "done");
    private int    TaskInProgressCount => TaskOnlyIssues.Count(i => i.StatusCategoryKey == "indeterminate");
    private double TaskCompletionPct   => TaskOnlyIssues.Count == 0 ? 0
        : TaskDoneCount * 100.0 / TaskOnlyIssues.Count;
    private bool   TaskCompletionBehind => Report != null && Report.SprintProgressPct - TaskCompletionPct > 12;

    // ── Scope split: initial scope vs added-during-sprint (tasks & sub-tasks) ─
    private DateTime? SprintStartDate => Report?.StartDate?.Date;

    private List<SprintIssue> TaskAddedIssues => SprintStartDate == null ? new()
        : TaskOnlyIssues.Where(i => i.Created.HasValue && i.Created.Value.Date >= SprintStartDate.Value).ToList();

    private List<SprintIssue> TaskInitialIssues => SprintStartDate == null ? TaskOnlyIssues
        : TaskOnlyIssues.Where(i => !(i.Created.HasValue && i.Created.Value.Date >= SprintStartDate.Value)).ToList();

    private record ScopeSplitStat(int Total, int Done, int Active, int ToDo, double Pct);
    private static ScopeSplitStat StatFor(List<SprintIssue> src) => new(
        Total:  src.Count,
        Done:   src.Count(i => i.StatusCategoryKey == "done"),
        Active: src.Count(i => i.StatusCategoryKey == "indeterminate"),
        ToDo:   src.Count(i => i.StatusCategoryKey == "new"),
        Pct:    src.Count == 0 ? 0 : Math.Round(src.Count(i => i.StatusCategoryKey == "done") * 100.0 / src.Count, 1));

    private double DoneHours => ActiveIssues
        .Where(i => i.StatusCategoryKey == "done")
        .Sum(i => i.TimeSpentSeconds) / 3600.0;
    private double DoneAndInReviewHours => ActiveIssues
        .Where(i => i.StatusCategoryKey == "done" ||
                    string.Equals(i.Status, "In Review", StringComparison.OrdinalIgnoreCase))
        .Sum(i => i.TimeSpentSeconds) / 3600.0;

    // ── Hours ────────────────────────────────────────────────────────────────
    private double TotalLoggedHours => ActiveIssues.Sum(i => i.TimeSpentSeconds) / 3600.0;
    private double TotalRemainingHours => ActiveIssues
        .Where(i => i.StatusCategoryKey != "done")
        .Sum(i => i.ComputedRemainingSeconds) / 3600.0;

    private int EffectiveDaysRemaining =>
        int.TryParse(OverrideDaysLeftInput, out var d) ? d : Report?.DaysRemaining ?? 0;

    private double CapacityHours
    {
        get
        {
            var contributors = Math.Max(1, ActiveIssues
                .Where(i => i.Assignee != "Unassigned").Select(i => i.Assignee).Distinct().Count());
            return EffectiveDaysRemaining * 6.0 * contributors;
        }
    }

    private bool   IsOverCapacity => TotalRemainingHours > CapacityHours;
    private double HoursLoggedPerWorkday
    {
        get
        {
            var elapsed = Math.Max(1, Report?.ElapsedDays ?? 1);
            return TotalLoggedHours / elapsed;
        }
    }

    private double VelocityPerDay
    {
        get
        {
            var elapsed = Math.Max(1, Report?.ElapsedDays ?? 1);
            return Report?.HasStoryPoints == true ? Report.DoneStoryPoints / (double)elapsed : 0;
        }
    }

    private double NeededDailyHours => EffectiveDaysRemaining > 0 ? TotalRemainingHours / EffectiveDaysRemaining : 0;
    private double ProjectedFinishHours => HoursLoggedPerWorkday * (Report?.TotalSprintDays ?? 0);
    private double ProjectedCompletionPct
    {
        get
        {
            if (ActiveIssues.Count == 0) return 0;
            var totalDays = Math.Max(1, Report!.TotalSprintDays);
            var elapsed = Math.Max(1, Report.ElapsedDays);
            // Linear extrapolation
            var rate = DoneCount / (double)elapsed;
            var projected = Math.Min(ActiveIssues.Count, rate * totalDays);
            return projected * 100.0 / ActiveIssues.Count;
        }
    }

    private string ForecastVerdict
    {
        get
        {
            if (Report == null) return "—";
            if (IsOverCapacity) return "Over budget";
            if (ProjectedCompletionPct < 90) return "Slip risk";
            if (ProjectedCompletionPct >= 100) return "On track";
            return "Tight";
        }
    }

    private string ForecastMessage
    {
        get
        {
            if (Report == null) return "";
            if (IsOverCapacity) return $"Remaining work exceeds capacity by {(TotalRemainingHours - CapacityHours):F0}h";
            if (ProjectedCompletionPct < 90) return $"Pace projects {ProjectedCompletionPct:F0}% — accelerate or descope";
            return $"Pace projects {ProjectedCompletionPct:F0}% — buffer of {(CapacityHours - TotalRemainingHours):F0}h";
        }
    }

    // ── Bug & risk metrics ───────────────────────────────────────────────────
    private int TotalBugsCount => ActiveIssues.Count(i => string.Equals(i.IssueType, "Bug", StringComparison.OrdinalIgnoreCase));
    private int OpenBugsCount  => ActiveIssues.Count(i => string.Equals(i.IssueType, "Bug", StringComparison.OrdinalIgnoreCase) && i.StatusCategoryKey != "done");
    private int CriticalBugsCount => ActiveIssues.Count(i => string.Equals(i.IssueType, "Bug", StringComparison.OrdinalIgnoreCase)
        && (i.Priority == "Highest" || i.Priority == "High" || i.Priority == "Critical"));

    private int AtRiskCount => AtRiskIssuesScoped.Count;
    private int StaleCount  => ActiveIssues.Count(i => i.StatusCategoryKey == "indeterminate" && i.DaysSinceLastWorklog >= 2);
    private int UnassignedCount => ActiveIssues.Count(i =>
        string.IsNullOrWhiteSpace(i.Assignee) || i.Assignee.Equals("Unassigned", StringComparison.OrdinalIgnoreCase));
    private int OverloggedCount => ActiveIssues.Count(i =>
        i.OriginalEstimateSeconds > 0 && i.TimeSpentSeconds > i.OriginalEstimateSeconds);
    private int UnestimatedCount => ActiveIssues.Count(i => i.OriginalEstimateSeconds == 0 && i.StatusCategoryKey != "done");

    // ── New manager KPIs ─────────────────────────────────────────────────────

    // Idle: in-progress without a worklog in the last 24h
    private int IdleActiveCount => ActiveIssues.Count(i => i.StatusCategoryKey == "indeterminate" && i.DaysSinceLastWorklog >= 1);

    // On Hold: tickets whose status name contains "hold" or "block"
    private int OnHoldTicketsCount => ActiveIssues.Count(i =>
        i.StatusCategoryKey != "done" &&
        (i.Status?.Contains("Hold", StringComparison.OrdinalIgnoreCase) == true
         || i.Status?.Contains("Block", StringComparison.OrdinalIgnoreCase) == true));

    // Never logged: open tickets with zero worklogs
    private int NeverLoggedCount => ActiveIssues.Count(i =>
        i.StatusCategoryKey != "done" && (i.Worklogs == null || i.Worklogs.Count == 0));

    // Throughput: tasks/workday so far in sprint vs needed pace to finish
    private double ThroughputPerDay => Report == null || Report.ElapsedDays <= 0 ? 0
        : DoneCount / (double)Report.ElapsedDays;

    private double NeededThroughputPerDay => EffectiveDaysRemaining <= 0 ? 0
        : (ActiveIssues.Count - DoneCount) / (double)EffectiveDaysRemaining;

    private bool ThroughputBehind => NeededThroughputPerDay > 0 && ThroughputPerDay < NeededThroughputPerDay * 0.9;

    // Workload imbalance: how far the heaviest member is above the team average remaining hours
    private record HeaviestRow(string Name, double RemainingHours);

    private List<(string Name, double RemainingHours)> RemainingPerMember => ActiveIssues
        .Where(i => i.StatusCategoryKey != "done"
                 && !string.IsNullOrWhiteSpace(i.Assignee)
                 && i.Assignee != "Unassigned")
        .GroupBy(i => i.Assignee)
        .Select(g => (g.Key, g.Sum(x => x.ComputedRemainingSeconds) / 3600.0))
        .Where(x => x.Item2 > 0)
        .ToList();

    private double AvgRemainingPerMember => RemainingPerMember.Count == 0 ? 0
        : RemainingPerMember.Average(x => x.RemainingHours);

    private HeaviestRow? HeaviestMember
    {
        get
        {
            if (RemainingPerMember.Count == 0) return null;
            var top = RemainingPerMember.OrderByDescending(x => x.RemainingHours).First();
            return new HeaviestRow(top.Name, top.RemainingHours);
        }
    }

    private double WorkloadImbalancePct
    {
        get
        {
            if (RemainingPerMember.Count == 0 || AvgRemainingPerMember <= 0) return 0;
            var max = RemainingPerMember.Max(x => x.RemainingHours);
            return (max - AvgRemainingPerMember) / AvgRemainingPerMember * 100.0;
        }
    }

    // Estimation coverage: % of non-done tasks with an estimate
    private double EstimationCoveragePct
    {
        get
        {
            var open = ActiveIssues.Where(i => i.StatusCategoryKey != "done").ToList();
            if (open.Count == 0) return 100;
            var withEst = open.Count(i => i.OriginalEstimateSeconds > 0);
            return withEst * 100.0 / open.Count;
        }
    }

    // Scope churn — issues created after sprint start
    private int AddedAfterStartCount
    {
        get
        {
            if (Report?.StartDate == null) return 0;
            return ActiveIssues.Count(i => i.Created.HasValue && i.Created.Value.Date > Report.StartDate.Value.Date);
        }
    }
    private double ScopeChurnPct => ActiveIssues.Count == 0 ? 0
        : AddedAfterStartCount * 100.0 / ActiveIssues.Count;

    private int QaRejectionsCount => ActiveIssues.Sum(i => i.QaRejectedCount);
    private int QaRejectedIssuesCount => ActiveIssues.Count(i => i.QaRejectedCount > 0);

    // ── Task-only KPI variants (Task & Sub-task issue types only) ────────────
    // Mirror the all-issue KPIs but restrict the population to TaskOnlyIssues, so the
    // Capacity / Idle Tasks / Throughput cards line up with the Task Completion card.
    private int    TaskToDoCount       => TaskOnlyIssues.Count(i => i.StatusCategoryKey == "new");
    private int    TaskContributors    => Math.Max(1, TaskOnlyIssues
        .Where(i => i.Assignee != "Unassigned").Select(i => i.Assignee).Distinct().Count());
    private double TaskCapacityHours   => EffectiveDaysRemaining * 6.0 * TaskContributors;
    private double TaskRemainingHours  => TaskOnlyIssues
        .Where(i => i.StatusCategoryKey != "done").Sum(i => i.ComputedRemainingSeconds) / 3600.0;
    private bool   TaskOverCapacity    => TaskRemainingHours > TaskCapacityHours;

    private int    TaskIdleActiveCount => TaskOnlyIssues.Count(i => i.StatusCategoryKey == "indeterminate" && i.DaysSinceLastWorklog >= 1);
    private int    TaskStaleCount      => TaskOnlyIssues.Count(i => i.StatusCategoryKey == "indeterminate" && i.DaysSinceLastWorklog >= 2);

    private double TaskThroughputPerDay => Report == null || Report.ElapsedDays <= 0 ? 0
        : TaskDoneCount / (double)Report.ElapsedDays;
    private double TaskNeededThroughputPerDay => EffectiveDaysRemaining <= 0 ? 0
        : (TaskOnlyIssues.Count - TaskDoneCount) / (double)EffectiveDaysRemaining;
    private bool   TaskThroughputBehind => TaskNeededThroughputPerDay > 0 && TaskThroughputPerDay < TaskNeededThroughputPerDay * 0.9;

    // ── Task-only health score (0-100) — same composite, tasks & sub-tasks only ─
    // "Quality" (open bugs) doesn't apply to a tasks-only view, so that 15% slot is
    // replaced by an execution factor: in-progress tasks stalled 2d+ erode the score.
    private int TaskHealthScore
    {
        get
        {
            if (Report == null || TaskOnlyIssues.Count == 0) return 0;

            double pace;
            if (Report.SprintProgressPct < 5 && TaskCompletionPct < 5)
                pace = 0.5;
            else
            {
                var gap = Report.SprintProgressPct - TaskCompletionPct; // pp
                pace = 1.0 - Math.Clamp(gap / 30.0, 0, 1);
            }

            double capacity;
            if (TaskRemainingHours <= 0)       capacity = 1.0;
            else if (TaskCapacityHours <= 0)   capacity = 0.0;
            else                               capacity = Math.Min(1.0, TaskCapacityHours / TaskRemainingHours);

            var taskAtRisk = AtRiskIssuesScoped.Count(IsTaskType);
            var risk = 1.0 - Math.Min(1.0, taskAtRisk / (double)Math.Max(1, TaskOnlyIssues.Count) * 2.0);

            var execution = 1.0 - Math.Min(1.0, TaskStaleCount / (double)Math.Max(1, TaskInProgressCount));

            var score = pace * 35 + capacity * 30 + risk * 20 + execution * 15;
            return Math.Clamp((int)Math.Round(score), 0, 100);
        }
    }

    private string TaskHealthBand => TaskHealthScore >= 75 ? "success" : TaskHealthScore >= 50 ? "warn" : "danger";
    private string TaskHealthMessage => TaskHealthScore switch
    {
        >= 85 => "Task delivery excellent — pace, capacity & execution aligned.",
        >= 75 => "Healthy task delivery — minor risks only.",
        >= 60 => "Task pace on track — watch stalled items.",
        >= 40 => "Task delivery at risk — re-balance or de-scope.",
        _     => "Critical — tasks are well behind the sprint pace."
    };

    // ── Health score (0-100) — weighted composite ────────────────────────────
    private int HealthScore
    {
        get
        {
            if (Report == null || ActiveIssues.Count == 0) return 0;

            // Pace: full credit only if the sprint is actually progressing.
            // If both elapsed and completion are ~0, we can't claim "on track" — score it neutral.
            double pace;
            if (Report.SprintProgressPct < 5 && CompletionPct < 5)
                pace = 0.5;
            else
            {
                var gap = Report.SprintProgressPct - CompletionPct; // pp
                pace = 1.0 - Math.Clamp(gap / 30.0, 0, 1); // 30pp behind → 0
            }

            // Capacity: 0 when remaining work exists but capacity is unknown/zero.
            double capacity;
            if (TotalRemainingHours <= 0)      capacity = 1.0;
            else if (CapacityHours <= 0)       capacity = 0.0;
            else                               capacity = Math.Min(1.0, CapacityHours / TotalRemainingHours);

            // Risk: scale by 2 so 50% at-risk drives factor to 0.
            var risk = 1.0 - Math.Min(1.0, AtRiskCount / (double)Math.Max(1, ActiveIssues.Count) * 2.0);

            // Quality: scale by 2 so 50% open bugs drives factor to 0.
            var quality = 1.0 - Math.Min(1.0, OpenBugsCount / (double)Math.Max(1, ActiveIssues.Count) * 2.0);

            var score = pace * 35 + capacity * 30 + risk * 20 + quality * 15;
            return Math.Clamp((int)Math.Round(score), 0, 100);
        }
    }

    private string HealthBand => HealthScore >= 75 ? "success" : HealthScore >= 50 ? "warn" : "danger";

    private string HealthMessage => HealthScore switch
    {
        >= 85 => "Sprint is performing exceptionally — pace, capacity and quality all aligned.",
        >= 75 => "Healthy sprint — minor risks but trajectory is solid.",
        >= 60 => "On track but watch the pacing — small adjustments will help.",
        >= 40 => "At risk — consider de-scoping or reallocating work to recover.",
        _     => "Critical — significant gap between commitment and current pace."
    };

    private string RagClass  => HealthScore >= 75 ? "v2-rag-g" : HealthScore >= 50 ? "v2-rag-a" : "v2-rag-r";
    private string RagText   => HealthScore >= 75 ? "On Track" : HealthScore >= 50 ? "At Risk" : "Behind";

