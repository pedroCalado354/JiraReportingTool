@page "/epic-forecast"
@rendermode InteractiveServer
@inject IJiraService JiraService
@inject IJSRuntime JS
@using JiraReportingTool.Models
@using ClosedXML.Excel

<PageTitle>Epic Delivery Forecast</PageTitle>

<h1 class="mb-3">Epic Delivery Forecast</h1>

<!-- ── Load form ─────────────────────────────────────────────────────────── -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-3 align-items-end flex-wrap">

            <!-- Step 1: Sprint ID -->
            <div class="col-auto">
                <label class="form-label small text-muted mb-1">Sprint ID</label>
                <div class="d-flex gap-2">
                    <input class="form-control" style="width:140px"
                           @bind="SprintId" @onkeyup="HandleSprintKeyUp"
                           placeholder="e.g. 6690" />
                    <button class="btn btn-outline-secondary" @onclick="LoadSprintEpics"
                            disabled="@(IsLoadingEpics || string.IsNullOrWhiteSpace(SprintId))">
                        @if (IsLoadingEpics)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                        }
                        Load
                    </button>
                </div>
            </div>

            <!-- Step 2: Epic dropdown (shown after sprint is loaded) -->
            @if (SprintEpics.Count > 0)
            {
                <div class="col-auto">
                    <label class="form-label small text-muted mb-1">Epic</label>
                    <select class="form-select" style="width:280px" @bind="EpicKey">
                        <option value="">— select an epic —</option>
                        @foreach (var epic in SprintEpics)
                        {
                            <option value="@epic.Key">@epic.Key — @epic.Name</option>
                        }
                    </select>
                </div>

                <div class="col-md-auto">
                    <label class="form-label small text-muted mb-1">
                        Productive hours / day &nbsp;<span class="badge bg-primary">@HoursPerDay h</span>
                    </label>
                    <div class="d-flex align-items-center gap-2">
                        <span class="small text-muted">1h</span>
                        <input type="range" class="form-range" min="1" max="12" step="0.5"
                               style="width:160px"
                               @bind="HoursPerDay" @bind:event="oninput" />
                        <span class="small text-muted">12h</span>
                    </div>
                </div>

                <div class="col-auto d-flex gap-2">
                    <button class="btn btn-primary" @onclick="LoadData"
                            disabled="@(IsLoading || string.IsNullOrWhiteSpace(EpicKey))">
                        @if (IsLoading)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                        }
                        Forecast
                    </button>
                    <button class="btn btn-outline-success" @onclick="OpenExportModal"
                            title="Export all epics for selected team members to Excel">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16" class="me-1">
                            <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5z"/>
                            <path d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708l3 3z"/>
                        </svg>
                        Export .xlsx
                    </button>
                </div>
            }
            else if (NoEpicsFound)
            {
                <div class="col-auto align-self-center">
                    <span class="text-warning small">No epics found in this sprint.</span>
                </div>
            }

        </div>
    </div>
</div>

@if (ErrorMessage != null)
{
    <div class="alert alert-danger">@ErrorMessage</div>
}

@if (Report != null)
{
    <!-- ── Sprint timeline bar ───────────────────────────────────────────── -->
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body py-2">
            <div class="d-flex flex-wrap gap-4 align-items-center small">
                <div><span class="text-muted">Sprint</span>&nbsp;<strong>@(string.IsNullOrEmpty(Report.SprintName) ? "—" : Report.SprintName)</strong></div>
                <div><span class="text-muted">Start</span>&nbsp;<strong>@(Report.StartDate?.ToString("MMM d, yyyy") ?? "—")</strong></div>
                <div><span class="text-muted">End</span>&nbsp;<strong>@(Report.EndDate?.ToString("MMM d, yyyy") ?? "—")</strong></div>
                <div><span class="text-muted">Today</span>&nbsp;<strong>@DateTime.Today.ToString("MMM d, yyyy")</strong></div>
                <div class="ms-auto">
                    <div class="d-flex align-items-center gap-2">
                        <div class="progress" style="height:8px;width:140px;border-radius:4px">
                            <div class="progress-bar bg-primary" style="width:@((int)Report.SprintProgressPct)%"></div>
                        </div>
                        <span class="text-muted">@((int)Report.SprintProgressPct)% elapsed ·
                            <input type="number" class="form-control form-control-sm d-inline-block text-center fw-bold"
                                   min="0" max="999" style="width:56px;padding:1px 4px"
                                   @bind="EffectiveDaysRemaining" @bind:event="oninput" />
                            weekdays left</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Member filter ────────────────────────────────────────────────── -->
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body py-2">
            <div class="d-flex align-items-center gap-3 flex-wrap">
                <label class="form-label small text-muted mb-0">Filter by member</label>
                <div style="width:210px">
                    <input class="form-control form-control-sm mb-1" placeholder="Search member…"
                           @bind="FilterMemberSearch" @bind:event="oninput" />
                    <select class="form-select form-select-sm" @bind="FilterMember">
                        <option value="">All members</option>
                        @foreach (var m in MemberOptions)
                        {
                            <option value="@m">@m</option>
                        }
                    </select>
                </div>
                @if (!string.IsNullOrEmpty(FilterMember))
                {
                    <button class="btn btn-sm btn-outline-secondary"
                            @onclick='() => { FilterMember = ""; FilterMemberSearch = ""; }'>
                        Clear
                    </button>
                    <span class="text-muted small">@FilteredIssues.Count of @Report.TotalIssues issues</span>
                }
                else
                {
                    <span class="text-muted small">@FilteredIssues.Count issues</span>
                }
            </div>
        </div>
    </div>

    <!-- ── Verdict + Capacity + Issues summary ──────────────────────────── -->
    <div class="row g-3 mb-4">

        <!-- Verdict -->
        <div class="col-md-4">
            <div class="card border-0 border-start border-4 border-@VerdictColor shadow-sm h-100">
                <div class="card-body d-flex flex-column align-items-center justify-content-center text-center py-4">
                    <div style="font-size:3rem;line-height:1">@VerdictIcon</div>
                    <div class="fs-3 fw-bold text-@VerdictColor mt-2">@Verdict</div>
                    <div class="text-muted small mt-1">@LoadedEpicKey delivery forecast</div>
                    @if (NoEstimateCount > 0)
                    {
                        <div class="alert alert-warning py-1 px-2 mt-3 mb-0 small w-100">
                            ⚠ @NoEstimateCount issue(s) have no remaining estimate — excluded from calculation
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Capacity analysis -->
        <div class="col-md-5">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body py-3">
                    <h6 class="text-muted text-uppercase small fw-semibold mb-3">Capacity Analysis</h6>

                    <div class="d-flex justify-content-between align-items-center mb-1 small">
                        <span>Remaining work</span>
                        <span class="fw-semibold @(IsFeasible ? "text-body" : "text-danger")">@TotalRemainingHours.ToString("F1") h</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-3 small">
                        <span>Available capacity</span>
                        <span>
                            <span class="fw-semibold text-success">@CapacityHours.ToString("F1") h</span>
                            <span class="text-muted ms-1">(@Report.DaysRemaining d × @HoursPerDay h)</span>
                        </span>
                    </div>

                    <div class="progress mb-2" style="height:18px;border-radius:9px">
                        <div class="progress-bar @(IsFeasible ? "bg-success" : "bg-danger") fw-semibold"
                             style="width:@FillPct%;font-size:12px;line-height:18px">
                            @if (FillPct > 12) { <text>@FillPct%</text> }
                        </div>
                    </div>

                    @if (!IsFeasible)
                    {
                        <div class="small text-danger mt-1">
                            Exceeds capacity by <strong>@(Math.Abs(BufferHours).ToString("F1")) h</strong>
                            (@OverflowPct% over budget)
                        </div>
                    }

                    <hr class="my-2" />
                    <div class="d-flex justify-content-between small">
                        <span class="text-muted">@(IsFeasible ? "Buffer" : "Deficit")</span>
                        <span class="fw-semibold @(IsFeasible ? "text-success" : "text-danger")">
                            @(BufferHours >= 0 ? "+" : "")@BufferHours.ToString("F1") h
                        </span>
                    </div>
                    @if (IsFeasible)
                    {
                        <div class="small text-muted mt-1">
                            At current pace: sprint ends with @BufferHours.ToString("F1") h spare capacity
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Issue status summary -->
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body py-3">
                    <h6 class="text-muted text-uppercase small fw-semibold mb-3">Issue Status</h6>
                    <div class="d-flex flex-column gap-2 small">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="badge bg-success">Done</span>
                            <strong>@FilteredDoneCount</strong>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="badge bg-primary">In Progress</span>
                            <strong>@FilteredInProgressCount</strong>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="badge bg-secondary">To Do</span>
                            <strong>@FilteredToDoCount</strong>
                        </div>
                        <hr class="my-1" />
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-muted">Total</span>
                            <strong>@FilteredIssues.Count</strong>
                        </div>
                    </div>
                    <div class="progress mt-3" style="height:8px;border-radius:4px">
                        <div class="progress-bar bg-success" style="width:@Pct(FilteredDoneCount, FilteredIssues.Count)%"></div>
                        <div class="progress-bar bg-primary" style="width:@Pct(FilteredInProgressCount, FilteredIssues.Count)%"></div>
                    </div>
                    <div class="small text-muted text-center mt-1">@((int)FilteredCompletionPct)% complete</div>
                </div>
            </div>
        </div>

    </div>

    <!-- ── Per-assignee forecast ─────────────────────────────────────────── -->
    @if (AssigneeBreakdown.Any())
    {
        <h6 class="text-muted text-uppercase small fw-semibold mb-2">Assignee Forecast</h6>
        <div class="row g-3 mb-4">
            @foreach (var am in AssigneeBreakdown)
            {
                var amFill = CapacityHours > 0 ? (int)Math.Min(am.RemainingHours / CapacityHours * 100, 100) : 0;
                var amFeasible = am.RemainingHours <= CapacityHours;
                var amColor = !amFeasible ? "danger" : am.RemainingHours >= CapacityHours * 0.85 ? "warning" : "success";

                <div class="col-md-4 col-lg-3">
                    <div class="card border-0 shadow-sm border-start border-3 border-@amColor h-100">
                        <div class="card-body py-3">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center fw-bold flex-shrink-0"
                                     style="width:34px;height:34px;font-size:12px">
                                    @Initials(am.Name)
                                </div>
                                <div class="fw-semibold small">@am.Name</div>
                            </div>
                            <div class="d-flex justify-content-between small mb-1">
                                <span class="text-muted">Remaining</span>
                                <span class="fw-semibold @(amFeasible ? "" : "text-danger")">@am.RemainingHours.ToString("F1") h</span>
                            </div>
                            <div class="d-flex justify-content-between small mb-2">
                                <span class="text-muted">Capacity</span>
                                <span>@CapacityHours.ToString("F1") h</span>
                            </div>
                            <div class="progress mb-2" style="height:8px;border-radius:4px">
                                <div class="progress-bar bg-@amColor" style="width:@amFill%"></div>
                            </div>
                            <div class="small text-muted">
                                @am.Done done · @am.InProgress in progress · @am.ToDo to do
                            </div>
                            @if (!amFeasible)
                            {
                                <div class="small text-danger mt-1 fw-semibold">
                                    +@((am.RemainingHours - CapacityHours).ToString("F1")) h over capacity
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <!-- ── Issues table ──────────────────────────────────────────────────── -->
    <h6 class="text-muted text-uppercase small fw-semibold mb-2">All Issues</h6>
    <div class="table-responsive">
        <table class="table table-sm align-middle small">
            <thead class="table-light">
                <tr>
                    <th>Key</th>
                    <th>Summary</th>
                    <th>Assignee</th>
                    <th>Type</th>
                    <th>Status</th>
                    <th>Estimate</th>
                    <th>Logged</th>
                    <th>Remaining</th>
                    <th>Progress</th>
                    <th class="text-center">Feasible?</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var issue in SortedIssues)
                {
                    var pct = IssuePct(issue);
                    var issueFeasible = issue.StatusCategoryKey == "done"
                        || issue.RemainingEstimateSeconds == 0
                        || issue.RemainingEstimateSeconds <= CapacityHours * 3600;
                    var hasNoEstimate = issue.StatusCategoryKey != "done" && issue.RemainingEstimateSeconds == 0 && issue.OriginalEstimateSeconds == 0;

                    <tr class="@(issue.StatusCategoryKey == "done" ? "table-success opacity-75" : !issueFeasible ? "table-danger" : "")">
                        <td class="fw-semibold text-nowrap">@issue.Key</td>
                        <td>@issue.Summary</td>
                        <td class="text-nowrap">@issue.Assignee</td>
                        <td class="text-nowrap small text-muted">@issue.IssueType</td>
                        <td><span class="badge @StatusBadge(issue.Status, issue.StatusCategoryKey)">@issue.Status</span></td>
                        <td class="text-nowrap">@(issue.OriginalEstimate == "-" ? "—" : issue.OriginalEstimate)</td>
                        <td class="text-nowrap">@(issue.TimeSpent == "-" ? "—" : issue.TimeSpent)</td>
                        <td class="text-nowrap @(issue.StatusCategoryKey != "done" && !issueFeasible && issue.RemainingEstimateSeconds > 0 ? "text-danger fw-semibold" : "")">
                            @if (issue.StatusCategoryKey == "done")
                            {
                                <span class="text-muted">—</span>
                            }
                            else if (hasNoEstimate)
                            {
                                <span class="text-warning">No estimate</span>
                            }
                            else
                            {
                                @(issue.RemainingEstimate == "-" ? "—" : issue.RemainingEstimate)
                            }
                        </td>
                        <td style="min-width:90px">
                            <div class="d-flex align-items-center gap-1">
                                <div class="progress flex-grow-1" style="height:5px;border-radius:3px">
                                    <div class="progress-bar @(pct > 100 ? "bg-danger" : pct == 100 ? "bg-success" : "bg-primary")"
                                         style="width:@Math.Min(pct, 100)%"></div>
                                </div>
                                <span class="text-muted text-nowrap" style="min-width:32px">@pct%</span>
                            </div>
                        </td>
                        <td class="text-center">
                            @if (issue.StatusCategoryKey == "done")
                            {
                                <span class="text-success fw-bold">✓</span>
                            }
                            else if (hasNoEstimate)
                            {
                                <span class="text-warning fw-bold" title="No estimate — cannot determine feasibility">?</span>
                            }
                            else if (!issueFeasible)
                            {
                                <span class="text-danger fw-bold" title="Remaining estimate exceeds sprint capacity">✗</span>
                            }
                            else
                            {
                                <span class="text-success fw-bold">✓</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot class="table-light fw-semibold small">
                <tr>
                    <td colspan="5">Totals</td>
                    <td class="text-nowrap">@Fmt(FilteredIssues.Sum(i => i.OriginalEstimateSeconds))</td>
                    <td class="text-nowrap">@Fmt(FilteredIssues.Sum(i => i.TimeSpentSeconds))</td>
                    <td class="text-nowrap @(IsFeasible ? "" : "text-danger")">@Fmt(FilteredIssues.Where(i => i.StatusCategoryKey != "done").Sum(i => i.RemainingEstimateSeconds))</td>
                    <td colspan="2"></td>
                </tr>
            </tfoot>
        </table>
    </div>
}

<!-- ── Export Modal ──────────────────────────────────────────────────────── -->
@if (ShowExportModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.45)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header">
                    <h5 class="modal-title fw-semibold">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="#198754" viewBox="0 0 16 16" class="me-2">
                            <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5z"/>
                            <path d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708l3 3z"/>
                        </svg>
                        Export Forecast to Excel
                    </h5>
                    <button type="button" class="btn-close" @onclick="() => ShowExportModal = false"></button>
                </div>
                <div class="modal-body">
                    <p class="small text-muted mb-3">
                        Exports <strong>all epics</strong> in sprint
                        <strong>@(SprintAllIssues?.SprintName is { Length: > 0 } sn ? sn : SprintId)</strong>
                        for the selected team members.
                        Capacity: <strong>@ExportDaysRemaining d × @HoursPerDay h = @ExportCapacityHours.ToString("F1") h</strong>.
                        Two sheets: <em>Forecast Summary</em> (one row per epic &amp; member) and <em>Issues Detail</em>.
                    </p>

                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <label class="form-label small fw-semibold mb-0">Select team members</label>
                        <div class="d-flex gap-2">
                            <button class="btn btn-link btn-sm p-0 text-decoration-none"
                                    @onclick='() => ExportSelectedMembers = new HashSet<string>(ExportAllMembers)'>
                                All
                            </button>
                            <span class="text-muted small">/</span>
                            <button class="btn btn-link btn-sm p-0 text-decoration-none"
                                    @onclick="() => ExportSelectedMembers.Clear()">
                                None
                            </button>
                        </div>
                    </div>

                    <div class="border rounded p-2" style="max-height:240px;overflow-y:auto">
                        @foreach (var member in ExportAllMembers)
                        {
                            var isChecked = ExportSelectedMembers.Contains(member);
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="exp_@member"
                                       checked="@isChecked"
                                       @onchange="e => ToggleExportMember(member, (bool)(e.Value ?? false))" />
                                <label class="form-check-label small" for="exp_@member">@member</label>
                            </div>
                        }
                    </div>
                    <div class="text-muted small mt-2">@ExportSelectedMembers.Count of @ExportAllMembers.Count member(s) selected</div>

                    <hr class="my-3" />

                    <div>
                        <label class="form-label small fw-semibold mb-1">Exclude epics (comma-separated keys)</label>
                        <input class="form-control form-control-sm" placeholder="e.g. JM-10, JM-42, JM-77"
                               @bind="ExportIgnoredEpicsInput" />
                        <div class="text-muted mt-1" style="font-size:0.72rem">
                            Issues belonging to these epics will be omitted from the export.
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => ShowExportModal = false">Cancel</button>
                    <button class="btn btn-success" @onclick="ExportToExcel"
                            disabled="@(IsExporting || ExportSelectedMembers.Count == 0)">
                        @if (IsExporting)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                        }
                        else
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16" class="me-1">
                                <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5z"/>
                                <path d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708l3 3z"/>
                            </svg>
                        }
                        Export .xlsx
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private string EpicKey = "";
    private string SprintId = "";
    private double HoursPerDay = 6;
    private bool IsLoading = false;
    private bool IsLoadingEpics = false;
    private bool NoEpicsFound = false;
    private string? ErrorMessage;
    private SprintReport? Report;
    private string LoadedEpicKey = "";
    private List<EpicSummary> SprintEpics = [];
    private int EffectiveDaysRemaining = 0;
    private SprintReport? SprintAllIssues;   // all sprint issues — loaded alongside epics

    // ── Export state ─────────────────────────────────────────────────────────
    private bool ShowExportModal;
    private bool IsExporting;
    private HashSet<string> ExportSelectedMembers = [];

    private string ExportIgnoredEpicsInput = "";

    // Team members come from the full-sprint data (available once sprint is loaded)
    private List<string> ExportAllMembers => SprintAllIssues?.Issues
        .Where(i => i.Assignee != "Unassigned")
        .Select(i => i.Assignee).Distinct().Order().ToList() ?? [];

    // Days / capacity for export — respects user override if a forecast is loaded
    private int ExportDaysRemaining => Report != null
        ? EffectiveDaysRemaining
        : SprintAllIssues?.DaysRemaining ?? 0;
    private double ExportCapacityHours => ExportDaysRemaining * HoursPerDay;

    // ── Member filter ─────────────────────────────────────────────────────────
    private string FilterMember = "";
    private string FilterMemberSearch = "";

    private List<SprintIssue> FilteredIssues => Report?.Issues
        .Where(i => !i.Key.Contains("JSSUPPORT", StringComparison.OrdinalIgnoreCase)
                 && (string.IsNullOrEmpty(FilterMember) || i.Assignee == FilterMember))
        .ToList() ?? [];

    private IEnumerable<string> MemberOptions => Report?.Issues
        .Select(i => i.Assignee).Distinct().Order()
        .Where(a => string.IsNullOrEmpty(FilterMemberSearch) || a.Contains(FilterMemberSearch, StringComparison.OrdinalIgnoreCase))
        ?? Enumerable.Empty<string>();

    private int FilteredDoneCount => FilteredIssues.Count(i => i.StatusCategoryKey == "done");
    private int FilteredInProgressCount => FilteredIssues.Count(i => i.StatusCategoryKey == "indeterminate");
    private int FilteredToDoCount => FilteredIssues.Count(i => i.StatusCategoryKey == "new");
    private double FilteredCompletionPct => FilteredIssues.Count == 0 ? 0
        : (double)FilteredDoneCount / FilteredIssues.Count * 100;

    // ── Computed metrics ─────────────────────────────────────────────────────
    private double TotalRemainingHours => FilteredIssues
        .Where(i => i.StatusCategoryKey != "done")
        .Sum(i => (double)i.RemainingEstimateSeconds) / 3600.0;

    private int NoEstimateCount => FilteredIssues
        .Count(i => i.StatusCategoryKey != "done" && i.RemainingEstimateSeconds == 0 && i.OriginalEstimateSeconds == 0);

    private double CapacityHours => EffectiveDaysRemaining * HoursPerDay;

    private double BufferHours => CapacityHours - TotalRemainingHours;

    private bool IsFeasible => TotalRemainingHours <= CapacityHours;

    private int FillPct => CapacityHours > 0
        ? (int)Math.Min(TotalRemainingHours / CapacityHours * 100, 100)
        : 0;

    private int OverflowPct => CapacityHours > 0
        ? (int)((TotalRemainingHours - CapacityHours) / CapacityHours * 100)
        : 0;

    private string Verdict => IsFeasible
        ? (BufferHours >= CapacityHours * 0.15 ? "On Track" : "At Risk")
        : "Not Feasible";

    private string VerdictColor => Verdict switch
    {
        "On Track"  => "success",
        "At Risk"   => "warning",
        _           => "danger"
    };

    private string VerdictIcon => Verdict switch
    {
        "On Track"  => "✅",
        "At Risk"   => "⚠️",
        _           => "❌"
    };

    // ── Per-assignee breakdown ────────────────────────────────────────────────
    private record AssigneeMetrics(string Name, double RemainingHours, int Done, int InProgress, int ToDo);

    private List<AssigneeMetrics> AssigneeBreakdown => FilteredIssues
        .GroupBy(i => i.Assignee)
        .Select(g => new AssigneeMetrics(
            g.Key,
            g.Where(i => i.StatusCategoryKey != "done").Sum(i => i.RemainingEstimateSeconds) / 3600.0,
            g.Count(i => i.StatusCategoryKey == "done"),
            g.Count(i => i.StatusCategoryKey == "indeterminate"),
            g.Count(i => i.StatusCategoryKey == "new")
        ))
        .OrderByDescending(a => a.RemainingHours)
        .ToList();

    private IEnumerable<SprintIssue> SortedIssues =>
FilteredIssues
    .OrderBy(i => i.StatusCategoryKey switch
    {
        "indeterminate" => 0,
        "new" => 1,
        _ => 2
    })
    .ThenByDescending(i => i.RemainingEstimateSeconds);
    // ── Load ─────────────────────────────────────────────────────────────────
    private async Task LoadSprintEpics()
    {
        if (!int.TryParse(SprintId.Trim(), out var sprintId)) return;

        IsLoadingEpics = true;
        NoEpicsFound = false;
        SprintEpics = [];
        SprintAllIssues = null;
        EpicKey = "";
        Report = null;
        ErrorMessage = null;

        try
        {
            // Load epics list and all sprint issues in parallel
            var epicsTask = JiraService.GetEpicsInSprintAsync(sprintId);
            var allIssuesTask = JiraService.GetDeliveryDataAsync(sprintId);
            await Task.WhenAll(epicsTask, allIssuesTask);

            SprintEpics = epicsTask.Result;
            SprintAllIssues = allIssuesTask.Result;
            NoEpicsFound = SprintEpics.Count == 0;
        }
        catch (HttpRequestException ex) { ErrorMessage = $"Failed to load sprint: {ex.Message}"; }
        catch (Exception ex)            { ErrorMessage = $"Unexpected error: {ex.Message}"; }
        finally { IsLoadingEpics = false; }
    }

    private async Task LoadData()
    {
        if (string.IsNullOrWhiteSpace(EpicKey) || !int.TryParse(SprintId.Trim(), out var sprintId)) return;

        IsLoading = true;
        ErrorMessage = null;
        Report = null;
        FilterMember = "";
        FilterMemberSearch = "";

        try
        {
            LoadedEpicKey = EpicKey.Trim().ToUpper();
            Report = await JiraService.GetEpicSprintForecastAsync(LoadedEpicKey, sprintId);
            EffectiveDaysRemaining = Report.DaysRemaining;
            if (Report.TotalIssues == 0)
                ErrorMessage = $"No issues found for epic {LoadedEpicKey} in sprint {sprintId}. Check the epic key and sprint ID.";
        }
        catch (HttpRequestException ex) { ErrorMessage = $"Failed to load: {ex.Message}"; }
        catch (Exception ex)            { ErrorMessage = $"Unexpected error: {ex.Message}"; }
        finally { IsLoading = false; }
    }

    private async Task HandleSprintKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await LoadSprintEpics();
    }

    // ── Helpers ──────────────────────────────────────────────────────────────
    private static int IssuePct(SprintIssue issue)
    {
        if (issue.StatusCategoryKey == "done") return 100;
        if (issue.OriginalEstimateSeconds == 0) return 0;
        return (int)((double)issue.TimeSpentSeconds / issue.OriginalEstimateSeconds * 100);
    }

    private static string Fmt(int seconds)
    {
        if (seconds <= 0) return "—";
        var h = seconds / 3600;
        var m = seconds % 3600 / 60;
        return m == 0 ? $"{h}h" : $"{h}h {m}m";
    }

    private static int Pct(int part, int total) =>
        total == 0 ? 0 : (int)((double)part / total * 100);

    private static string Initials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}".ToUpper()
            : name.Length >= 2 ? name[..2].ToUpper() : name.ToUpper();
    }

    private static string StatusBadge(string status, string categoryKey) => (status, categoryKey) switch
    {
        ("Dev Ready", _)    => "bg-info text-dark",
        ("In Review", _)    => "text-bg-warning",
        (_, "done")         => "bg-success",
        (_, "indeterminate")=> "bg-primary",
        _                   => "bg-secondary"
    };

    // ── Export ───────────────────────────────────────────────────────────────

    private void OpenExportModal()
    {
        ExportSelectedMembers = new HashSet<string>(ExportAllMembers);
        ShowExportModal = true;
    }

    private void ToggleExportMember(string member, bool selected)
    {
        if (selected) ExportSelectedMembers.Add(member);
        else          ExportSelectedMembers.Remove(member);
    }

    private async Task ExportToExcel()
    {
        if (SprintAllIssues == null || ExportSelectedMembers.Count == 0) return;

        IsExporting = true;
        StateHasChanged();

        try
        {
            // Parse ignored epic keys from the input field
            var ignoredEpics = ExportIgnoredEpicsInput
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Select(k => k.ToUpperInvariant())
                .ToHashSet();

            // All sprint issues for selected members — exclude Epics, JSSUPPORT tasks, and manually ignored epics
            var issues = SprintAllIssues.Issues
                .Where(i => ExportSelectedMembers.Contains(i.Assignee)
                         && !string.Equals(i.IssueType, "Epic", StringComparison.OrdinalIgnoreCase)
                         && !i.Key.Contains("JSSUPPORT", StringComparison.OrdinalIgnoreCase)
                         && (ignoredEpics.Count == 0 || !ignoredEpics.Contains(i.EpicKey.ToUpperInvariant())))
                .ToList();

            using var wb = new XLWorkbook();
            BuildSummarySheet(wb.Worksheets.Add("Forecast Summary"), issues);
            BuildDetailSheet(wb.Worksheets.Add("Issues Detail"), issues);

            using var ms = new MemoryStream();
            wb.SaveAs(ms);
            var base64   = Convert.ToBase64String(ms.ToArray());
            var sprintLabel = SprintAllIssues.SprintName is { Length: > 0 } sn
                ? sn.Replace(" ", "_").Replace("/", "-")
                : SprintId;
            var fileName = $"EpicForecast_{sprintLabel}_{DateTime.Today:yyyyMMdd}.xlsx";
            const string mime = "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet";

            await JS.InvokeVoidAsync("downloadBase64File", base64, fileName, mime);
            ShowExportModal = false;
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Export failed: {ex.Message}";
        }
        finally
        {
            IsExporting = false;
        }
    }

    private void BuildSummarySheet(IXLWorksheet ws, List<SprintIssue> issues)
    {
        var capacityH = ExportCapacityHours;
        var days      = ExportDaysRemaining;
        var sprintName = Report?.SprintName ?? SprintAllIssues?.SprintName ?? SprintId;

        // ── Meta block ────────────────────────────────────────────────────────
        void Meta(int row, string label, string value)
        {
            ws.Cell(row, 1).Value = label;
            ws.Cell(row, 1).Style.Font.Bold = true;
            ws.Cell(row, 1).Style.Font.FontColor = XLColor.FromHtml("#6c757d");
            ws.Cell(row, 2).Value = value;
        }

        Meta(1, "Sprint",           sprintName);
        Meta(2, "Days Remaining",   days.ToString());
        Meta(3, "Hours / Day",      HoursPerDay.ToString("F1"));
        Meta(4, "Capacity (h)",     Math.Round(capacityH, 1).ToString("F1"));
        Meta(5, "Members exported", string.Join(", ", ExportSelectedMembers.Order()));
        Meta(6, "Exported",         DateTime.Now.ToString("yyyy-MM-dd HH:mm"));

        // ── Column group labels (row 8) ────────────────────────────────────────
        ws.Cell(8, 4).Value = "─── Capacity Analysis ───";
        ws.Cell(8, 4).Style.Font.Italic = true;
        ws.Cell(8, 4).Style.Font.FontColor = XLColor.FromHtml("#4361ee");
        ws.Range(8, 4, 8, 8).Merge();

        ws.Cell(8, 9).Value = "─── Delivery Forecast ───";
        ws.Cell(8, 9).Style.Font.Italic = true;
        ws.Cell(8, 9).Style.Font.FontColor = XLColor.FromHtml("#198754");
        ws.Range(8, 9, 8, 13).Merge();

        // ── Headers (row 9) ───────────────────────────────────────────────────
        var headers = new[]
        {
            "Epic Key", "Epic Description", "Team Member",
            "Remaining (h)", "Capacity (h)", "Fill %", "Feasible?", "Buffer / Deficit (h)",
            "Done", "In Progress", "To Do", "Total Issues", "Completion %"
        };

        for (int i = 0; i < headers.Length; i++)
        {
            var hCell = ws.Cell(9, i + 1);
            hCell.Value = headers[i];
            hCell.Style.Font.Bold = true;
            hCell.Style.Fill.BackgroundColor = XLColor.FromHtml("#1e3a5f");
            hCell.Style.Font.FontColor = XLColor.White;
            hCell.Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;
            hCell.Style.Alignment.WrapText = true;
        }

        ws.SheetView.FreezeRows(9);

        // ── Data rows — one per (Epic, Team Member) ───────────────────────────
        var rows = issues
            .GroupBy(i => new { i.EpicKey, EpicDesc = i.EpicName, i.Assignee })
            .OrderBy(g => string.IsNullOrEmpty(g.Key.EpicKey) ? "ZZZ" : g.Key.EpicKey)
            .ThenBy(g => g.Key.Assignee)
            .Select(g => new
            {
                g.Key.EpicKey,
                g.Key.EpicDesc,
                g.Key.Assignee,
                RemH  = g.Where(i => i.StatusCategoryKey != "done").Sum(i => i.RemainingEstimateSeconds) / 3600.0,
                Done  = g.Count(i => i.StatusCategoryKey == "done"),
                InProg= g.Count(i => i.StatusCategoryKey == "indeterminate"),
                ToDo  = g.Count(i => i.StatusCategoryKey == "new"),
                Total = g.Count()
            });

        int row = 10;
        string? lastEpic = null;

        foreach (var r in rows)
        {
            var feasible      = r.RemH <= capacityH;
            var buffer        = Math.Round(capacityH - r.RemH, 2);
            var fillPct       = capacityH > 0 ? (int)Math.Min(r.RemH / capacityH * 100, 100) : 0;
            var completionPct = r.Total > 0 ? Math.Round((double)r.Done / r.Total * 100, 1) : 0.0;

            // Alternate shading per epic group
            bool shade = lastEpic != null && lastEpic != r.EpicKey
                ? !((row - 10) % 2 == 0)
                : (row - 10) % 2 == 0;
            if (shade)
                ws.Row(row).Style.Fill.BackgroundColor = XLColor.FromHtml("#f0f4ff");
            lastEpic = r.EpicKey;

            int col = 1;
            ws.Cell(row, col++).Value = string.IsNullOrEmpty(r.EpicKey) ? "No Epic" : r.EpicKey;
            ws.Cell(row, col++).Value = string.IsNullOrEmpty(r.EpicDesc) || r.EpicDesc == "No Epic"
                ? (string.IsNullOrEmpty(r.EpicKey) ? "No Epic" : r.EpicKey)
                : r.EpicDesc;
            ws.Cell(row, col++).Value = r.Assignee;
            ws.Cell(row, col++).Value = Math.Round(r.RemH, 2);
            ws.Cell(row, col++).Value = Math.Round(capacityH, 2);
            ws.Cell(row, col++).Value = fillPct;

            var feasCell = ws.Cell(row, col++);
            feasCell.Value = feasible ? "Yes" : "No";
            feasCell.Style.Fill.BackgroundColor = feasible ? XLColor.FromHtml("#d1e7dd") : XLColor.FromHtml("#f8d7da");
            feasCell.Style.Font.FontColor        = feasible ? XLColor.FromHtml("#0a3622") : XLColor.FromHtml("#58151c");
            feasCell.Style.Font.Bold = true;
            feasCell.Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;

            var bufCell = ws.Cell(row, col++);
            bufCell.Value = buffer;
            bufCell.Style.Font.FontColor = buffer >= 0 ? XLColor.FromHtml("#0a3622") : XLColor.FromHtml("#58151c");

            ws.Cell(row, col++).Value = r.Done;
            ws.Cell(row, col++).Value = r.InProg;
            ws.Cell(row, col++).Value = r.ToDo;
            ws.Cell(row, col++).Value = r.Total;
            ws.Cell(row, col++).Value = completionPct;

            row++;
        }

        ws.Columns().AdjustToContents();
        ws.Column(2).Width = Math.Min(ws.Column(2).Width, 50);
        ws.Row(9).Height = 28;
    }

    private void BuildDetailSheet(IXLWorksheet ws, List<SprintIssue> issues)
    {
        var capacityH = ExportCapacityHours;

        // ── Headers ───────────────────────────────────────────────────────────
        var headers = new[]
        {
            "Epic Key", "Epic Description", "Team Member",
            "Issue Key", "Summary", "Issue Type", "Status",
            "Original Estimate", "Time Spent", "Remaining", "Progress %", "Feasible?"
        };

        for (int i = 0; i < headers.Length; i++)
        {
            var hCell = ws.Cell(1, i + 1);
            hCell.Value = headers[i];
            hCell.Style.Font.Bold = true;
            hCell.Style.Fill.BackgroundColor = XLColor.FromHtml("#1e3a5f");
            hCell.Style.Font.FontColor = XLColor.White;
        }

        ws.SheetView.FreezeRows(1);

        // ── Data rows ─────────────────────────────────────────────────────────
        var sorted = issues
            .OrderBy(i => string.IsNullOrEmpty(i.EpicKey) ? "ZZZ" : i.EpicKey)
            .ThenBy(i => i.Assignee)
            .ThenBy(i => i.StatusCategoryKey switch { "indeterminate" => 0, "new" => 1, _ => 2 })
            .ThenByDescending(i => i.RemainingEstimateSeconds);

        int row = 2;
        foreach (var issue in sorted)
        {
            var isDone        = issue.StatusCategoryKey == "done";
            var hasNoEstimate = !isDone && issue.RemainingEstimateSeconds == 0 && issue.OriginalEstimateSeconds == 0;
            var issueFeasible = isDone || issue.RemainingEstimateSeconds == 0
                                || issue.RemainingEstimateSeconds <= capacityH * 3600;
            var pct           = IssuePct(issue);
            var epicDesc      = string.IsNullOrEmpty(issue.EpicName) || issue.EpicName == "No Epic"
                ? (string.IsNullOrEmpty(issue.EpicKey) ? "No Epic" : issue.EpicKey)
                : issue.EpicName;

            if (isDone)
                ws.Row(row).Style.Fill.BackgroundColor = XLColor.FromHtml("#f0fff4");
            else if (row % 2 == 0)
                ws.Row(row).Style.Fill.BackgroundColor = XLColor.FromHtml("#f8f9fa");

            int col = 1;
            ws.Cell(row, col++).Value = string.IsNullOrEmpty(issue.EpicKey) ? "No Epic" : issue.EpicKey;
            ws.Cell(row, col++).Value = epicDesc;
            ws.Cell(row, col++).Value = issue.Assignee;
            ws.Cell(row, col++).Value = issue.Key;
            ws.Cell(row, col++).Value = issue.Summary;
            ws.Cell(row, col++).Value = issue.IssueType;
            ws.Cell(row, col++).Value = issue.Status;
            ws.Cell(row, col++).Value = issue.OriginalEstimate == "-" ? "" : issue.OriginalEstimate;
            ws.Cell(row, col++).Value = issue.TimeSpent == "-" ? "" : issue.TimeSpent;
            ws.Cell(row, col++).Value = isDone ? "—"
                : hasNoEstimate ? "No estimate"
                : issue.RemainingEstimate == "-" ? "" : issue.RemainingEstimate;
            ws.Cell(row, col++).Value = pct;

            var feasCell = ws.Cell(row, col++);
            if (isDone)
            {
                feasCell.Value = "Done";
                feasCell.Style.Fill.BackgroundColor = XLColor.FromHtml("#d1e7dd");
                feasCell.Style.Font.FontColor        = XLColor.FromHtml("#0a3622");
            }
            else if (hasNoEstimate)
            {
                feasCell.Value = "No estimate";
                feasCell.Style.Fill.BackgroundColor = XLColor.FromHtml("#fff3cd");
                feasCell.Style.Font.FontColor        = XLColor.FromHtml("#664d03");
            }
            else if (!issueFeasible)
            {
                feasCell.Value = "No";
                feasCell.Style.Fill.BackgroundColor = XLColor.FromHtml("#f8d7da");
                feasCell.Style.Font.FontColor        = XLColor.FromHtml("#58151c");
                feasCell.Style.Font.Bold = true;
            }
            else
            {
                feasCell.Value = "Yes";
                feasCell.Style.Fill.BackgroundColor = XLColor.FromHtml("#d1e7dd");
                feasCell.Style.Font.FontColor        = XLColor.FromHtml("#0a3622");
            }

            feasCell.Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;
            row++;
        }

        ws.Columns().AdjustToContents();
        ws.Column(2).Width = Math.Min(ws.Column(2).Width, 50);
        ws.Column(5).Width = Math.Min(ws.Column(5).Width, 60);
        ws.Row(1).Height = 22;
    }
