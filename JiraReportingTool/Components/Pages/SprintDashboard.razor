@page "/sprint"
@rendermode InteractiveServer
@inject JiraService JiraService
@using JiraReportingTool.Models

<PageTitle>Sprint Dashboard</PageTitle>

<h1 class="mb-4">Sprint Dashboard</h1>

<div class="row g-2 mb-4">
    <div class="col-auto">
        <input class="form-control"
               style="width: 200px"
               @bind="EpicKey"
               @onkeyup="HandleKeyUp"
               placeholder="Epic key (e.g. JM-123)" />
        <input class="form-control"
               style="width: 200px"
               @bind="SprintId"
               @onkeyup="HandleKeyUp"
               placeholder="Sprint ID (e.g. 6690)" />
    </div>
    <div class="col-auto">
        <button class="btn btn-primary" @onclick="LoadSprint" disabled="@IsLoading">
            @if (IsLoading)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
            }
            Load Sprint
        </button>
    </div>
</div>

@if (ErrorMessage != null)
{
    <div class="alert alert-danger">@ErrorMessage</div>
}

@if (Report != null)
{
    <!-- Sprint header -->
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div>
                    <h4 class="mb-0">@(string.IsNullOrEmpty(Report.SprintName) ? "Active Sprint" : Report.SprintName)</h4>
                    @if (Report.StartDate.HasValue && Report.EndDate.HasValue)
                    {
                        <span class="text-muted small">
                            @Report.StartDate.Value.ToString("dd MMM") → @Report.EndDate.Value.ToString("dd MMM yyyy")
                            &nbsp;·&nbsp;
                        </span>
                    }
                    <span class="text-muted small">@Report.ElapsedDays days elapsed · @Report.DaysRemaining days remaining</span>
                </div>
                <span class="badge @RiskBadge(Report.RiskLevel) fs-6">@RiskLabel(Report.RiskLevel)</span>
            </div>

            <!-- Sprint timeline bar -->
            <div class="mt-3">
                <div class="d-flex justify-content-between small text-muted mb-1">
                    <span>Sprint progress</span>
                    <span>@((int)Report.SprintProgressPct)%</span>
                </div>
                <div class="progress" style="height:6px; border-radius:4px; background:#e9ecef;">
                    <div class="progress-bar bg-dark opacity-50"
                         style="width:@((int)Report.SprintProgressPct)%">
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- KPI cards -->
    <div class="row g-3 mb-3">
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm text-center h-100">
                <div class="card-body py-3">
                    <div class="fs-2 fw-bold">@Report.TotalIssues</div>
                    <div class="text-muted small">Total Issues</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm text-center h-100 border-success border-start border-3">
                <div class="card-body py-3">
                    <div class="fs-2 fw-bold text-success">@Report.DoneCount</div>
                    <div class="text-muted small">Done</div>
                    @if (Report.TotalIssues > 0)
                    {
                        <div class="text-success small">@((int)Report.CompletionPct)%</div>
                    }
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm text-center h-100 border-primary border-start border-3">
                <div class="card-body py-3">
                    <div class="fs-2 fw-bold text-primary">@Report.InProgressCount</div>
                    <div class="text-muted small">In Progress</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            @if (Report.HasStoryPoints)
            {
                <div class="card border-0 shadow-sm text-center h-100 border-warning border-start border-3">
                    <div class="card-body py-3">
                        <div class="fs-2 fw-bold text-warning">@Report.DoneStoryPoints<span class="fs-5 text-muted">/@Report.TotalStoryPoints</span></div>
                        <div class="text-muted small">Story Points</div>
                    </div>
                </div>
            }
            else
            {
                <div class="card border-0 shadow-sm text-center h-100 border-secondary border-start border-3">
                    <div class="card-body py-3">
                        <div class="fs-2 fw-bold text-secondary">@Report.ToDoCount</div>
                        <div class="text-muted small">To Do</div>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Completion progress bar -->
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body py-2">
            <div class="d-flex justify-content-between small text-muted mb-1">
                <span>Completion</span>
                <span>@Report.DoneCount / @Report.TotalIssues issues done</span>
            </div>
            <div class="progress" style="height:12px; border-radius:6px;">
                <div class="progress-bar bg-success"
                     style="width:@Pct(Report.DoneCount, Report.TotalIssues)%"
                     title="Done">
                </div>
                <div class="progress-bar bg-primary"
                     style="width:@Pct(Report.InProgressCount, Report.TotalIssues)%"
                     title="In Progress">
                </div>
                <div class="progress-bar bg-secondary opacity-25"
                     style="width:@Pct(Report.ToDoCount, Report.TotalIssues)%"
                     title="To Do">
                </div>
            </div>
            <div class="d-flex gap-3 mt-2 small">
                <span><span class="badge bg-success me-1">@Report.DoneCount</span>Done</span>
                <span><span class="badge bg-primary me-1">@Report.InProgressCount</span>In Progress</span>
                <span><span class="badge bg-secondary me-1">@Report.ToDoCount</span>To Do</span>
                @if (Report.TotalOriginalEstimateSeconds > 0)
                {
                    <span class="ms-auto text-muted">
                        <strong>@Fmt(Report.TotalTimeSpentSeconds)</strong> logged / @Fmt(Report.TotalOriginalEstimateSeconds) estimated
                    </span>
                }
            </div>
        </div>
    </div>

    <!-- Tabs -->
    <ul class="nav nav-tabs mb-0" role="tablist">
        <li class="nav-item">
            <button class="nav-link @(ActiveTab == "overview" ? "active" : "")"
                    @onclick='() => ActiveTab = "overview"'>
                Overview
                @if (Report.AtRiskIssues.Any())
                {
                    <span class="badge bg-danger ms-1">@Report.AtRiskIssues.Count</span>
                }
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(ActiveTab == "issues" ? "active" : "")"
                    @onclick='() => ActiveTab = "issues"'>
                Issues <span class="badge bg-secondary ms-1">@Report.TotalIssues</span>
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(ActiveTab == "team" ? "active" : "")"
                    @onclick='() => ActiveTab = "team"'>
                Team <span class="badge bg-secondary ms-1">@TeamGroups.Count()</span>
            </button>
        </li>
    </ul>

    <div class="card border-0 shadow-sm border-top-0" style="border-top-left-radius:0; border-top-right-radius:0;">
        <div class="card-body">

            <!-- ── TAB: OVERVIEW ──────────────────────────────────────── -->
            @if (ActiveTab == "overview")
            {
                @if (Report.AtRiskIssues.Any())
                {
                    <div class="alert @(Report.RiskLevel == SprintRisk.Behind ? "alert-danger" : "alert-warning") d-flex align-items-start gap-2 mb-4">
                        <span class="fs-5">⚠️</span>
                        <div>
                            <strong>@Report.AtRiskIssues.Count issue@(Report.AtRiskIssues.Count != 1 ? "s" : "") at risk</strong>
                            — these may not close by end of sprint.
                            <ul class="mb-0 mt-1">
                                @foreach (var i in Report.AtRiskIssues)
                                {
                                    <li>
                                        <strong>@i.Key</strong> (@i.Assignee) — @i.Summary
                                        <span class="badge @StatusBadge(i.Status, i.StatusCategoryKey) ms-1">@i.Status</span>
                                        @if (i.DaysSinceLastWorklog >= 2 && i.DaysSinceLastWorklog < 999)
                                        {
                                            <span class="text-muted ms-1 small">No worklog in @i.DaysSinceLastWorklog days</span>
                                        }
                                        @if (i.StatusCategoryKey == "new" && Report.SprintProgressPct > 50)
                                        {
                                            <span class="text-muted ms-1 small">Not started</span>
                                        }
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                }
                else
                {
                    <div class="alert alert-success d-flex align-items-center gap-2">
                        <span class="fs-5">✅</span>
                        <span><strong>Sprint on track.</strong> No issues flagged as at risk.</span>
                    </div>
                }

                <div class="row g-3">
                    <div class="col-md-6">
                        <h6 class="text-muted text-uppercase small fw-semibold mb-2">In Progress (@InProgressIssues.Count)</h6>
                        @foreach (var i in InProgressIssues)
                        {
                            <div class="d-flex align-items-center gap-2 p-2 rounded border mb-1 bg-white">
                                <span class="badge @PriorityBadge(i.Priority)" style="width:8px; height:8px; padding:0; border-radius:50%;"></span>
                                <span class="fw-semibold small text-nowrap">@i.Key</span>
                                <span class="text-truncate small flex-grow-1">@i.Summary</span>
                                <span class="text-muted small text-nowrap">@i.Assignee.Split(' ')[0]</span>
                                @if (i.DaysSinceLastWorklog >= 2 && i.DaysSinceLastWorklog < 999)
                                {
                                    <span class="badge bg-warning text-dark" title="No worklog in @i.DaysSinceLastWorklog days">@i.DaysSinceLastWorklog d idle</span>
                                }
                            </div>
                        }
                    </div>
                    <div class="col-md-6">
                        <h6 class="text-muted text-uppercase small fw-semibold mb-2">To Do (@NotStartedIssues.Count)</h6>
                        @foreach (var i in NotStartedIssues)
                        {
                            <div class="d-flex align-items-center gap-2 p-2 rounded border mb-1 bg-white @(Report.SprintProgressPct > 50 ? "border-warning" : "")">
                                <span class="badge @PriorityBadge(i.Priority)" style="width:8px; height:8px; padding:0; border-radius:50%;"></span>
                                <span class="fw-semibold small text-nowrap">@i.Key</span>
                                <span class="text-truncate small flex-grow-1">@i.Summary</span>
                                <span class="text-muted small text-nowrap">@i.Assignee.Split(' ')[0]</span>
                                @if (i.OriginalEstimate != "-")
                                {
                                    <span class="text-muted small text-nowrap">@i.OriginalEstimate</span>
                                }
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- ── TAB: ISSUES ────────────────────────────────────────── -->
            @if (ActiveTab == "issues")
            {
                <div class="row g-2 mb-3 align-items-center">
                    <div class="col-auto">
                        <input class="form-control form-control-sm"
                               style="width:200px"
                               @bind="FilterText"
                               @bind:event="oninput"
                               placeholder="Search key or summary..." />
                    </div>
                    <div class="col-auto">
                        <select class="form-select form-select-sm" style="width:150px" @bind="FilterStatus">
                            <option value="">All statuses</option>
                            @foreach (var s in Report.Issues.Select(i => i.Status).Distinct().Order())
                            {
                                <option value="@s">@s</option>
                            }
                        </select>
                    </div>
                    <div class="col-auto">
                        <select class="form-select form-select-sm" style="width:160px" @bind="FilterAssignee">
                            <option value="">All assignees</option>
                            @foreach (var a in Report.Issues.Select(i => i.Assignee).Distinct().Order())
                            {
                                <option value="@a">@a</option>
                            }
                        </select>
                    </div>
                    <div class="col-auto">
                        <select class="form-select form-select-sm" style="width:130px" @bind="FilterType">
                            <option value="">All types</option>
                            @foreach (var t in Report.Issues.Select(i => i.IssueType).Distinct().Order())
                            {
                                <option value="@t">@t</option>
                            }
                        </select>
                    </div>
                    @if (IsFiltered)
                    {
                        <div class="col-auto">
                            <button class="btn btn-sm btn-outline-secondary" @onclick="ClearFilters">Clear</button>
                        </div>
                    }
                    <div class="col-auto ms-auto">
                        <span class="text-muted small">@FilteredIssues.Count of @Report.TotalIssues issues</span>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width:30px">P</th>
                                <th style="width:100px">Key</th>
                                <th style="width:85px">Type</th>
                                <th>Summary</th>
                                <th style="width:140px">Status</th>
                                <th style="width:150px">Assignee</th>
                                @if (Report.HasStoryPoints)
                                {
                                    <th style="width:50px" title="Story Points">SP</th>
                                }
                                <th style="width:80px">Logged</th>
                                <th style="width:80px">Estimate</th>
                                <th style="width:80px">Remaining</th>
                                <th style="width:110px">Progress</th>
                                <th style="width:70px"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var issue in FilteredIssues)
                            {
                                <tr class="@(issue.IsExpanded ? "table-active" : "")"
                                    style="cursor:pointer"
                                    @onclick="() => issue.IsExpanded = !issue.IsExpanded">
                                    <td>
                                        <span title="@issue.Priority"
                                              class="d-inline-block rounded-circle @PriorityBadge(issue.Priority)"
                                              style="width:10px;height:10px;">
                                        </span>
                                    </td>
                                    <td class="fw-semibold text-nowrap">@issue.Key</td>
                                    <td><span class="badge bg-light text-dark border">@issue.IssueType</span></td>
                                    <td>@issue.Summary</td>
                                    <td><span class="badge @StatusBadge(issue.Status, issue.StatusCategoryKey)">@issue.Status</span></td>
                                    <td class="text-truncate" style="max-width:150px">@issue.Assignee</td>
                                    @if (Report.HasStoryPoints)
                                    {
                                        <td class="text-center">@(issue.StoryPoints.HasValue ? issue.StoryPoints.ToString() : "—")</td>
                                    }
                                    <td class="text-nowrap">@(issue.TimeSpent == "-" ? "—" : issue.TimeSpent)</td>
                                    <td class="text-nowrap">@(issue.OriginalEstimate == "-" ? "—" : issue.OriginalEstimate)</td>
                                    <td class="text-nowrap @(issue.RemainingEstimateSeconds > Report.DaysRemaining * 8 * 3600 && issue.RemainingEstimateSeconds > 0 ? "text-danger fw-semibold" : "")">
                                        @(issue.RemainingEstimate == "-" ? "—" : issue.RemainingEstimate)
                                    </td>
                                    <td>
                                        @{ var pct = IssueProgress(issue); }
                                        <div class="d-flex align-items-center gap-1">
                                            <div class="progress flex-grow-1" style="height:6px; border-radius:3px;">
                                                <div class="progress-bar @(pct > 100 ? "bg-danger" : pct == 100 ? "bg-success" : "bg-primary")"
                                                     style="width:@(Math.Min(pct, 100))%">
                                                </div>
                                            </div>
                                            <span class="small text-nowrap @(pct > 100 ? "text-danger fw-semibold" : pct == 100 ? "text-success" : "text-muted")" style="min-width:36px">@pct%</span>
                                        </div>
                                    </td>
                                    <td class="text-muted small text-nowrap">
                                        @if (issue.Worklogs.Any())
                                        {
                                            @(issue.IsExpanded ? "▲" : "▼")
                                            <span class="ms-1">@issue.Worklogs.Count</span>
                                        }
                                    </td>
                                </tr>

                                @if (issue.IsExpanded)
                                {
                                    <tr>
                                        <td colspan="@(Report.HasStoryPoints ? 12 : 11)" class="p-0 border-0">
                                            <div class="px-4 py-3 bg-light border-start border-3 border-primary">
                                                @if (issue.Worklogs.Any())
                                                {
                                                    <table class="table table-sm mb-0">
                                                        <thead>
                                                            <tr>
                                                                <th>Author</th>
                                                                <th>Time Spent</th>
                                                                <th>Date</th>
                                                                <th>Comment</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            @foreach (var wl in issue.Worklogs.OrderByDescending(w => w.Started))
                                                            {
                                                                <tr>
                                                                    <td class="text-nowrap">@wl.Author</td>
                                                                    <td class="text-nowrap">@wl.TimeSpent</td>
                                                                    <td class="text-nowrap text-muted">@wl.Started.ToString("dd MMM yyyy")</td>
                                                                    <td class="text-muted">@(string.IsNullOrEmpty(wl.Comment) ? "—" : wl.Comment)</td>
                                                                </tr>
                                                            }
                                                        </tbody>
                                                    </table>
                                                }
                                                else
                                                {
                                                    <span class="text-muted small">No worklog entries.</span>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            }

            <!-- ── TAB: TEAM ──────────────────────────────────────────── -->
            @if (ActiveTab == "team")
            {
                @foreach (var group in TeamGroups)
                {
                    var memberIssues = group.ToList();
                    var done = memberIssues.Count(i => i.StatusCategoryKey == "done");
                    var inProg = memberIssues.Count(i => i.StatusCategoryKey == "indeterminate");
                    var todo = memberIssues.Count(i => i.StatusCategoryKey == "new");
                    var logged = memberIssues.Sum(i => i.TimeSpentSeconds);
                    var staleCount = memberIssues.Count(i => i.StatusCategoryKey == "indeterminate" && i.DaysSinceLastWorklog >= 2);
                    var memberId = group.Key.Replace(" ", "_");

                    <div class="card border-0 shadow-sm mb-3">
                        <div class="card-body"
                             style="cursor:pointer"
                             @onclick="() => ToggleMember(group.Key)">
                            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                                <div class="d-flex align-items-center gap-3">
                                    <!-- Avatar initials -->
                                    <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center fw-bold flex-shrink-0"
                                         style="width:40px;height:40px;font-size:14px;">
                                        @Initials(group.Key)
                                    </div>
                                    <div>
                                        <div class="fw-semibold">@group.Key</div>
                                        <div class="small text-muted">
                                            @done done · @inProg in progress · @todo to do
                                            @if (logged > 0)
                                            {
                                                <span> · @Fmt(logged) logged</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    @if (staleCount > 0)
                                    {
                                        <span class="badge bg-warning text-dark" title="In Progress but no worklog in 2+ days">
                                            ⚠️ @staleCount stale
                                        </span>
                                    }
                                    <div style="width:120px">
                                        <div class="progress" style="height:8px; border-radius:4px;">
                                            <div class="progress-bar bg-success"
                                                 style="width:@Pct(done, memberIssues.Count)%">
                                            </div>
                                            <div class="progress-bar bg-primary"
                                                 style="width:@Pct(inProg, memberIssues.Count)%">
                                            </div>
                                        </div>
                                    </div>
                                    <span class="text-muted small text-nowrap">@Pct(done, memberIssues.Count)%</span>
                                    <span class="text-muted">@(ExpandedMembers.Contains(group.Key) ? "▲" : "▼")</span>
                                </div>
                            </div>
                        </div>

                        @if (ExpandedMembers.Contains(group.Key))
                        {
                            <div class="card-footer bg-light p-0">
                                <table class="table table-sm align-middle mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Key</th>
                                            <th>Summary</th>
                                            <th>Status</th>
                                            <th>Logged</th>
                                            <th>Remaining</th>
                                            @if (Report.HasStoryPoints)
                                            {
                                                <th>SP</th>
                                            }
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var issue in memberIssues)
                                        {
                                            <tr>
                                                <td class="fw-semibold text-nowrap">@issue.Key</td>
                                                <td>@issue.Summary</td>
                                                <td>
                                                    <span class="badge @StatusBadge(issue.Status, issue.StatusCategoryKey)">@issue.Status</span>
                                                    @if (issue.StatusCategoryKey == "indeterminate" && issue.DaysSinceLastWorklog >= 2 && issue.DaysSinceLastWorklog < 999)
                                                    {
                                                        <span class="badge bg-warning text-dark ms-1" title="No worklog in @issue.DaysSinceLastWorklog days">@issue.DaysSinceLastWorklog d idle</span>
                                                    }
                                                </td>
                                                <td class="text-nowrap">@(issue.TimeSpent == "-" ? "—" : issue.TimeSpent)</td>
                                                <td class="text-nowrap">@(issue.RemainingEstimate == "-" ? "—" : issue.RemainingEstimate)</td>
                                                @if (Report.HasStoryPoints)
                                                {
                                                    <td>@(issue.StoryPoints.HasValue ? issue.StoryPoints.ToString() : "—")</td>
                                                }
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                }
            }

        </div>
    </div>
}

@code {
    private string EpicKey = "";
    private string SprintId = "";
    private bool IsLoading = false;
    private string? ErrorMessage;
    private SprintReport? Report;
    private string ActiveTab = "overview";
    private HashSet<string> ExpandedMembers = new();

    // ── Issue table filters ───────────────────────────────────────────────────
    private string FilterText = "";
    private string FilterStatus = "";
    private string FilterAssignee = "";
    private string FilterType = "";

    private bool IsFiltered =>
        !string.IsNullOrEmpty(FilterText) ||
        !string.IsNullOrEmpty(FilterStatus) ||
        !string.IsNullOrEmpty(FilterAssignee) ||
        !string.IsNullOrEmpty(FilterType);

    private List<SprintIssue> FilteredIssues => Report?.Issues
        .Where(i =>
            (string.IsNullOrEmpty(FilterText) ||
                i.Key.Contains(FilterText, StringComparison.OrdinalIgnoreCase) ||
                i.Summary.Contains(FilterText, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrEmpty(FilterStatus) || i.Status == FilterStatus) &&
            (string.IsNullOrEmpty(FilterAssignee) || i.Assignee == FilterAssignee) &&
            (string.IsNullOrEmpty(FilterType) || i.IssueType == FilterType))
        .ToList() ?? [];

    private List<SprintIssue> InProgressIssues =>
        Report?.Issues.Where(i => i.StatusCategoryKey == "indeterminate").ToList() ?? [];

    private List<SprintIssue> NotStartedIssues =>
        Report?.Issues.Where(i => i.StatusCategoryKey == "new").ToList() ?? [];

    private IEnumerable<IGrouping<string, SprintIssue>> TeamGroups =>
        Report?.Issues.GroupBy(i => i.Assignee).OrderBy(g => g.Key)
        ?? Enumerable.Empty<IGrouping<string, SprintIssue>>();

    private async Task LoadSprint()
    {
        if (string.IsNullOrWhiteSpace(EpicKey)) return;

        IsLoading = true;
        ErrorMessage = null;
        Report = null;
        ActiveTab = "overview";
        ExpandedMembers.Clear();
        ClearFilters();

        try
        {
            Report = await JiraService.GetSprintReportAsync(EpicKey.Trim().ToUpper(), int.Parse(SprintId.Trim()));
        }
        catch (HttpRequestException ex)
        {
            ErrorMessage = $"Failed to load sprint: {ex.Message}";
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Unexpected error: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await LoadSprint();
    }

    private void ClearFilters()
    {
        FilterText = "";
        FilterStatus = "";
        FilterAssignee = "";
        FilterType = "";
    }

    private void ToggleMember(string name)
    {
        if (!ExpandedMembers.Remove(name))
            ExpandedMembers.Add(name);
    }

    private static string StatusBadge(string statusName, string categoryKey) => statusName switch
    {
        "Dev Ready"  => "bg-info text-dark",
        "In Review"  => "bg-warning text-dark",
        _ => categoryKey switch
        {
            "done"          => "bg-success",
            "indeterminate" => "bg-primary",
            _               => "bg-secondary"
        }
    };

    private static string RiskBadge(SprintRisk risk) => risk switch
    {
        SprintRisk.OnTrack => "bg-success",
        SprintRisk.AtRisk  => "bg-warning text-dark",
        _                  => "bg-danger"
    };

    private static string RiskLabel(SprintRisk risk) => risk switch
    {
        SprintRisk.OnTrack => "✅ On Track",
        SprintRisk.AtRisk  => "⚠️ At Risk",
        _                  => "🔴 Behind"
    };

    private static string PriorityBadge(string priority) => priority switch
    {
        "Highest" or "Critical" => "bg-danger",
        "High"                  => "bg-warning",
        "Medium"                => "bg-info",
        "Low" or "Lowest"       => "bg-secondary",
        _                       => "bg-secondary"
    };

    private static string Initials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}".ToUpper()
            : name.Length >= 2 ? name[..2].ToUpper() : name.ToUpper();
    }

    private static int IssueProgress(SprintIssue issue)
    {
        if (issue.StatusCategoryKey == "done") return 100;
        if (issue.OriginalEstimateSeconds <= 0) return 0;
        return Math.Max(0, (int)Math.Round((double)issue.TimeSpentSeconds / issue.OriginalEstimateSeconds * 100));
    }

    private static int Pct(int count, int total) =>
        total == 0 ? 0 : (int)Math.Round((double)count / total * 100);

    private static string Fmt(int seconds)
    {
        if (seconds <= 0) return "—";
        var h = seconds / 3600;
        var m = (seconds % 3600) / 60;
        return h > 0 ? $"{h}h {m}m" : $"{m}m";
    }
}
