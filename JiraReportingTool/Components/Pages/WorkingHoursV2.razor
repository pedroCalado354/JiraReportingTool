@page "/working-hours-v2"
@rendermode InteractiveServer
@inject IJiraService JiraService
@inject TeamRosterService Roster
@inject SprintConfigService SprintConfig
@inject WorkingHoursSnapshotService Snapshots
@inject IJSRuntime JS
@using JiraReportingTool.Models
@using ClosedXML.Excel
@using ClosedXML.Excel.Drawings

<PageTitle>Working Hours</PageTitle>

<div class="v2-root">

    <!-- ═══ HERO ══════════════════════════════════════════════════════════════ -->
    <div class="v2-hero">
        <div class="v2-hero-row">
            <div class="v2-hero-icon"><i class="bi bi-clock-history"></i></div>
            <div class="v2-hero-titles">
                <span class="v2-eyebrow">Sprint Analysis</span>
                <h1 class="v2-hero-title">Working Hours</h1>
                <span class="v2-hero-sub">
                    @if (SprintReports.Count > 0)
                    {
                        @string.Join(" · ", SprintReports.Where(r => !string.IsNullOrEmpty(r.SprintName)).Select(r => r.SprintName))
                    }
                    else
                    {
                        <span>Worklog breakdown across sprints, members and epics</span>
                    }
                </span>
            </div>
            <div class="v2-hero-spacer"></div>
            @if (SprintReports.Count > 0)
            {
                <div class="v2-hero-actions">
                    <span class="v2-pill v2-pill-neutral"><i class="bi bi-collection"></i> @SprintReports.Count sprint@(SprintReports.Count == 1 ? "" : "s")</span>
                    <span class="v2-pill v2-pill-neutral"><i class="bi bi-people"></i> @ActiveMemberCount active</span>
                    <span class="v2-pill @UtilPillClass(AvgUtilization)"><i class="bi bi-speedometer2"></i> @AvgUtilization.ToString("F0")% utilised</span>
                </div>
            }
        </div>
    </div>

    <!-- ═══ CONTROL BAR ════════════════════════════════════════════════════════ -->
    <div class="v2-control-bar">
        <div class="v2-field" style="min-width:260px">
            <label class="v2-label">Previous sprints</label>
            <select class="v2-select" @onchange="OnKnownSprintPicked">
                <option value="">— pick a sprint —</option>
                @foreach (var s in _knownSprints)
                {
                    <option value="@s.SprintId">@SprintLabel(s)</option>
                }
            </select>
        </div>

        <div class="v2-or">or</div>

        <div class="v2-field" style="min-width:400px">
            <label class="v2-label">Sprint ID(s)</label>
            <input class="v2-input" placeholder="e.g. 6690  or  6690, 6691, 6692"
                   @bind="SprintIdsInput" @onkeyup="HandleKeyUp" />
        </div>
        <button class="v2-btn v2-btn-primary" @onclick="LoadData"
                disabled="@(IsLoading || string.IsNullOrWhiteSpace(SprintIdsInput))">
            @if (IsLoading) { <span class="v2-spin"></span> }
            else { <i class="bi bi-lightning-charge-fill"></i> }
            <span>Load</span>
        </button>
        @if (_snapshotSprintIds.Count > 0)
        {
            <span class="v2-pill v2-pill-info" title="Loaded from a frozen historical snapshot — never re-fetched from Jira">
                <i class="bi bi-box-seam-fill"></i> @_snapshotSprintIds.Count historical
            </span>
        }
        @if (SprintReports.Count > 0)
        {
            <span class="v2-hint" style="margin-left:auto">@FilteredEntryCount log entries · @TotalHours.ToString("F1") h logged · @WorkingDayCount working day@(WorkingDayCount == 1 ? "" : "s")</span>
        }
    </div>

    <!-- ═══ DATE RANGE (independent of sprint selection) ══════════════════════ -->
    <div class="v2-control-bar">
        <div class="v2-field">
            <label class="v2-label">Date range <span class="v2-section-note">· all team members, regardless of sprint</span></label>
            <div style="display:flex;align-items:center;gap:8px">
                <input type="date" class="v2-input" @bind="_rangeFrom" />
                <span class="v2-hint">to</span>
                <input type="date" class="v2-input" @bind="_rangeTo" />
                <button class="btn small" @onclick="ResetDateRange"
                        disabled="@(_rangeFrom == _fullSpanStart && _rangeTo == _fullSpanEnd)">Full span</button>
            </div>
        </div>
        <button class="v2-btn v2-btn-primary" @onclick="LoadByDateRangeAsync" disabled="@IsLoading">
            @if (IsLoading) { <span class="v2-spin"></span> }
            else { <i class="bi bi-calendar-range"></i> }
            <span>Load range</span>
        </button>
    </div>

    @if (ErrorMessage != null)
    {
        <div class="v2-alert v2-alert-error"><i class="bi bi-exclamation-triangle-fill"></i> @ErrorMessage</div>
    }

    @if (SprintReports.Count == 0 && IsLoading)
    {
        <!-- skeleton while first load runs -->
        <div class="wh2-kpi-row">
            @for (var s = 0; s < 7; s++)
            {
                <div class="wh2-kpi">
                    <div class="v2-skeleton" style="height:12px;width:60%;margin-bottom:10px"></div>
                    <div class="v2-skeleton" style="height:26px;width:45%"></div>
                    <div class="v2-skeleton" style="height:10px;width:70%;margin-top:8px"></div>
                </div>
            }
        </div>
        <div class="v2-skeleton" style="height:280px;margin-top:14px;border-radius:var(--v2-r-md)"></div>
    }

    @if (SprintReports.Count == 0 && !IsLoading)
    {
        <div class="v2-empty">
            <div class="v2-empty-icon"><i class="bi bi-clock"></i></div>
            <div class="v2-empty-title">Pick a sprint or a date range to begin</div>
            <div>Load worklog data to see hours by member, day and epic — with capacity utilisation against the team roster. Use the date range to see every team member's logged hours across a period, regardless of sprint.</div>
        </div>
    }

    @if (SprintReports.Count > 0)
    {
        var heatDays = HeatDays; var heatMembers = HeatMembers; var heatMap = MemberDayHours;

        <!-- ═══ KPI STRIP ═════════════════════════════════════════════════════ -->
        <div class="wh2-kpi-row">
            <div class="wh2-kpi" style="--kpi-accent:var(--v2-brand-grad)">
                <div class="wh2-kpi-label"><i class="bi bi-clock-fill"></i> Total Hours</div>
                <div class="wh2-kpi-val">@TotalHours.ToString("F1")<span class="wh2-kpi-unit">h</span></div>
                <div class="wh2-kpi-sub">filtered logs</div>
            </div>
            <div class="wh2-kpi" style="--kpi-accent:@UtilAccent(AvgUtilization)">
                <div class="wh2-kpi-label"><i class="bi bi-speedometer2"></i> Utilisation</div>
                <div class="wh2-kpi-val">@AvgUtilization.ToString("F0")<span class="wh2-kpi-unit">%</span></div>
                <div class="wh2-kpi-sub">@TotalHours.ToString("F0") / @TotalCapacityHours.ToString("F0") h capacity</div>
            </div>
            <div class="wh2-kpi" style="--kpi-accent:linear-gradient(180deg,#6366f1,#8b5cf6)">
                <div class="wh2-kpi-label"><i class="bi bi-people-fill"></i> Members</div>
                <div class="wh2-kpi-val">@ActiveMemberCount</div>
                <div class="wh2-kpi-sub">contributors</div>
            </div>
            <div class="wh2-kpi" style="--kpi-accent:linear-gradient(180deg,#8b5cf6,#a855f7)">
                <div class="wh2-kpi-label"><i class="bi bi-journal-text"></i> Log Entries</div>
                <div class="wh2-kpi-val">@FilteredEntryCount</div>
                <div class="wh2-kpi-sub">worklog records</div>
            </div>
            <div class="wh2-kpi" style="--kpi-accent:linear-gradient(180deg,#a855f7,#d946ef)">
                <div class="wh2-kpi-label"><i class="bi bi-person-lines-fill"></i> Avg / Member</div>
                <div class="wh2-kpi-val">@AvgHoursPerMember.ToString("F1")<span class="wh2-kpi-unit">h</span></div>
                <div class="wh2-kpi-sub">mean per contributor</div>
            </div>
            <div class="wh2-kpi" style="--kpi-accent:linear-gradient(180deg,#6366f1,#4f46e5)">
                <div class="wh2-kpi-label"><i class="bi bi-calendar-day"></i> Avg / Day</div>
                <div class="wh2-kpi-val">@AvgHoursPerDay.ToString("F1")<span class="wh2-kpi-unit">h</span></div>
                <div class="wh2-kpi-sub">mean per workday</div>
            </div>
            <div class="wh2-kpi" style="--kpi-accent:linear-gradient(180deg,#0891b2,#0e7490)">
                <div class="wh2-kpi-label"><i class="bi bi-person-workspace"></i> Avg / Member / Day</div>
                <div class="wh2-kpi-val">@AvgHoursPerMemberPerDay.ToString("F1")<span class="wh2-kpi-unit">h</span></div>
                <div class="wh2-kpi-sub">mean per contributor per workday</div>
            </div>
            <div class="wh2-kpi" style="--kpi-accent:linear-gradient(180deg,#7c3aed,#a855f7)">
                <div class="wh2-kpi-label"><i class="bi bi-graph-up"></i> Peak Day</div>
                <div class="wh2-kpi-val">@MaxDayHours.ToString("F1")<span class="wh2-kpi-unit">h</span></div>
                <div class="wh2-kpi-sub">highest single-day</div>
            </div>
        </div>

        <!-- ═══ INSIGHT BAR ═══════════════════════════════════════════════════ -->
        <div class="wh2-insight-bar">
            <div class="wh2-insight-item">
                <i class="bi bi-trophy-fill" style="color:#f59e0b"></i>
                <span class="wh2-insight-label">Top contributor</span>
                <span class="wh2-insight-val">@TopContributor</span>
            </div>
            <div class="wh2-insight-sep"></div>
            <div class="wh2-insight-item">
                <i class="bi bi-calendar-week" style="color:var(--v2-brand)"></i>
                <span class="wh2-insight-label">Busiest weekday</span>
                <span class="wh2-insight-val">@BusiestWeekday</span>
            </div>
            <div class="wh2-insight-sep"></div>
            <div class="wh2-insight-item">
                <i class="bi bi-collection-fill" style="color:var(--v2-brand-2)"></i>
                <span class="wh2-insight-label">Most-active epic</span>
                <span class="wh2-insight-val">@MostActiveEpic</span>
            </div>
            <div class="wh2-insight-spacer"></div>
            @if (SelectedMembers.Count == 1)
            {
                <button class="wh2-focus-clear" @onclick="SelectAllMembers" title="Clear member focus">
                    <i class="bi bi-x-circle"></i> Focused: @SelectedMembers.First()
                </button>
            }
            <button class="wh2-export-btn" @onclick="ExportToExcel" disabled="@IsExporting">
                @if (IsExporting) { <span class="v2-spin" style="width:12px;height:12px"></span> }
                else { <i class="bi bi-download"></i> }
                Export .xlsx
            </button>
        </div>

        <!-- ═══ FILTERS ═══════════════════════════════════════════════════════ -->
        <div class="v2-card wh2-filter-card">
            <div class="wh2-filter-grid">

                <!-- Members -->
                <div class="wh2-filter-col">
                    <div class="wh2-filter-head">
                        <span class="wh2-filter-title"><i class="bi bi-people"></i> Members</span>
                        <label class="wh2-roster-toggle" title="Show only people who exist in the Team Roster (matched by Jira account, email or name). Filters members, epics, charts and tables.">
                            <input type="checkbox" checked="@_rosterOnly" @onchange="e => ToggleRosterOnly((bool)e.Value!)" />
                            <span>Roster only</span>
                            @if (_rosterOnly)
                            {
                                <span class="wh2-roster-toggle-n">@RosterAuthorSet.Count matched</span>
                            }
                        </label>
                        <div class="wh2-filter-actions">
                            <button class="wh2-link-btn" @onclick="SelectAllMembers">All</button>
                            <span class="wh2-dot-sep">·</span>
                            <button class="wh2-link-btn" @onclick="ClearMembersFilter">None</button>
                        </div>
                    </div>
                    @if (AllAuthors.Count > 8)
                    {
                        <input class="v2-input v2-input-sm wh2-chip-search" placeholder="Filter members…"
                               @bind="_memberSearch" @bind:event="oninput" />
                    }
                    <div class="wh2-chip-list">
                        @foreach (var author in AllAuthors.Where(a => MatchSearch(a, _memberSearch)))
                        {
                            var a = author;
                            <button class="wh2-chip @(SelectedMembers.Contains(a) ? "is-on" : "")"
                                    @onclick="() => ToggleMember(a, !SelectedMembers.Contains(a))">
                                @if (SelectedMembers.Contains(a)) { <i class="bi bi-check2"></i> }
                                @a
                            </button>
                        }
                    </div>
                    <div class="wh2-filter-count">@SelectedMembers.Count of @AllAuthors.Count selected</div>
                </div>

                <!-- Epics -->
                <div class="wh2-filter-col">
                    <div class="wh2-filter-head">
                        <span class="wh2-filter-title"><i class="bi bi-collection"></i> Epics</span>
                        <div class="wh2-filter-actions">
                            <button class="wh2-link-btn" @onclick="SelectAllEpics">All</button>
                            <span class="wh2-dot-sep">·</span>
                            <button class="wh2-link-btn" @onclick="ClearEpicsFilter">None</button>
                        </div>
                    </div>
                    @if (AllEpics.Count > 8)
                    {
                        <input class="v2-input v2-input-sm wh2-chip-search" placeholder="Filter epics…"
                               @bind="_epicSearch" @bind:event="oninput" />
                    }
                    <div class="wh2-chip-list">
                        @foreach (var (key, name) in AllEpics.Where(e => MatchSearch(e.Key, _epicSearch) || MatchSearch(e.Name, _epicSearch)))
                        {
                            var k = key; var n = name;
                            <button class="wh2-chip wh2-chip-mono @(SelectedEpics.Contains(k) ? "is-on" : "")" title="@n"
                                    @onclick="() => ToggleEpic(k, !SelectedEpics.Contains(k))">
                                @if (SelectedEpics.Contains(k)) { <i class="bi bi-check2"></i> }
                                @k
                            </button>
                        }
                    </div>
                    <div class="wh2-filter-count">@SelectedEpics.Count of @AllEpics.Count selected</div>
                </div>

                <!-- Product -->
                <div class="wh2-filter-col">
                    <div class="wh2-filter-head">
                        <span class="wh2-filter-title"><i class="bi bi-grid-fill"></i> Product</span>
                        <div class="wh2-filter-actions">
                            <button class="wh2-link-btn" @onclick="SelectAllProducts">All</button>
                            <span class="wh2-dot-sep">·</span>
                            <button class="wh2-link-btn" @onclick="ClearProductsFilter">None</button>
                        </div>
                    </div>
                    <div class="wh2-chip-list">
                        @foreach (var (name, count) in AllProducts)
                        {
                            var n = name;
                            <button class="wh2-chip @(SelectedProducts.Contains(n) ? "is-on" : "")"
                                    @onclick="() => ToggleProduct(n, !SelectedProducts.Contains(n))">
                                @if (SelectedProducts.Contains(n)) { <i class="bi bi-check2"></i> }
                                @n <span class="wh2-chip-n">@count</span>
                            </button>
                        }
                    </div>
                    <div class="wh2-filter-count">@SelectedProducts.Count of @AllProducts.Count selected</div>
                </div>

                <!-- Date range -->
                <div class="wh2-filter-col wh2-filter-col-sm">
                    <div class="wh2-filter-head">
                        <span class="wh2-filter-title"><i class="bi bi-calendar-range"></i> Date Range</span>
                        @if (DateFrom.HasValue || DateTo.HasValue)
                        {
                            <button class="wh2-link-btn" @onclick="ClearDates">Clear</button>
                        }
                    </div>
                    <div style="display:flex;flex-direction:column;gap:6px">
                        <input type="date" class="v2-input" style="width:100%" @bind="DateFrom" @bind:after="OnFilterChanged" />
                        <input type="date" class="v2-input" style="width:100%" @bind="DateTo" @bind:after="OnFilterChanged" />
                    </div>
                </div>
            </div>
        </div>

        <!-- ═══ CHARTS ════════════════════════════════════════════════════════ -->
        <div class="wh2-chart-grid">
            <div class="v2-card">
                <div class="v2-section-title"><i class="bi bi-bar-chart-line" style="color:var(--v2-brand)"></i>Logged vs Capacity per Member</div>
                <div class="wh2-util-key">
                    <span class="wh2-util-key-item"><span class="wh2-util-dot" style="background:#16a34a"></span>≥ 80% capacity</span>
                    <span class="wh2-util-key-item"><span class="wh2-util-dot" style="background:#f59e0b"></span>60–80%</span>
                    <span class="wh2-util-key-item"><span class="wh2-util-dot" style="background:#dc2626"></span>&lt; 60%</span>
                </div>
                <div style="height:@(Math.Clamp(ActiveMemberCount * 30, 220, 520))px;position:relative">
                    <canvas id="chart-hours-member"></canvas>
                </div>
            </div>
            <div class="v2-card">
                <div class="v2-section-title"><i class="bi bi-calendar-event" style="color:var(--v2-brand-3)"></i>Hours per Day <span class="v2-section-note">· dashed line = team daily capacity</span></div>
                <div style="height:300px;position:relative">
                    <canvas id="chart-hours-day"></canvas>
                </div>
            </div>
            <div class="v2-card">
                <div class="v2-section-title"><i class="bi bi-pie-chart" style="color:var(--v2-brand-2)"></i>Hours per Epic</div>
                <div style="height:300px;position:relative">
                    <canvas id="chart-hours-epic"></canvas>
                </div>
            </div>
        </div>

        <!-- ═══ AVG HOURS PER MEMBER PER DAY ═══════════════════════════════════ -->
        <div class="v2-card" style="margin-top:12px">
            <div class="v2-section-title"><i class="bi bi-bar-chart-steps" style="color:#0891b2"></i>Avg Hours per Member per Day <span class="v2-section-note">· team total ÷ contributor count, per day · dashed line = overall average</span></div>
            <div style="height:260px;position:relative">
                <canvas id="chart-avg-member-day"></canvas>
            </div>
        </div>

        <!-- ═══ ACTIVITY HEATMAP ══════════════════════════════════════════════ -->
        @if (heatDays.Count > 0 && heatMembers.Count > 0)
        {
            <div class="v2-card">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;flex-wrap:wrap;gap:10px">
                    <div class="v2-section-title" style="margin:0"><i class="bi bi-grid-3x3-gap-fill" style="color:var(--v2-brand)"></i>Activity Heatmap <span class="v2-section-note">· hours logged per member per day</span></div>
                    <div class="wh2-heat-legend">
                        <span>Less</span>
                        <span class="wh2-heat-swatch wh2-h0"></span>
                        <span class="wh2-heat-swatch wh2-h1"></span>
                        <span class="wh2-heat-swatch wh2-h2"></span>
                        <span class="wh2-heat-swatch wh2-h3"></span>
                        <span class="wh2-heat-swatch wh2-h4"></span>
                        <span class="wh2-heat-swatch wh2-h5"></span>
                        <span>More</span>
                    </div>
                </div>
                <div class="wh2-heat">
                    <div class="wh2-heat-grid" style="grid-template-columns:150px repeat(@heatDays.Count, minmax(26px, 1fr))">
                        <!-- header -->
                        <div class="wh2-heat-corner"></div>
                        @foreach (var d in heatDays)
                        {
                            var wknd = d.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday;
                            <div class="wh2-heat-colh @(wknd ? "weekend" : "")" title="@d.ToString("dddd, MMM d")">
                                <span class="wh2-heat-dow">@d.ToString("ddd")</span>
                                <span class="wh2-heat-dom">@d.Day</span>
                            </div>
                        }
                        <!-- rows -->
                        @foreach (var member in heatMembers)
                        {
                            var mTotal = heatMap.TryGetValue(member, out var mm) ? mm.Values.Sum() : 0;
                            <div class="wh2-heat-rowlabel" title="@member — @mTotal.ToString("F1") h total">
                                <span class="wh2-heat-avatar">@Initials(member)</span>
                                <span class="v2-truncate">@member</span>
                            </div>
                            @foreach (var d in heatDays)
                            {
                                var wknd = d.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday;
                                var hrs  = heatMap.TryGetValue(member, out var dm) && dm.TryGetValue(d.Date, out var h) ? h : 0;
                                <div class="wh2-heat-cell @HeatClass(hrs) @(wknd ? "weekend" : "")"
                                     title="@member · @d.ToString("ddd MMM d") · @hrs.ToString("F2") h">
                                    @(hrs > 0 ? hrs.ToString("0.#") : "")
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        }

        <!-- ═══ PER-MEMBER SUMMARY ════════════════════════════════════════════ -->
        <div class="v2-card">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
                <div class="v2-section-title" style="margin:0"><i class="bi bi-person-rolodex"></i>Member Summary <span class="v2-section-note">· click a name to focus</span></div>
                <span class="v2-hint">@WorkingDayCount working day@(WorkingDayCount == 1 ? "" : "s") in range · capacity from roster</span>
            </div>
            <div class="v2-table-wrap">
                <table class="v2-table">
                    <thead>
                        <tr>
                            <th>Member</th>
                            <th class="v2-table-num">Logged</th>
                            <th class="v2-table-num">Active days</th>
                            <th class="v2-table-num">Avg / active day</th>
                            <th class="v2-table-num">Capacity</th>
                            <th style="width:200px">Utilisation</th>
                            <th>Top epic</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in MemberSummaries)
                        {
                            <tr>
                                <td>
                                    <button class="wh2-member-btn" @onclick="() => FocusMember(m.Name)" title="Focus on @m.Name">
                                        <span class="v2-avatar v2-avatar-sm">@Initials(m.Name)</span>
                                        <span style="font-weight:600">@m.Name</span>
                                    </button>
                                </td>
                                <td class="v2-table-num" style="font-weight:700">@m.Hours.ToString("F1")</td>
                                <td class="v2-table-num">@m.ActiveDays</td>
                                <td class="v2-table-num">@m.AvgPerActiveDay.ToString("F1")</td>
                                <td class="v2-table-num v2-text-muted">@m.Capacity.ToString("F0")</td>
                                <td>
                                    <div class="wh2-util-row">
                                        <div class="v2-bar" style="flex:1">
                                            <div class="v2-bar-fill @UtilBarClass(m.Util)" style="width:@(Math.Clamp(m.Util, 0, 100).ToString("F0"))%"></div>
                                        </div>
                                        <span class="wh2-util-pct @UtilTextClass(m.Util)">@m.Util.ToString("F0")%</span>
                                    </div>
                                </td>
                                <td style="white-space:nowrap">
                                    @if (m.TopEpic != "—")
                                    {
                                        <span style="font-size:11px;font-weight:700;color:var(--v2-brand)">@m.TopEpic</span>
                                    }
                                    else { <span class="v2-hint">—</span> }
                                </td>
                            </tr>
                        }
                        @if (MemberSummaries.Count == 0)
                        {
                            <tr><td colspan="7" style="text-align:center;padding:32px;color:var(--v2-ink-4)">No members match the current filters.</td></tr>
                        }
                    </tbody>
                    @if (MemberSummaries.Count > 0)
                    {
                        <tfoot>
                            <tr style="background:var(--v2-surface-2);font-weight:700;border-top:2px solid var(--v2-border)">
                                <td style="padding:8px 14px">Total</td>
                                <td class="v2-table-num" style="padding:8px 14px">@TotalHours.ToString("F1")</td>
                                <td colspan="2"></td>
                                <td class="v2-table-num" style="padding:8px 14px">@TotalCapacityHours.ToString("F0")</td>
                                <td class="v2-table-num" style="padding:8px 14px">@AvgUtilization.ToString("F0")%</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    }
                </table>
            </div>
        </div>

        <!-- ═══ WORKLOG BY EPIC ════════════════════════════════════════════════ -->
        <div>
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">
                <div class="v2-section-title" style="margin:0"><i class="bi bi-layers"></i>Worklog Entries by Epic</div>
                <div style="display:flex;align-items:center;gap:12px">
                    <span class="v2-hint">@FilteredEntryCount entries · @TotalHours.ToString("F1") h</span>
                    <button class="wh2-link-btn" style="font-size:11px" @onclick="ExpandAllEpics">Expand all</button>
                    <span class="wh2-dot-sep">·</span>
                    <button class="wh2-link-btn" style="font-size:11px" @onclick="CollapseAllEpics">Collapse all</button>
                </div>
            </div>

            @if (FilteredEntryCount == 0)
            {
                <div class="v2-card" style="text-align:center;padding:32px;color:var(--v2-ink-4)">No worklogs match the current filters.</div>
            }

            @foreach (var eg in WorklogsByEpic)
            {
                var epicKey  = eg.EpicKey;
                var isOpen   = _wlExpanded.Contains(epicKey);
                var epicHours = eg.Rows.Sum(r => r.TimeSpentSeconds) / 3600.0;
                var epicMembers = eg.Rows.Select(r => r.Author).Distinct().OrderBy(a => a).ToList();
                var hasEpic  = epicKey != "—";
                var epicShare = TotalHours > 0 ? epicHours / TotalHours * 100 : 0;

                <div class="wh2-epic-block">
                    <!-- Header row -->
                    <button class="wh2-epic-header" @onclick="() => ToggleWlEpic(epicKey)">
                        <i class="bi @(isOpen ? "bi-chevron-down" : "bi-chevron-right") wh2-chevron"></i>

                        @if (hasEpic)
                        {
                            <span class="wh2-epic-key">@epicKey</span>
                            <span class="wh2-epic-name">@(string.IsNullOrEmpty(eg.EpicName) || eg.EpicName == "No Epic" ? epicKey : eg.EpicName)</span>
                        }
                        else
                        {
                            <span class="wh2-epic-name" style="color:var(--v2-ink-3);font-style:italic">No Epic</span>
                        }

                        <div class="wh2-epic-meta">
                            <span class="wh2-epic-share" title="@epicShare.ToString("F0")% of logged hours">
                                <span class="wh2-epic-share-fill" style="width:@epicShare.ToString("F0")%"></span>
                            </span>
                            <span class="wh2-epic-stat"><i class="bi bi-journal-text"></i>@eg.Rows.Count entries</span>
                            <span class="wh2-epic-stat wh2-epic-hours"><i class="bi bi-clock"></i>@epicHours.ToString("F1") h</span>
                            <div class="wh2-epic-members">
                                @foreach (var m in epicMembers.Take(6))
                                {
                                    <span class="wh2-avatar" title="@m">@Initials(m)</span>
                                }
                                @if (epicMembers.Count > 6)
                                {
                                    <span class="wh2-avatar wh2-avatar-more">+@(epicMembers.Count - 6)</span>
                                }
                            </div>
                        </div>
                    </button>

                    <!-- Expanded rows -->
                    @if (isOpen)
                    {
                        <div class="v2-table-wrap wh2-epic-body">
                            <table class="v2-table">
                                <thead>
                                    <tr>
                                        <th>Date</th>
                                        <th>Day</th>
                                        <th>Member</th>
                                        <th class="v2-table-num">Hours</th>
                                        <th>Task</th>
                                        <th>Summary</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var wl in eg.Rows.OrderByDescending(r => r.Date).ThenBy(r => r.Author))
                                    {
                                        var wknd = wl.Date.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday;
                                        <tr>
                                            <td class="v2-hint" style="white-space:nowrap;font-size:12px">@wl.Date.ToString("yyyy-MM-dd")</td>
                                            <td class="@(wknd ? "wh2-weekend-day" : "v2-hint")" style="white-space:nowrap;font-size:12px">@wl.Date.ToString("ddd")</td>
                                            <td style="font-weight:600;white-space:nowrap">@wl.Author</td>
                                            <td class="v2-table-num" style="font-weight:700">@((wl.TimeSpentSeconds / 3600.0).ToString("F2"))</td>
                                            <td><span class="v2-table-key">@wl.IssueKey</span></td>
                                            <td class="v2-truncate" style="max-width:340px" title="@wl.IssueSummary">@wl.IssueSummary</td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot>
                                    <tr style="background:var(--v2-surface-2);font-weight:700;border-top:2px solid var(--v2-border)">
                                        <td colspan="3" style="padding:7px 12px">Epic total</td>
                                        <td class="v2-table-num" style="padding:7px 12px">@epicHours.ToString("F2")</td>
                                        <td colspan="2"></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- ═══ DONE FEATURES TABLE ═══════════════════════════════════════════ -->
        <div class="v2-card">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
                <div class="v2-section-title" style="margin:0"><i class="bi bi-check2-all"></i>Done Features</div>
                <span class="v2-hint">@DoneFeatures.Count issues · @DoneTotalSP SP · @DoneTotalHours.ToString("F1") h logged</span>
            </div>
            <div class="v2-table-wrap">
                <table class="v2-table">
                    <thead>
                        <tr>
                            <th class="@SI2("Key",      _sortColDF, _sortAscDF)" @onclick='() => SortDF("Key")'>Key</th>
                            <th class="@SI2("Summary",  _sortColDF, _sortAscDF)" @onclick='() => SortDF("Summary")'>Summary</th>
                            <th class="@SI2("Type",     _sortColDF, _sortAscDF)" @onclick='() => SortDF("Type")'>Type</th>
                            <th class="@SI2("Assignee", _sortColDF, _sortAscDF)" @onclick='() => SortDF("Assignee")'>Assignee</th>
                            @if (ShowSprintColDF)
                            {
                                <th class="@SI2("Sprint", _sortColDF, _sortAscDF)" @onclick='() => SortDF("Sprint")'>Sprint</th>
                            }
                            <th class="@SI2("Epic",     _sortColDF, _sortAscDF)" @onclick='() => SortDF("Epic")'>Epic</th>
                            <th class="v2-table-num @SI2("SP",    _sortColDF, _sortAscDF)" @onclick='() => SortDF("SP")'>SP</th>
                            <th class="v2-table-num @SI2("Hours", _sortColDF, _sortAscDF)" @onclick='() => SortDF("Hours")'>Hours</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in DoneFeatures)
                        {
                            <tr>
                                <td><span class="v2-table-key">@r.Key</span></td>
                                <td class="v2-truncate" style="max-width:260px" title="@r.Summary">@r.Summary</td>
                                <td><span class="v2-chip v2-chip-@r.IssueType.ToLower()">@r.IssueType</span></td>
                                <td style="white-space:nowrap">@r.Assignee</td>
                                @if (ShowSprintColDF)
                                {
                                    <td class="v2-hint" style="white-space:nowrap;font-size:12px">@r.SprintName</td>
                                }
                                <td style="white-space:nowrap;max-width:180px">
                                    @if (!string.IsNullOrEmpty(r.EpicKey))
                                    {
                                        <span style="font-size:11px;font-weight:700;color:var(--v2-brand)">@r.EpicKey</span>
                                        @if (!string.IsNullOrEmpty(r.EpicName) && r.EpicName != "No Epic")
                                        {
                                            <span class="v2-hint" style="margin-left:4px;font-size:11px">@r.EpicName</span>
                                        }
                                    }
                                    else { <span class="v2-hint">—</span> }
                                </td>
                                <td class="v2-table-num">@(r.StoryPoints.HasValue ? r.StoryPoints.Value.ToString() : "—")</td>
                                <td class="v2-table-num" style="font-weight:700">@r.HoursLogged.ToString("F2")</td>
                            </tr>
                        }
                        @if (DoneFeatures.Count == 0)
                        {
                            <tr>
                                <td colspan="@(ShowSprintColDF ? 8 : 7)" style="text-align:center;padding:32px;color:var(--v2-ink-4)">No done features match the current filters.</td>
                            </tr>
                        }
                    </tbody>
                    @if (DoneFeatures.Count > 0)
                    {
                        <tfoot>
                            <tr style="background:var(--v2-surface-2);font-weight:700;border-top:2px solid var(--v2-border)">
                                <td colspan="@(ShowSprintColDF ? 6 : 5)" style="padding:8px 12px">Total</td>
                                <td class="v2-table-num" style="padding:8px 12px">@DoneTotalSP</td>
                                <td class="v2-table-num" style="padding:8px 12px">@DoneTotalHours.ToString("F2")</td>
                            </tr>
                        </tfoot>
                    }
                </table>
            </div>
        </div>
    }
</div>

<style>
    /* ── KPI strip ─────────────────────────────────────────────────────── */
    .wh2-kpi-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 10px;
    }
    .wh2-kpi {
        position: relative;
        background: var(--v2-elevated);
        border: 1px solid var(--v2-border);
        border-radius: var(--v2-r-md);
        padding: 14px 16px 14px 18px;
        box-shadow: var(--v2-sh-xs);
        overflow: hidden;
        transition: transform .15s, box-shadow .15s;
    }
    .wh2-kpi:hover { transform: translateY(-2px); box-shadow: var(--v2-sh-md); }
    .wh2-kpi::before {
        content: ""; position: absolute; left: 0; top: 0; bottom: 0; width: 3px;
        background: var(--kpi-accent, var(--v2-brand-grad));
    }
    .wh2-kpi-label  { font-size: 11px; font-weight: 600; color: var(--v2-ink-3); text-transform: uppercase; letter-spacing: .04em; margin-bottom: 6px; display: flex; align-items: center; gap: 5px; }
    .wh2-kpi-val    { font-size: 26px; font-weight: 800; color: var(--v2-ink-1); line-height: 1.1; font-variant-numeric: tabular-nums; }
    .wh2-kpi-unit   { font-size: 14px; font-weight: 600; color: var(--v2-ink-3); margin-left: 2px; }
    .wh2-kpi-sub    { font-size: 11px; color: var(--v2-ink-4); margin-top: 3px; }

    /* ── Insight bar ───────────────────────────────────────────────────── */
    .wh2-insight-bar {
        display: flex;
        align-items: center;
        gap: 0;
        background: var(--v2-elevated);
        border: 1px solid var(--v2-border);
        border-radius: var(--v2-r-md);
        padding: 10px 20px;
        box-shadow: var(--v2-sh-xs);
        margin-top: 14px;
        flex-wrap: wrap;
    }
    .wh2-insight-item   { display: flex; align-items: center; gap: 8px; padding: 2px 16px; }
    .wh2-insight-item:first-child { padding-left: 0; }
    .wh2-insight-label  { font-size: 12px; color: var(--v2-ink-3); }
    .wh2-insight-val    { font-size: 13px; font-weight: 700; color: var(--v2-ink-1); }
    .wh2-insight-sep    { width: 1px; height: 22px; background: var(--v2-border); flex-shrink: 0; }
    .wh2-insight-spacer { flex: 1; }
    .wh2-focus-clear {
        background: var(--v2-brand-soft); border: 1px solid #c7d2fe; cursor: pointer;
        font-size: 12px; font-weight: 600; color: var(--v2-brand);
        padding: 4px 10px; border-radius: 999px; display: flex; align-items: center; gap: 5px;
        margin-right: 14px;
    }
    .wh2-focus-clear:hover { background: #e0e7ff; }
    .wh2-export-btn {
        background: var(--v2-success-soft); border: 1px solid var(--v2-success-border); cursor: pointer;
        font-size: 12px; font-weight: 600; color: #15803d;
        padding: 5px 12px; border-radius: 8px; display: flex; align-items: center; gap: 6px;
    }
    .wh2-export-btn:hover:not(:disabled) { background: #d1fae5; }
    .wh2-export-btn:disabled { opacity: .5; cursor: default; }

    /* ── Filter card ───────────────────────────────────────────────────── */
    .wh2-filter-card    { padding: 16px 20px; margin-top: 16px; }
    .wh2-filter-grid    { display: grid; grid-template-columns: 1fr 1fr 1fr 200px; gap: 24px; align-items: start; }
    @@media (max-width: 1200px) { .wh2-filter-grid { grid-template-columns: 1fr 1fr; } }
    .wh2-filter-col-sm  { min-width: 0; }
    .wh2-filter-head    { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
    .wh2-filter-title   { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .05em; color: var(--v2-ink-2); display: flex; align-items: center; gap: 5px; }
    .wh2-filter-actions { display: flex; align-items: center; gap: 4px; }
    .wh2-link-btn       { background: none; border: none; cursor: pointer; font-size: 11px; font-weight: 600; color: var(--v2-brand); padding: 0; }
    .wh2-link-btn:hover { text-decoration: underline; }
    .wh2-dot-sep        { font-size: 10px; color: var(--v2-ink-4); }
    .wh2-filter-count   { font-size: 11px; color: var(--v2-ink-4); margin-top: 8px; }
    .wh2-chip-search    { width: 100%; margin-bottom: 8px; }
    .wh2-roster-toggle  { display: inline-flex; align-items: center; gap: 5px; font-size: 11px; font-weight: 600; color: var(--v2-ink-2); cursor: pointer; user-select: none; margin: 0 auto 0 12px; }
    .wh2-roster-toggle input { cursor: pointer; accent-color: var(--v2-brand); }
    .wh2-roster-toggle-n { font-size: 10px; font-weight: 700; color: var(--v2-brand); background: color-mix(in srgb, var(--v2-brand) 12%, transparent); border-radius: 8px; padding: 1px 6px; }

    /* chip list */
    .wh2-chip-list { display: flex; flex-wrap: wrap; gap: 4px; max-height: 120px; overflow-y: auto; padding: 2px 0 4px; }
    .wh2-chip {
        display: inline-flex; align-items: center; gap: 3px;
        padding: 3px 9px;
        border-radius: 6px;
        border: 1px solid var(--v2-border);
        background: var(--v2-surface);
        color: var(--v2-ink-2);
        font-size: 11px; font-weight: 500;
        cursor: pointer;
        transition: border-color .1s, background .1s, color .1s;
        white-space: nowrap;
        user-select: none;
    }
    .wh2-chip:hover             { border-color: #c7d2fe; background: var(--v2-brand-soft); color: var(--v2-brand); }
    .wh2-chip.is-on             { background: var(--v2-brand-soft); border-color: #c7d2fe; color: #4338ca; font-weight: 600; }
    .wh2-chip.wh2-chip-mono     { font-family: monospace; font-size: 10.5px; }
    .wh2-chip-n                 { font-size: 10px; font-weight: 700; color: var(--v2-ink-4); }
    .wh2-chip.is-on .wh2-chip-n { color: #4338ca; }

    /* ── Chart grid ────────────────────────────────────────────────────── */
    .wh2-chart-grid { display: grid; grid-template-columns: 1fr 1fr 320px; gap: 12px; margin-top: 16px; }
    @@media (max-width: 1100px) { .wh2-chart-grid { grid-template-columns: 1fr; } }

    /* ── Activity heatmap ──────────────────────────────────────────────── */
    .wh2-heat { overflow-x: auto; padding-bottom: 4px; }
    .wh2-heat-grid { display: grid; gap: 3px; align-items: center; min-width: max-content; }
    .wh2-heat-corner { }
    .wh2-heat-colh {
        display: flex; flex-direction: column; align-items: center; justify-content: flex-end;
        font-size: 9px; color: var(--v2-ink-3); font-weight: 600; line-height: 1.3; padding-bottom: 3px;
    }
    .wh2-heat-colh .wh2-heat-dom { font-size: 11px; font-weight: 700; color: var(--v2-ink-2); }
    .wh2-heat-colh.weekend { color: var(--v2-ink-5); }
    .wh2-heat-colh.weekend .wh2-heat-dom { color: var(--v2-ink-4); }
    .wh2-heat-rowlabel { font-size: 12px; font-weight: 600; color: var(--v2-ink-2); white-space: nowrap; padding-right: 10px; display: flex; align-items: center; gap: 7px; overflow: hidden; }
    .wh2-heat-avatar {
        display: inline-flex; align-items: center; justify-content: center;
        width: 22px; height: 22px; border-radius: 50%;
        background: var(--v2-brand-grad); color: #fff;
        font-size: 9px; font-weight: 700; flex-shrink: 0;
        box-shadow: 0 2px 6px rgba(99,102,241,0.2);
    }
    .wh2-heat-cell {
        height: 30px; border-radius: 5px; background: #eef1f6;
        display: flex; align-items: center; justify-content: center;
        font-size: 10px; font-weight: 700; color: #fff;
        cursor: default; transition: transform .1s, box-shadow .1s;
    }
    .wh2-heat-cell:hover { transform: scale(1.12); box-shadow: var(--v2-sh-sm); z-index: 1; }
    .wh2-heat-cell.weekend { background: #f1f5f9; }
    /* Cool → warm intensity ramp (empty → light → full day → over) for a readable heatmap. */
    .wh2-h0 { background: #eef1f6; }
    .wh2-h1 { background: #bfdbfe; color: #1e40af; }  /* up to 2h  light blue */
    .wh2-h2 { background: #5eead4; color: #115e59; }  /* up to 4h  teal       */
    .wh2-h3 { background: #fde047; color: #854d0e; }  /* up to 6h  yellow     */
    .wh2-h4 { background: #fb923c; color: #7c2d12; }  /* up to 8h  orange     */
    .wh2-h5 { background: #ef4444; color: #fff;    }  /* 8h plus   red        */
    .wh2-heat-legend { display: flex; align-items: center; gap: 4px; font-size: 11px; color: var(--v2-ink-4); }
    .wh2-heat-swatch { width: 16px; height: 16px; border-radius: 4px; display: inline-block; }

    /* ── Per-member chart utilisation key ──────────────────────────────── */
    .wh2-util-key { display: flex; flex-wrap: wrap; gap: 12px; margin: -4px 0 8px; }
    .wh2-util-key-item { display: flex; align-items: center; gap: 5px; font-size: 11px; color: var(--v2-ink-3); font-weight: 600; }
    .wh2-util-dot { width: 10px; height: 10px; border-radius: 3px; display: inline-block; }

    /* ── Member summary ────────────────────────────────────────────────── */
    .wh2-member-btn { display: flex; align-items: center; gap: 8px; background: none; border: none; cursor: pointer; padding: 0; color: var(--v2-ink-1); }
    .wh2-member-btn:hover span:last-child { color: var(--v2-brand); text-decoration: underline; }
    .wh2-util-row { display: flex; align-items: center; gap: 8px; }
    .wh2-util-pct { font-size: 12px; font-weight: 700; font-variant-numeric: tabular-nums; min-width: 38px; text-align: right; }

    /* ── Epic accordion ────────────────────────────────────────────────── */
    .wh2-epic-block {
        border: 1px solid var(--v2-border);
        border-radius: var(--v2-r-sm);
        background: var(--v2-elevated);
        margin-bottom: 6px;
        overflow: hidden;
        box-shadow: var(--v2-sh-xs);
    }
    .wh2-epic-header {
        width: 100%; display: flex; align-items: center; gap: 10px;
        padding: 11px 16px;
        background: none; border: none; cursor: pointer; text-align: left;
        transition: background .1s;
    }
    .wh2-epic-header:hover { background: var(--v2-surface-2); }
    .wh2-chevron   { font-size: 11px; color: var(--v2-ink-3); flex-shrink: 0; width: 12px; }
    .wh2-epic-key  {
        font-family: monospace; font-size: 11px; font-weight: 700;
        color: var(--v2-brand); background: var(--v2-brand-soft); border: 1px solid #c7d2fe;
        border-radius: 4px; padding: 1px 6px; white-space: nowrap; flex-shrink: 0;
    }
    .wh2-epic-name { font-size: 13px; font-weight: 600; color: var(--v2-ink-1); flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .wh2-epic-meta { display: flex; align-items: center; gap: 14px; flex-shrink: 0; margin-left: auto; }
    .wh2-epic-share { width: 60px; height: 6px; border-radius: 999px; background: #eef0f6; overflow: hidden; flex-shrink: 0; }
    .wh2-epic-share-fill { display: block; height: 100%; border-radius: 999px; background: var(--v2-brand-grad); }
    .wh2-epic-stat { display: flex; align-items: center; gap: 4px; font-size: 12px; color: var(--v2-ink-3); white-space: nowrap; }
    .wh2-epic-hours { font-weight: 700; color: var(--v2-ink-1); }
    .wh2-epic-members { display: flex; gap: 3px; }
    .wh2-avatar {
        display: inline-flex; align-items: center; justify-content: center;
        width: 22px; height: 22px; border-radius: 50%;
        background: var(--v2-brand-grad); color: #fff;
        font-size: 9px; font-weight: 700; border: 1.5px solid white;
        flex-shrink: 0;
    }
    .wh2-avatar-more { background: var(--v2-surface-2); color: var(--v2-ink-3); }
    .wh2-epic-body { border-top: 1px solid var(--v2-border); }
    .wh2-weekend-day { color: var(--v2-warn); font-weight: 600; }
</style>

@code {
    private string SprintIdsInput = "";
    private bool IsLoading;
    private bool IsExporting;
    private string? ErrorMessage;
    private bool _renderCharts;

    private string _memberSearch = "";
    private string _epicSearch = "";

    private string _sortColDF = ""; private bool _sortAscDF = true;
    private void SortDF(string c) { if (_sortColDF == c) _sortAscDF = !_sortAscDF; else { _sortColDF = c; _sortAscDF = true; } }

    // ── Worklog-by-epic accordion ──────────────────────────────────────────────
    private HashSet<string> _wlExpanded = [];
    private void ToggleWlEpic(string key) { if (!_wlExpanded.Remove(key)) _wlExpanded.Add(key); }
    private void ExpandAllEpics()   { _wlExpanded = new HashSet<string>(WorklogsByEpic.Select(g => g.EpicKey)); }
    private void CollapseAllEpics() { _wlExpanded.Clear(); }

    private List<(string EpicKey, string EpicName, List<WorklogRow> Rows)> WorklogsByEpic =>
        FilteredWorklogs
            .GroupBy(w => string.IsNullOrEmpty(w.EpicKey) ? "—" : w.EpicKey)
            .Select(g => (
                EpicKey:  g.Key,
                EpicName: g.First().EpicName,
                Rows:     g.ToList()))
            .OrderByDescending(g => g.Rows.Sum(r => r.TimeSpentSeconds))
            .ToList();

    private static string SI2(string c, string sc, bool sa) =>
        sc == c ? (sa ? "v2-sortable v2-sort-asc" : "v2-sortable v2-sort-desc") : "v2-sortable";

    private static bool MatchSearch(string text, string search) =>
        string.IsNullOrWhiteSpace(search) || (text?.Contains(search.Trim(), StringComparison.OrdinalIgnoreCase) ?? false);

    private List<int> ParsedSprintIds = [];
    private List<SprintReport> SprintReports = [];
    private List<SprintConfig> _knownSprints = [];
    private HashSet<int> _snapshotSprintIds = [];

    private string SprintLabel(SprintConfig s)
    {
        var name = string.IsNullOrEmpty(s.Name) ? $"Sprint {s.SprintId}" : s.Name;
        return $"{name} ({s.StartDate:MMM d} – {s.EndDate:MMM d})";
    }

    private async Task OnKnownSprintPicked(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString();
        if (string.IsNullOrEmpty(raw)) return;
        SprintIdsInput = raw;
        await LoadData();
    }

    // ── Date range (independent of sprint selection) ────────────────────────────
    // Pulls every issue with worklog activity in the window, across the whole
    // project — not scoped to a specific sprint's cached report. Mirrors the
    // Support Trends "Window" filter's From/To + Full span pattern.
    private DateOnly _fullSpanStart;
    private DateOnly _fullSpanEnd;
    private DateOnly _rangeFrom;
    private DateOnly _rangeTo;

    private void ResetDateRange()
    {
        _rangeFrom = _fullSpanStart;
        _rangeTo   = _fullSpanEnd;
    }

    private async Task LoadByDateRangeAsync()
    {
        if (_rangeTo < _rangeFrom) { ErrorMessage = "End date must be on or after the start date."; return; }

        IsLoading = true; ErrorMessage = null;
        SprintReports.Clear(); SelectedMembers.Clear();
        DateFrom = null; DateTo = null;
        _memberSearch = ""; _epicSearch = "";
        StateHasChanged();

        try
        {
            _roster   = await Roster.GetAllAsync();
            _holidays = await Roster.GetHolidaysAsync();

            var jql = $"project = JM AND worklogDate >= \"{_rangeFrom:yyyy-MM-dd}\" AND worklogDate <= \"{_rangeTo:yyyy-MM-dd}\" ORDER BY key ASC";
            var report = await JiraService.GetDeliveryDataByFilterAsync(jql);
            report.SprintName = $"{_rangeFrom:MMM d, yyyy} – {_rangeTo:MMM d, yyyy}";
            report.StartDate  = _rangeFrom.ToDateTime(TimeOnly.MinValue);
            report.EndDate    = _rangeTo.ToDateTime(TimeOnly.MinValue);

            ParsedSprintIds = [];
            SprintReports   = [report];
            _snapshotSprintIds.Clear();
            _rosterAuthorCache = null;

            DateFrom = report.StartDate;
            DateTo   = report.EndDate;

            SelectedMembers  = new HashSet<string>(AllAuthors);
            SelectedEpics    = new HashSet<string>(AllEpics.Select(e => e.Key));
            SelectedProducts = new HashSet<string>(AllProducts.Select(p => p.Name));
            _renderCharts    = true;
        }
        catch (Exception ex) { ErrorMessage = $"Failed to load: {ex.Message}"; }
        finally { IsLoading = false; }
    }

    // ── Roster (capacity source) ─────────────────────────────────────────────────
    private List<RosterMember> _roster = [];
    private List<SharedHoliday> _holidays = [];

    // Matches a Jira author/assignee display name to a roster member name on word boundaries.
    private static bool AuthorMatchesMember(string? author, string memberName)
    {
        if (string.IsNullOrWhiteSpace(author) || string.IsNullOrWhiteSpace(memberName)) return false;
        var words = author.Split(new[] { ' ', '.', ',', '-', '_', '@', '(', ')', '\t' },
                                 StringSplitOptions.RemoveEmptyEntries);
        return words.Any(w => string.Equals(w, memberName, StringComparison.OrdinalIgnoreCase));
    }

    private decimal HoursPerDayFor(string author) =>
        _roster.FirstOrDefault(r => AuthorMatchesMember(author, r.Name))?.HoursPerDay ?? 6m;

    // ── Roster-only filter ───────────────────────────────────────────────────────
    private bool _rosterOnly;
    private HashSet<string>? _rosterAuthorCache;

    // Display names (worklog authors + assignees) that resolve to an ACTIVE roster member.
    // Worklog authors match by Jira accountId first, then email, then the name heuristic;
    // assignees carry no Jira identity on this page, so they match by name only.
    private HashSet<string> RosterAuthorSet
    {
        get
        {
            if (_rosterAuthorCache is not null) return _rosterAuthorCache;

            var active = _roster.Where(r => r.Active).ToList();
            var accountIds = active.Where(r => !string.IsNullOrWhiteSpace(r.JiraAccountId))
                                   .Select(r => r.JiraAccountId!.Trim())
                                   .ToHashSet(StringComparer.OrdinalIgnoreCase);
            var emails = active.Where(r => !string.IsNullOrWhiteSpace(r.JiraEmail))
                               .Select(r => r.JiraEmail!.Trim())
                               .ToHashSet(StringComparer.OrdinalIgnoreCase);

            var set = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
            foreach (var wl in SprintReports.SelectMany(r => r.Issues).SelectMany(i => i.Worklogs))
            {
                if (string.IsNullOrEmpty(wl.Author) || set.Contains(wl.Author)) continue;
                if ((!string.IsNullOrEmpty(wl.AuthorAccountId) && accountIds.Contains(wl.AuthorAccountId)) ||
                    (!string.IsNullOrEmpty(wl.AuthorEmail)     && emails.Contains(wl.AuthorEmail)) ||
                    active.Any(r => AuthorMatchesMember(wl.Author, r.Name)))
                {
                    set.Add(wl.Author);
                }
            }
            foreach (var assignee in SprintReports.SelectMany(r => r.Issues)
                         .Select(i => i.Assignee).Where(a => !string.IsNullOrEmpty(a)).Distinct())
            {
                if (!set.Contains(assignee) && active.Any(r => AuthorMatchesMember(assignee, r.Name)))
                    set.Add(assignee);
            }
            return _rosterAuthorCache = set;
        }
    }

    private bool IsRosterPerson(string? name) =>
        !string.IsNullOrEmpty(name) && RosterAuthorSet.Contains(name);

    private void ToggleRosterOnly(bool on)
    {
        _rosterOnly = on;
        if (on)
            SelectedMembers.RemoveWhere(m => !RosterAuthorSet.Contains(m));
        OnFilterChanged();
    }

    // ── Filters ────────────────────────────────────────────────────────────────
    private HashSet<string> SelectedMembers  = [];
    private HashSet<string> SelectedEpics    = [];
    private HashSet<string> SelectedProducts = [];
    private DateTime? DateFrom;
    private DateTime? DateTo;

    // ── Product (JS Project field) ───────────────────────────────────────────────
    private const string NoProductLabel = "—";

    private static string ProductOf(SprintIssue i) =>
        string.IsNullOrWhiteSpace(i.Product) ? NoProductLabel : i.Product;

    private List<(string Name, int Count)> AllProducts => SprintReports
        .SelectMany(r => r.Issues)
        .GroupBy(ProductOf)
        .Select(g => (Name: g.Key, Count: g.Count()))
        .OrderBy(g => g.Name == NoProductLabel ? 1 : 0)
        .ThenBy(g => g.Name)
        .ToList();

    private void SelectAllProducts()    { SelectedProducts = new HashSet<string>(AllProducts.Select(p => p.Name)); OnFilterChanged(); }
    private void ClearProductsFilter()  { SelectedProducts.Clear(); OnFilterChanged(); }

    private void ToggleProduct(string name, bool selected)
    {
        if (selected) SelectedProducts.Add(name); else SelectedProducts.Remove(name);
        OnFilterChanged();
    }

    // ── Derived: source lists ──────────────────────────────────────────────────
    private List<string> AllAuthors => SprintReports
        .SelectMany(r => r.Issues)
        .SelectMany(i => i.Worklogs)
        .Select(w => w.Author)
        .Where(a => !string.IsNullOrEmpty(a))
        .Where(a => !_rosterOnly || RosterAuthorSet.Contains(a))
        .Distinct().Order().ToList();

    private List<(string Key, string Name)> AllEpics => SprintReports
        .SelectMany(r => r.Issues)
        .Where(i => !string.IsNullOrEmpty(i.EpicKey))
        .Select(i => (i.EpicKey, string.IsNullOrEmpty(i.EpicName) || i.EpicName == "No Epic" ? i.EpicKey : i.EpicName))
        .DistinctBy(e => e.EpicKey)
        .OrderBy(e => e.EpicKey)
        .ToList();

    private sealed record WorklogRow(
        DateTime Date, string Author, int TimeSpentSeconds,
        string IssueKey, string IssueSummary, string IssueType,
        string EpicKey, string EpicName, string Product);

    private static bool IsFeatureIssue(SprintIssue i) =>
        !i.IssueType.Contains("Bug",    StringComparison.OrdinalIgnoreCase) &&
        !i.IssueType.Contains("Defect", StringComparison.OrdinalIgnoreCase) &&
        !i.IssueType.Contains("Epic",   StringComparison.OrdinalIgnoreCase);

    private sealed record DoneFeatureRow(
        string Key, string Summary, string IssueType,
        string Assignee, string EpicKey, string EpicName,
        int? StoryPoints, double HoursLogged, string SprintName);

    private sealed record MemberSummaryRow(
        string Name, double Hours, int ActiveDays, double AvgPerActiveDay,
        double Capacity, double Util, string TopEpic);

    private List<WorklogRow> AllWorklogs => SprintReports
        .SelectMany(r => r.Issues)
        .SelectMany(i => i.Worklogs.Select(w => new WorklogRow(
            w.Started.Date, w.Author, w.TimeSpentSeconds,
            i.Key, i.Summary, i.IssueType, i.EpicKey, i.EpicName, ProductOf(i))))
        .OrderByDescending(w => w.Date).ThenBy(w => w.Author)
        .ToList();

    private List<WorklogRow> FilteredWorklogs =>
        AllWorklogs.Where(w =>
            !string.IsNullOrEmpty(w.Author) &&
            (!_rosterOnly || RosterAuthorSet.Contains(w.Author)) &&
            (SelectedMembers.Count == 0  || SelectedMembers.Contains(w.Author)) &&
            (SelectedEpics.Count == 0    || SelectedEpics.Contains(w.EpicKey)) &&
            (SelectedProducts.Count == 0 || SelectedProducts.Contains(w.Product)) &&
            (!DateFrom.HasValue || w.Date >= DateFrom.Value.Date) &&
            (!DateTo.HasValue   || w.Date <= DateTo.Value.Date))
        .OrderByDescending(w => w.Date).ThenBy(w => w.Author)
        .ToList();

    private List<DoneFeatureRow> DoneFeatures
    {
        get
        {
            var q = SprintReports
                .SelectMany(r => r.Issues.Select(i => (Issue: i, SprintName: r.SprintName)))
                .Where(x => x.Issue.StatusCategoryKey == "done" && IsFeatureIssue(x.Issue))
                .Where(x => SelectedEpics.Count == 0 || SelectedEpics.Contains(x.Issue.EpicKey))
                .Where(x => SelectedProducts.Count == 0 || SelectedProducts.Contains(ProductOf(x.Issue)))
                .Where(x => !_rosterOnly || IsRosterPerson(x.Issue.Assignee))
                .Where(x => SelectedMembers.Count == 0 || SelectedMembers.Contains(x.Issue.Assignee))
                .DistinctBy(x => x.Issue.Key)
                .Select(x => new DoneFeatureRow(
                    x.Issue.Key, x.Issue.Summary, x.Issue.IssueType,
                    x.Issue.Assignee, x.Issue.EpicKey, x.Issue.EpicName,
                    x.Issue.StoryPoints,
                    x.Issue.Worklogs.Sum(w => w.TimeSpentSeconds) / 3600.0,
                    x.SprintName));
            return (_sortColDF switch
            {
                "Key"      => _sortAscDF ? q.OrderBy(r => r.Key)        : q.OrderByDescending(r => r.Key),
                "Summary"  => _sortAscDF ? q.OrderBy(r => r.Summary)    : q.OrderByDescending(r => r.Summary),
                "Type"     => _sortAscDF ? q.OrderBy(r => r.IssueType)  : q.OrderByDescending(r => r.IssueType),
                "Assignee" => _sortAscDF ? q.OrderBy(r => r.Assignee)   : q.OrderByDescending(r => r.Assignee),
                "Sprint"   => _sortAscDF ? q.OrderBy(r => r.SprintName) : q.OrderByDescending(r => r.SprintName),
                "Epic"     => _sortAscDF ? q.OrderBy(r => r.EpicName)   : q.OrderByDescending(r => r.EpicName),
                "SP"       => _sortAscDF ? q.OrderBy(r => r.StoryPoints)  : q.OrderByDescending(r => r.StoryPoints),
                "Hours"    => _sortAscDF ? q.OrderBy(r => r.HoursLogged)  : q.OrderByDescending(r => r.HoursLogged),
                _          => q.OrderBy(r => r.Key),
            }).ToList();
        }
    }

    private double DoneTotalSP    => DoneFeatures.Sum(r => r.StoryPoints ?? 0);
    private double DoneTotalHours => DoneFeatures.Sum(r => r.HoursLogged);
    private bool   ShowSprintColDF => SprintReports.Count > 1;

    // ── Capacity / working days ──────────────────────────────────────────────────
    private (DateTime From, DateTime To)? WorklogSpan
    {
        get
        {
            var dates = FilteredWorklogs.Select(w => w.Date).ToList();
            if (dates.Count == 0) return null;
            return (dates.Min(), dates.Max());
        }
    }

    // The window capacity/heatmap are computed over. Prefers the sprint window
    // (set from SprintReport dates on load), falls back to the worklog span, and
    // is always capped at today so utilisation reflects elapsed — not future — days.
    private (DateTime From, DateTime To)? AnalysisSpan
    {
        get
        {
            var span = WorklogSpan;
            var from = DateFrom?.Date ?? span?.From;
            var toRaw = DateTo?.Date ?? span?.To;
            if (from is null || toRaw is null) return null;
            var to = toRaw.Value > DateTime.Today ? DateTime.Today : toRaw.Value;
            if (to < from.Value) to = from.Value;
            return (from.Value, to);
        }
    }

    private int WorkingDayCount
    {
        get
        {
            var span = AnalysisSpan;
            if (span is null) return 0;
            var holidaySet = _holidays.Select(h => h.Date.ToDateTime(TimeOnly.MinValue).Date).ToHashSet();
            var count = 0;
            for (var d = span.Value.From; d <= span.Value.To; d = d.AddDays(1))
                if (d.DayOfWeek is not (DayOfWeek.Saturday or DayOfWeek.Sunday) && !holidaySet.Contains(d.Date))
                    count++;
            return count;
        }
    }

    private double TotalCapacityHours
    {
        get
        {
            var wd = WorkingDayCount;
            return FilteredWorklogs.Select(w => w.Author).Distinct()
                .Sum(a => wd * (double)HoursPerDayFor(a));
        }
    }

    private double AvgUtilization => TotalCapacityHours > 0 ? TotalHours / TotalCapacityHours * 100 : 0;

    // ── KPI properties ──────────────────────────────────────────────────────────
    private double TotalHours         => FilteredWorklogs.Sum(w => w.TimeSpentSeconds) / 3600.0;
    private int    ActiveMemberCount  => FilteredWorklogs.Select(w => w.Author).Distinct().Count();
    private int    FilteredEntryCount => FilteredWorklogs.Count;
    private double AvgHoursPerMember  => ActiveMemberCount > 0 ? TotalHours / ActiveMemberCount : 0;

    private double AvgHoursPerDay => FilteredWorklogs.Select(w => w.Date).Distinct().Any()
        ? TotalHours / FilteredWorklogs.Select(w => w.Date).Distinct().Count()
        : 0;

    // How many hours a typical member logs on a typical working day of the loaded span.
    private double AvgHoursPerMemberPerDay => WorkingDayCount > 0 ? AvgHoursPerMember / WorkingDayCount : 0;

    private double MaxDayHours => FilteredWorklogs
        .GroupBy(w => w.Date)
        .Select(g => g.Sum(w => w.TimeSpentSeconds) / 3600.0)
        .DefaultIfEmpty(0).Max();

    private string TopContributor => FilteredWorklogs
        .GroupBy(w => w.Author)
        .OrderByDescending(g => g.Sum(w => w.TimeSpentSeconds))
        .Select(g => g.Key)
        .FirstOrDefault() ?? "—";

    private string BusiestWeekday => FilteredWorklogs
        .GroupBy(w => w.Date.DayOfWeek)
        .OrderByDescending(g => g.Sum(w => w.TimeSpentSeconds))
        .Select(g => g.Key.ToString())
        .FirstOrDefault() ?? "—";

    private string MostActiveEpic => FilteredWorklogs
        .Where(w => !string.IsNullOrEmpty(w.EpicKey))
        .GroupBy(w => w.EpicKey)
        .OrderByDescending(g => g.Sum(w => w.TimeSpentSeconds))
        .Select(g => g.Key)
        .FirstOrDefault() ?? "—";

    // ── Member summary rows ──────────────────────────────────────────────────────
    private List<MemberSummaryRow> MemberSummaries
    {
        get
        {
            var wd = WorkingDayCount;
            return FilteredWorklogs
                .GroupBy(w => w.Author)
                .Select(g =>
                {
                    var hours      = g.Sum(w => w.TimeSpentSeconds) / 3600.0;
                    var activeDays = g.Select(w => w.Date).Distinct().Count();
                    var capacity   = wd * (double)HoursPerDayFor(g.Key);
                    var topEpic    = g.Where(w => !string.IsNullOrEmpty(w.EpicKey))
                                      .GroupBy(w => w.EpicKey)
                                      .OrderByDescending(eg => eg.Sum(w => w.TimeSpentSeconds))
                                      .Select(eg => eg.Key).FirstOrDefault() ?? "—";
                    return new MemberSummaryRow(
                        g.Key, hours, activeDays,
                        activeDays > 0 ? hours / activeDays : 0,
                        capacity,
                        capacity > 0 ? hours / capacity * 100 : 0,
                        topEpic);
                })
                .OrderByDescending(m => m.Hours)
                .ToList();
        }
    }

    // ── Heatmap data ─────────────────────────────────────────────────────────────
    private List<DateTime> HeatDays
    {
        get
        {
            var span = AnalysisSpan;
            if (span is null) return [];
            var list = new List<DateTime>();
            for (var d = span.Value.From; d <= span.Value.To && list.Count < 90; d = d.AddDays(1))
                list.Add(d);
            return list;
        }
    }

    private List<string> HeatMembers => FilteredWorklogs
        .GroupBy(w => w.Author)
        .OrderByDescending(g => g.Sum(w => w.TimeSpentSeconds))
        .Select(g => g.Key)
        .ToList();

    private Dictionary<string, Dictionary<DateTime, double>> MemberDayHours => FilteredWorklogs
        .GroupBy(w => w.Author)
        .ToDictionary(
            g => g.Key,
            g => g.GroupBy(w => w.Date.Date)
                  .ToDictionary(d => d.Key, d => d.Sum(w => w.TimeSpentSeconds) / 3600.0));

    private static string HeatClass(double hours) => hours switch
    {
        <= 0  => "wh2-h0",
        < 2   => "wh2-h1",
        < 4   => "wh2-h2",
        < 6   => "wh2-h3",
        < 8   => "wh2-h4",
        _     => "wh2-h5",
    };

    private static string Initials(string name) =>
        string.Concat((name ?? "").Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Take(2).Select(p => p.Length > 0 ? p[0].ToString() : "")).ToUpper();

    // ── Utilisation styling helpers ──────────────────────────────────────────────
    private static string UtilBarClass(double util) => util switch
    {
        >= 85 and <= 115 => "v2-bar-fill-success",
        >= 60 and < 130  => "v2-bar-fill-warn",
        _                => "v2-bar-fill-danger",
    };
    private static string UtilTextClass(double util) => util switch
    {
        >= 85 and <= 115 => "v2-text-success",
        >= 60 and < 130  => "v2-text-warn",
        _                => "v2-text-danger",
    };
    private static string UtilPillClass(double util) => util switch
    {
        >= 85 and <= 115 => "v2-pill-success",
        >= 60 and < 130  => "v2-pill-warn",
        _                => "v2-pill-danger",
    };
    private static string UtilAccent(double util) => util switch
    {
        >= 85 and <= 115 => "var(--v2-success-grad)",
        >= 60 and < 130  => "var(--v2-warn-grad)",
        _                => "var(--v2-danger-grad)",
    };

    // ── Load ────────────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        _knownSprints = (await SprintConfig.GetAllAsync())
            .OrderByDescending(c => c.StartDate)
            .ToList();

        // Default the sprint input to the dashboard-config sprint that contains today.
        var current = await SprintConfig.GetCurrentAsync();
        if (current is not null && string.IsNullOrWhiteSpace(SprintIdsInput))
            SprintIdsInput = current.SprintId.ToString();

        // Date range defaults to the widest span covered by Dashboard Config's sprints.
        _fullSpanStart = _knownSprints.Count > 0 ? _knownSprints.Min(c => c.StartDate) : DateOnly.FromDateTime(DateTime.Today.AddDays(-30));
        _fullSpanEnd   = _knownSprints.Count > 0 ? _knownSprints.Max(c => c.EndDate)   : DateOnly.FromDateTime(DateTime.Today);
        _rangeFrom = _fullSpanStart;
        _rangeTo   = _fullSpanEnd;
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await LoadData();
    }

    private async Task LoadData()
    {
        var ids = SprintIdsInput
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(s => int.TryParse(s.Trim(), out var n) ? (int?)n : null)
            .Where(n => n.HasValue).Select(n => n!.Value).Distinct().ToList();

        if (ids.Count == 0) { ErrorMessage = "Enter at least one sprint ID."; return; }

        IsLoading = true; ErrorMessage = null;
        SprintReports.Clear(); SelectedMembers.Clear();
        DateFrom = null; DateTo = null;
        _memberSearch = ""; _epicSearch = "";
        StateHasChanged();

        try
        {
            // All of these hit the one circuit-scoped AppDbContext, so they MUST run
            // sequentially — concurrent EF operations on a shared context throw.
            _roster   = await Roster.GetAllAsync();
            _holidays = await Roster.GetHolidaysAsync();

            var reports = new List<SprintReport>();
            var snapshotIds = new HashSet<int>();
            foreach (var id in ids)
            {
                // A frozen snapshot (sprint ended 3+ days ago) is a permanent, read-only
                // record — serve it straight from the DB and skip Jira entirely.
                var snapshot = await Snapshots.GetSnapshotAsync(id);
                if (snapshot is not null)
                {
                    reports.Add(snapshot);
                    snapshotIds.Add(id);
                    continue;
                }

                var report = await JiraService.GetDeliveryDataAsync(id);
                reports.Add(report);
                await Snapshots.SaveIfSettledAsync(report);
            }

            ParsedSprintIds = ids;
            SprintReports   = reports;
            _snapshotSprintIds = snapshotIds;
            _rosterAuthorCache = null; // roster + worklogs changed — rebuild the match set lazily

            // Bound the view to the sprint window so capacity/heatmap aren't skewed by
            // stale worklogs logged on these issues long before the sprint. Users can clear it.
            var starts = SprintReports.Where(r => r.StartDate.HasValue).Select(r => r.StartDate!.Value.Date).ToList();
            var ends   = SprintReports.Where(r => r.EndDate.HasValue).Select(r => r.EndDate!.Value.Date).ToList();
            if (starts.Count > 0) DateFrom = starts.Min();
            if (ends.Count > 0)   DateTo   = ends.Max();

            SelectedMembers  = new HashSet<string>(AllAuthors);
            SelectedEpics    = new HashSet<string>(AllEpics.Select(e => e.Key));
            SelectedProducts = new HashSet<string>(AllProducts.Select(p => p.Name));
            _renderCharts    = true;
        }
        catch (Exception ex) { ErrorMessage = $"Failed to load sprint data: {ex.Message}"; }
        finally { IsLoading = false; }
    }

    // ── Filter actions ──────────────────────────────────────────────────────────
    private void SelectAllMembers()   { SelectedMembers = new HashSet<string>(AllAuthors); OnFilterChanged(); }
    private void ClearMembersFilter() { SelectedMembers.Clear(); OnFilterChanged(); }
    private void FocusMember(string member) { SelectedMembers = new HashSet<string> { member }; OnFilterChanged(); }

    private void ToggleMember(string author, bool selected)
    {
        if (selected) SelectedMembers.Add(author); else SelectedMembers.Remove(author);
        OnFilterChanged();
    }

    private void SelectAllEpics()    { SelectedEpics = new HashSet<string>(AllEpics.Select(e => e.Key)); OnFilterChanged(); }
    private void ClearEpicsFilter()   { SelectedEpics.Clear(); OnFilterChanged(); }

    private void ToggleEpic(string key, bool selected)
    {
        if (selected) SelectedEpics.Add(key); else SelectedEpics.Remove(key);
        OnFilterChanged();
    }

    private void ClearDates() { DateFrom = null; DateTo = null; OnFilterChanged(); }

    private void OnFilterChanged() { _renderCharts = true; StateHasChanged(); }

    // ── Charts ──────────────────────────────────────────────────────────────────
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_renderCharts && SprintReports.Count > 0)
        {
            _renderCharts = false;
            var filtered = FilteredWorklogs;
            await RenderMemberChart(filtered);
            await RenderDayChart(filtered);
            await RenderAvgMemberDayChart(filtered);
            await RenderEpicChart(filtered);
        }
    }

    private async Task RenderMemberChart(List<WorklogRow> filtered)
    {
        var wd = WorkingDayCount;
        var byMember = filtered
            .GroupBy(w => w.Author)
            .Select(g =>
            {
                var hours    = Math.Round(g.Sum(w => w.TimeSpentSeconds) / 3600.0, 1);
                var capacity = Math.Round(wd * (double)HoursPerDayFor(g.Key), 1);
                return new
                {
                    Name     = g.Key,
                    Hours    = hours,
                    Capacity = capacity,
                    Util     = capacity > 0 ? hours / capacity * 100 : 0
                };
            })
            .OrderByDescending(m => m.Hours).ToList();
        if (byMember.Count == 0) return;

        // Colour each Logged bar by utilisation: green ≥ 80% (well utilised),
        // amber 60–80%, red < 60% (under-utilised).
        static string UtilFill(double u)   => u >= 80 ? "rgba(22,163,74,0.85)"  : u >= 60 ? "rgba(245,158,11,0.85)" : "rgba(220,38,38,0.85)";
        static string UtilStroke(double u) => u >= 80 ? "rgba(21,128,61,1)"     : u >= 60 ? "rgba(180,83,9,1)"     : "rgba(185,28,28,1)";

        await JS.InvokeVoidAsync("renderChart", "chart-hours-member", new
        {
            type = "bar",
            data = new
            {
                labels   = byMember.Select(m => m.Name).ToArray(),
                datasets = new object[]
                {
                    new
                    {
                        label           = "Logged",
                        data            = byMember.Select(m => m.Hours).ToArray(),
                        backgroundColor = byMember.Select(m => UtilFill(m.Util)).ToArray(),
                        borderColor     = byMember.Select(m => UtilStroke(m.Util)).ToArray(),
                        borderWidth = 1, borderRadius = 4
                    },
                    new
                    {
                        label           = "Capacity",
                        data            = byMember.Select(m => m.Capacity).ToArray(),
                        backgroundColor = "rgba(148,163,184,0.28)",
                        borderColor     = "rgba(148,163,184,0.5)",
                        borderWidth = 1, borderRadius = 4
                    }
                }
            },
            options = new
            {
                indexAxis = "y", responsive = true, maintainAspectRatio = false,
                plugins = new { legend = new { display = true, position = "top", labels = new { font = new { size = 11 }, boxWidth = 12, padding = 10 } } },
                scales  = new { x = new { beginAtZero = true, grid = new { color = "rgba(0,0,0,0.04)" } } }
            }
        });
    }

