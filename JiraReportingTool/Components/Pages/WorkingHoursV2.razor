    private async Task ExportToExcel()
    {
        var filtered = FilteredWorklogs;
        if (filtered.Count == 0) return;

        IsExporting = true; StateHasChanged();
        try
        {
            using var wb = new XLWorkbook();

            var sprintNames = SprintReports.Where(r => !string.IsNullOrEmpty(r.SprintName))
                .Select(r => r.SprintName).Distinct();
            var sprintLabel = sprintNames.Any()
                ? string.Join(", ", sprintNames)
                : string.Join(", ", ParsedSprintIds);
            var dateRangeLabel = DateFrom.HasValue || DateTo.HasValue
                ? $"{(DateFrom.HasValue ? DateFrom.Value.ToString("yyyy-MM-dd") : "—")} → {(DateTo.HasValue ? DateTo.Value.ToString("yyyy-MM-dd") : "—")}"
                : "All dates";
            var exportedAt = DateTime.Now.ToString("yyyy-MM-dd HH:mm");

            BuildOverviewSheet(wb, sprintLabel, dateRangeLabel, exportedAt);
            await BuildChartsSheetAsync(wb);
            BuildMemberSummarySheet(wb);
            BuildHeatmapSheet(wb);
            BuildByEpicSheet(wb);
            BuildDoneFeaturesSheet(wb);
            BuildWorkingHoursSheet(wb, filtered, sprintLabel, dateRangeLabel, exportedAt);
            BuildWeekdaySummarySheet(wb, filtered, sprintLabel, exportedAt);

            using var ms = new MemoryStream();
            wb.SaveAs(ms);
            var base64    = Convert.ToBase64String(ms.ToArray());
            var fileLabel = sprintLabel.Replace(" ", "_").Replace("/", "-").Replace(",", "");
            var fileName  = $"WorkingHours_{fileLabel}_{DateTime.Today:yyyyMMdd}.xlsx";
            const string mime = "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet";
            await JS.InvokeVoidAsync("downloadBase64File", base64, fileName, mime);
        }
        catch (Exception ex) { ErrorMessage = $"Export failed: {ex.Message}"; }
        finally { IsExporting = false; }
    }

    private void BuildOverviewSheet(XLWorkbook wb, string sprintLabel, string dateRangeLabel, string exportedAt)
    {
        var ws = wb.Worksheets.Add("Overview");
        int row = 1;
        void Meta(string label, string value)
        {
            var lc = ws.Cell(row, 1); lc.Value = label; StyleMetaLabel(lc);
            ws.Cell(row, 2).Value = value;
            row++;
        }

        Meta("Sprint(s)", sprintLabel);
        Meta("Members",   SelectedMembers.Count == AllAuthors.Count ? "All" : string.Join(", ", SelectedMembers.Order()));
        Meta("Epics",     SelectedEpics.Count == AllEpics.Count ? "All" : string.Join(", ", SelectedEpics.Order()));
        Meta("Products",  SelectedProducts.Count == AllProducts.Count ? "All" : string.Join(", ", SelectedProducts.Order()));
        Meta("Date Range", dateRangeLabel);
        Meta("Exported",   exportedAt);
        row++;

        StyleHeaderCell(ws.Cell(row, 1)); ws.Cell(row, 1).Value = "Metric";
        StyleHeaderCell(ws.Cell(row, 2)); ws.Cell(row, 2).Value = "Value";
        row++;

        void Kpi(string label, string value)
        {
            ws.Cell(row, 1).Value = label;
            ws.Cell(row, 1).Style.Font.Bold = true;
            ws.Cell(row, 2).Value = value;
            row++;
        }

        Kpi("Total Hours",         $"{TotalHours:F1} h");
        Kpi("Utilisation",         $"{AvgUtilization:F0}% ({TotalHours:F0} / {TotalCapacityHours:F0} h capacity)");
        Kpi("Members",             ActiveMemberCount.ToString());
        Kpi("Log Entries",         FilteredEntryCount.ToString());
        Kpi("Avg / Member",        $"{AvgHoursPerMember:F1} h");
        Kpi("Avg / Day",           $"{AvgHoursPerDay:F1} h");
        Kpi("Avg / Member / Day",  $"{AvgHoursPerMemberPerDay:F1} h");
        Kpi("Peak Day",            $"{MaxDayHours:F1} h");
        Kpi("Top Contributor",     TopContributor);
        Kpi("Busiest Weekday",     BusiestWeekday);
        Kpi("Most-Active Epic",    MostActiveEpic);
        Kpi("Working Days",        WorkingDayCount.ToString());

        ws.Columns().AdjustToContents();
    }

    private async Task BuildChartsSheetAsync(XLWorkbook wb)
    {
        var ws = wb.Worksheets.Add("Charts");
        int row = 1;
        foreach (var (canvasId, title) in ChartExports)
        {
            var titleCell = ws.Cell(row, 1);
            titleCell.Value = title;
            titleCell.Style.Font.Bold = true;
            titleCell.Style.Font.FontSize = 13;
            row++;

            string? dataUrl = null;
            try { dataUrl = await JS.InvokeAsync<string?>("getChartImage", canvasId); } catch { }

            if (!string.IsNullOrEmpty(dataUrl))
            {
                var comma = dataUrl.IndexOf(',');
                var base64Img = comma >= 0 ? dataUrl[(comma + 1)..] : dataUrl;
                var bytes = Convert.FromBase64String(base64Img);
                using var imgStream = new MemoryStream(bytes);
                ws.AddPicture(imgStream, XLPictureFormat.Png)
                  .MoveTo(ws.Cell(row, 1))
                  .WithSize(640, 340);
                row += 18;
            }
            else
            {
                ws.Cell(row, 1).Value = "(chart not available — no data for current filters)";
                row += 1;
            }
            row += 2;
        }
        ws.Column(1).Width = 16;
    }

    private void BuildMemberSummarySheet(XLWorkbook wb)
    {
        var rows = MemberSummaries;
        var ws = wb.Worksheets.Add("Member Summary");
        var headers = new[] { "Member", "Logged (h)", "Active Days", "Avg / Active Day (h)", "Capacity (h)", "Utilisation %", "Top Epic" };
        for (int i = 0; i < headers.Length; i++) { var hc = ws.Cell(1, i + 1); hc.Value = headers[i]; StyleHeaderCell(hc); }
        ws.SheetView.FreezeRows(1);

        int row = 2;
        foreach (var m in rows)
        {
            if (row % 2 == 0) ws.Row(row).Style.Fill.BackgroundColor = XLColor.FromHtml("#f8f9fa");
            ws.Cell(row, 1).Value = m.Name;
            ws.Cell(row, 2).Value = Math.Round(m.Hours, 2);
            ws.Cell(row, 3).Value = m.ActiveDays;
            ws.Cell(row, 4).Value = Math.Round(m.AvgPerActiveDay, 2);
            ws.Cell(row, 5).Value = Math.Round(m.Capacity, 1);
            ws.Cell(row, 6).Value = Math.Round(m.Util, 1);
            ws.Cell(row, 7).Value = m.TopEpic;
            row++;
        }
        if (rows.Count > 0)
        {
            ws.Cell(row, 1).Value = "TOTAL"; ws.Cell(row, 1).Style.Font.Bold = true;
            ws.Cell(row, 2).Value = Math.Round(TotalHours, 2); ws.Cell(row, 2).Style.Font.Bold = true;
            ws.Cell(row, 5).Value = Math.Round(TotalCapacityHours, 1); ws.Cell(row, 5).Style.Font.Bold = true;
            ws.Cell(row, 6).Value = Math.Round(AvgUtilization, 1); ws.Cell(row, 6).Style.Font.Bold = true;
            ws.Row(row).Style.Fill.BackgroundColor = XLColor.FromHtml("#e9ecef");
        }
        ws.Columns().AdjustToContents();
        ws.Row(1).Height = 22;
    }

    private void BuildHeatmapSheet(XLWorkbook wb)
    {
        var days = HeatDays; var members = HeatMembers; var map = MemberDayHours;
        if (days.Count == 0 || members.Count == 0) return;

        var ws = wb.Worksheets.Add("Activity Heatmap");
        var corner = ws.Cell(1, 1); corner.Value = "Member"; StyleHeaderCell(corner);
        for (int d = 0; d < days.Count; d++)
        {
            var hc = ws.Cell(1, d + 2);
            hc.Value = days[d].ToString("MMM d");
            StyleHeaderCell(hc);
        }
        ws.SheetView.FreezeRows(1);
        ws.SheetView.FreezeColumns(1);

        int row = 2;
        foreach (var member in members)
        {
            ws.Cell(row, 1).Value = member;
            ws.Cell(row, 1).Style.Font.Bold = true;
            var dayMap = map.TryGetValue(member, out var dm) ? dm : new();
            for (int d = 0; d < days.Count; d++)
            {
                var hrs = dayMap.TryGetValue(days[d].Date, out var h) ? h : 0;
                var c = ws.Cell(row, d + 2);
                if (hrs > 0) c.Value = Math.Round(hrs, 2);
                c.Style.Fill.BackgroundColor = HeatFillColor(hrs);
                c.Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;
            }
            row++;
        }
        ws.Column(1).Width = 22;
        for (int d = 0; d < days.Count; d++) ws.Column(d + 2).Width = 9;
    }

    // Mirrors the on-screen heatmap's cool-to-warm intensity ramp (.wh2-h0 … .wh2-h5).
    private static XLColor HeatFillColor(double hours) => hours switch
    {
        <= 0 => XLColor.FromHtml("#eef1f6"),
        < 2  => XLColor.FromHtml("#bfdbfe"),
        < 4  => XLColor.FromHtml("#5eead4"),
        < 6  => XLColor.FromHtml("#fde047"),
        < 8  => XLColor.FromHtml("#fb923c"),
        _    => XLColor.FromHtml("#ef4444"),
    };

    private void BuildByEpicSheet(XLWorkbook wb)
    {
        var groups = WorklogsByEpic;
        var ws = wb.Worksheets.Add("By Epic");
        var headers = new[] { "Epic Key", "Epic Name", "Entries", "Hours", "Share %", "Members" };
        for (int i = 0; i < headers.Length; i++) { var hc = ws.Cell(1, i + 1); hc.Value = headers[i]; StyleHeaderCell(hc); }
        ws.SheetView.FreezeRows(1);

        var total = TotalHours;
        int row = 2;
        foreach (var eg in groups)
        {
            if (row % 2 == 0) ws.Row(row).Style.Fill.BackgroundColor = XLColor.FromHtml("#f8f9fa");
            var hours = eg.Rows.Sum(r => r.TimeSpentSeconds) / 3600.0;
            var members = eg.Rows.Select(r => r.Author).Distinct().OrderBy(a => a);
            ws.Cell(row, 1).Value = eg.EpicKey;
            ws.Cell(row, 2).Value = string.IsNullOrEmpty(eg.EpicName) || eg.EpicName == "No Epic" ? "No Epic" : eg.EpicName;
            ws.Cell(row, 3).Value = eg.Rows.Count;
            ws.Cell(row, 4).Value = Math.Round(hours, 2);
            ws.Cell(row, 5).Value = Math.Round(total > 0 ? hours / total * 100 : 0, 1);
            ws.Cell(row, 6).Value = string.Join(", ", members);
            row++;
        }
        if (groups.Count > 0)
        {
            ws.Cell(row, 1).Value = "TOTAL"; ws.Cell(row, 1).Style.Font.Bold = true;
            ws.Cell(row, 4).Value = Math.Round(total, 2); ws.Cell(row, 4).Style.Font.Bold = true;
            ws.Row(row).Style.Fill.BackgroundColor = XLColor.FromHtml("#e9ecef");
        }
        ws.Columns().AdjustToContents();
        ws.Row(1).Height = 22;
    }

