    // Diverse categorical scale so adjacent epic slices are easy to tell apart.
    private static string ChartColor(int index, double alpha)
    {
        (int R, int G, int B)[] palette =
        [
            (79, 70, 229),    // indigo-600
            (13, 148, 136),   // teal-600
            (217, 119, 6),    // amber-600
            (219, 39, 119),   // pink-600
            (22, 163, 74),    // green-600
            (124, 58, 237),   // violet-600
            (8, 145, 178),    // cyan-600
            (234, 88, 12),    // orange-600
            (147, 51, 234),   // purple-600
            (202, 138, 4),    // yellow-600
            (5, 150, 105),    // emerald-600
            (225, 29, 72),    // rose-600
        ];
        var (r, g, b) = palette[index % palette.Length];
        return $"rgba({r},{g},{b},{alpha:F2})";
    }

