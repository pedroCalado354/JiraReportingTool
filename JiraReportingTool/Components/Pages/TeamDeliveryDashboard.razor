@page "/delivery"
@rendermode InteractiveServer
@inject IJiraService JiraService
@inject IJSRuntime JS
@using JiraReportingTool.Models
@using ClosedXML.Excel

<PageTitle>Team Delivery Dashboard</PageTitle>

<h1 class="mb-3">Team Delivery Dashboard</h1>

<!-- ── Load form ─────────────────────────────────────────────────────────── -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-3 align-items-end">

            <!-- Saved filter -->
            <div class="col-md-auto">
                <label class="form-label small text-muted mb-1">Jira Saved Filter</label>
                <div class="d-flex gap-2">
                    <select class="form-select" style="width:280px"
                            @bind="SelectedFilterId"
                            disabled="@(FiltersLoading || !string.IsNullOrEmpty(SprintId))">
                        <option value="">— select a filter —</option>
                        @foreach (var f in MyFilters)
                        {
                            <option value="@f.Id" title="@f.Jql">@f.Name</option>
                        }
                    </select>
                    @if (FiltersLoading)
                    {
                        <span class="spinner-border spinner-border-sm align-self-center text-muted"></span>
                    }
                </div>
                @if (!string.IsNullOrEmpty(SelectedFilterJql))
                {
                    <div class="text-muted small mt-1 text-truncate" style="max-width:280px" title="@SelectedFilterJql">
                        JQL: @SelectedFilterJql
                    </div>
                }
            </div>

            <!-- OR divider -->
            <div class="col-auto d-flex align-items-center pb-1">
                <span class="text-muted fw-semibold">or</span>
            </div>

            <!-- Sprint ID -->
            <div class="col-auto">
                <label class="form-label small text-muted mb-1">Sprint ID</label>
                <input class="form-control" style="width:140px"
                       @bind="SprintId" @onkeyup="HandleKeyUp"
                       placeholder="e.g. 6690"
                       disabled="@(!string.IsNullOrEmpty(SelectedFilterId))" />
            </div>

            <!-- Days Left override -->
            <div class="col-auto">
                <label class="form-label small text-muted mb-1">
                    Days Left in Sprint
                    @if (Report != null && string.IsNullOrEmpty(OverrideDaysLeftInput))
                    {
                        <span class="fw-normal text-muted"> (auto: @Report.DaysRemaining)</span>
                    }
                </label>
                <input type="number" class="form-control" style="width:100px"
                       @bind="OverrideDaysLeftInput"
                       placeholder="@(Report != null ? Report.DaysRemaining.ToString() : "auto")"
                       min="0" max="99" />
            </div>

            <div class="col-auto d-flex gap-2">
                <button class="btn btn-primary" @onclick="LoadData"
                        disabled="@(IsLoading || (string.IsNullOrEmpty(SprintId) && string.IsNullOrEmpty(SelectedFilterId)))">
                    @if (IsLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    }
                    Load
                </button>
                <button class="btn btn-outline-success" @onclick="OpenExportModal"
                        disabled="@(Report == null)"
                        title="Export remaining work to Excel">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16" class="me-1">
                        <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5z"/>
                        <path d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708l3 3z"/>
                    </svg>
                    Export .xlsx
                </button>
            </div>

        </div>
    </div>
</div>

@if (ErrorMessage != null)
{
    <div class="alert alert-danger">@ErrorMessage</div>
}

@if (Report != null)
{
    <!-- ── Sprint Health Bar ──────────────────────────────────────────────── -->
    <div class="row g-3 mb-3">
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm text-center h-100">
                <div class="card-body py-3">
                    <div class="fs-3 fw-bold @(Report.CompletionPct >= 80 ? "text-success" : Report.CompletionPct >= 50 ? "text-warning" : "text-danger")">
                        @((int)FilteredReport.CompletionPct)%
                    </div>
                    <div class="text-muted small">Sprint Completion</div>
                    <div class="progress mt-2" style="height:5px">
                        <div class="progress-bar bg-success" style="width:@((int)FilteredReport.CompletionPct)%"></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm text-center h-100">
                <div class="card-body py-3">
                    <div class="fs-3 fw-bold">@Fmt(FilteredTotalLoggedSeconds)<span class="fs-6 text-muted"> / @Fmt(FilteredReport.TotalOriginalEstimateSeconds)</span></div>
                    <div class="text-muted small">Hours Logged / Planned</div>
                    @if (FilteredReport.TotalOriginalEstimateSeconds > 0)
                    {
                        var budgetPct = (int)((double)FilteredTotalLoggedSeconds / FilteredReport.TotalOriginalEstimateSeconds * 100);
                        <div class="progress mt-2" style="height:5px">
                            <div class="progress-bar @(budgetPct > 100 ? "bg-danger" : "bg-primary")" style="width:@Math.Min(budgetPct,100)%"></div>
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            @{
                var sprintCapacitySecs = EffectiveDaysRemaining * 6 * 3600;
                var remainingSecs      = FilteredReport.TotalRemainingEstimateSeconds;
                var overCapacity       = sprintCapacitySecs > 0 && remainingSecs > sprintCapacitySecs;
                var capacityPct        = sprintCapacitySecs > 0
                    ? Math.Min((int)((double)remainingSecs / sprintCapacitySecs * 100), 100)
                    : 0;
            }
            <div class="card border-0 shadow-sm text-center h-100 @(overCapacity ? "border-danger border-start border-3" : "")">
                <div class="card-body py-3">
                    <div class="fs-3 fw-bold @(overCapacity ? "text-danger" : "")">@Fmt(remainingSecs)</div>
                    <div class="text-muted small">Work Remaining</div>
                    <hr class="my-2" />
                    <div class="fw-semibold @(overCapacity ? "text-danger" : "text-success")">
                        @Fmt(sprintCapacitySecs)
                    </div>
                    <div class="text-muted small">Sprint Capacity</div>
                    <div class="text-muted small mt-1">@EffectiveDaysRemaining days × 6h</div>
                    @if (sprintCapacitySecs > 0)
                    {
                        <div class="progress mt-2" style="height:5px">
                            <div class="progress-bar @(overCapacity ? "bg-danger" : "bg-success")"
                                 style="width:@capacityPct%"></div>
                        </div>
                        <div class="text-muted small mt-1">
                            @if (overCapacity)
                            {
                                <span class="text-danger">@Fmt(remainingSecs - sprintCapacitySecs) over capacity</span>
                            }
                            else
                            {
                                <span class="text-success">@Fmt(sprintCapacitySecs - remainingSecs) buffer</span>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm text-center h-100 border-@RiskColor(Report.RiskLevel) border-start border-3">
                <div class="card-body py-3">
                    <div class="fs-5 fw-bold">@RiskLabel(Report.RiskLevel)</div>
                    <div class="text-muted small">Sprint Risk</div>
                    <div class="text-muted small mt-1">@FilteredReport.AtRiskIssues.Count at-risk tasks</div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Filters ────────────────────────────────────────────────────────── -->
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body py-2">
            <div class="row g-2 align-items-center">
                <div class="col-auto">
                    <label class="form-label small text-muted mb-0 me-1">Assignee</label>
                    <div style="width:180px">
                        <input class="form-control form-control-sm mb-1" placeholder="Search member…"
                               @bind="AssigneeSearch" @bind:event="oninput" />
                        <select class="form-select form-select-sm" @bind="FilterAssignee" @bind:after="OnFilterChanged">
                            <option value="">All members</option>
                            @foreach (var a in AssigneeOptions)
                            {
                                <option value="@a">@a</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="col-auto">
                    <label class="form-label small text-muted mb-0 me-1">Epic</label>
                    <div style="width:280px">
                        <input class="form-control form-control-sm mb-1" placeholder="Search epic…"
                               @bind="EpicSearch" @bind:event="oninput" />
                        <select class="form-select form-select-sm" @bind="FilterEpic" @bind:after="OnFilterChanged">
                            <option value="">All epics</option>
                            @foreach (var e in EpicOptions)
                            {
                                <option value="@e.Key">@e.Key — @e.DisplayName</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="col-auto">
                    <label class="form-label small text-muted mb-0 me-1">Worklog date</label>
                    <div class="d-flex align-items-center gap-1">
                        <input type="date" class="form-control form-control-sm" style="width:145px"
                               @bind="FilterDateFrom" @bind:after="OnFilterChanged" />
                        <span class="text-muted small">–</span>
                        <input type="date" class="form-control form-control-sm" style="width:145px"
                               @bind="FilterDateTo" @bind:after="OnFilterChanged" />
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(FilterAssignee) || !string.IsNullOrEmpty(FilterEpic) || FilterDateFrom.HasValue || FilterDateTo.HasValue)
                {
                    <div class="col-auto">
                        <button class="btn btn-sm btn-outline-secondary" @onclick="ClearFilters">Clear filters</button>
                    </div>
                }
                <div class="col-auto ms-auto">
                    <span class="text-muted small">@FilteredIssues.Count of @Report.TotalIssues issues</span>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Tabs ───────────────────────────────────────────────────────────── -->
    <ul class="nav nav-tabs mb-0">
        <li class="nav-item">
            <button class="nav-link @(ActiveTab=="remaining" ? "active" : "")" @onclick='() => SwitchTab("remaining")'>
                Remaining Work
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(ActiveTab=="forecast" ? "active" : "")" @onclick='() => SwitchTab("forecast")'>
                Hours &amp; Forecast
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(ActiveTab=="workload" ? "active" : "")" @onclick='() => SwitchTab("workload")'>
                Workload
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(ActiveTab=="blockers" ? "active" : "")" @onclick='() => SwitchTab("blockers")'>
                Blockers &amp; Risk
                @if (Report != null && RiskIssues.Count > 0)
                {
                    <span class="badge bg-danger ms-1">@RiskIssues.Count</span>
                }
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(ActiveTab=="standup" ? "active" : "")" @onclick='() => SwitchTab("standup")'>
                Standup View
            </button>
        </li>
    </ul>

    <div class="card border-0 shadow-sm" style="border-top-left-radius:0">
        <div class="card-body">

            <!-- ══ TAB 1: REMAINING WORK ══════════════════════════════════ -->
            @if (ActiveTab == "remaining")
            {
                <!-- Epic progress cards -->
                <div class="row g-3 mb-4">
                    @foreach (var epic in FilteredEpics)
                    {
                        var epicPct = (int)epic.CompletionPct;
                        <div class="col-md-6 col-lg-4">
                            <div class="card border-0 border-start border-3 @EpicBorderColor(epic) shadow-sm h-100">
                                <div class="card-body py-3">
                                    <div class="d-flex justify-content-between align-items-start mb-1">
                                        <div>
                                            <div class="fw-semibold text-truncate" style="max-width:200px" title="@epic.DisplayName">@epic.DisplayName</div>
                                            <div class="text-muted small">@epic.Key</div>
                                        </div>
                                        <span class="badge @StatusBadgeFromPct(epicPct)">@epicPct%</span>
                                    </div>
                                    <div class="progress my-2" style="height:8px;border-radius:4px">
                                        <div class="progress-bar bg-success" style="width:@Pct(epic.DoneCount,epic.TotalIssues)%"></div>
                                        <div class="progress-bar bg-primary" style="width:@Pct(epic.InProgressCount,epic.TotalIssues)%"></div>
                                        <div class="progress-bar bg-secondary opacity-25" style="width:@Pct(epic.ToDoCount,epic.TotalIssues)%"></div>
                                    </div>
                                    <div class="d-flex justify-content-between small text-muted">
                                        <span>@epic.DoneCount/@epic.TotalIssues tasks done</span>
                                        <span>@Fmt(epic.TotalRemainingSeconds) remaining</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Task table -->
                <h6 class="text-muted text-uppercase small fw-semibold mb-2">Task Detail</h6>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 small">
                        <thead class="table-light">
                            <tr>
                                <th>Epic</th>
                                <th>Key</th>
                                <th>Task</th>
                                <th>Assignee</th>
                                <th style="width:80px">Status</th>
                                <th style="width:80px">Type</th>
                                <th style="width:75px">Est.</th>
                                <th style="width:75px">Logged</th>
                                <th style="width:75px">Remaining</th>
                                <th style="width:110px">Progress</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var epic in FilteredEpics)
                            {
                                @foreach (var issue in epic.Issues)
                                {
                                    var pct = IssueProgress(issue);
                                    <tr>
                                        <td class="text-muted text-nowrap small">@(string.IsNullOrEmpty(issue.EpicKey) ? "—" : issue.EpicKey)</td>
                                        <td class="fw-semibold text-nowrap">@issue.Key</td>
                                        <td>@issue.Summary</td>
                                        <td class="text-nowrap">@issue.Assignee</td>
                                        <td><span class="badge @StatusBadge(issue.Status, issue.StatusCategoryKey)">@issue.Status</span></td>
                                        <td><span class="badge @IssueTypeBadge(issue.IssueType)">@issue.IssueType</span></td>
                                        <td class="text-nowrap">@(issue.OriginalEstimate == "-" ? "—" : issue.OriginalEstimate)</td>
                                        <td class="text-nowrap">@(FilteredSpentSeconds(issue) > 0 ? FmtH(FilteredSpentSeconds(issue)) : "—")</td>
                                        <td class="text-nowrap @(issue.RemainingEstimateSeconds > EffectiveDaysRemaining * 6 * 3600 && issue.RemainingEstimateSeconds > 0 ? "text-danger fw-semibold" : "")">
                                            @(issue.RemainingEstimate == "-" ? "—" : issue.RemainingEstimate)
                                        </td>
                                        <td>
                                            <div class="d-flex align-items-center gap-1">
                                                <div class="progress flex-grow-1" style="height:5px;border-radius:3px">
                                                    <div class="progress-bar @(pct > 100 ? "bg-danger" : pct == 100 ? "bg-success" : "bg-primary")"
                                                         style="width:@Math.Min(pct,100)%"></div>
                                                </div>
                                                <span class="text-nowrap @(pct > 100 ? "text-danger fw-semibold" : pct == 100 ? "text-success" : "text-muted")" style="min-width:34px">@pct%</span>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            }

            <!-- ══ TAB 2: HOURS & FORECAST ════════════════════════════════ -->
            @if (ActiveTab == "forecast")
            {
                <!-- Epic delivery status cards -->
                <div class="row g-3 mb-4">
                    @foreach (var epic in FilteredEpics)
                    {
                        var variance = EpicFilteredVariancePct(epic);
                        var isOver = EpicFilteredIsOverBudget(epic);
                        var label = isOver ? "Over Budget" : Report.RiskLevel == SprintRisk.Behind ? "At Risk" : "On Track";
                        var labelColor = isOver ? "danger" : Report.RiskLevel == SprintRisk.Behind ? "warning" : "success";
                        <div class="col-md-6 col-lg-4">
                            <div class="card border-0 shadow-sm h-100">
                                <div class="card-body py-3">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <div class="fw-semibold text-truncate" style="max-width:180px">@epic.DisplayName</div>
                                        <span class="badge bg-@labelColor">@label</span>
                                    </div>
                                    <div class="row g-2 text-center small">
                                        <div class="col-4">
                                            <div class="fw-bold">@FmtH(epic.TotalEstimateSeconds)</div>
                                            <div class="text-muted">Planned</div>
                                        </div>
                                        <div class="col-4">
                                            <div class="fw-bold @(isOver ? "text-danger" : "")">@FmtH(EpicFilteredSpent(epic))</div>
                                            <div class="text-muted">Logged</div>
                                        </div>
                                        <div class="col-4">
                                            <div class="fw-bold @(variance > 0 ? "text-danger" : "text-success")">
                                                @(variance > 0 ? "+" : "")@variance.ToString("0")%
                                            </div>
                                            <div class="text-muted">Variance</div>
                                        </div>
                                    </div>
                                    @if (epic.TotalEstimateSeconds > 0)
                                    {
                                        var spentPct = Math.Min(100, (int)((double)EpicFilteredSpent(epic) / epic.TotalEstimateSeconds * 100));
                                        <div class="progress mt-2" style="height:6px;border-radius:3px">
                                            <div class="progress-bar @(isOver ? "bg-danger" : "bg-primary")" style="width:@spentPct%"></div>
                                        </div>
                                        <div class="d-flex justify-content-between small text-muted mt-1">
                                            <span>0h</span><span>@FmtH(epic.TotalEstimateSeconds) est.</span>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Estimated vs Actual chart -->
                <h6 class="text-muted text-uppercase small fw-semibold mb-2">Estimated vs Actual Hours per Epic</h6>
                <div style="max-height:320px">
                    <canvas id="chart-forecast"></canvas>
                </div>

                <!-- Variance table -->
                <h6 class="text-muted text-uppercase small fw-semibold mt-4 mb-2">Variance Detail</h6>
                <div class="table-responsive">
                    <table class="table table-hover align-middle small mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Epic</th>
                                <th>Tasks</th>
                                <th>Done</th>
                                <th>Planned (h)</th>
                                <th>Logged (h)</th>
                                <th>Remaining (h)</th>
                                <th>Variance</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var epic in FilteredEpics)
                            {
                                var v = EpicFilteredVariancePct(epic);
                                var epicOver = EpicFilteredIsOverBudget(epic);
                                <tr class="@(epicOver ? "table-danger" : "")">
                                    <td class="fw-semibold">@epic.DisplayName</td>
                                    <td>@epic.TotalIssues</td>
                                    <td>@epic.DoneCount</td>
                                    <td>@FmtH(epic.TotalEstimateSeconds)</td>
                                    <td class="@(epicOver ? "text-danger fw-semibold" : "")">@FmtH(EpicFilteredSpent(epic))</td>
                                    <td>@FmtH(epic.TotalRemainingSeconds)</td>
                                    <td class="@(v > 0 ? "text-danger" : "text-success")">
                                        @(v > 0 ? "+" : "")@v.ToString("0.0")%
                                    </td>
                                    <td>
                                        @if (epicOver)
                                        {
                                            <span class="badge bg-danger">Over Budget</span>
                                        }
                                        else if (Report.RiskLevel == SprintRisk.Behind)
                                        {
                                            <span class="badge bg-warning text-dark">At Risk</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">On Track</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light fw-semibold">
                            <tr>
                                <td>Total</td>
                                <td>@FilteredIssues.Count</td>
                                <td>@FilteredIssues.Count(i => i.StatusCategoryKey == "done")</td>
                                <td>@FmtH(FilteredIssues.Sum(i => i.OriginalEstimateSeconds))</td>
                                <td>@FmtH(FilteredTotalLoggedSeconds)</td>
                                <td>@FmtH(FilteredIssues.Sum(i => i.RemainingEstimateSeconds))</td>
                                <td colspan="2"></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }

            <!-- ══ TAB 3: WORKLOAD ════════════════════════════════════════ -->
            @if (ActiveTab == "workload")
            {
                <!-- Workload chart -->
                <h6 class="text-muted text-uppercase small fw-semibold mb-2">Hours per Team Member</h6>
                <div style="max-height:300px" class="mb-4">
                    <canvas id="chart-workload"></canvas>
                </div>

                <!-- Per-person cards — includes assignees + anyone who logged work -->
                @foreach (var person in WorkloadPeople)
                {
                    var issues = FilteredIssues.Where(i => i.Assignee.Equals(person, StringComparison.OrdinalIgnoreCase)).ToList();
                    var logged = WorklogSecondsByAuthor.TryGetValue(person, out var authorSecs) ? authorSecs : 0;
                    var remaining = issues.Sum(i => i.RemainingEstimateSeconds);
                    var estimated = issues.Sum(i => i.OriginalEstimateSeconds);
                    var done = issues.Count(i => i.StatusCategoryKey == "done");
                    var inProg = issues.Count(i => i.StatusCategoryKey == "indeterminate");
                    var stale = issues.Count(i => i.StatusCategoryKey == "indeterminate" && i.DaysSinceLastWorklog >= 2);
                    var overloaded = estimated > 0 && logged > estimated;

                    <div class="card border-0 shadow-sm mb-3">
                        <div class="card-body" style="cursor:pointer" @onclick="() => ToggleMember(person)">
                            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="rounded-circle @(overloaded ? "bg-danger" : "bg-primary") text-white d-flex align-items-center justify-content-center fw-bold flex-shrink-0"
                                         style="width:42px;height:42px;font-size:14px">
                                        @Initials(person)
                                    </div>
                                    <div>
                                        <div class="fw-semibold">@person</div>
                                        <div class="small text-muted">
                                            @done done · @inProg in progress · @(issues.Count - done - inProg) to do
                                        </div>
                                    </div>
                                </div>
                                <div class="d-flex align-items-center gap-3 flex-wrap">
                                    <div class="text-center small">
                                        <div class="fw-semibold">@FmtH(logged)</div>
                                        <div class="text-muted">Logged</div>
                                    </div>
                                    <div class="text-center small">
                                        <div class="fw-semibold">@FmtH(remaining)</div>
                                        <div class="text-muted">Remaining</div>
                                    </div>
                                    <div class="text-center small">
                                        <div class="fw-semibold @(overloaded ? "text-danger" : "")">@FmtH(estimated)</div>
                                        <div class="text-muted">Planned</div>
                                    </div>
                                    @if (overloaded)
                                    {
                                        <span class="badge bg-danger">Overloaded</span>
                                    }
                                    @if (stale > 0)
                                    {
                                        <span class="badge bg-warning text-dark">⚠️ @stale stale</span>
                                    }
                                    <div style="width:100px">
                                        <div class="progress" style="height:8px;border-radius:4px">
                                            <div class="progress-bar bg-success" style="width:@Pct(done,issues.Count)%"></div>
                                            <div class="progress-bar bg-primary" style="width:@Pct(inProg,issues.Count)%"></div>
                                        </div>
                                        <div class="text-muted small text-center">@Pct(done,issues.Count)%</div>
                                    </div>
                                    <span class="text-muted">@(ExpandedMembers.Contains(person) ? "▲" : "▼")</span>
                                </div>
                            </div>
                        </div>

                        @if (ExpandedMembers.Contains(person))
                        {
                            var personLogs = FilteredIssues
                                .SelectMany(i => i.Worklogs.Select(w => new { Issue = i, Log = w }))
                                .Where(x => x.Log.Author.Equals(person, StringComparison.OrdinalIgnoreCase)
                                         && WorklogInRange(x.Log))
                                .OrderByDescending(x => x.Log.Started)
                                .ToList();

                            <div class="card-footer bg-light p-0">

                                <!-- ── Worklog entries ── -->
                                <div class="px-3 pt-3 pb-2">
                                    <div class="small fw-semibold text-muted text-uppercase mb-2" style="letter-spacing:.05em">
                                        Worklogs by @person
                                        <span class="fw-normal ms-1">(@FmtH(logged) total)</span>
                                    </div>
                                    @if (!personLogs.Any())
                                    {
                                        <div class="text-muted small fst-italic">No worklogs found in current filter.</div>
                                    }
                                    else
                                    {
                                        <table class="table table-sm align-middle mb-0 small">
                                            <thead class="table-light">
                                                <tr>
                                                    <th>Date</th>
                                                    <th>Issue</th>
                                                    <th>Summary</th>
                                                    <th>Time Logged</th>
                                                    <th>Comment</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var x in personLogs)
                                                {
                                                    <tr>
                                                        <td class="text-nowrap text-muted">@x.Log.Started.ToString("MMM d, HH:mm")</td>
                                                        <td class="fw-semibold text-nowrap">@x.Issue.Key</td>
                                                        <td class="text-truncate" style="max-width:220px" title="@x.Issue.Summary">@x.Issue.Summary</td>
                                                        <td class="fw-semibold text-nowrap text-primary">@x.Log.TimeSpent</td>
                                                        <td class="text-muted text-truncate" style="max-width:220px" title="@x.Log.Comment">
                                                            @(string.IsNullOrEmpty(x.Log.Comment) ? "—" : x.Log.Comment)
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                            <tfoot class="table-light fw-semibold small">
                                                <tr>
                                                    <td colspan="3">Total</td>
                                                    <td class="text-primary">@FmtH(personLogs.Sum(x => x.Log.TimeSpentSeconds))</td>
                                                    <td></td>
                                                </tr>
                                            </tfoot>
                                        </table>
                                    }
                                </div>

                                <!-- ── Assigned issues ── -->
                                @if (issues.Any())
                                {
                                    <div class="border-top px-3 pt-3 pb-2">
                                        <div class="small fw-semibold text-muted text-uppercase mb-2" style="letter-spacing:.05em">Assigned Issues</div>
                                        <table class="table table-sm align-middle mb-0 small">
                                            <thead class="table-light">
                                                <tr>
                                                    <th>Epic</th>
                                                    <th>Key</th>
                                                    <th>Summary</th>
                                                    <th>Status</th>
                                                    <th>Type</th>
                                                    <th>My Logged</th>
                                                    <th>Remaining</th>
                                                    <th>Progress</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var issue in issues)
                                                {
                                                    var pct = IssueProgress(issue);
                                                    var myLogged = issue.Worklogs
                                                        .Where(w => w.Author.Equals(person, StringComparison.OrdinalIgnoreCase) && WorklogInRange(w))
                                                        .Sum(w => w.TimeSpentSeconds);
                                                    <tr>
                                                        <td class="text-muted text-nowrap">@(string.IsNullOrEmpty(issue.EpicKey) ? "—" : issue.EpicKey)</td>
                                                        <td class="fw-semibold text-nowrap">@issue.Key</td>
                                                        <td>@issue.Summary</td>
                                                        <td>
                                                            <span class="badge @StatusBadge(issue.Status, issue.StatusCategoryKey)">@issue.Status</span>
                                                            @if (issue.StatusCategoryKey == "indeterminate" && issue.DaysSinceLastWorklog >= 2 && issue.DaysSinceLastWorklog < 999)
                                                            {
                                                                <span class="badge bg-warning text-dark ms-1">@issue.DaysSinceLastWorklog d idle</span>
                                                            }
                                                        </td>
                                                        <td>
                                                            <span class="badge @IssueTypeBadge(issue.IssueType)">@issue.Status</span>
                                                        </td>
                                                        <td class="text-nowrap">@(myLogged > 0 ? FmtH(myLogged) : "—")</td>
                                                        <td class="text-nowrap">@(issue.RemainingEstimate == "-" ? "—" : issue.RemainingEstimate)</td>
                                                        <td>
                                                            <div class="d-flex align-items-center gap-1">
                                                                <div class="progress flex-grow-1" style="height:5px;border-radius:3px">
                                                                    <div class="progress-bar @(pct > 100 ? "bg-danger" : pct == 100 ? "bg-success" : "bg-primary")"
                                                                         style="width:@Math.Min(pct,100)%"></div>
                                                                </div>
                                                                <span class="text-nowrap @(pct > 100 ? "text-danger fw-semibold" : pct == 100 ? "text-success" : "text-muted")" style="min-width:34px">@pct%</span>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }

                            </div>
                        }
                    </div>
                }
            }

            <!-- ══ TAB 4: BLOCKERS & RISK ════════════════════════════════ -->
            @if (ActiveTab == "blockers")
            {
                <!-- Risk summary cards -->
                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <div class="card border-0 border-start border-3 border-danger shadow-sm h-100">
                            <div class="card-body text-center py-3">
                                <div class="fs-2 fw-bold text-danger">@StaleCount</div>
                                <div class="text-muted small">Stale — in progress, idle 2+ days</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card border-0 border-start border-3 border-warning shadow-sm h-100">
                            <div class="card-body text-center py-3">
                                <div class="fs-2 fw-bold text-warning">@NotStartedLateCount</div>
                                <div class="text-muted small">Not started — sprint &gt;50% elapsed</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card border-0 border-start border-3 border-warning shadow-sm h-100">
                            <div class="card-body text-center py-3">
                                <div class="fs-2 fw-bold text-warning">@OverCapacityCount</div>
                                <div class="text-muted small">Over capacity — remaining &gt; days left</div>
                            </div>
                        </div>
                    </div>
                </div>

                @if (RiskIssues.Count == 0)
                {
                    <div class="alert alert-success mb-0">
                        <strong>All clear!</strong> No blockers or at-risk items detected.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle small">
                            <thead class="table-light">
                                <tr>
                                    <th>Key</th>
                                    <th>Summary</th>
                                    <th>Assignee</th>
                                    <th>Status</th>
                                    <th>Type</th>
                                    <th>Risk Reason</th>
                                    <th>Idle (days)</th>
                                    <th>Remaining</th>
                                    <th>Days left</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ri in RiskIssues)
                                {
                                    <tr class="@(ri.Reasons.Contains("Stale") ? "table-danger" : "table-warning")">
                                        <td class="fw-semibold text-nowrap">@ri.Issue.Key</td>
                                        <td>@ri.Issue.Summary</td>
                                        <td class="text-nowrap">@ri.Issue.Assignee</td>
                                        <td><span class="badge @StatusBadge(ri.Issue.Status, ri.Issue.StatusCategoryKey)">@ri.Issue.Status</span></td>
                                        <td>
                                            @foreach (var reason in ri.Reasons)
                                            {
                                                <span class="badge @RiskBadgeColor(reason) me-1">@reason</span>
                                            }
                                        </td>
                                        <td>
                                            <span class="badge @IssueTypeBadge(ri.Issue.IssueType)">@ri.Issue.Status</span>
                                        </td>
                                        <td class="text-center">@(ri.Issue.DaysSinceLastWorklog < 999 ? ri.Issue.DaysSinceLastWorklog.ToString() : "—")</td>
                                        <td class="text-nowrap">@(ri.Issue.RemainingEstimate == "-" ? "—" : ri.Issue.RemainingEstimate)</td>
                                        <td class="text-center">@EffectiveDaysRemaining</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            }

            <!-- ══ TAB 5: STANDUP VIEW ════════════════════════════════════ -->
            @if (ActiveTab == "standup")
            {
                <div class="d-flex align-items-center gap-2 mb-4">
                    <h6 class="text-muted text-uppercase small fw-semibold mb-0">Daily Standup</h6>
                    <span class="badge bg-secondary">@DateTime.Today.ToString("ddd, MMM d")</span>
                    <span class="text-muted small ms-2">Sprint: @EffectiveDaysRemaining days remaining</span>
                </div>

                @foreach (var group in StandupGroups)
                {
                    var recentLogs = group.Issues
                        .SelectMany(i => i.Worklogs.Select(w => new { Issue = i, Log = w }))
                        .Where(x => x.Log.Author.Equals(group.Assignee, StringComparison.OrdinalIgnoreCase)
                                 && x.Log.Started.Date >= DateTime.Today.AddDays(-2))
                        .OrderByDescending(x => x.Log.Started)
                        .ToList();
                    var inProgress = group.Issues.Where(i => i.StatusCategoryKey == "indeterminate").ToList();
                    var toDo = group.Issues.Where(i => i.StatusCategoryKey == "new").ToList();
                    var hasActivity = recentLogs.Any();
                    var isIdle = !hasActivity && group.Issues.Any(i => i.StatusCategoryKey == "indeterminate");

                    <div class="card border-0 shadow-sm mb-3 @(isIdle ? "border-start border-3 border-warning" : "")">
                        <div class="card-body">
                            <div class="d-flex align-items-center gap-2 mb-3">
                                <div class="rounded-circle @(isIdle ? "bg-warning" : "bg-primary") text-white d-flex align-items-center justify-content-center fw-bold flex-shrink-0"
                                     style="width:38px;height:38px;font-size:13px">
                                    @Initials(group.Assignee)
                                </div>
                                <div>
                                    <div class="fw-semibold">@group.Assignee</div>
                                    <div class="text-muted small">
                                        @group.Issues.Count(i => i.StatusCategoryKey == "done") done ·
                                        @inProgress.Count in progress ·
                                        @toDo.Count to do
                                    </div>
                                </div>
                                @if (isIdle)
                                {
                                    <span class="badge bg-warning text-dark ms-2">No recent activity</span>
                                }
                            </div>

                            <div class="row g-3">
                                <!-- Recent worklogs -->
                                <div class="col-md-4">
                                    <div class="small text-uppercase text-muted fw-semibold mb-2" style="letter-spacing:.05em">Recent activity</div>
                                    @if (!recentLogs.Any())
                                    {
                                        <div class="text-muted small">No worklogs in last 2 days</div>
                                    }
                                    else
                                    {
                                        @foreach (var x in recentLogs)
                                        {
                                            <div class="mb-2 small">
                                                <div class="d-flex align-items-center gap-1">
                                                    <span class="text-muted">@x.Log.Started.ToString("MMM d")</span>
                                                    <span class="fw-semibold text-nowrap">@x.Log.TimeSpent</span>
                                                    <span class="text-muted text-nowrap">on @x.Issue.Key</span>
                                                </div>
                                                @if (!string.IsNullOrEmpty(x.Log.Comment))
                                                {
                                                    <div class="text-muted text-truncate" style="max-width:220px" title="@x.Log.Comment">@x.Log.Comment</div>
                                                }
                                            </div>
                                        }
                                    }
                                </div>

                                <!-- In Progress -->
                                <div class="col-md-4">
                                    <div class="small text-uppercase text-muted fw-semibold mb-2" style="letter-spacing:.05em">In progress (@inProgress.Count)</div>
                                    @if (!inProgress.Any())
                                    {
                                        <div class="text-muted small">—</div>
                                    }
                                    else
                                    {
                                        @foreach (var issue in inProgress)
                                        {
                                            <div class="mb-2 small">
                                                <div class="fw-semibold text-nowrap">@issue.Key</div>
                                                <div class="text-muted text-truncate" style="max-width:200px" title="@issue.Summary">@issue.Summary</div>
                                                @if (issue.DaysSinceLastWorklog >= 2 && issue.DaysSinceLastWorklog < 999)
                                                {
                                                    <span class="badge bg-danger" style="font-size:10px">Idle @issue.DaysSinceLastWorklog d</span>
                                                }
                                            </div>
                                        }
                                    }
                                </div>

                                <!-- To Do / Up Next -->
                                <div class="col-md-4">
                                    <div class="small text-uppercase text-muted fw-semibold mb-2" style="letter-spacing:.05em">Up next (@toDo.Count)</div>
                                    @if (!toDo.Any())
                                    {
                                        <div class="text-muted small">—</div>
                                    }
                                    else
                                    {
                                        @foreach (var issue in toDo)
                                        {
                                            <div class="mb-2 small">
                                                <div class="fw-semibold text-nowrap">
                                                    @issue.Key
                                                    @if (!string.IsNullOrEmpty(issue.Priority) && issue.Priority == "Highest")
                                                    {
                                                        <span class="badge bg-danger ms-1" style="font-size:10px">P1</span>
                                                    }
                                                </div>
                                                <div class="text-muted text-truncate" style="max-width:200px" title="@issue.Summary">@issue.Summary</div>
                                            </div>
                                        }
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }

        </div>
    </div>
}

<!-- ── Export Modal ──────────────────────────────────────────────────────── -->
@if (ShowExportModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.45)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header">
                    <h5 class="modal-title fw-semibold">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="#198754" viewBox="0 0 16 16" class="me-2">
                            <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5z"/>
                            <path d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708l3 3z"/>
                        </svg>
                        Export Remaining Work to Excel
                    </h5>
                    <button type="button" class="btn-close" @onclick="() => ShowExportModal = false"></button>
                </div>
                <div class="modal-body">
                    <p class="small text-muted mb-3">
                        Exports remaining work for sprint
                        <strong>@(Report?.SprintName is { Length: > 0 } sn ? sn : SprintId)</strong>
                        · <strong>@EffectiveDaysRemaining days left</strong>.
                        One row per open issue for the selected team members.
                    </p>

                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <label class="form-label small fw-semibold mb-0">Select team members</label>
                        <div class="d-flex gap-2">
                            <button class="btn btn-link btn-sm p-0 text-decoration-none"
                                    @onclick='() => ExportSelectedMembers = new HashSet<string>(ExportAllMembers)'>
                                All
                            </button>
                            <span class="text-muted small">/</span>
                            <button class="btn btn-link btn-sm p-0 text-decoration-none"
                                    @onclick="() => ExportSelectedMembers.Clear()">
                                None
                            </button>
                        </div>
                    </div>

                    <div class="border rounded p-2" style="max-height:220px;overflow-y:auto">
                        @foreach (var member in ExportAllMembers)
                        {
                            var isChecked = ExportSelectedMembers.Contains(member);
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="dexp_@member"
                                       checked="@isChecked"
                                       @onchange="e => ToggleExportMember(member, (bool)(e.Value ?? false))" />
                                <label class="form-check-label small" for="dexp_@member">@member</label>
                            </div>
                        }
                    </div>
                    <div class="text-muted small mt-2">@ExportSelectedMembers.Count of @ExportAllMembers.Count member(s) selected</div>

                    <hr class="my-3" />

                    <div>
                        <label class="form-label small fw-semibold mb-1">Exclude epics (comma-separated keys)</label>
                        <input class="form-control form-control-sm" placeholder="e.g. JM-10, JM-42"
                               @bind="ExportIgnoredEpicsInput" />
                        <div class="text-muted mt-1" style="font-size:0.72rem">
                            Issues belonging to these epics will be omitted from the export.
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => ShowExportModal = false">Cancel</button>
                    <button class="btn btn-success" @onclick="ExportToExcel"
                            disabled="@(IsExporting || ExportSelectedMembers.Count == 0)">
                        @if (IsExporting)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                        }
                        else
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16" class="me-1">
                                <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5z"/>
                                <path d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708l3 3z"/>
                            </svg>
                        }
                        Export .xlsx
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private string SprintId = "";
    private bool IsLoading = false;
    private string? ErrorMessage;
    private SprintReport? Report;

    // ── Days left override ────────────────────────────────────────────────────
    private string OverrideDaysLeftInput = "";
    private int EffectiveDaysRemaining =>
        int.TryParse(OverrideDaysLeftInput, out var n) && n >= 0 ? n : Report?.DaysRemaining ?? 0;

    // ── Saved filters ─────────────────────────────────────────────────────────
    private List<JiraFilter> MyFilters = [];
    private bool FiltersLoading = false;
    private string SelectedFilterId = "";
    private string SelectedFilterJql => MyFilters.FirstOrDefault(f => f.Id == SelectedFilterId)?.Jql ?? "";
    private string ActiveTab = "remaining";
    private HashSet<string> ExpandedMembers = new();
    private bool _renderCharts;

    // ── Filters ──────────────────────────────────────────────────────────────
    private string FilterAssignee = "";
    private string FilterEpic = "";
    private string AssigneeSearch = "";
    private string EpicSearch = "";
    private DateTime? FilterDateFrom;
    private DateTime? FilterDateTo;

    private IEnumerable<string> AssigneeOptions => Report?.Issues
        .Select(i => i.Assignee).Distinct().Order()
        .Where(a => string.IsNullOrEmpty(AssigneeSearch) || a.Contains(AssigneeSearch, StringComparison.OrdinalIgnoreCase))
        ?? Enumerable.Empty<string>();

    private IEnumerable<EpicSummary> EpicOptions => Report?.EpicSummaries
        .Where(e => string.IsNullOrEmpty(EpicSearch) ||
            e.Key.Contains(EpicSearch, StringComparison.OrdinalIgnoreCase) ||
            e.DisplayName.Contains(EpicSearch, StringComparison.OrdinalIgnoreCase))
        ?? Enumerable.Empty<EpicSummary>();

    private List<SprintIssue> FilteredIssues => Report?.Issues
        .Where(i =>
            (string.IsNullOrEmpty(FilterAssignee) || i.Assignee == FilterAssignee) &&
            (string.IsNullOrEmpty(FilterEpic) || i.EpicKey == FilterEpic) &&
            (!FilterDateFrom.HasValue && !FilterDateTo.HasValue ||
             i.Worklogs.Any(w =>
                 (!FilterDateFrom.HasValue || w.Started.Date >= FilterDateFrom.Value.Date) &&
                 (!FilterDateTo.HasValue   || w.Started.Date <= FilterDateTo.Value.Date))))
        .ToList() ?? [];

    private List<EpicSummary> FilteredEpics => FilteredIssues
        .GroupBy(i => i.EpicKey)
        .Select(g => new EpicSummary
        {
            Key = g.Key,
            Name = g.First().EpicName,
            Issues = g.ToList()
        })
        .OrderBy(e => string.IsNullOrEmpty(e.Key) ? "ZZZ" : e.Key)
        .ToList();

    // Filtered report acts as a sub-report for KPI calculations
    private SprintReport FilteredReport => Report == null ? new() : new SprintReport
    {
        StartDate = Report.StartDate,
        EndDate = Report.EndDate,
        SprintName = Report.SprintName,
        Issues = FilteredIssues
    };

    private IEnumerable<IGrouping<string, SprintIssue>> AssigneeGroups =>
        FilteredIssues.GroupBy(i => i.Assignee).OrderBy(g => g.Key);

    // Returns true if the worklog falls within the active date filter (or no date filter is set).
    private bool WorklogInRange(WorklogEntry w) =>
        (!FilterDateFrom.HasValue || w.Started.Date >= FilterDateFrom.Value.Date) &&
        (!FilterDateTo.HasValue   || w.Started.Date <= FilterDateTo.Value.Date);

    // Hours logged keyed by worklog author — only entries within the active date range.
    private Dictionary<string, int> WorklogSecondsByAuthor => FilteredIssues
        .SelectMany(i => i.Worklogs)
        .Where(WorklogInRange)
        .GroupBy(w => w.Author, StringComparer.OrdinalIgnoreCase)
        .ToDictionary(g => g.Key, g => g.Sum(w => w.TimeSpentSeconds), StringComparer.OrdinalIgnoreCase);

    // Union of assignees + authors who have logged within the active date range.
    private IEnumerable<string> WorkloadPeople => FilteredIssues
        .Select(i => i.Assignee)
        .Concat(FilteredIssues.SelectMany(i => i.Worklogs).Where(WorklogInRange).Select(w => w.Author))
        .Where(n => !string.IsNullOrEmpty(n))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .Order();

    // ── Blockers & Risk ───────────────────────────────────────────────────────
    private record RiskIssueRecord(SprintIssue Issue, List<string> Reasons);

    private List<RiskIssueRecord> RiskIssues
    {
        get
        {
            var result = new List<RiskIssueRecord>();
            var sprintPct = FilteredReport.SprintProgressPct;
            var daysLeft = EffectiveDaysRemaining;
            foreach (var issue in FilteredIssues.Where(i => i.StatusCategoryKey != "done" && i.Status != "In Review"))
            {
                var reasons = new List<string>();
                if (issue.StatusCategoryKey == "indeterminate" && issue.DaysSinceLastWorklog >= 2 && issue.DaysSinceLastWorklog < 999)
                    reasons.Add("Stale");
                if (sprintPct > 50 && issue.StatusCategoryKey == "new")
                    reasons.Add("Not Started");
                if (daysLeft > 0 && issue.RemainingEstimateSeconds > 0 && issue.RemainingEstimateSeconds > daysLeft * 6 * 3600)
                    reasons.Add("Over Capacity");
                if (reasons.Any())
                    result.Add(new(issue, reasons));
            }
            return result.OrderByDescending(r => r.Reasons.Count).ThenBy(r => r.Issue.Assignee).ToList();
        }
    }

    private int StaleCount => RiskIssues.Count(r => r.Reasons.Contains("Stale"));
    private int NotStartedLateCount => RiskIssues.Count(r => r.Reasons.Contains("Not Started"));
    private int OverCapacityCount => RiskIssues.Count(r => r.Reasons.Contains("Over Capacity"));

