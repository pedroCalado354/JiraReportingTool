@page "/epic-progress-v2"
@rendermode InteractiveServer
@inject IJiraService JiraService
@using JiraReportingTool.Models

<PageTitle>Epic Progress — Executive View</PageTitle>

<div class="v2-root">

    <!-- ═══ HERO ═════════════════════════════════════════════════════════════ -->
    <div class="v2-hero">
        <div class="v2-hero-row">
            <div class="v2-hero-icon" style="background: linear-gradient(135deg,#7c3aed 0%,#ec4899 100%); box-shadow: 0 8px 24px rgba(124,58,237,0.30);">
                <i class="bi bi-collection-fill"></i>
            </div>
            <div class="v2-hero-titles">
                <span class="v2-eyebrow">Epic Progress</span>
                <h1 class="v2-hero-title">@(EpicData?.Summary is { Length: > 0 } s ? s : "Epic Progress")</h1>
                <span class="v2-hero-sub">
                    @if (EpicData is not null)
                    {
                        <strong>@EpicData.Key</strong>
                        <span> · @EpicData.Status · </span>
                        <span>@(string.IsNullOrEmpty(EpicData.Assignee) ? "Unassigned" : EpicData.Assignee)</span>
                        @if (Metrics?.Sprint is not null)
                        {
                            <span> · Sprint scope: <strong>@Metrics.Sprint.SprintName</strong></span>
                        }
                    }
                    else
                    {
                        <span>Executive epic snapshot · delivery · effort · quality · projection</span>
                    }
                </span>
            </div>
            <div class="v2-hero-spacer"></div>
            @if (Metrics is not null)
            {
                <div class="v2-hero-actions">
                    <span class="v2-rag @RagClass">@RagText</span>
                    <span class="v2-pill v2-pill-brand"><i class="bi bi-percent"></i> @($"{Metrics.Delivery.CompletionPct:F0}%")</span>
                </div>
            }
        </div>
    </div>

    <!-- ═══ LOAD CONTROL BAR ════════════════════════════════════════════════ -->
    <div class="v2-control-bar">
        <div class="v2-field" style="min-width:200px">
            <label class="v2-label">Epic Key</label>
            <input class="v2-input" placeholder="e.g. JM-15977"
                   @bind="EpicKeyInput" @bind:event="oninput" @onkeypress="OnEpicKeyPress" />
        </div>

        <button class="v2-btn v2-btn-primary" @onclick="LoadEpicAsync" disabled="@IsLoading">
            @if (IsLoadingEpic) { <span class="v2-spin"></span> }
            else { <i class="bi bi-search"></i> }
            <span>Load Epic</span>
        </button>

        <div class="v2-field" style="min-width:140px">
            <label class="v2-label">Sprint Filter (optional)</label>
            <input class="v2-input v2-input-sm" type="number" placeholder="Sprint ID"
                   @bind="SprintIdInput" @bind:event="oninput"
                   disabled="@(EpicData is null)" />
        </div>

        <button class="v2-btn v2-btn-ghost" @onclick="ApplySprintFilterAsync"
                disabled="@(EpicData is null || IsLoadingSprint || string.IsNullOrWhiteSpace(SprintIdInput))">
            @if (IsLoadingSprint) { <span class="v2-spin"></span> }
            else { <i class="bi bi-funnel"></i> }
            <span>Apply</span>
        </button>

        @if (Metrics?.Sprint is not null)
        {
            <button class="v2-btn v2-btn-ghost" @onclick="ClearSprintFilter">
                <i class="bi bi-x"></i> Clear sprint filter
            </button>
        }
    </div>

    @if (!string.IsNullOrWhiteSpace(InfoMessage))
    {
        <div class="v2-alert v2-alert-info"><i class="bi bi-info-circle"></i> @InfoMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="v2-alert v2-alert-error"><i class="bi bi-exclamation-triangle"></i> @ErrorMessage</div>
    }
    @if (IsLoading)
    {
        <div class="v2-card" style="display:flex;align-items:center;gap:10px">
            <span class="v2-spin" style="border-color:rgba(99,102,241,0.20);border-top-color:var(--v2-brand)"></span>
            <span class="v2-text-muted">Loading epic data from Jira…</span>
        </div>
    }

    @if (Metrics is null && !IsLoading)
    {
        <div class="v2-empty">
            <div class="v2-empty-icon"><i class="bi bi-search"></i></div>
            <div class="v2-empty-title">Enter an epic key to begin</div>
            <div>You'll get an executive snapshot — delivery health, effort burn, quality and forecast.</div>
        </div>
    }

    @if (Metrics is not null)
    {
        var m = Metrics;

        <!-- ═══ HEALTH GAUGE ════════════════════════════════════════════════ -->
        <div class="v2-gauge">
            <div class="v2-gauge-score @($"v2-gauge-score-{HealthBand}")">@HealthScore</div>
            <div class="v2-gauge-mid">
                <div class="v2-gauge-label">Epic Health Score</div>
                <div class="v2-gauge-track">
                    <div class="v2-gauge-marker" style="left:@HealthScore%;border-color:@HealthMarkerColor"></div>
                </div>
                <div class="v2-gauge-desc">@HealthMessage</div>
            </div>
            <div class="v2-gauge-side">
                <div class="v2-gauge-side-stat">
                    <div class="v2-gauge-side-val">@m.Delivery.Total</div>
                    <div class="v2-gauge-side-lbl">Total tasks</div>
                </div>
                <div class="v2-gauge-side-stat">
                    <div class="v2-gauge-side-val v2-text-success">@m.Delivery.Done</div>
                    <div class="v2-gauge-side-lbl">Done</div>
                </div>
                <div class="v2-gauge-side-stat">
                    <div class="v2-gauge-side-val">@EpicProgressCalculator.FormatSeconds(m.Effort.SpentSec)</div>
                    <div class="v2-gauge-side-lbl">Logged</div>
                </div>
                <div class="v2-gauge-side-stat">
                    <div class="v2-gauge-side-val @(m.Effort.EffortPct > 100 ? "v2-text-danger" : "")">@($"{m.Effort.EffortPct:F0}%")</div>
                    <div class="v2-gauge-side-lbl">Effort %</div>
                </div>
            </div>
        </div>

        <!-- ═══ KPI GRID ════════════════════════════════════════════════════ -->
        <div class="v2-kpi-grid">
            <div class="v2-kpi @CompletionKpiClass">
                <div class="v2-kpi-head"><i class="bi bi-check2-circle"></i>Completion</div>
                <div class="v2-kpi-value">@($"{m.Delivery.CompletionPct:F0}%")</div>
                <div class="v2-bar" style="margin-top:8px">
                    <div class="v2-bar-fill v2-bar-fill-success" style="width:@Math.Min(m.Delivery.CompletionPct, 100)%"></div>
                </div>
                <div class="v2-kpi-sub">@m.Delivery.Done of @m.Delivery.Total tasks done</div>
            </div>

            <div class="v2-kpi @EffortKpiClass">
                <div class="v2-kpi-head"><i class="bi bi-hourglass-split"></i>Effort burn</div>
                <div class="v2-kpi-value @(m.Effort.EffortPct > 110 ? "v2-text-danger" : "")">@($"{m.Effort.EffortPct:F0}%")</div>
                <div class="v2-bar" style="margin-top:8px">
                    <div class="v2-bar-fill @(m.Effort.EffortPct > 110 ? "v2-bar-fill-danger" : m.Effort.EffortPct > 90 ? "v2-bar-fill-warn" : "v2-bar-fill-success")"
                         style="width:@Math.Min(m.Effort.EffortPct, 100)%"></div>
                </div>
                <div class="v2-kpi-sub">@EpicProgressCalculator.FormatSeconds(m.Effort.SpentSec) of @EpicProgressCalculator.FormatSeconds(m.Effort.TotalEstimateSec)</div>
            </div>

            <div class="v2-kpi v2-kpi-neutral">
                <div class="v2-kpi-head"><i class="bi bi-clock"></i>Remaining</div>
                <div class="v2-kpi-value">@EpicProgressCalculator.FormatSeconds(m.Effort.RemainingEstSec)</div>
                <div class="v2-kpi-sub">@(m.Delivery.InProgress + m.Delivery.ToDo) tasks remaining</div>
            </div>

            <div class="v2-kpi @(m.Quality.OpenBugs > 0 ? "v2-kpi-warn" : "v2-kpi-success")">
                <div class="v2-kpi-head"><i class="bi bi-bug"></i>Quality</div>
                <div class="v2-kpi-value">@m.Quality.OpenBugs<span class="v2-kpi-of">/ @m.Quality.TotalBugs bugs</span></div>
                <div class="v2-bar" style="margin-top:8px">
                    <div class="v2-bar-fill v2-bar-fill-warn" style="width:@Math.Min(m.Quality.BugRatio, 100)%"></div>
                </div>
                <div class="v2-kpi-sub">@($"{m.Quality.BugRatio:F1}%") bug share · @($"{m.Quality.BugOverhead:F0}%") overhead</div>
            </div>

            <div class="v2-kpi @(TaskForecastClass)">
                <div class="v2-kpi-head"><i class="bi bi-flag"></i>Tasks Projection</div>
                <div class="v2-kpi-value v2-kpi-value-sm">@TaskProjectedEndLabel</div>
                <div class="v2-kpi-sub">@TaskProjectionMessage</div>
            </div>

            @if (m.Quality.TotalBugs > 0)
            {
                <div class="v2-kpi @(BugForecastClass)">
                    <div class="v2-kpi-head"><i class="bi bi-bug-fill"></i>Bugs Projection</div>
                    <div class="v2-kpi-value v2-kpi-value-sm">@BugProjectedEndLabel</div>
                    <div class="v2-kpi-sub">@BugProjectionMessage</div>
                </div>
            }

            <div class="v2-kpi @(m.Risk.StaleInProgress + m.Risk.Unestimated > 0 ? "v2-kpi-warn" : "v2-kpi-success")">
                <div class="v2-kpi-head"><i class="bi bi-shield-exclamation"></i>Risk signals</div>
                <div class="v2-kpi-value">@(m.Risk.StaleInProgress + m.Risk.Unestimated + m.Risk.Overlogged + m.Risk.Unassigned)</div>
                <div class="v2-kpi-sub">@m.Risk.StaleInProgress stale · @m.Risk.Unestimated unestimated</div>
            </div>
        </div>

        <!-- ═══ MAIN TABS ═══════════════════════════════════════════════════ -->
        <div class="v2-section" style="margin-bottom:0">
            <div class="v2-tabs">
                <button class="v2-tab @(MainTab=="overview" ? "is-active" : "")" @onclick='() => MainTab="overview"'>
                    <i class="bi bi-grid-1x2"></i>Overview
                </button>
                <button class="v2-tab @(MainTab=="quality" ? "is-active" : "")" @onclick='() => MainTab="quality"'>
                    <i class="bi bi-shield-check"></i>Quality
                    @if (QOpenBugs > 0) { <span class="v2-tab-badge">@QOpenBugs</span> }
                </button>
                <button class="v2-tab @(MainTab=="issues" ? "is-active" : "")" @onclick='() => MainTab="issues"'>
                    <i class="bi bi-list-ul"></i>Issues
                </button>
            </div>
        </div>

        @if (MainTab == "overview")
        {

        <!-- ═══ DETAIL GRID — Delivery, Effort, Quality, Risk ═══════════════ -->
        <div class="v2-grid-2">
            <!-- Delivery panel -->
            <div class="v2-card v2-card-lg">
                <div class="v2-section-title"><i class="bi bi-box-seam" style="color:#6366f1"></i>Delivery</div>
                <div style="display:flex;gap:18px;align-items:center">
                    <div class="v2-donut v2-donut-lg" style="--p:@((int)m.Delivery.CompletionPct);--c1:#6366f1">
                        <span>@((int)m.Delivery.CompletionPct)%</span>
                    </div>
                    <div style="flex:1">
                        <div class="v2-bar-stack v2-tall-bar">
                            <span style="width:@(SafePct(m.Delivery.Done, m.Delivery.Total))%; background:var(--v2-success-grad)" title="Done"></span>
                            <span style="width:@(SafePct(m.Delivery.InProgress, m.Delivery.Total))%; background:var(--v2-brand-grad)" title="In Progress"></span>
                            <span style="width:@(SafePct(m.Delivery.ToDo, m.Delivery.Total))%; background:linear-gradient(90deg,#94a3b8,#64748b)" title="To Do"></span>
                        </div>
                        <div style="display:flex;gap:14px;margin-top:8px;font-size:11px;color:var(--v2-ink-3)">
                            <span><span class="v2-dot v2-dot-success"></span> Done @m.Delivery.Done</span>
                            <span><span class="v2-dot v2-dot-brand"></span> Active @m.Delivery.InProgress</span>
                            <span><span class="v2-dot v2-dot-neutral"></span> To do @m.Delivery.ToDo</span>
                        </div>
                    </div>
                </div>
                <div class="v2-divider"></div>
                <div class="v2-row"><span class="v2-row-label">Total work items</span><span class="v2-row-value">@m.Delivery.Total</span></div>
                <div class="v2-row"><span class="v2-row-label">Tasks vs Bugs</span><span class="v2-row-value">@m.Delivery.TotalTasks tasks · @m.Delivery.TotalBugs bugs</span></div>
                <div class="v2-row"><span class="v2-row-label">Active</span><span class="v2-row-value">@m.Delivery.InProgress</span></div>
                @if (m.Sprint is not null)
                {
                    <div class="v2-divider"></div>
                    <div style="font-size:11px;font-weight:700;color:var(--v2-brand);text-transform:uppercase;letter-spacing:0.05em;margin-bottom:6px">Sprint scope</div>
                    <div class="v2-row"><span class="v2-row-label">Sprint tasks</span><span class="v2-row-value">@m.Sprint.Total</span></div>
                    <div class="v2-row"><span class="v2-row-label">Sprint done</span><span class="v2-row-value">@m.Sprint.Done (@($"{m.Sprint.CompletionPct:F0}%"))</span></div>
                    <div class="v2-row"><span class="v2-row-label">Epic contribution</span><span class="v2-row-value">@($"{m.Sprint.EpicContributionPct:F0}%") of total</span></div>
                }
            </div>

            <!-- Effort panel -->
            <div class="v2-card v2-card-lg">
                <div class="v2-section-title"><i class="bi bi-stopwatch" style="color:#10b981"></i>Effort</div>
                <div class="v2-stat-row">
                    <span class="v2-num-lg @(m.Effort.EffortPct > 110 ? "v2-text-danger" : "")">@($"{m.Effort.EffortPct:F0}%")</span>
                    <span class="v2-num-suffix">logged vs estimate</span>
                </div>
                <div class="v2-bar v2-tall-bar" style="margin:10px 0 16px">
                    <div class="v2-bar-fill @(m.Effort.EffortPct > 110 ? "v2-bar-fill-danger" : m.Effort.EffortPct > 90 ? "v2-bar-fill-warn" : "v2-bar-fill-success")"
                         style="width:@Math.Min(m.Effort.EffortPct, 100)%"></div>
                </div>
                <div class="v2-row"><span class="v2-row-label">Estimated</span><span class="v2-row-value">@EpicProgressCalculator.FormatSeconds(m.Effort.TotalEstimateSec)</span></div>
                <div class="v2-row"><span class="v2-row-label">Logged</span><span class="v2-row-value">@EpicProgressCalculator.FormatSeconds(m.Effort.SpentSec)</span></div>
                <div class="v2-row"><span class="v2-row-label">Remaining</span><span class="v2-row-value">@EpicProgressCalculator.FormatSeconds(m.Effort.RemainingEstSec)</span></div>
                <div class="v2-row"><span class="v2-row-label">Variance</span>
                    <span class="v2-row-value @(m.Effort.EffortPct > 100 ? "v2-text-danger" : "")">
                        @(m.Effort.EffortPct > 100 ? $"+{m.Effort.EffortPct - 100:F0}%" : $"{m.Effort.EffortPct - 100:F0}%")
                    </span>
                </div>
            </div>

            <!-- Quality panel -->
            <div class="v2-card v2-card-lg">
                <div class="v2-section-title"><i class="bi bi-bug-fill" style="color:#ef4444"></i>Quality</div>
                <div class="v2-grid-2" style="margin-bottom:14px">
                    <div class="v2-risk-card @(m.Quality.OpenBugs > 0 ? "v2-risk-card-warn" : "v2-risk-card-success")">
                        <div class="v2-risk-num">@m.Quality.OpenBugs</div>
                        <div class="v2-risk-lbl">Open bugs</div>
                    </div>
                    <div class="v2-risk-card @(m.Quality.BugOverhead > 30 ? "v2-risk-card-danger" : m.Quality.BugOverhead > 15 ? "v2-risk-card-warn" : "v2-risk-card-success")">
                        <div class="v2-risk-num">@($"{m.Quality.BugOverhead:F0}%")</div>
                        <div class="v2-risk-lbl">Bug overhead</div>
                    </div>
                </div>
                <div class="v2-row"><span class="v2-row-label">Total bugs</span><span class="v2-row-value">@m.Quality.TotalBugs</span></div>
                <div class="v2-row"><span class="v2-row-label">Bug fix rate</span><span class="v2-row-value">@($"{m.Quality.BugFixRate:F0}%")</span></div>
                <div class="v2-row"><span class="v2-row-label">Avg fix time</span><span class="v2-row-value">@EpicProgressCalculator.FormatSeconds(m.Quality.AvgBugFixTimeSec)</span></div>
                <div class="v2-row"><span class="v2-row-label">Stale bugs</span><span class="v2-row-value @(m.Quality.StaleBugs > 0 ? "v2-text-warn" : "")">@m.Quality.StaleBugs</span></div>
                <div class="v2-row"><span class="v2-row-label">Bug ratio</span><span class="v2-row-value">@($"{m.Quality.BugRatio:F1}%") of all work</span></div>
            </div>

            <!-- Risk panel -->
            <div class="v2-card v2-card-lg">
                <div class="v2-section-title"><i class="bi bi-cone-striped" style="color:#f59e0b"></i>Risk Signals</div>
                <div class="v2-grid-2">
                    <div class="v2-risk-card @(m.Risk.StaleInProgress > 0 ? "v2-risk-card-warn" : "v2-risk-card-success")">
                        <div class="v2-risk-num">@m.Risk.StaleInProgress</div>
                        <div class="v2-risk-lbl">Stale (no log 2d+)</div>
                    </div>
                    <div class="v2-risk-card @(m.Risk.Unestimated > 0 ? "v2-risk-card-warn" : "v2-risk-card-success")">
                        <div class="v2-risk-num">@m.Risk.Unestimated</div>
                        <div class="v2-risk-lbl">Unestimated</div>
                    </div>
                    <div class="v2-risk-card @(m.Risk.Overlogged > 0 ? "v2-risk-card-warn" : "v2-risk-card-success")">
                        <div class="v2-risk-num">@m.Risk.Overlogged</div>
                        <div class="v2-risk-lbl">Overlogged</div>
                    </div>
                    <div class="v2-risk-card @(m.Risk.Unassigned > 0 ? "v2-risk-card-warn" : "v2-risk-card-success")">
                        <div class="v2-risk-num">@m.Risk.Unassigned</div>
                        <div class="v2-risk-lbl">Unassigned</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ═══ CONTRIBUTOR LEADERBOARD ═════════════════════════════════════ -->
        @if (m.AssigneeBreakdown.Count > 0)
        {
            <div class="v2-section v2-mt-lg">
                <div class="v2-section-title">
                    <i class="bi bi-people-fill"></i>Contributor Breakdown
                    <span class="v2-section-note">tasks assigned across the epic</span>
                </div>
                <div class="v2-table-wrap">
                    <table class="v2-table">
                        <thead>
                            <tr>
                                <th style="width:30px">#</th>
                                <th class="@SI("Name", _sortCB, _ascCB)" @onclick='() => SortCB("Name")'>Contributor</th>
                                <th class="v2-table-num @SI("Total", _sortCB, _ascCB)" @onclick='() => SortCB("Total")'>Total</th>
                                <th class="v2-table-num @SI("Done", _sortCB, _ascCB)" @onclick='() => SortCB("Done")'>Done</th>
                                <th class="v2-table-num @SI("Active", _sortCB, _ascCB)" @onclick='() => SortCB("Active")'>Active</th>
                                <th class="v2-table-num @SI("ToDo", _sortCB, _ascCB)" @onclick='() => SortCB("ToDo")'>To Do</th>
                                <th class="@SI("Pct", _sortCB, _ascCB)" @onclick='() => SortCB("Pct")'>Completion</th>
                                <th class="@SI("Share", _sortCB, _ascCB)" @onclick='() => SortCB("Share")'>Epic share</th>
                                <th class="v2-table-num @SI("Log", _sortCB, _ascCB)" @onclick='() => SortCB("Log")'>Logged</th>
                                <th class="v2-table-num @SI("Rem", _sortCB, _ascCB)" @onclick='() => SortCB("Rem")'>Remaining</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ var rank = 1; }
                            @foreach (var row in ApplySortCB(m.AssigneeBreakdown))
                            {
                                <tr>
                                    <td style="color:var(--v2-ink-4);font-weight:700">@rank</td>
                                    <td>
                                        <div style="display:flex;align-items:center;gap:8px">
                                            <span class="v2-avatar @($"v2-avatar-grad-{1 + (rank % 5)}")">@Initials(row.Assignee)</span>
                                            <span style="font-weight:600">@row.Assignee</span>
                                        </div>
                                    </td>
                                    <td class="v2-table-num">@row.Total</td>
                                    <td class="v2-table-num"><strong style="color:var(--v2-success)">@row.Done</strong></td>
                                    <td class="v2-table-num">@row.InProgress</td>
                                    <td class="v2-table-num">@row.ToDo</td>
                                    <td style="min-width:130px">
                                        <div style="display:flex;align-items:center;gap:6px">
                                            <div class="v2-bar" style="flex:1;height:6px">
                                                <div class="v2-bar-fill v2-bar-fill-success" style="width:@row.CompletionPct%"></div>
                                            </div>
                                            <span class="v2-row-value" style="font-size:11px">@($"{row.CompletionPct:F0}%")</span>
                                        </div>
                                    </td>
                                    <td style="min-width:120px">
                                        <div style="display:flex;align-items:center;gap:6px">
                                            <div class="v2-bar" style="flex:1;height:6px">
                                                <div class="v2-bar-fill" style="width:@row.EpicSharePct%"></div>
                                            </div>
                                            <span class="v2-row-value" style="font-size:11px">@($"{row.EpicSharePct:F0}%")</span>
                                        </div>
                                    </td>
                                    <td class="v2-table-num">
                                        @(row.TotalSpentSec > 0 ? EpicProgressCalculator.FormatSeconds(row.TotalSpentSec) : "—")
                                    </td>
                                    <td class="v2-table-num">
                                        @(row.TotalRemainingEstimateSec > 0 ? EpicProgressCalculator.FormatSeconds(row.TotalRemainingEstimateSec) : "—")
                                    </td>
                                </tr>
                                rank++;
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        }
        else if (MainTab == "quality")
        {
            <!-- ── Quality Health Gauge ──────────────────────────────────────── -->
            <div class="v2-gauge qm-gauge-clickable" @onclick='() => ShowScoreBreakdown = true' title="Click to see how this score is calculated">
                <div class="v2-gauge-score @($"v2-gauge-score-{QualityBand}")">@QualityScore</div>
                <div class="v2-gauge-mid">
                    <div class="v2-gauge-label">Quality Health Score <i class="bi bi-info-circle" style="font-size:11px;opacity:.6;margin-left:4px"></i></div>
                    <div class="v2-gauge-track">
                        <div class="v2-gauge-marker" style="left:@QualityScore%;border-color:@QualityMarkerColor"></div>
                    </div>
                    <div class="v2-gauge-desc">@QualityMessage</div>
                </div>
                <div class="v2-gauge-side">
                    <div class="v2-gauge-side-stat">
                        <div class="v2-gauge-side-val @(QBugRate > 25 ? "v2-text-danger" : QBugRate > 10 ? "v2-text-warn" : "v2-text-success")">@($"{QBugRate:F1}%")</div>
                        <div class="v2-gauge-side-lbl">Bug rate</div>
                    </div>
                    <div class="v2-gauge-side-stat">
                        <div class="v2-gauge-side-val">@QOpenBugs</div>
                        <div class="v2-gauge-side-lbl">Open bugs</div>
                    </div>
                    <div class="v2-gauge-side-stat">
                        <div class="v2-gauge-side-val">@FormatHours(QAvgFixHours)</div>
                        <div class="v2-gauge-side-lbl">Avg fix</div>
                    </div>
                    <div class="v2-gauge-side-stat">
                        <div class="v2-gauge-side-val @(QBugEffortShare > 30 ? "v2-text-danger" : "")">@($"{QBugEffortShare:F0}%")</div>
                        <div class="v2-gauge-side-lbl">Bug effort</div>
                    </div>
                </div>
            </div>

            @if (ShowScoreBreakdown)
            {
                <div class="qm-modal-backdrop" @onclick='() => ShowScoreBreakdown = false'>
                    <div class="qm-modal" @onclick:stopPropagation="true">
                        <div class="qm-modal-head">
                            <div>
                                <div class="qm-modal-eyebrow">Quality Health Score</div>
                                <div class="qm-modal-title">
                                    <span class="@($"v2-text-{QualityBand}")" style="font-size:32px;font-weight:800">@QualityScore</span>
                                    <span style="font-size:14px;color:var(--v2-ink-3);font-weight:500"> / 100 · @QualityRagText</span>
                                </div>
                            </div>
                            <button class="qm-modal-close" @onclick='() => ShowScoreBreakdown = false' title="Close" aria-label="Close"><i class="bi bi-x-lg"></i></button>
                        </div>
                        <div class="qm-modal-body">
                            <p class="qm-modal-desc">Composite of three signals. Each is scored 0–100 and weighted, then summed.</p>
                            <div class="v2-table-wrap" style="margin-bottom:0">
                                <table class="v2-table">
                                    <thead><tr><th>Factor</th><th class="v2-table-num">Weight</th><th class="v2-table-num">Current</th><th class="v2-table-num">Score</th><th class="v2-table-num">Contribution</th></tr></thead>
                                    <tbody>
                                        <tr>
                                            <td><strong>Bug effort share</strong><div class="v2-hint">Time logged on bugs ÷ total logged · 0% → 100, 50%+ → 0</div></td>
                                            <td class="v2-table-num"><strong>40%</strong></td>
                                            <td class="v2-table-num">@($"{QBugEffortShare:F1}%")</td>
                                            <td class="v2-table-num">@($"{QEffortScore:F0}")</td>
                                            <td class="v2-table-num"><strong>@($"{QEffortScore * 0.40:F1}")</strong></td>
                                        </tr>
                                        <tr>
                                            <td><strong>Open bugs (% of scope)</strong><div class="v2-hint">@QOpenBugs open ÷ @QTotalIssues issues · 0% → 100, 33%+ → 0</div></td>
                                            <td class="v2-table-num"><strong>35%</strong></td>
                                            <td class="v2-table-num">@($"{QOpenBugRatePct:F1}%")</td>
                                            <td class="v2-table-num">@($"{QOpenBugsScore:F0}")</td>
                                            <td class="v2-table-num"><strong>@($"{QOpenBugsScore * 0.35:F1}")</strong></td>
                                        </tr>
                                        <tr>
                                            <td><strong>Avg fix time</strong><div class="v2-hint">MTTR across @QResolvedBugs resolved bug@(QResolvedBugs == 1 ? "" : "s") · 0h → 100, 72h+ → 0</div></td>
                                            <td class="v2-table-num"><strong>25%</strong></td>
                                            <td class="v2-table-num">@FormatHours(QAvgFixHours)</td>
                                            <td class="v2-table-num">@($"{QAvgFixScore:F0}")</td>
                                            <td class="v2-table-num"><strong>@($"{QAvgFixScore * 0.25:F1}")</strong></td>
                                        </tr>
                                    </tbody>
                                    <tfoot>
                                        <tr style="font-weight:700;background:var(--v2-surface-2)">
                                            <td>Total</td><td class="v2-table-num">100%</td><td></td><td></td>
                                            <td class="v2-table-num"><span class="@($"v2-text-{QualityBand}")">@QualityScore</span></td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                            <div class="qm-modal-note"><i class="bi bi-lightbulb" style="color:#f59e0b"></i>@QualityMessage</div>
                        </div>
                    </div>
                </div>
            }

            <!-- ── Quality KPI Grid ──────────────────────────────────────────── -->
            <div class="v2-kpi-grid">
                <div class="v2-kpi @(QTotalBugs == 0 ? "v2-kpi-success" : "v2-kpi-warn")">
                    <div class="v2-kpi-head"><i class="bi bi-bug-fill"></i>Total bugs</div>
                    <div class="v2-kpi-value">@QTotalBugs</div>
                    <div class="v2-kpi-sub">@QOpenBugs open · @QResolvedBugs resolved</div>
                </div>
                <div class="v2-kpi @(QBugRate > 25 ? "v2-kpi-danger" : QBugRate > 10 ? "v2-kpi-warn" : "v2-kpi-success")">
                    <div class="v2-kpi-head"><i class="bi bi-percent"></i>Bug rate</div>
                    <div class="v2-kpi-value">@($"{QBugRate:F1}%")</div>
                    <div class="v2-bar" style="margin-top:8px">
                        <div class="v2-bar-fill @(QBugRate > 25 ? "v2-bar-fill-danger" : QBugRate > 10 ? "v2-bar-fill-warn" : "v2-bar-fill-success")" style="width:@Math.Min(QBugRate, 100)%"></div>
                    </div>
                    <div class="v2-kpi-sub">@QTotalBugs of @QTotalIssues items</div>
                </div>
                <div class="v2-kpi @(QCriticalOpenBugs > 0 ? "v2-kpi-danger" : "v2-kpi-success")">
                    <div class="v2-kpi-head"><i class="bi bi-exclamation-octagon"></i>Critical open</div>
                    <div class="v2-kpi-value">@QCriticalOpenBugs</div>
                    <div class="v2-kpi-sub">@QHighOpenBugs high priority · @QLowOpenBugs low</div>
                </div>
                <div class="v2-kpi @(QAvgFixHours > 24 ? "v2-kpi-warn" : "v2-kpi-success")">
                    <div class="v2-kpi-head"><i class="bi bi-stopwatch"></i>MTTR (logged time)</div>
                    <div class="v2-kpi-value">@FormatHours(QAvgFixHours)</div>
                    <div class="v2-kpi-sub">across @QResolvedBugs resolved bugs</div>
                </div>
                <div class="v2-kpi @(QQaRejectedBugs > 0 ? "v2-kpi-warn" : "v2-kpi-success")">
                    <div class="v2-kpi-head"><i class="bi bi-x-octagon"></i>QA rejections</div>
                    <div class="v2-kpi-value">@QQaRejectionsTotal<span class="v2-kpi-of">/ @QQaRejectedBugs bugs</span></div>
                    <div class="v2-kpi-sub">@($"{QQaRejectionRate:F1}%") of bugs rejected</div>
                </div>
                <div class="v2-kpi @(QStaleOpenBugs > 0 ? "v2-kpi-warn" : "v2-kpi-success")">
                    <div class="v2-kpi-head"><i class="bi bi-hourglass"></i>Stale bugs</div>
                    <div class="v2-kpi-value">@QStaleOpenBugs</div>
                    <div class="v2-kpi-sub">no worklog in 2+ days</div>
                </div>
                <div class="v2-kpi @(QBugEffortShare > 30 ? "v2-kpi-danger" : QBugEffortShare > 15 ? "v2-kpi-warn" : "v2-kpi-success")">
                    <div class="v2-kpi-head"><i class="bi bi-clock-history"></i>Effort on bugs</div>
                    <div class="v2-kpi-value">@($"{QBugEffortShare:F0}%")</div>
                    <div class="v2-bar" style="margin-top:8px">
                        <div class="v2-bar-fill @(QBugEffortShare > 30 ? "v2-bar-fill-danger" : QBugEffortShare > 15 ? "v2-bar-fill-warn" : "v2-bar-fill-success")" style="width:@Math.Min(QBugEffortShare, 100)%"></div>
                    </div>
                    <div class="v2-kpi-sub">@FormatHours(QBugLoggedHours) on bugs · @FormatHours(QNonBugLoggedHours) on tasks</div>
                </div>
                <div class="v2-kpi v2-kpi-neutral">
                    <div class="v2-kpi-head"><i class="bi bi-bullseye"></i>Defect age (avg)</div>
                    <div class="v2-kpi-value">@QAvgBugAgeDays<span class="v2-kpi-of">days</span></div>
                    <div class="v2-kpi-sub">@QOldestBugDays day-old oldest open bug</div>
                </div>
            </div>

            <!-- ── Quality Sub-Tabs ──────────────────────────────────────────── -->
            <div class="v2-section">
                <div class="v2-tabs">
                    <button class="v2-tab @(QualityTab=="overview" ? "is-active" : "")" @onclick='() => QualityTab="overview"'><i class="bi bi-grid-1x2"></i>Overview</button>
                    <button class="v2-tab @(QualityTab=="bugs" ? "is-active" : "")" @onclick='() => QualityTab="bugs"'>
                        <i class="bi bi-bug"></i>Bugs
                        @if (QOpenBugs > 0) { <span class="v2-tab-badge">@QOpenBugs</span> }
                    </button>
                    <button class="v2-tab @(QualityTab=="aging" ? "is-active" : "")" @onclick='() => QualityTab="aging"'><i class="bi bi-hourglass-split"></i>Aging</button>
                    <button class="v2-tab @(QualityTab=="people" ? "is-active" : "")" @onclick='() => QualityTab="people"'><i class="bi bi-people"></i>By Team Member</button>
                </div>
            </div>

            @if (QualityTab == "overview")
            {
                <div class="v2-grid-2">
                    <div class="v2-card v2-card-lg">
                        <div class="v2-section-title"><i class="bi bi-bar-chart-line" style="color:#ef4444"></i>Bug priority distribution</div>
                        @{
                            var prios = new[] { "Highest", "Critical", "High", "Medium", "Low", "Lowest" };
                            var byPrio = prios.Select(p => new { Prio = p, Open = QOpenBugList.Count(b => b.Priority == p), Total = QAllBugs.Count(b => b.Priority == p) }).Where(x => x.Total > 0).ToList();
                            var maxTotal = byPrio.Select(x => x.Total).DefaultIfEmpty(1).Max();
                        }
                        @foreach (var p in byPrio)
                        {
                            var fillClass = p.Prio is "Highest" or "Critical" ? "v2-bar-fill-danger" : p.Prio == "High" ? "v2-bar-fill-warn" : p.Prio == "Medium" ? "" : "v2-bar-fill-neutral";
                            <div style="margin-bottom:12px">
                                <div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:4px">
                                    <span><span class="v2-chip v2-chip-pri-@p.Prio.ToLower()" style="margin-right:6px">@p.Prio</span><span class="v2-text-muted">@p.Open open / @p.Total total</span></span>
                                    <span class="v2-row-value">@(p.Total > 0 ? (p.Open * 100 / p.Total) : 0)% open</span>
                                </div>
                                <div class="v2-bar v2-tall-bar"><div class="v2-bar-fill @fillClass" style="width:@(p.Total * 100 / maxTotal)%"></div></div>
                            </div>
                        }
                    </div>

                    <div class="v2-card v2-card-lg">
                        <div class="v2-section-title"><i class="bi bi-stopwatch-fill" style="color:#10b981"></i>Time-to-fix distribution</div>
                        @{
                            var mttrBuckets = new[] { ("<2h", 0d, 2d), ("2–6h", 2d, 6d), ("6–12h", 6d, 12d), ("12–24h", 12d, 24d), ("1–3d", 24d, 72d), (">3d", 72d, double.MaxValue) };
                            var resolvedHours = QResolvedBugList.Where(b => b.TimeSpentSeconds > 0).Select(b => b.TimeSpentSeconds / 3600.0).ToList();
                            var maxBucket = mttrBuckets.Select(b => resolvedHours.Count(h => h >= b.Item2 && h < b.Item3)).DefaultIfEmpty(1).Max();
                            if (maxBucket == 0) maxBucket = 1;
                        }
                        @if (resolvedHours.Count == 0)
                        {
                            <div class="v2-text-muted" style="padding:30px 0;text-align:center">No resolved bugs in scope yet.</div>
                        }
                        else
                        {
                            @foreach (var b in mttrBuckets)
                            {
                                var count = resolvedHours.Count(h => h >= b.Item2 && h < b.Item3);
                                var fillClass = b.Item1 is "<2h" or "2–6h" ? "v2-bar-fill-success" : b.Item1 is "6–12h" or "12–24h" ? "" : "v2-bar-fill-warn";
                                <div style="margin-bottom:10px">
                                    <div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:4px">
                                        <span style="font-weight:600">@b.Item1</span><span class="v2-text-muted">@count bugs</span>
                                    </div>
                                    <div class="v2-bar v2-tall-bar"><div class="v2-bar-fill @fillClass" style="width:@(count * 100 / maxBucket)%"></div></div>
                                </div>
                            }
                        }
                    </div>
                </div>

                <div class="v2-grid-2 v2-mt-lg">
                    <div class="v2-card v2-card-lg">
                        <div class="v2-section-title"><i class="bi bi-pie-chart"></i>Bug status breakdown</div>
                        <div class="v2-bar-stack v2-tall-bar" style="height:20px">
                            <span style="width:@(SafePct(QResolvedBugs, QTotalBugs))%; background:var(--v2-success-grad)" title="Resolved @QResolvedBugs"></span>
                            <span style="width:@(SafePct(QInProgressBugs, QTotalBugs))%; background:var(--v2-brand-grad)" title="In progress @QInProgressBugs"></span>
                            <span style="width:@(SafePct(QNewBugs, QTotalBugs))%; background:linear-gradient(90deg,#fbbf24,#f59e0b)" title="To do @QNewBugs"></span>
                        </div>
                        <div style="display:flex;gap:14px;margin-top:10px;font-size:12px">
                            <span><span class="v2-dot v2-dot-success"></span> Resolved <strong>@QResolvedBugs</strong></span>
                            <span><span class="v2-dot v2-dot-brand"></span> In progress <strong>@QInProgressBugs</strong></span>
                            <span><span class="v2-dot v2-dot-warn"></span> To do <strong>@QNewBugs</strong></span>
                        </div>
                        <div class="v2-divider"></div>
                        <div class="v2-row"><span class="v2-row-label">Bug fix rate</span><span class="v2-row-value">@($"{QBugFixRate:F1}%")</span></div>
                        <div class="v2-row"><span class="v2-row-label">Unassigned bugs</span><span class="v2-row-value @(QUnassignedBugs > 0 ? "v2-text-warn" : "")">@QUnassignedBugs</span></div>
                        <div class="v2-row"><span class="v2-row-label">Unestimated bugs</span><span class="v2-row-value @(QUnestimatedBugs > 0 ? "v2-text-warn" : "")">@QUnestimatedBugs</span></div>
                    </div>

                    <div class="v2-card v2-card-lg">
                        <div class="v2-section-title"><i class="bi bi-shield-fill-check"></i>QA Rejection insights</div>
                        <div class="v2-stat-row">
                            <span class="v2-num-lg @(QQaRejectionRate > 30 ? "v2-text-danger" : QQaRejectionRate > 10 ? "v2-text-warn" : "v2-text-success")">@($"{QQaRejectionRate:F1}%")</span>
                            <span class="v2-num-suffix">of bugs rejected at least once</span>
                        </div>
                        <div class="v2-bar v2-tall-bar" style="margin:10px 0 16px">
                            <div class="v2-bar-fill @(QQaRejectionRate > 30 ? "v2-bar-fill-danger" : QQaRejectionRate > 10 ? "v2-bar-fill-warn" : "v2-bar-fill-success")" style="width:@Math.Min(QQaRejectionRate, 100)%"></div>
                        </div>
                        <div class="v2-row"><span class="v2-row-label">Total rejections logged</span><span class="v2-row-value">@QQaRejectionsTotal</span></div>
                        <div class="v2-row"><span class="v2-row-label">Bugs with rejections</span><span class="v2-row-value">@QQaRejectedBugs of @QTotalBugs</span></div>
                        <div class="v2-row"><span class="v2-row-label">Avg rejections / bug</span><span class="v2-row-value">@($"{(QQaRejectedBugs == 0 ? 0 : (double)QQaRejectionsTotal / QQaRejectedBugs):F1}")</span></div>
                    </div>
                </div>
            }
            else if (QualityTab == "bugs")
            {
                <div class="v2-table-wrap">
                    <table class="v2-table">
                        <thead>
                            <tr>
                                <th>Key</th><th>Summary</th><th>Priority</th><th>Status</th><th>Assignee</th>
                                <th class="v2-table-num">Days open</th><th class="v2-table-num">Logged</th><th class="v2-table-num">QA rej.</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var b in QAllBugs.OrderBy(x => QStatusOrder(x.StatusCategoryKey)).ThenByDescending(x => QPriorityOrder(x.Priority)).ThenByDescending(x => QDaysOpen(x)))
                            {
                                <tr class="@(b.StatusCategoryKey == "done" ? "is-done" : "")">
                                    <td class="v2-table-key">@b.Key</td>
                                    <td class="v2-truncate" style="max-width:340px">@b.Summary</td>
                                    <td><span class="v2-chip v2-chip-pri-@b.Priority.ToLower()">@b.Priority</span></td>
                                    <td><span class="v2-pill v2-pill-@(b.StatusCategoryKey == "done" ? "success" : b.StatusCategoryKey == "indeterminate" ? "brand" : "warn")">@b.Status</span></td>
                                    <td>@b.Assignee</td>
                                    <td class="v2-table-num">@(b.StatusCategoryKey == "done" ? "—" : QDaysOpen(b).ToString())</td>
                                    <td class="v2-table-num">@(b.TimeSpentSeconds > 0 ? FormatHours(b.TimeSpentSeconds / 3600.0) : "—")</td>
                                    <td class="v2-table-num @(b.QaRejectedCount > 0 ? "v2-text-warn" : "")">@(b.QaRejectedCount > 0 ? b.QaRejectedCount.ToString() : "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else if (QualityTab == "aging")
            {
                <div class="v2-grid-2">
                    <div class="v2-card v2-card-lg">
                        <div class="v2-section-title"><i class="bi bi-calendar-week"></i>Open bug age distribution</div>
                        @{
                            var ageBuckets = new[] { ("<1d", 0, 1), ("1-3d", 1, 3), ("3-7d", 3, 7), ("1-2w", 7, 14), ("2-4w", 14, 28), ("1m+", 28, int.MaxValue) };
                            var maxAge = ageBuckets.Select(bucket => QOpenBugList.Count(x => QDaysOpen(x) >= bucket.Item2 && QDaysOpen(x) < bucket.Item3)).DefaultIfEmpty(1).Max();
                            if (maxAge == 0) maxAge = 1;
                        }
                        @if (QOpenBugList.Count == 0)
                        {
                            <div class="v2-text-muted" style="padding:30px 0;text-align:center">No open bugs — quality is in great shape.</div>
                        }
                        else
                        {
                            @foreach (var bucket in ageBuckets)
                            {
                                var count = QOpenBugList.Count(x => QDaysOpen(x) >= bucket.Item2 && QDaysOpen(x) < bucket.Item3);
                                var fillClass = bucket.Item1 == "<1d" || bucket.Item1 == "1-3d" ? "v2-bar-fill-success" : bucket.Item1 == "3-7d" ? "" : bucket.Item1 == "1-2w" ? "v2-bar-fill-warn" : "v2-bar-fill-danger";
                                <div style="margin-bottom:10px">
                                    <div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:4px">
                                        <span style="font-weight:600">@bucket.Item1</span><span class="v2-text-muted">@count bug@(count == 1 ? "" : "s")</span>
                                    </div>
                                    <div class="v2-bar v2-tall-bar"><div class="v2-bar-fill @fillClass" style="width:@(count * 100 / maxAge)%"></div></div>
                                </div>
                            }
                        }
                    </div>

                    <div class="v2-card v2-card-lg">
                        <div class="v2-section-title"><i class="bi bi-fire"></i>Oldest open bugs</div>
                        @if (QOpenBugList.Count == 0)
                        {
                            <div class="v2-text-muted" style="padding:30px 0;text-align:center">No open bugs.</div>
                        }
                        else
                        {
                            <table class="v2-table" style="margin:0">
                                <thead><tr><th>Key</th><th>Summary</th><th class="v2-table-num">Age</th></tr></thead>
                                <tbody>
                                    @foreach (var b in QOpenBugList.OrderByDescending(x => QDaysOpen(x)).Take(8))
                                    {
                                        var age = QDaysOpen(b);
                                        <tr>
                                            <td class="v2-table-key">@b.Key</td>
                                            <td class="v2-truncate" style="max-width:240px">@b.Summary</td>
                                            <td class="v2-table-num @(age > 14 ? "v2-text-danger" : age > 7 ? "v2-text-warn" : "")">@age d</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                </div>
            }
            else if (QualityTab == "people")
            {
                <!-- ── Bug Effort by Team Member ──────────────────────────────── -->
                <div class="v2-table-wrap">
                    <table class="v2-table">
                        <thead>
                            <tr>
                                <th>Assignee</th>
                                <th class="v2-table-num">Bugs</th>
                                <th class="v2-table-num">Open</th>
                                <th class="v2-table-num">Resolved</th>
                                <th class="v2-table-num">Bug Hours</th>
                                <th class="v2-table-num">Avg Fix Time</th>
                                <th style="min-width:150px">Bug Effort</th>
                                <th class="v2-table-num">Stale</th>
                                <th class="v2-table-num">QA Rej. Tickets</th>
                                <th class="v2-table-num">Total QA Rej.</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                // Worklogs → who logged what on bugs vs tasks
                                var memberLogMap = QAllIssues
                                    .SelectMany(i => i.Worklogs
                                        .Where(w => !string.IsNullOrEmpty(w.Author))
                                        .Select(w => (Author: w.Author, IsBug: IsBugIssue(i), Hours: w.TimeSpentSeconds / 3600.0)))
                                    .GroupBy(x => x.Author)
                                    .ToDictionary(
                                        g => g.Key,
                                        g => (BugHrs: g.Where(x => x.IsBug).Sum(x => x.Hours), TotalHrs: g.Sum(x => x.Hours)));

                                var memberRows = QAllIssues
                                    .Where(i => !string.IsNullOrEmpty(i.Assignee) && i.Assignee != "Unassigned")
                                    .GroupBy(i => i.Assignee)
                                    .Select(g =>
                                    {
                                        var bugs = g.Where(IsBugIssue).ToList();
                                        var openBugs = bugs.Where(b => b.StatusCategoryKey != "done").ToList();
                                        var resolvedBugs = bugs.Where(b => b.StatusCategoryKey == "done").ToList();
                                        var resolvedWithDates = resolvedBugs
                                            .Where(b => b.Created.HasValue && b.ResolutionDate.HasValue).ToList();
                                        var avgFix = resolvedWithDates.Count > 0
                                            ? resolvedWithDates.Average(b => WorkingHours(b.Created!.Value, b.ResolutionDate!.Value))
                                            : -1.0;
                                        memberLogMap.TryGetValue(g.Key, out var logs);
                                        return new
                                        {
                                            Name         = g.Key,
                                            BugCount     = bugs.Count,
                                            Open         = openBugs.Count,
                                            Resolved     = resolvedBugs.Count,
                                            BugHrs       = logs.BugHrs,
                                            TotalHrs     = logs.TotalHrs,
                                            BugEffort    = logs.TotalHrs == 0 ? 0.0 : logs.BugHrs / logs.TotalHrs * 100,
                                            AvgFix       = avgFix,
                                            Stale        = openBugs.Count(b => b.DaysSinceLastWorklog >= 2),
                                            QaRejTickets = bugs.Count(b => b.QaRejectedCount > 0),
                                            QaRejTotal   = bugs.Sum(b => b.QaRejectedCount)
                                        };
                                    })
                                    .Where(r => r.BugCount > 0 || r.QaRejTotal > 0)
                                    .OrderByDescending(r => r.BugCount)
                                    .ThenByDescending(r => r.BugEffort)
                                    .ToList();
                            }
                            @if (!memberRows.Any())
                            {
                                <tr><td colspan="10" style="text-align:center;padding:20px" class="v2-text-muted">No bugs found in this epic.</td></tr>
                            }
                            @foreach (var r in memberRows)
                            {
                                <tr>
                                    <td>
                                        <div style="display:flex;align-items:center;gap:8px">
                                            <span class="v2-avatar v2-avatar-grad-2">@Initials(r.Name)</span>
                                            <span style="font-weight:600">@r.Name</span>
                                        </div>
                                    </td>
                                    <td class="v2-table-num">@r.BugCount</td>
                                    <td class="v2-table-num @(r.Open > 0 ? "v2-text-warn" : "v2-text-muted")">@r.Open</td>
                                    <td class="v2-table-num"><strong style="color:var(--v2-success)">@r.Resolved</strong></td>
                                    <td class="v2-table-num v2-text-muted">@FormatHours(r.BugHrs)</td>
                                    <td class="v2-table-num v2-text-muted">@(r.AvgFix < 0 ? "—" : FormatFixTime(r.AvgFix))</td>
                                    <td style="min-width:150px">
                                        <div style="display:flex;align-items:center;gap:6px">
                                            <div class="v2-bar" style="flex:1;height:6px">
                                                <div class="v2-bar-fill @(r.BugEffort > 50 ? "v2-bar-fill-danger" : r.BugEffort > 25 ? "v2-bar-fill-warn" : "v2-bar-fill-success")"
                                                     style="width:@Math.Min(r.BugEffort, 100)%"></div>
                                            </div>
                                            <span class="v2-row-value" style="font-size:11px;min-width:34px;text-align:right">@($"{r.BugEffort:F0}%")</span>
                                        </div>
                                    </td>
                                    <td class="v2-table-num @(r.Stale > 0 ? "v2-text-warn" : "v2-text-muted")">@(r.Stale > 0 ? r.Stale.ToString() : "—")</td>
                                    <td class="v2-table-num @(r.QaRejTickets > 0 ? "v2-text-warn" : "v2-text-muted")">@(r.QaRejTickets > 0 ? r.QaRejTickets.ToString() : "—")</td>
                                    <td class="v2-table-num @(r.QaRejTotal > r.QaRejTickets ? "v2-text-danger" : r.QaRejTotal > 0 ? "v2-text-warn" : "v2-text-muted")">@(r.QaRejTotal > 0 ? r.QaRejTotal.ToString() : "—")</td>
                                </tr>
                            }
                        </tbody>
                        @if (memberRows.Count > 1)
                        {
                            <tfoot>
                                <tr style="font-weight:700;background:var(--v2-surface-2)">
                                    <td>Total</td>
                                    <td class="v2-table-num">@QTotalBugs</td>
                                    <td class="v2-table-num v2-text-warn">@QOpenBugs</td>
                                    <td class="v2-table-num"><strong style="color:var(--v2-success)">@QResolvedBugs</strong></td>
                                    <td class="v2-table-num v2-text-muted">@FormatHours(QBugLoggedHours)</td>
                                    <td class="v2-table-num v2-text-muted">@(QAvgFixHours <= 0 ? "—" : FormatFixTime(QAvgFixHours))</td>
                                    <td>
                                        <div style="display:flex;align-items:center;gap:6px">
                                            <div class="v2-bar" style="flex:1;height:6px">
                                                <div class="v2-bar-fill @(QBugEffortShare > 50 ? "v2-bar-fill-danger" : QBugEffortShare > 25 ? "v2-bar-fill-warn" : "v2-bar-fill-success")"
                                                     style="width:@Math.Min(QBugEffortShare, 100)%"></div>
                                            </div>
                                            <span class="v2-row-value" style="font-size:11px;min-width:34px;text-align:right">@($"{QBugEffortShare:F0}%")</span>
                                        </div>
                                    </td>
                                    <td class="v2-table-num v2-text-muted">@(QStaleOpenBugs > 0 ? QStaleOpenBugs.ToString() : "—")</td>
                                    <td class="v2-table-num v2-text-muted">@(QQaRejectedBugs > 0 ? QQaRejectedBugs.ToString() : "—")</td>
                                    <td class="v2-table-num v2-text-muted">@(QQaRejectionsTotal > 0 ? QQaRejectionsTotal.ToString() : "—")</td>
                                </tr>
                            </tfoot>
                        }
                    </table>
                </div>

                <!-- ── QA Rejected Tickets ────────────────────────────────────── -->
                <div class="v2-section-title v2-mt-lg">
                    <i class="bi bi-x-octagon-fill" style="color:#ef4444"></i>QA Rejected Tickets
                    <span class="v2-hint" style="margin-left:8px;font-weight:400">tickets that transitioned to "QA REJECTED" · ordered by assignee, status</span>
                </div>
                <div class="v2-table-wrap">
                    <table class="v2-table">
                        <thead>
                            <tr>
                                <th>Key</th>
                                <th>Summary</th>
                                <th>Assignee</th>
                                <th>Priority</th>
                                <th>Status</th>
                                <th class="v2-table-num">QA Rej.</th>
                                <th class="v2-table-num">Days open</th>
                                <th class="v2-table-num">Logged</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var qaRejList = QAllIssues
                                    .Where(i => i.QaRejectedCount > 0)
                                    .OrderBy(i => i.Assignee)
                                    .ThenBy(i => i.Status)
                                    .ToList();
                            }
                            @if (!qaRejList.Any())
                            {
                                <tr><td colspan="8" style="text-align:center;padding:20px" class="v2-text-muted">No tickets found with QA REJECTED status transitions.</td></tr>
                            }
                            @foreach (var t in qaRejList)
                            {
                                <tr class="@(t.StatusCategoryKey == "done" ? "is-done" : "")">
                                    <td class="v2-table-key">@t.Key</td>
                                    <td class="v2-truncate" style="max-width:320px">@t.Summary</td>
                                    <td>
                                        <div style="display:flex;align-items:center;gap:6px">
                                            <span class="v2-avatar v2-avatar-grad-2" style="width:22px;height:22px;font-size:9px">@Initials(t.Assignee)</span>
                                            <span>@t.Assignee</span>
                                        </div>
                                    </td>
                                    <td><span class="v2-chip v2-chip-pri-@t.Priority.ToLower()">@t.Priority</span></td>
                                    <td><span class="v2-pill v2-pill-@(t.StatusCategoryKey == "done" ? "success" : t.StatusCategoryKey == "indeterminate" ? "brand" : "warn")">@t.Status</span></td>
                                    <td class="v2-table-num @(t.QaRejectedCount > 1 ? "v2-text-danger" : "v2-text-warn")"><strong>@t.QaRejectedCount</strong></td>
                                    <td class="v2-table-num">@(t.StatusCategoryKey == "done" ? "—" : QDaysOpen(t).ToString())</td>
                                    <td class="v2-table-num">@(t.TimeSpentSeconds > 0 ? FormatHours(t.TimeSpentSeconds / 3600.0) : "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }
        else if (MainTab == "issues")
        {

        <!-- ═══ ISSUES TABLE ════════════════════════════════════════════════ -->
        <div class="v2-section v2-mt-lg">
            <div class="v2-section-title">
                <i class="bi bi-list-ul"></i>All issues
                <span class="v2-section-note">@FilteredIssues.Count of @(EpicData?.Issues.Count ?? 0)</span>
            </div>

            <div class="v2-filter-bar">
                <div class="v2-filter-group">
                    <span class="v2-label">Status</span>
                    <select class="v2-select v2-input-sm" @bind="FilterStatus">
                        <option value="">All</option>
                        <option value="indeterminate">In Progress</option>
                        <option value="done">Done</option>
                        <option value="new">To Do</option>
                    </select>
                </div>
                <div class="v2-filter-sep"></div>
                <div class="v2-filter-group">
                    <span class="v2-label">Type</span>
                    <select class="v2-select v2-input-sm" @bind="FilterType">
                        <option value="">All</option>
                        @foreach (var t in TypeOptions) { <option value="@t">@t</option> }
                    </select>
                </div>
                <div class="v2-filter-sep"></div>
                <div class="v2-filter-group">
                    <span class="v2-label">Assignee</span>
                    <select class="v2-select v2-input-sm" @bind="FilterAssignee">
                        <option value="">All</option>
                        @foreach (var a in AssigneeOptions) { <option value="@a">@a</option> }
                    </select>
                </div>
                <span class="v2-filter-count">@FilteredIssues.Count items</span>
            </div>

            <div class="v2-table-wrap">
                <table class="v2-table">
                    <thead>
                        <tr>
                            <th class="@SI("Key", _sortIS, _ascIS)" @onclick='() => SortIS("Key")'>Key</th>
                            <th class="@SI("Summary", _sortIS, _ascIS)" @onclick='() => SortIS("Summary")'>Summary</th>
                            <th class="@SI("Type", _sortIS, _ascIS)" @onclick='() => SortIS("Type")'>Type</th>
                            <th class="@SI("Status", _sortIS, _ascIS)" @onclick='() => SortIS("Status")'>Status</th>
                            <th class="@SI("Assignee", _sortIS, _ascIS)" @onclick='() => SortIS("Assignee")'>Assignee</th>
                            <th class="v2-table-num @SI("Est", _sortIS, _ascIS)" @onclick='() => SortIS("Est")'>Estimate</th>
                            <th class="v2-table-num @SI("Log", _sortIS, _ascIS)" @onclick='() => SortIS("Log")'>Logged</th>
                            <th class="v2-table-num @SI("Rem", _sortIS, _ascIS)" @onclick='() => SortIS("Rem")'>Remaining</th>
                            <th class="@SI("Pct", _sortIS, _ascIS)" @onclick='() => SortIS("Pct")'>Progress</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var i in ApplySortIS(FilteredIssues))
                        {
                            var pct = IssuePct(i);
                            <tr class="@(i.StatusCategoryKey == "done" ? "is-done" : "")">
                                <td class="v2-table-key">@i.Key</td>
                                <td class="v2-truncate" style="max-width:340px">@i.Summary</td>
                                <td><span class="v2-chip v2-chip-@(i.IssueType.ToLower())">@i.IssueType</span></td>
                                <td><span class="v2-pill v2-pill-@StatusPillClass(i.StatusCategoryKey)">@i.Status</span></td>
                                <td>@i.Assignee</td>
                                <td class="v2-table-num">@(i.OriginalEstimate == "-" ? "—" : i.OriginalEstimate)</td>
                                <td class="v2-table-num">@(i.TimeSpent == "-" ? "—" : i.TimeSpent)</td>
                                <td class="v2-table-num">@(i.RemainingEstimate == "-" ? "—" : i.RemainingEstimate)</td>
                                <td style="min-width:110px">
                                    <div style="display:flex;align-items:center;gap:6px">
                                        <div class="v2-bar" style="flex:1;height:5px">
                                            <div class="v2-bar-fill @(pct > 100 ? "v2-bar-fill-danger" : pct == 100 ? "v2-bar-fill-success" : "")"
                                                 style="width:@Math.Min(pct, 100)%"></div>
                                        </div>
                                        <span class="v2-row-value" style="font-size:11px;min-width:32px;text-align:right">@pct%</span>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        }
    }
</div>

@code {
    // ── State ────────────────────────────────────────────────────────────────
    private string EpicKeyInput  = "";
    private string SprintIdInput = "";
    private bool   IsLoadingEpic;
    private bool   IsLoadingSprint;
    private bool   IsLoading => IsLoadingEpic || IsLoadingSprint;
    private string? InfoMessage;
    private string? ErrorMessage;
    private JiraEpicReport? EpicData;
    private SprintReport?   SprintData;
    private EpicProgressResult? Metrics;

    // ── Tab state ────────────────────────────────────────────────────────────
    private string MainTab = "overview";
    private string QualityTab = "overview";
    private bool   ShowScoreBreakdown;

    // Filters for issue list
    private string FilterStatus   = "";
    private string FilterType     = "";
    private string FilterAssignee = "";

    private List<SprintIssue> FilteredIssues => (EpicData?.Issues ?? new())
        .Where(i => string.IsNullOrEmpty(FilterStatus)   || i.StatusCategoryKey == FilterStatus)
        .Where(i => string.IsNullOrEmpty(FilterType)     || i.IssueType == FilterType)
        .Where(i => string.IsNullOrEmpty(FilterAssignee) || i.Assignee == FilterAssignee)
        .ToList();

    private IEnumerable<string> TypeOptions => (EpicData?.Issues ?? new())
        .Select(i => i.IssueType).Where(t => !string.IsNullOrEmpty(t)).Distinct().OrderBy(t => t);

    private IEnumerable<string> AssigneeOptions => (EpicData?.Issues ?? new())
        .Select(i => i.Assignee).Where(a => !string.IsNullOrEmpty(a)).Distinct().OrderBy(a => a);

    // ── Health score (composite) ─────────────────────────────────────────────
    private int HealthScore
    {
        get
        {
            if (Metrics is null) return 0;
            var m = Metrics;
            var delivery = m.Delivery.CompletionPct / 100.0;                                     // 40%
            var effort   = m.Effort.EffortPct == 0 ? 1.0 : Math.Clamp(1 - Math.Max(0, (m.Effort.EffortPct - 100) / 100.0), 0, 1); // 25%
            var risk     = 1 - Math.Min(1.0, (m.Risk.StaleInProgress + m.Risk.Unestimated + m.Risk.Overlogged) / (double)Math.Max(1, m.Delivery.Total)); // 20%
            var quality  = 1 - Math.Min(1.0, m.Quality.OpenBugs / (double)Math.Max(1, m.Delivery.Total));                          // 15%
            return Math.Clamp((int)Math.Round(delivery * 40 + effort * 25 + risk * 20 + quality * 15), 0, 100);
        }
    }

    private string HealthBand => HealthScore >= 75 ? "success" : HealthScore >= 50 ? "warn" : "danger";

    private string HealthMarkerColor => HealthBand switch
    {
        "success" => "#059669",
        "warn"    => "#d97706",
        _         => "#dc2626"
    };

    private string HealthMessage => HealthScore switch
    {
        >= 85 => "Epic is in excellent shape — high completion, controlled effort, low risk.",
        >= 75 => "Healthy epic — minor risks but trajectory is solid.",
        >= 60 => "On track but watch the bug load and effort burn.",
        >= 40 => "At risk — significant blockers or budget overrun.",
        _     => "Critical — multiple metrics signal the epic needs intervention."
    };

    private string RagClass => HealthScore >= 75 ? "v2-rag-g" : HealthScore >= 50 ? "v2-rag-a" : "v2-rag-r";
    private string RagText  => HealthScore >= 75 ? "On Track" : HealthScore >= 50 ? "At Risk" : "Behind";

    private string CompletionKpiClass => Metrics?.Delivery.CompletionPct >= 75 ? "v2-kpi-success"
        : Metrics?.Delivery.CompletionPct >= 40 ? "v2-kpi-warn" : "v2-kpi-danger";

    private string EffortKpiClass => Metrics?.Effort.EffortPct > 110 ? "v2-kpi-danger"
        : Metrics?.Effort.EffortPct > 90 ? "v2-kpi-warn" : "v2-kpi-success";

    // ── Forecast ─────────────────────────────────────────────────────────────
    private string TaskProjectedEndLabel
    {
        get
        {
            if (EpicData is null) return "—";
            if (!EpicData.Issues.Any(i => !IsBugIssue(i) && i.StatusCategoryKey != "done")) return "Complete";
            var (date, _) = ProjectEndTasks();
            return date is null ? "Unknown" : date.Value.ToString("MMM d, yyyy");
        }
    }

    private string TaskProjectionMessage
    {
        get
        {
            if (EpicData is null) return "";
            if (!EpicData.Issues.Any(i => !IsBugIssue(i) && i.StatusCategoryKey != "done")) return "All tasks done";
            var (date, daysLeft) = ProjectEndTasks();
            if (date is null) return "Insufficient worklog history to forecast";
            if (daysLeft <= 0) return "Past projected completion date";
            return $"~{daysLeft} working days at current logging pace";
        }
    }

    private string TaskForecastClass
    {
        get
        {
            if (EpicData is null) return "v2-kpi-neutral";
            if (!EpicData.Issues.Any(i => !IsBugIssue(i) && i.StatusCategoryKey != "done")) return "v2-kpi-success";
            var (date, _) = ProjectEndTasks();
            return date is null ? "v2-kpi-neutral" : "v2-kpi-success";
        }
    }

    private string BugProjectedEndLabel
    {
        get
        {
            if (EpicData is null || Metrics is null) return "—";
            if (Metrics.Quality.OpenBugs == 0) return "All clear";
            var (date, _) = ProjectEndBugs();
            return date is null ? "Unknown" : date.Value.ToString("MMM d, yyyy");
        }
    }

    private string BugProjectionMessage
    {
        get
        {
            if (EpicData is null || Metrics is null) return "";
            if (Metrics.Quality.OpenBugs == 0) return "No open bugs";
            var (date, daysLeft) = ProjectEndBugs();
            if (date is null) return "Insufficient worklog history to forecast";
            if (daysLeft <= 0) return "Past projected completion date";
            var avgLabel = Metrics.Quality.AvgBugFixTimeSec > 0
                ? $"avg {EpicProgressCalculator.FormatSeconds((int)Metrics.Quality.AvgBugFixTimeSec)}/bug"
                : "remaining estimates";
            return $"{Metrics.Quality.OpenBugs} open · ~{daysLeft} working days ({avgLabel})";
        }
    }

    private string BugForecastClass
    {
        get
        {
            if (EpicData is null || Metrics is null) return "v2-kpi-neutral";
            if (Metrics.Quality.OpenBugs == 0) return "v2-kpi-success";
            var (date, _) = ProjectEndBugs();
            return date is null ? "v2-kpi-neutral" : "v2-kpi-warn";
        }
    }

    private static bool IsBugIssue(SprintIssue i) =>
        string.Equals(i.IssueType, "Bug", StringComparison.OrdinalIgnoreCase);

    private (DateTime? Date, int DaysLeft) ProjectEndTasks()
    {
        if (EpicData is null) return (null, 0);
        var tasks = EpicData.Issues.Where(i => !IsBugIssue(i)).ToList();
        var totalRemainingSec = tasks
            .Where(i => i.StatusCategoryKey != "done")
            .Sum(i => (long)i.RemainingEstimateSeconds);
        if (totalRemainingSec <= 0) return (null, 0);
        var allLogs = tasks.SelectMany(i => i.Worklogs).ToList();
        if (allLogs.Count == 0) return (null, 0);
        var activeDays = Math.Max(1, allLogs.Select(w => w.Started.Date).Distinct().Count());
        var dailyRateSec = allLogs.Sum(w => (long)w.TimeSpentSeconds) / (double)activeDays;
        if (dailyRateSec <= 0) return (null, 0);
        var daysLeft = (int)Math.Ceiling(totalRemainingSec / dailyRateSec);
        return (DateTime.Today.AddDays(daysLeft), (int)Math.Ceiling(daysLeft * 5.0 / 7.0));
    }

    private (DateTime? Date, int DaysLeft) ProjectEndBugs()
    {
        if (EpicData is null || Metrics is null) return (null, 0);
        var bugs = EpicData.Issues.Where(IsBugIssue).ToList();
        var openBugs = bugs.Count(i => i.StatusCategoryKey != "done");
        if (openBugs == 0) return (null, 0);
        var avgFixSec = Metrics.Quality.AvgBugFixTimeSec;
        var totalRemainingBugSec = avgFixSec > 0
            ? openBugs * avgFixSec
            : bugs.Where(i => i.StatusCategoryKey != "done").Sum(i => (long)i.RemainingEstimateSeconds);
        if (totalRemainingBugSec <= 0) return (null, 0);
        var allLogs = bugs.SelectMany(i => i.Worklogs).ToList();
        if (allLogs.Count == 0) return (null, 0);
        var activeDays = Math.Max(1, allLogs.Select(w => w.Started.Date).Distinct().Count());
        var dailyRateSec = allLogs.Sum(w => (long)w.TimeSpentSeconds) / (double)activeDays;
        if (dailyRateSec <= 0) return (null, 0);
        var daysLeft = (int)Math.Ceiling(totalRemainingBugSec / dailyRateSec);
        return (DateTime.Today.AddDays(daysLeft), (int)Math.Ceiling(daysLeft * 5.0 / 7.0));
    }

    // ── Loading ──────────────────────────────────────────────────────────────
    private async Task LoadEpicAsync()
    {
        if (string.IsNullOrWhiteSpace(EpicKeyInput)) return;
        IsLoadingEpic = true; ErrorMessage = null; InfoMessage = null;
        Metrics = null; SprintData = null; SprintIdInput = "";
        try
        {
            EpicData = await JiraService.GetEpicReportAsync(EpicKeyInput.Trim().ToUpper());
            if (EpicData is null || EpicData.Issues.Count == 0)
            {
                ErrorMessage = $"Epic {EpicKeyInput} not found or has no issues.";
                EpicData = null;
                return;
            }
            Metrics = EpicProgressCalculator.Compute(EpicData);
        }
        catch (Exception ex) { ErrorMessage = $"Failed to load epic: {ex.Message}"; }
        finally { IsLoadingEpic = false; }
    }

    private async Task ApplySprintFilterAsync()
    {
        if (EpicData is null || !int.TryParse(SprintIdInput.Trim(), out var sprintId)) return;
        IsLoadingSprint = true; ErrorMessage = null; InfoMessage = null;
        try
        {
            SprintData = await JiraService.GetEpicSprintForecastAsync(EpicData.Key, sprintId);
            if (SprintData.Issues.Count == 0)
            {
                InfoMessage = $"Epic {EpicData.Key} has no issues in sprint {sprintId}.";
                Metrics = EpicProgressCalculator.Compute(EpicData);
            }
            else
            {
                Metrics = EpicProgressCalculator.Compute(EpicData, SprintData);
            }
        }
        catch (Exception ex) { ErrorMessage = $"Failed to apply sprint filter: {ex.Message}"; }
        finally { IsLoadingSprint = false; }
    }

    private void ClearSprintFilter()
    {
        SprintData = null; SprintIdInput = "";
        if (EpicData is not null) Metrics = EpicProgressCalculator.Compute(EpicData);
    }

    private async Task OnEpicKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await LoadEpicAsync();
    }

    // ── Helpers ──────────────────────────────────────────────────────────────
    private static int IssuePct(SprintIssue i)
    {
        if (i.StatusCategoryKey == "done") return 100;
        if (i.OriginalEstimateSeconds == 0) return 0;
        return (int)((double)i.TimeSpentSeconds / i.OriginalEstimateSeconds * 100);
    }

    private static int SafePct(int part, int total) => total == 0 ? 0 : (int)(part * 100.0 / total);

    private static string Initials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2 ? $"{parts[0][0]}{parts[^1][0]}".ToUpper()
            : name.Length >= 2 ? name[..2].ToUpper() : name.ToUpper();
    }

    private static string StatusPillClass(string statusCategoryKey) => statusCategoryKey switch
    {
        "done"          => "success",
        "indeterminate" => "brand",
        _               => "neutral"
    };

    // ── Sorting ──────────────────────────────────────────────────────────────
    private static string SI(string col, string sortCol, bool asc) =>
        sortCol == col ? (asc ? "v2-sortable v2-sort-asc" : "v2-sortable v2-sort-desc") : "v2-sortable";

    // Contributor leaderboard
    private string _sortCB = ""; private bool _ascCB = false;
    private void SortCB(string c) { if (_sortCB == c) _ascCB = !_ascCB; else { _sortCB = c; _ascCB = false; } }

    private IEnumerable<TaskAssigneeRow> ApplySortCB(IEnumerable<TaskAssigneeRow> src) => _sortCB switch
    {
        "Name"   => _ascCB ? src.OrderBy(r => r.Assignee)              : src.OrderByDescending(r => r.Assignee),
        "Total"  => _ascCB ? src.OrderBy(r => r.Total)                 : src.OrderByDescending(r => r.Total),
        "Done"   => _ascCB ? src.OrderBy(r => r.Done)                  : src.OrderByDescending(r => r.Done),
        "Active" => _ascCB ? src.OrderBy(r => r.InProgress)            : src.OrderByDescending(r => r.InProgress),
        "ToDo"   => _ascCB ? src.OrderBy(r => r.ToDo)                  : src.OrderByDescending(r => r.ToDo),
        "Pct"    => _ascCB ? src.OrderBy(r => r.CompletionPct)         : src.OrderByDescending(r => r.CompletionPct),
        "Share"  => _ascCB ? src.OrderBy(r => r.EpicSharePct)          : src.OrderByDescending(r => r.EpicSharePct),
        "Log"    => _ascCB ? src.OrderBy(r => r.TotalSpentSec)         : src.OrderByDescending(r => r.TotalSpentSec),
        "Rem"    => _ascCB ? src.OrderBy(r => r.TotalRemainingEstimateSec) : src.OrderByDescending(r => r.TotalRemainingEstimateSec),
        _        => src,
    };

    // Issues table
    private string _sortIS = ""; private bool _ascIS = true;
    private void SortIS(string c) { if (_sortIS == c) _ascIS = !_ascIS; else { _sortIS = c; _ascIS = true; } }

    private IEnumerable<SprintIssue> ApplySortIS(IEnumerable<SprintIssue> src) => _sortIS switch
    {
        "Key"      => _ascIS ? src.OrderBy(i => i.Key)                       : src.OrderByDescending(i => i.Key),
        "Summary"  => _ascIS ? src.OrderBy(i => i.Summary)                   : src.OrderByDescending(i => i.Summary),
        "Type"     => _ascIS ? src.OrderBy(i => i.IssueType)                 : src.OrderByDescending(i => i.IssueType),
        "Status"   => _ascIS ? src.OrderBy(i => i.Status)                    : src.OrderByDescending(i => i.Status),
        "Assignee" => _ascIS ? src.OrderBy(i => i.Assignee)                  : src.OrderByDescending(i => i.Assignee),
        "Est"      => _ascIS ? src.OrderBy(i => i.OriginalEstimateSeconds)   : src.OrderByDescending(i => i.OriginalEstimateSeconds),
        "Log"      => _ascIS ? src.OrderBy(i => i.TimeSpentSeconds)          : src.OrderByDescending(i => i.TimeSpentSeconds),
        "Rem"      => _ascIS ? src.OrderBy(i => i.RemainingEstimateSeconds)  : src.OrderByDescending(i => i.RemainingEstimateSeconds),
        "Pct"      => _ascIS ? src.OrderBy(i => IssuePct(i))                 : src.OrderByDescending(i => IssuePct(i)),
        _          => src.OrderBy(i => i.StatusCategoryKey switch { "indeterminate" => 0, "new" => 1, _ => 2 })
                         .ThenByDescending(i => i.RemainingEstimateSeconds),
    };

    // ── Quality tab derived data ──────────────────────────────────────────────
    private List<SprintIssue> QAllIssues => (EpicData?.Issues ?? [])
        .Where(i => !string.Equals(i.IssueType, "Epic", StringComparison.OrdinalIgnoreCase))
        .ToList();

    private List<SprintIssue> QAllBugs => QAllIssues.Where(IsBugIssue).ToList();
    private List<SprintIssue> QOpenBugList => QAllBugs.Where(b => b.StatusCategoryKey != "done").ToList();
    private List<SprintIssue> QResolvedBugList => QAllBugs.Where(b => b.StatusCategoryKey == "done").ToList();

    private int QTotalIssues => QAllIssues.Count;
    private int QTotalBugs => QAllBugs.Count;
    private int QOpenBugs => QOpenBugList.Count;
    private int QResolvedBugs => QResolvedBugList.Count;
    private int QInProgressBugs => QAllBugs.Count(b => b.StatusCategoryKey == "indeterminate");
    private int QNewBugs => QAllBugs.Count(b => b.StatusCategoryKey == "new");

    private int QCriticalOpenBugs => QOpenBugList.Count(b => b.Priority is "Highest" or "Critical");
    private int QHighOpenBugs => QOpenBugList.Count(b => b.Priority == "High");
    private int QLowOpenBugs => QOpenBugList.Count(b => b.Priority is "Low" or "Lowest");

    private int QUnassignedBugs => QAllBugs.Count(b =>
        string.IsNullOrWhiteSpace(b.Assignee) || b.Assignee.Equals("Unassigned", StringComparison.OrdinalIgnoreCase));
    private int QUnestimatedBugs => QAllBugs.Count(b => b.OriginalEstimateSeconds == 0);
    private int QStaleOpenBugs => QOpenBugList.Count(b => b.StatusCategoryKey == "indeterminate" && b.DaysSinceLastWorklog >= 2);

    private double QBugRate => QTotalIssues == 0 ? 0 : QTotalBugs * 100.0 / QTotalIssues;
    private double QBugFixRate => QTotalBugs == 0 ? 0 : QResolvedBugs * 100.0 / QTotalBugs;

    private double QBugLoggedHours => QAllBugs.Sum(b => b.TimeSpentSeconds) / 3600.0;
    private double QNonBugLoggedHours => QAllIssues.Where(i => !IsBugIssue(i)).Sum(i => i.TimeSpentSeconds) / 3600.0;
    private double QBugEffortShare => (QBugLoggedHours + QNonBugLoggedHours) == 0 ? 0
        : QBugLoggedHours / (QBugLoggedHours + QNonBugLoggedHours) * 100;

    private double QAvgFixHours
    {
        get
        {
            var withTime = QResolvedBugList.Where(b => b.TimeSpentSeconds > 0).ToList();
            return withTime.Count == 0 ? 0 : withTime.Average(b => b.TimeSpentSeconds / 3600.0);
        }
    }

    private int QQaRejectionsTotal => QAllBugs.Sum(b => b.QaRejectedCount);
    private int QQaRejectedBugs => QAllBugs.Count(b => b.QaRejectedCount > 0);
    private double QQaRejectionRate => QTotalBugs == 0 ? 0 : QQaRejectedBugs * 100.0 / QTotalBugs;

    private int QAvgBugAgeDays => QOpenBugList.Count == 0 ? 0 : (int)Math.Round(QOpenBugList.Average(b => (double)QDaysOpen(b)));
    private int QOldestBugDays => QOpenBugList.Count == 0 ? 0 : QOpenBugList.Max(QDaysOpen);

    private double QOpenBugRatePct => QTotalIssues == 0 ? 0 : QOpenBugs * 100.0 / QTotalIssues;

    private double QEffortScore   => Math.Clamp(100 - QBugEffortShare * 2, 0, 100);
    private double QOpenBugsScore => Math.Clamp(100 - QOpenBugRatePct * 3, 0, 100);
    private double QAvgFixScore   => QResolvedBugs == 0 ? 100 : Math.Clamp(100 - QAvgFixHours * 1.4, 0, 100);

    private int QualityScore
    {
        get
        {
            if (EpicData is null || QTotalIssues == 0) return 100;
            var score = QEffortScore * 0.40 + QOpenBugsScore * 0.35 + QAvgFixScore * 0.25;
            return Math.Clamp((int)Math.Round(score), 0, 100);
        }
    }

    private string QualityBand => QualityScore >= 75 ? "success" : QualityScore >= 50 ? "warn" : "danger";

    private string QualityMarkerColor => QualityBand switch
    {
        "success" => "#059669",
        "warn"    => "#d97706",
        _         => "#dc2626"
    };

    private string QualityMessage => QualityScore switch
    {
        >= 85 => "Excellent quality posture — defect density and rework are minimal.",
        >= 75 => "Healthy quality — minor signals to monitor but no red flags.",
        >= 60 => "Acceptable quality — bug load or rework consuming meaningful capacity.",
        >= 40 => "Quality at risk — high bug rate, slow MTTR or notable QA rework.",
        _     => "Critical quality issues — escalate and prioritise stabilisation."
    };

    private string QualityRagText => QualityScore >= 75 ? "Healthy" : QualityScore >= 50 ? "Watching" : "At Risk";

    private int QDaysOpen(SprintIssue i)
    {
        var start = i.Created ?? DateTime.Today;
        return Math.Max(0, (int)(DateTime.Today - start.Date).TotalDays);
    }

    private static string FormatHours(double h)
    {
        if (h <= 0) return "—";
        var hh = (int)h; var mm = (int)Math.Round((h - hh) * 60);
        return mm > 0 ? $"{hh}h {mm}m" : $"{hh}h";
    }

    private static string FormatFixTime(double h) =>
        h < 0 ? "N/A" : h == 0 ? "<6h" : $"{(int)h}h";

    private static int QStatusOrder(string s) => s switch
    {
        "indeterminate" => 0,
        "new"           => 1,
        _               => 2
    };

    private static int QPriorityOrder(string p) => p switch
    {
        "Highest" or "Critical" => 5,
        "High"                  => 4,
        "Medium"                => 3,
        "Low"                   => 2,
        "Lowest"                => 1,
        _                       => 0
    };

    private static double WorkingHours(DateTime from, DateTime to)
    {
        if (to.Date <= from.Date) return 0;
        int days = 0;
        var d = from.Date.AddDays(1);
        while (d <= to.Date)
        {
            if (d.DayOfWeek != DayOfWeek.Saturday && d.DayOfWeek != DayOfWeek.Sunday) days++;
            d = d.AddDays(1);
        }
        return days * 6.0;
    }

    private record AssigneeBugMetric(string Assignee, int IssuesWorked, int BugsWorked,
        double BugHours, double TotalHours, double BugEffortRate, double AvgFixHours);

    private List<AssigneeBugMetric> AssigneeBugRates
    {
        get
        {
            var all = QAllIssues;
            return all
                .SelectMany(i => i.Worklogs
                    .Where(w => !string.IsNullOrEmpty(w.Author))
                    .Select(w => (Author: w.Author, IssueKey: i.Key, IsBugI: IsBugIssue(i), Hours: w.TimeSpentSeconds / 3600.0)))
                .GroupBy(x => x.Author)
                .Select(g =>
                {
                    var bugHrs   = g.Where(x => x.IsBugI).Sum(x => x.Hours);
                    var totalHrs = g.Sum(x => x.Hours);
                    var resolvedBugs = all
                        .Where(i => IsBugIssue(i) && i.StatusCategoryKey == "done" && i.Assignee == g.Key
                                 && i.ResolutionDate.HasValue && i.Created.HasValue)
                        .ToList();
                    return new AssigneeBugMetric(
                        g.Key,
                        g.Select(x => x.IssueKey).Distinct().Count(),
                        g.Where(x => x.IsBugI).Select(x => x.IssueKey).Distinct().Count(),
                        bugHrs,
                        totalHrs,
                        totalHrs == 0 ? 0 : bugHrs / totalHrs * 100,
                        resolvedBugs.Count > 0
                            ? resolvedBugs.Average(b => WorkingHours(b.Created!.Value, b.ResolutionDate!.Value))
                            : -1);
                })
                .OrderByDescending(m => m.BugEffortRate)
                .ThenByDescending(m => m.BugHours)
                .ToList();
        }
    }

    private record QaRejectionRow(string Assignee, int TotalTickets, int RejectedTickets, int TotalRejections)
    {
        public double PctRejected => TotalTickets == 0 ? 0 : RejectedTickets * 100.0 / TotalTickets;
    }

    private List<QaRejectionRow> QaRejectionByAssignee => QAllIssues
        .Where(i => !string.IsNullOrEmpty(i.Assignee))
        .GroupBy(i => i.Assignee)
        .Where(g => g.Any(i => i.QaRejectedCount > 0))
        .Select(g => new QaRejectionRow(
            Assignee:         g.Key,
            TotalTickets:     g.Count(),
            RejectedTickets:  g.Count(i => i.QaRejectedCount > 0),
            TotalRejections:  g.Sum(i => i.QaRejectedCount)))
        .OrderByDescending(r => r.TotalRejections)
        .ToList();
}

