    private const string Prio1Jql     = "\"JM Prio List[Date]\" <= 3d and \"JM Prio List[Date]\" >1d and status not in (done,rejected, Canceled)";
    private const string Prio2Jql     = "project = JM AND \"Customers Jimpisoft[Dropdown]\" IS NOT EMPTY AND status NOT IN (Done, Canceled, Rejected) AND issuetype = Bug AND creator NOT IN (\"Pedro Calado\") AND \"JS Project[Radio Buttons]\" IN (\"Rentway Pro\", \"Integrations\") and \"Customers Jimpisoft[Dropdown]\" not in (\"000 - Emotion\") and priority in (Highest) order BY createdDate asc";
    private const string Prio3Jql     = "project = JM AND \"Customers Jimpisoft[Dropdown]\" IS NOT EMPTY AND status NOT IN (Done, Canceled, Rejected) AND issuetype = Bug AND creator NOT IN (\"Pedro Calado\") AND \"JS Project[Radio Buttons]\" IN (\"Rentway Pro\", \"Integrations\") and \"Customers Jimpisoft[Dropdown]\" not in (\"000 - Emotion\") and priority in (High) order BY createdDate asc";
    private const string WatchlistJql = "\"JM Prio List[Date]\" > 3d and \"JM Prio List[Date]\" <= 7d and status not in (done,rejected)";

    private static readonly string[] PriorityOrder = ["Critical", "Highest", "High", "Medium", "Low", "Lowest"];
    private static int PriOrder(SprintIssue b)
    {
        var idx = Array.FindIndex(PriorityOrder, p => p.Equals(b.Priority, StringComparison.OrdinalIgnoreCase));
        return idx < 0 ? 99 : idx;
    }

    // ── Priority table per-table sort state ─────────────────────────────────────
    private Dictionary<string, string> _ptCol = new() { ["p0"]="", ["p1"]="", ["p2"]="", ["p3"]="", ["w"]="" };
    private Dictionary<string, bool>   _ptAsc = new() { ["p0"]=true, ["p1"]=true, ["p2"]=true, ["p3"]=true, ["w"]=true };
    private void PtSort(string t, string col) { if (_ptCol[t] == col) _ptAsc[t] = !_ptAsc[t]; else { _ptCol[t] = col; _ptAsc[t] = true; } }
    private string PtSI(string t, string col) => _ptCol[t] == col ? (_ptAsc[t] ? "sort-asc" : "sort-desc") : "";
    private IEnumerable<SprintIssue> PtSorted(List<SprintIssue> list, string t)
    {
        var asc = _ptAsc[t];
        return _ptCol[t] switch
        {
            "key"      => asc ? list.OrderBy(b => b.Key)                               : list.OrderByDescending(b => b.Key),
            "title"    => asc ? list.OrderBy(b => b.Summary)                           : list.OrderByDescending(b => b.Summary),
            "assignee" => asc ? list.OrderBy(b => b.Assignee)                          : list.OrderByDescending(b => b.Assignee),
            "customer" => asc ? list.OrderBy(b => b.Customer)                          : list.OrderByDescending(b => b.Customer),
            "status"   => asc ? list.OrderBy(b => b.Status)                            : list.OrderByDescending(b => b.Status),
            "pri"      => asc ? list.OrderBy(b => PriOrder(b))                         : list.OrderByDescending(b => PriOrder(b)),
            "due"      => asc ? list.OrderBy(b => b.PrioListDate ?? DateTime.MaxValue) : list.OrderByDescending(b => b.PrioListDate ?? DateTime.MinValue),
            "days"     => asc ? list.OrderBy(b => GetDaysOpen(b))                      : list.OrderByDescending(b => GetDaysOpen(b)),
            "logged"   => asc ? list.OrderBy(b => b.TimeSpentSeconds)                  : list.OrderByDescending(b => b.TimeSpentSeconds),
            _          => list.AsEnumerable()
        };
    }

    private async Task ActivatePriorityTab()
    {
        _activeTab = "priority";
        if (!_masterLoaded && !_masterLoading)
            await LoadMasterDashboardAsync();
    }

    private async Task LoadMasterDashboardAsync()
    {
        _masterLoading = true;
        _masterError   = "";
        StateHasChanged();
        try
        {
            var t0 = JiraService.GetBugsByJqlAsync(Prio0Jql);
            var t1 = JiraService.GetBugsByJqlAsync(Prio1Jql);
            var t2 = JiraService.GetBugsByJqlAsync(Prio2Jql);
            var t3 = JiraService.GetBugsByJqlAsync(Prio3Jql);
            var t4 = JiraService.GetBugsByJqlAsync(WatchlistJql);
            await Task.WhenAll(t0, t1, t2, t3, t4);
            _prio0Bugs     = t0.Result.Issues ?? new();
            _prio1Bugs     = t1.Result.Issues ?? new();
            _prio2Bugs     = t2.Result.Issues ?? new();
            _prio3Bugs     = t3.Result.Issues ?? new();
            _watchlistBugs = t4.Result.Issues ?? new();
            _masterLoaded  = true;
        }
        catch (Exception ex)
        {
            _masterError = $"Failed to load Bug Master Dashboard: {ex.Message}";
        }
        finally
        {
            _masterLoading = false;
        }
    }

    private static string FormatPrioDate(DateTime? d)
    {
        if (d == null) return "—";
        var days = (int)Math.Round((d.Value.Date - DateTime.Today).TotalDays);
        var label = d.Value.ToString("dd MMM");
        if (days < 0)   return $"{label} ({-days}d overdue)";
        if (days == 0)  return $"{label} (today)";
        if (days == 1)  return $"{label} (tomorrow)";
        return $"{label} (+{days}d)";
    }

    private int MasterTotalCount => _prio0Bugs.Count + _prio1Bugs.Count + _prio2Bugs.Count + _prio3Bugs.Count + _watchlistBugs.Count;

    // ── SLA Dashboard ───────────────────────────────────────────────────────────
    private bool   _slaLoading          = false;
    private bool   _slaLoaded           = false;
    private string _slaError            = "";
    private bool   _slaChartsNeedRender = false;
    private List<SprintIssue> _slaP2 = new();
    private List<SprintIssue> _slaP3 = new();
    private List<SprintIssue> _slaP4 = new();
    private List<SprintIssue> _slaP5 = new();
    private DotNetObjectReference<SupportBugsSlas>? _slaDotNetRef;

    // Drill-down selection (set from a bar click)
    private string _slaDrillTier   = "";
    private int    _slaDrillWeek   = -1;   // index into SlaWeekOffsets
    private int    _slaDrillBucket = -1;   // 0=inside, 1=<7d, 2=7–30d, 3=>30d past

    // Week snapshots: 2 weeks ago, 1 week ago, now (oldest → newest)
    private static readonly int[] SlaWeekOffsets = { 14, 7, 0 };

    // Age = the Jira createdDate token that marks the SLA breach line (used to build inside/outside Jira filter links).
    private record SlaTier(string Id, string Num, string Title, string Sub, double SlaHours, string Age, string Jql);

    private const string SlaBaseJql =
        "project = JM AND \"Customers Jimpisoft[Dropdown]\" IS NOT EMPTY AND issuetype = Bug "
      + "AND creator NOT IN (\"Pedro Calado\") AND status NOT IN (Done, Rejected)";

    // One "all open" query per tier (the createdDate split is applied client-side from the SLA threshold).
    private static readonly SlaTier[] SlaTiers =
    {
        new("P2", "P2", "P2 — Highest priority",     "SLA 24h",     24,      "-24h", $"{SlaBaseJql} AND priority in (Highest)"),
        new("P3", "P3", "P3 — High priority",        "SLA 72h",     72,      "-72h", $"{SlaBaseJql} AND priority in (High)"),
        new("P4", "P4", "P4 — Medium priority",      "SLA 2 weeks", 24 * 14, "-2w",  $"{SlaBaseJql} AND priority in (Medium)"),
        new("P5", "P5", "P5 — Low / Lowest priority","SLA 4 weeks", 24 * 28, "-4w",  $"{SlaBaseJql} AND priority in (Low, Lowest)"),
    };

    // Jira issue-navigator URL for an arbitrary JQL string (opens as a filter the user can save).
    private string SlaJiraUrl(string jql) => $"{_jiraBase}/issues/?jql={Uri.EscapeDataString(jql)}";
    private string SlaOutsideJql(SlaTier t) => $"{t.Jql} AND createdDate <= {t.Age}";
    private string SlaInsideJql(SlaTier t)  => $"{t.Jql} AND createdDate > {t.Age}";

    private List<SprintIssue> SlaBugsFor(string tierId) => tierId switch
    {
        "P2" => _slaP2, "P3" => _slaP3, "P4" => _slaP4, "P5" => _slaP5, _ => new()
    };

    // Bucket of a bug as it would have appeared at a given snapshot time:
    // 0=inside, 1=<7d past, 2=7–30d past, 3=>30d past, -1 if it didn't exist yet at the snapshot.
    private static int SlaBucketAt(SprintIssue b, double slaHours, DateTime snapshot)
    {
        if (!b.Created.HasValue || b.Created.Value > snapshot) return -1;
        var breachHours = (snapshot - b.Created.Value).TotalHours - slaHours;
        if (breachHours <= 0) return 0;
        var breachDays = breachHours / 24.0;
        if (breachDays < 7)  return 1;
        if (breachDays <= 30) return 2;
        return 3;
    }

    private static string SlaBucketLabel(int bucket) => bucket switch
    {
        0 => "Inside SLA",
        1 => "Outside SLA · <7d past",
        2 => "Outside SLA · 7–30d past",
        3 => "Outside SLA · >30d past",
        _ => ""
    };

    private static string SlaWeekLabel(int week)
    {
        if (week < 0 || week >= SlaWeekOffsets.Length) return "";
        var off  = SlaWeekOffsets[week];
        var date = DateTime.Today.AddDays(-off);
        return off == 0 ? $"week of {date:dd MMM} (now)" : $"week of {date:dd MMM}";
    }

    private List<SprintIssue> SlaDrillBugs(SlaTier tier, int week, int bucket)
    {
        if (week < 0 || week >= SlaWeekOffsets.Length || bucket < 0) return new();
        var snap = DateTime.Now.AddDays(-SlaWeekOffsets[week]);
        return SlaBugsFor(tier.Id)
            .Where(b => SlaBucketAt(b, tier.SlaHours, snap) == bucket)
            .OrderByDescending(b => GetDaysOpen(b))
            .ToList();
    }

    private void ClearSlaDrill()
    {
        _slaDrillTier = ""; _slaDrillWeek = -1; _slaDrillBucket = -1;
    }

    [JSInvokable]
    public void OnSlaBarClick(string tierId, int week, int bucket)
    {
        _slaDrillTier   = tierId;
        _slaDrillWeek   = week;
        _slaDrillBucket = bucket;
        StateHasChanged();
    }

    private async Task SwitchToSlaTab()
    {
        _activeTab = "slas";
        if (!_slaLoaded && !_slaLoading)
            await LoadSlaDashboardAsync();
        else
            _slaChartsNeedRender = true;
    }

    private async Task LoadSlaDashboardAsync()
    {
        _slaLoading = true;
        _slaError   = "";
        ClearSlaDrill();
        StateHasChanged();
        try
        {
            var tasks = SlaTiers.Select(t => JiraService.GetSlaBugsByJqlAsync(t.Jql)).ToArray();
            await Task.WhenAll(tasks);
            _slaP2 = tasks[0].Result.Issues ?? new();
            _slaP3 = tasks[1].Result.Issues ?? new();
            _slaP4 = tasks[2].Result.Issues ?? new();
            _slaP5 = tasks[3].Result.Issues ?? new();
            _slaLoaded           = true;
            _slaChartsNeedRender = true;
        }
        catch (Exception ex)
        {
            _slaError = $"Failed to load SLA data: {ex.Message}";
        }
        finally
        {
            _slaLoading = false;
        }
    }

    private async Task RenderSlaChartsAsync()
    {
        _slaDotNetRef ??= DotNetObjectReference.Create(this);
        foreach (var tier in SlaTiers)
            await RenderSlaTierChartAsync(tier);
    }

    private async Task RenderSlaTierChartAsync(SlaTier tier)
    {
        var canvasId = $"sb-sla-chart-{tier.Id}";
        var bugs     = SlaBugsFor(tier.Id);

        // brighter = more recent week
        var weekColors = new[] { "rgba(37,99,235,0.30)", "rgba(37,99,235,0.60)", "rgba(37,99,235,0.95)" };

        var datasets = new List<object>();
        for (int w = 0; w < SlaWeekOffsets.Length; w++)
        {
            var snap = DateTime.Now.AddDays(-SlaWeekOffsets[w]);
            var data = new int[4];
            foreach (var b in bugs)
            {
                var bk = SlaBucketAt(b, tier.SlaHours, snap);
                if (bk >= 0) data[bk]++;
            }
            datasets.Add(new
            {
                label           = $"Week of {DateTime.Today.AddDays(-SlaWeekOffsets[w]):dd MMM}" + (SlaWeekOffsets[w] == 0 ? " (now)" : ""),
                backgroundColor = weekColors[w],
                data,
                borderRadius    = 3,
                maxBarThickness = 48
            });
        }

        await JS.InvokeVoidAsync("renderClickableBarChart", canvasId, new
        {
            type = "bar",
            data = new
            {
                labels = new[] { "Inside SLA", "Outside <7d past", "Outside 7–30d past", "Outside >30d past" },
                datasets
            },
            options = new
            {
                responsive = true,
                maintainAspectRatio = false,
                plugins = new { legend = new { position = "top" } },
                scales = new
                {
                    x = new { grid = new { display = false } },
                    y = new
                    {
                        beginAtZero = true,
                        ticks = new { stepSize = 1, precision = 0 },
                        title = new { display = true, text = $"Open {tier.Id} tickets" },
                        grid  = new { color = "rgba(0,0,0,0.05)" }
                    }
                }
            }
        }, _slaDotNetRef, "OnSlaBarClick", tier.Id);
    }

    // ── Shared helpers ────────────────────────────────────────────────────────
    private static int GetDaysOpen(SprintIssue b) =>
        b.Created.HasValue ? (int)(DateTime.Today - b.Created.Value.Date).TotalDays : 0;

    private static string GetStatusClass(string? status) => status?.ToLowerInvariant() switch
    {
        "dev ready"   => "status-dev-ready",
        "in progress" => "status-in-progress",
        "in review"   => "status-in-review",
        "qa ready"    => "status-qa-ready",
        "done"        => "status-done",
        "on hold"     => "status-on-hold",
        _             => "status-default"
    };

    private static string GetPriorityClass(string? p) => p?.ToLowerInvariant() switch
    {
        "highest" or "critical" => "pri-critical",
        "high"                  => "pri-high",
        "medium"                => "pri-medium",
        "low"                   => "pri-low",
        "lowest"                => "pri-lowest",
        _                       => "pri-medium"
    };

    private static string FormatSeconds(int s)
    {
        if (s == 0) return "—";
        var abs = Math.Abs(s);
        var h = abs / 3600;
        var m = (abs % 3600) / 60;
        var fmt = h > 0 ? (m > 0 ? $"{h}h {m}m" : $"{h}h") : $"{m}m";
        return s < 0 ? $"-{fmt}" : fmt;
    }

    // ── Lifecycle ───────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        await LoadMasterDashboardAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_slaChartsNeedRender && _activeTab == "slas" && _slaLoaded)
        {
            _slaChartsNeedRender = false;
            await RenderSlaChartsAsync();
        }
    }

    public void Dispose() => _slaDotNetRef?.Dispose();
}

