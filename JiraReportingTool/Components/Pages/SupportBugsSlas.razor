        padding: 1px 6px;
    }

    .sb-section-clear { margin-left: auto; }

    .sb-person-mode {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 11px;
        color: var(--txt-2);
        cursor: pointer;
        margin: 2px 0 8px;
        user-select: none;
    }
    .sb-person-mode input { cursor: pointer; }

    .sb-check-list {
        display: flex;
        flex-direction: column;
        gap: 5px;
        max-height: 150px;
        overflow-y: auto;
    }

    .sb-check-item {
        display: flex;
        align-items: center;
        gap: 7px;
        font-size: 12px;
        color: var(--txt-2);
        cursor: pointer;
        user-select: none;
        white-space: nowrap;
    }
    .sb-check-item input[type="checkbox"] {
        width: 13px;
        height: 13px;
        cursor: pointer;
        accent-color: var(--primary);
        flex-shrink: 0;
    }
    .sb-check-item:hover { color: var(--txt-1); }

    .sb-date-range {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .sb-date-range-lbl {
        font-size: 10px;
        font-weight: 600;
        color: var(--txt-4);
        text-transform: uppercase;
        letter-spacing: .06em;
        margin-top: 4px;
    }
    .sb-date-range-lbl:first-child { margin-top: 0; }

    .sb-filter-date {
        font-size: 12px;
        padding: 4px 8px;
        height: 28px;
    }

    /* ── Chip-filter row (bottom row) ────────────────────────────── */
    .sb-filter-row {
        display: flex;
        align-items: flex-start;
        gap: 14px;
        padding: 10px 16px;
    }

    .sb-filter-row-inline {
        align-items: center;
        background: var(--surface-2);
    }

    .sb-filter-sep {
        height: 1px;
        background: var(--border);
    }

    .sb-filter-inline-sep {
        width: 1px;
        background: var(--border);
        align-self: stretch;
        margin: 0 4px;
    }

    .sb-filter-inline-group {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .sb-filter-label {
        font-size: 10px;
        font-weight: 700;
        color: var(--txt-3);
        text-transform: uppercase;
        letter-spacing: .07em;
        white-space: nowrap;
    }

    .sb-filter-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 5px;
    }

    .sb-chip-btn {
        display: inline-flex;
        align-items: center;
        padding: 3px 10px;
        border-radius: 20px;
        border: 1px solid var(--border);
        background: var(--surface);
        color: var(--txt-2);
        font-size: 12px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.12s;
        line-height: 1.5;
    }
    .sb-chip-btn:hover {
        border-color: var(--primary-border);
        background: var(--primary-light);
        color: var(--primary);
    }
    .sb-chip-btn.active {
        background: var(--primary);
        border-color: var(--primary);
        color: #fff;
        font-weight: 600;
    }

    /* Health chip colour overrides when active */
    .sb-chip-health-overdue.active    { background: var(--danger);  border-color: var(--danger); }
    .sb-chip-health-at-risk.active    { background: var(--warning); border-color: var(--warning); }
    .sb-chip-health-on-track.active   { background: var(--success); border-color: var(--success); }
    .sb-chip-health-no-due-date.active { background: #6b7280; border-color: #6b7280; }
    .sb-chip-health-done.active       { background: var(--success); border-color: var(--success); }

    /* ── Sections ────────────────────────────────────────────────── */
    .sb-section {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--r-md);
        overflow: hidden;
        box-shadow: var(--sh-xs);
    }

    .sb-section-header {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 11px 16px;
        cursor: pointer;
        user-select: none;
        background: var(--surface-2);
        border-bottom: 1px solid var(--border);
        transition: background 0.1s;
    }
    .sb-section-header:hover { background: #e9ecef; }

    .sb-section-toggle { font-size: 11px; color: var(--txt-4); }

    .sb-section-title {
        font-size: 13px;
        font-weight: 600;
        color: var(--txt-1);
    }

    .sb-section-sub {
        font-size: 12px;
        color: var(--txt-3);
    }

    /* ── Assignee Cards ──────────────────────────────────────────── */
    .sb-assignee-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 12px;
        padding: 16px;
    }

    .sb-assignee-card {
        border: 1px solid var(--border);
        border-radius: var(--r-md);
        padding: 14px 16px;
        background: var(--surface);
        transition: box-shadow 0.15s, border-color 0.15s;
    }
    .sb-assignee-card:hover {
        box-shadow: var(--sh-sm);
        border-color: #d1d5db;
    }

    .sb-ac-head {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 10px;
    }

    .sb-ac-avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 12px;
        font-weight: 700;
        flex-shrink: 0;
        letter-spacing: 0.5px;
    }

    .sb-ac-head-info { min-width: 0; }

    .sb-ac-name {
        font-size: 13px;
        font-weight: 600;
        color: var(--txt-1);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .sb-ac-pct-label {
        font-size: 11px;
        color: var(--txt-3);
        margin-top: 1px;
    }

    .sb-ac-progress {
        height: 4px;
        background: var(--border);
        border-radius: 2px;
        overflow: hidden;
        margin-bottom: 10px;
    }

    .sb-ac-progress-fill {
        height: 100%;
        background: var(--success);
        border-radius: 2px;
        transition: width 0.3s;
    }

    .sb-ac-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
        margin-bottom: 10px;
    }

    .ac-chip {
        display: inline-block;
        padding: 2px 7px;
        border-radius: 10px;
        font-size: 11px;
        font-weight: 600;
        white-space: nowrap;
    }
    .ac-chip-red   { background: #fee2e2; color: #b91c1c; }
    .ac-chip-amber { background: #fef3c7; color: #92400e; }
    .ac-chip-blue  { background: #dbeafe; color: #1e40af; }
    .ac-chip-green { background: #dcfce7; color: #15803d; }
    .ac-chip-gray  { background: #f3f4f6; color: #4b5563; }

    .sb-ac-time {
        display: flex;
        gap: 14px;
        font-size: 12px;
        color: var(--txt-2);
        font-weight: 600;
    }

    .sb-ac-time-lbl {
        font-size: 10px;
        font-weight: 600;
        color: var(--txt-4);
        text-transform: uppercase;
        letter-spacing: .05em;
        margin-right: 2px;
    }

    /* ── Main Table ──────────────────────────────────────────────── */
    .sb-table-wrap { overflow-x: auto; }

    .sb-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

    .sb-th {
        padding: 9px 10px;
        text-align: left;
        font-size: 10px;
        font-weight: 700;
        color: var(--txt-3);
        text-transform: uppercase;
        letter-spacing: .06em;
        background: var(--surface-2);
        border-bottom: 2px solid var(--border);
        white-space: nowrap;
    }

    .sb-th-pri      { width: 28px; text-align: center; }
    .sb-th-key      { width: 90px; }
    .sb-th-title    { min-width: 220px; max-width: 320px; }
    .sb-th-customer { width: 110px; }
    .sb-th-assignee { width: 120px; }
    .sb-th-labels   { width: 160px; }
    .sb-td-customer { font-size: 12px; color: var(--txt-2); white-space: nowrap; }
    .sb-th-status   { width: 110px; }
    .sb-th-due      { width: 130px; }
    .sb-th-forecast { width: 110px; }
    .sb-th-est      { width: 80px; text-align: right; }
    .sb-th-pct      { width: 90px; text-align: center; }
    .sb-th-activity { width: 130px; }
    .sb-th-expand   { width: 60px; text-align: center; }

    .sb-td {
        padding: 9px 10px;
        border-bottom: 1px solid var(--border);
        vertical-align: middle;
        color: var(--txt-2);
    }

    .sb-row:hover .sb-td { background: #f8fafc; }
    .sb-row-expanded .sb-td { background: #eff6ff; }

    .sb-td-key { font-family: monospace; font-size: 12px; }
    .sb-td-title { max-width: 320px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .sb-td-assignee { font-size: 12px; }
    .sb-td-labels   { font-size: 11px; }
    .sb-label-chip  { display: inline-block; padding: 1px 6px; margin: 1px 2px; border-radius: 10px; background: var(--surface-2); border: 1px solid var(--border); color: var(--txt-2); white-space: nowrap; }
    .sb-td-est { text-align: right; font-size: 12px; color: var(--txt-3); white-space: nowrap; }
    .sb-td-pct { text-align: center; }
    .sb-td-activity { font-size: 12px; color: var(--txt-2); white-space: nowrap; }
    .sb-td-stale { font-size: 12px; background: #fee2e2 !important; color: #991b1b; white-space: nowrap; }
    .sb-td-expand { text-align: center; }

    .sb-sprint-time { color: var(--primary); font-weight: 600; }

    .sb-key-link {
        color: var(--primary);
        text-decoration: none;
        font-weight: 600;
        font-size: 12px;
    }
    .sb-key-link:hover { text-decoration: underline; }

    .sb-never { color: var(--txt-4); font-style: italic; }
    .sb-no-due { color: var(--txt-4); }

    /* ── Priority dot ────────────────────────────────────────────── */
    .sb-td-pri { text-align: center; }

    .sb-pri-dot {
        display: inline-block;
        width: 10px;
        height: 10px;
        border-radius: 50%;
    }

    .pri-critical { background: #dc2626; }
    .pri-high     { background: #f97316; }
    .pri-medium   { background: #eab308; }
    .pri-low      { background: #22c55e; }
    .pri-lowest   { background: #94a3b8; }

    /* ── Due date cell ───────────────────────────────────────────── */
    .sb-due-date  { font-size: 12px; font-weight: 600; color: var(--txt-1); display: block; }
    .sb-due-delta { font-size: 11px; display: block; margin-top: 1px; }

    .sb-delta-red   { color: var(--danger); font-weight: 600; }
    .sb-delta-amber { color: var(--warning); font-weight: 600; }
    .sb-delta-green { color: var(--success); }

    .sb-due-overdue { background: #fff1f2 !important; }
    .sb-due-at-risk { background: #fffbeb !important; }

    /* ── Forecast badge ──────────────────────────────────────────── */
    .sb-forecast-badge {
        display: inline-block;
        padding: 2px 8px;
        border-radius: 10px;
        font-size: 11px;
        font-weight: 700;
        white-space: nowrap;
    }

    .fc-done    { background: #dcfce7; color: #15803d; }
    .fc-meet    { background: #dbeafe; color: #1d4ed8; }
    .fc-miss    { background: #fee2e2; color: #b91c1c; }
    .fc-blocked { background: #f3f4f6; color: #374151; }
    .fc-noest   { background: #fef9c3; color: #854d0e; }
    .fc-nodue   { background: #f3f4f6; color: #6b7280; }

    /* ── % Bar ───────────────────────────────────────────────────── */
    .sb-pct-bar-wrap {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .sb-pct-bar {
        display: inline-block;
        height: 5px;
        background: var(--primary);
        border-radius: 3px;
        min-width: 2px;
        max-width: 50px;
    }

    .sb-pct-label { font-size: 11px; color: var(--txt-3); }

    /* ── Expand button ───────────────────────────────────────────── */
    .sb-expand-btn { font-size: 11px; padding: 2px 6px; }

    /* ── Worklog section ─────────────────────────────────────────── */
    .sb-worklog-row .sb-worklog-cell {
        padding: 0;
        background: #f8fafc;
        border-bottom: 2px solid var(--primary);
    }

    /* ── Expanded row panels ─────────────────────────────────────── */
    .sb-expanded-panels {
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .sb-worklog-wrap { padding: 12px 24px 14px; }
    .sb-dev-panel { padding: 12px 24px 14px; border-top: 1px dashed var(--border); }

    .sb-worklog-header {
        font-size: 12px;
        font-weight: 600;
        color: var(--txt-2);
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .sb-wl-sprint-note {
        background: #dbeafe;
        color: #1d4ed8;
        padding: 2px 8px;
        border-radius: 10px;
        font-size: 11px;
        font-weight: 600;
    }

    .sb-wl-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 12px;
    }

    .sb-wl-table th {
        padding: 5px 10px;
        background: #e2e8f0;
        text-align: left;
        font-weight: 600;
        color: var(--txt-3);
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: .04em;
    }

    .sb-wl-table td {
        padding: 5px 10px;
        border-bottom: 1px solid #e2e8f0;
        color: var(--txt-2);
    }

    .sb-wl-in-sprint { background: #eff6ff; }
    .sb-wl-time  { font-weight: 600; white-space: nowrap; }
    .sb-wl-comment { max-width: 400px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: var(--txt-3); }
    .sb-wl-sprint-flag { text-align: center; color: var(--primary); font-weight: 700; }

    /* ── Dashboard Control ──────────────────────────────────────── */
    .sb-dash-kpis {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .sb-dash-kpi {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--r-md);
        padding: 12px 18px;
        flex: 1;
        min-width: 110px;
        box-shadow: var(--sh-xs);
    }

    .sb-dash-kpi-warn { border-color: #fbbf24; background: #fffbeb; }

    .sb-dash-kpi-val {
        font-size: 22px;
        font-weight: 700;
        color: var(--txt-1);
        line-height: 1.2;
    }

    .sb-dash-kpi-lbl {
        font-size: 11px;
        color: var(--txt-3);
        margin-top: 3px;
        font-weight: 500;
    }

    .sb-dash-legend {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 10px;
        padding: 8px 14px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--r-md);
    }

    .sb-dash-legend-title {
        font-size: 10px;
        font-weight: 700;
        color: var(--txt-4);
        text-transform: uppercase;
        letter-spacing: .06em;
        margin-right: 4px;
    }

    .sb-dash-legend-item {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 12px;
        color: var(--txt-2);
        font-weight: 500;
    }

    /* Swimlane */
    .sb-swimlane-outer {
        overflow-x: auto;
        padding-bottom: 6px;
    }

    .sb-swimlane-table {
        border-collapse: collapse;
        min-width: max-content;
    }

    .sb-sw-sticky-l {
        position: sticky;
        left: 0;
        z-index: 2;
        box-shadow: 2px 0 6px rgba(0,0,0,.07);
    }

    .sb-sw-info {
        min-width: 230px;
        max-width: 230px;
        padding: 6px 12px;
        border-right: 2px solid var(--border);
        vertical-align: middle;
        background: inherit;
    }

    .sb-swimlane-table thead .sb-sw-info {
        font-size: 10px;
        font-weight: 700;
        color: var(--txt-3);
        text-transform: uppercase;
        letter-spacing: .06em;
    }

    .sb-sw-bug-key { font-size: 12px; font-weight: 700; }
    .sb-sw-bug-key a { color: var(--primary); text-decoration: none; }
    .sb-sw-bug-key a:hover { text-decoration: underline; }

    .sb-sw-bug-sum {
        font-size: 11px;
        color: var(--txt-3);
        margin-top: 2px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 206px;
    }

    .sb-sw-day-th {
        min-width: 38px;
        width: 38px;
        text-align: center;
        padding: 4px 2px;
        border-right: 1px solid #efefef;
        cursor: pointer;
        user-select: none;
        transition: filter .1s;
        vertical-align: middle;
    }

    .sb-sw-day-th:hover { filter: brightness(.94); }

    .sb-sw-day-hdr {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 3px;
    }

    .sb-sw-day-name {
        font-size: 9px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .04em;
    }

    .sb-sw-day-num {
        font-size: 11px;
        font-weight: 700;
        color: var(--txt-2);
        width: 22px;
        height: 22px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
    }

    .sb-sw-today-num { background: var(--primary) !important; color: #fff !important; }

    .sb-sw-cell {
        min-width: 38px;
        width: 38px;
        text-align: center;
        padding: 3px 2px;
        border-right: 1px solid #f2f2f2;
        border-bottom: 1px solid #f8f8f8;
        vertical-align: middle;
        cursor: pointer;
        transition: filter .1s;
    }

    .sb-sw-cell:hover { filter: brightness(.93); }

    .sb-sw-row:hover .sb-sw-info { background: #f9fafb; }

    .sb-sw-end-th {
        min-width: 100px;
        padding: 5px 10px;
        border-left: 2px solid var(--border);
        vertical-align: middle;
        font-size: 10px;
        font-weight: 700;
        color: var(--txt-3);
        text-transform: uppercase;
        letter-spacing: .05em;
        white-space: nowrap;
    }

    .sb-sw-end-status { min-width: 120px; }

    .sb-sw-dot {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        color: #fff;
        font-size: 7.5px;
        font-weight: 800;
        cursor: default;
        flex-shrink: 0;
        margin: 1px;
        vertical-align: middle;
    }

    .sb-sw-dot-more {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background: #d1d5db;
        color: var(--txt-3);
        font-size: 8px;
        font-weight: 700;
        margin: 1px;
        vertical-align: middle;
    }

    /* Day detail panel */
    .sb-dash-day-panel {
        border: 1px solid #93c5fd;
        border-radius: 6px;
        margin: 10px 0 0;
        overflow: hidden;
    }

    .sb-dash-day-panel-hdr {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 9px 14px;
        background: #dbeafe;
        border-bottom: 1px solid #bfdbfe;
        flex-wrap: wrap;
    }

    .sb-dash-day-panel-title { font-weight: 700; font-size: 13px; color: var(--txt-1); }
    .sb-dash-day-panel-sub   { font-size: 12px; color: #1e40af; }

    /* Untouched banner */
    .sb-dash-untouched-banner {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 16px;
        background: #fffbeb;
        border: 1px solid #fbbf24;
        border-radius: var(--r-md);
        font-size: 13px;
        color: #92400e;
    }

    /* Contributor cards */
    .sb-dash-contrib-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
        gap: 12px;
        padding: 14px;
    }

    .sb-dash-contrib-card {
        background: var(--surface-2);
        border-radius: 8px;
        padding: 12px 14px;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .sb-dash-contrib-head { display: flex; align-items: center; gap: 10px; }

    .sb-dash-contrib-bugs {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
    }

    /* ── Development panel ───────────────────────────────────────── */
    .sb-dev-loading { font-size: 12px; color: var(--txt-3); display: flex; align-items: center; gap: 6px; padding: 4px 0; }
    .sb-dev-empty   { font-size: 12px; color: var(--txt-4); font-style: italic; padding: 4px 0; }

    .sb-dev-summary-row { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 10px; }
    .sb-dev-badge {
        display: inline-flex; align-items: center; gap: 4px;
        padding: 3px 9px; border-radius: 10px; font-size: 11px; font-weight: 600;
    }
    .sb-dev-badge-branch  { background: #f0fdf4; color: #15803d; border: 1px solid #bbf7d0; }
    .sb-dev-badge-commit  { background: #f5f3ff; color: #6d28d9; border: 1px solid #ddd6fe; }
    .sb-dev-badge-build-ok   { background: #f0fdf4; color: #15803d; border: 1px solid #bbf7d0; }
    .sb-dev-badge-build-fail { background: #fef2f2; color: #b91c1c; border: 1px solid #fecaca; }

    .sb-dev-table { margin-top: 2px; }
    .sb-dev-pr-status {
        display: inline-block; padding: 1px 7px; border-radius: 8px;
        font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .03em;
    }
    .sb-dev-pr-open    { background: #dbeafe; color: #1d4ed8; }
