@page "/support-bugs-slas"
@rendermode InteractiveServer
@using JiraReportingTool.Models
@using Microsoft.JSInterop
@inject IJiraService JiraService
@inject IConfiguration Config
@inject IJSRuntime JS
@implements IDisposable

<!-- ═══════════════════ HEADER ═══════════════════ -->
<div class="sb-root">

    <div class="sb-load-bar">
        <div class="sb-load-inner">
            <div class="sb-load-title-block">
                <div class="sb-load-title-row">
                    <span class="sb-load-title">Support Bugs · SLAs</span>
                </div>
                <span class="sb-load-sub">Priority list &amp; SLA compliance · live from Jira</span>
            </div>
        </div>
    </div>

    <!-- ═══════════════════ TABS ═══════════════════ -->
    <div class="sb-tabs">
        <button class="sb-tab @(_activeTab == "priority" ? "sb-tab-active" : "")" @onclick="ActivatePriorityTab">
            Priority
            @if (_masterLoaded && MasterTotalCount > 0) { <span class="sb-tab-badge">@MasterTotalCount</span> }
        </button>
        <button class="sb-tab @(_activeTab == "slas" ? "sb-tab-active" : "")" @onclick="SwitchToSlaTab">
            SLAs
        </button>
    </div>

    <!-- ═══════════════════ PRIORITY TAB — BUG MASTER DASHBOARD ═══════════════════ -->
    @if (_activeTab == "priority")
    {
    @if (_masterLoading)
    {
        <div class="sb-empty" style="padding:40px;font-size:14px">Loading Bug Master Dashboard…</div>
    }
    else if (!string.IsNullOrEmpty(_masterError))
    {
        <div class="sb-empty" style="padding:24px;color:var(--danger)">@_masterError</div>
    }
    else if (_masterLoaded)
    {
        <!-- KPI summary row -->
        <div class="sb-master-kpi-row">
            <div class="sb-master-kpi sb-master-kpi-p0">
                <div class="sb-master-kpi-label">🔴 Prio 0 — Overdue / Due Today</div>
                <div class="sb-master-kpi-count">@_prio0Bugs.Count</div>
            </div>
            <div class="sb-master-kpi sb-master-kpi-p1">
                <div class="sb-master-kpi-label">🟠 Prio 1 — Due in 3 Days</div>
                <div class="sb-master-kpi-count">@_prio1Bugs.Count</div>
            </div>
            <div class="sb-master-kpi sb-master-kpi-p2">
                <div class="sb-master-kpi-label">🔵 Prio 2 — Highest Priority</div>
                <div class="sb-master-kpi-count">@_prio2Bugs.Count</div>
            </div>
            <div class="sb-master-kpi sb-master-kpi-p3">
                <div class="sb-master-kpi-label">🟦 Prio 3 — High Priority</div>
                <div class="sb-master-kpi-count">@_prio3Bugs.Count</div>
            </div>
            <div class="sb-master-kpi sb-master-kpi-watch">
                <div class="sb-master-kpi-label">👁 Watchlist — Due in 7 Days</div>
                <div class="sb-master-kpi-count">@_watchlistBugs.Count</div>
            </div>
            <button class="btn small" style="align-self:center;margin-left:auto" @onclick="LoadMasterDashboardAsync">↻ Refresh</button>
        </div>

        <!-- Prio 0 -->
        <div class="sb-section sb-master-section sb-master-p0">
            <div class="sb-section-header" style="cursor:default">
                <span class="sb-master-badge sb-badge-p0">P0</span>
                <span class="sb-section-title">Overdue / Due Today</span>
                <span class="sb-section-sub">@_prio0Bugs.Count issue@(_prio0Bugs.Count == 1 ? "" : "s")</span>
            </div>
            <div class="sb-table-wrap">
                <table class="sb-table">
                    <thead><tr>
                        <th class="sb-th sb-th-pri sortable @PtSI("p0","pri")" @onclick='() => PtSort("p0","pri")' title="Priority">P</th>
                        <th class="sb-th sb-th-key sortable @PtSI("p0","key")" @onclick='() => PtSort("p0","key")'>Key</th>
                        <th class="sb-th sb-th-title sortable @PtSI("p0","title")" @onclick='() => PtSort("p0","title")'>Title</th>
                        <th class="sb-th sb-th-assignee sortable @PtSI("p0","assignee")" @onclick='() => PtSort("p0","assignee")'>Assignee</th>
                        <th class="sb-th sb-th-status sortable @PtSI("p0","status")" @onclick='() => PtSort("p0","status")'>Status</th>
                        <th class="sb-th sb-th-due sortable @PtSI("p0","due")" @onclick='() => PtSort("p0","due")'>Prio Date</th>
                        <th class="sb-th sb-th-est sortable @PtSI("p0","days")" @onclick='() => PtSort("p0","days")'>Days Open</th>
                        <th class="sb-th sb-th-est sortable @PtSI("p0","logged")" @onclick='() => PtSort("p0","logged")'>Logged</th>
                    </tr></thead>
                    <tbody>
                        @foreach (var bug in PtSorted(_prio0Bugs, "p0"))
                        {
                            var daysOpen = GetDaysOpen(bug);
                            <tr class="sb-row">
                                <td class="sb-td sb-td-pri"><span class="sb-pri-dot @GetPriorityClass(bug.Priority)" title="@bug.Priority"></span></td>
                                <td class="sb-td sb-td-key"><a class="sb-key-link" href="@_jiraBase/browse/@bug.Key" target="_blank" rel="noopener noreferrer">@bug.Key</a></td>
                                <td class="sb-td sb-td-title" title="@bug.Summary">@bug.Summary</td>
                                <td class="sb-td sb-td-assignee">@(bug.Assignee ?? "—")</td>
                                <td class="sb-td sb-td-status"><span class="rpt-status-chip @GetStatusClass(bug.Status)">@(bug.Status ?? "—")</span></td>
                                <td class="sb-td sb-td-due" style="color:var(--danger);font-weight:600">@FormatPrioDate(bug.PrioListDate)</td>
                                <td class="sb-td sb-td-est @(daysOpen > 30 ? "kpi-red" : daysOpen > 14 ? "kpi-amber" : "")">@daysOpen d</td>
                                <td class="sb-td sb-td-est">@FormatSeconds(bug.TimeSpentSeconds)</td>
                            </tr>
                        }
                        @if (_prio0Bugs.Count == 0) { <tr><td colspan="8" class="sb-empty">No issues.</td></tr> }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Prio 1 -->
        <div class="sb-section sb-master-section sb-master-p1">
            <div class="sb-section-header" style="cursor:default">
                <span class="sb-master-badge sb-badge-p1">P1</span>
                <span class="sb-section-title">Due in Next 3 Days</span>
                <span class="sb-section-sub">@_prio1Bugs.Count issue@(_prio1Bugs.Count == 1 ? "" : "s")</span>
            </div>
            <div class="sb-table-wrap">
                <table class="sb-table">
                    <thead><tr>
                        <th class="sb-th sb-th-pri sortable @PtSI("p1","pri")" @onclick='() => PtSort("p1","pri")' title="Priority">P</th>
                        <th class="sb-th sb-th-key sortable @PtSI("p1","key")" @onclick='() => PtSort("p1","key")'>Key</th>
                        <th class="sb-th sb-th-title sortable @PtSI("p1","title")" @onclick='() => PtSort("p1","title")'>Title</th>
                        <th class="sb-th sb-th-assignee sortable @PtSI("p1","assignee")" @onclick='() => PtSort("p1","assignee")'>Assignee</th>
                        <th class="sb-th sb-th-status sortable @PtSI("p1","status")" @onclick='() => PtSort("p1","status")'>Status</th>
                        <th class="sb-th sb-th-due sortable @PtSI("p1","due")" @onclick='() => PtSort("p1","due")'>Prio Date</th>
                        <th class="sb-th sb-th-est sortable @PtSI("p1","days")" @onclick='() => PtSort("p1","days")'>Days Open</th>
                        <th class="sb-th sb-th-est sortable @PtSI("p1","logged")" @onclick='() => PtSort("p1","logged")'>Logged</th>
                    </tr></thead>
                    <tbody>
                        @foreach (var bug in PtSorted(_prio1Bugs, "p1"))
                        {
                            var daysOpen = GetDaysOpen(bug);
                            <tr class="sb-row">
                                <td class="sb-td sb-td-pri"><span class="sb-pri-dot @GetPriorityClass(bug.Priority)" title="@bug.Priority"></span></td>
                                <td class="sb-td sb-td-key"><a class="sb-key-link" href="@_jiraBase/browse/@bug.Key" target="_blank" rel="noopener noreferrer">@bug.Key</a></td>
                                <td class="sb-td sb-td-title" title="@bug.Summary">@bug.Summary</td>
                                <td class="sb-td sb-td-assignee">@(bug.Assignee ?? "—")</td>
                                <td class="sb-td sb-td-status"><span class="rpt-status-chip @GetStatusClass(bug.Status)">@(bug.Status ?? "—")</span></td>
                                <td class="sb-td sb-td-due" style="color:var(--warning);font-weight:600">@FormatPrioDate(bug.PrioListDate)</td>
                                <td class="sb-td sb-td-est @(daysOpen > 30 ? "kpi-red" : daysOpen > 14 ? "kpi-amber" : "")">@daysOpen d</td>
                                <td class="sb-td sb-td-est">@FormatSeconds(bug.TimeSpentSeconds)</td>
                            </tr>
                        }
                        @if (_prio1Bugs.Count == 0) { <tr><td colspan="8" class="sb-empty">No issues.</td></tr> }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Prio 2 -->
        <div class="sb-section sb-master-section sb-master-p2">
            <div class="sb-section-header" style="cursor:default">
                <span class="sb-master-badge sb-badge-p2">P2</span>
                <span class="sb-section-title">Highest Priority Pro Bugs</span>
                <span class="sb-section-sub">@_prio2Bugs.Count issue@(_prio2Bugs.Count == 1 ? "" : "s") · Rentway Pro &amp; Integrations · Highest priority</span>
            </div>
            <div class="sb-table-wrap">
                <table class="sb-table">
                    <thead><tr>
                        <th class="sb-th sb-th-pri sortable @PtSI("p2","pri")" @onclick='() => PtSort("p2","pri")' title="Priority">P</th>
                        <th class="sb-th sb-th-key sortable @PtSI("p2","key")" @onclick='() => PtSort("p2","key")'>Key</th>
                        <th class="sb-th sb-th-title sortable @PtSI("p2","title")" @onclick='() => PtSort("p2","title")'>Title</th>
                        <th class="sb-th sb-th-customer sortable @PtSI("p2","customer")" @onclick='() => PtSort("p2","customer")'>Customer</th>
                        <th class="sb-th sb-th-assignee sortable @PtSI("p2","assignee")" @onclick='() => PtSort("p2","assignee")'>Assignee</th>
                        <th class="sb-th sb-th-status sortable @PtSI("p2","status")" @onclick='() => PtSort("p2","status")'>Status</th>
                        <th class="sb-th sb-th-est sortable @PtSI("p2","days")" @onclick='() => PtSort("p2","days")'>Days Open</th>
                        <th class="sb-th sb-th-est sortable @PtSI("p2","logged")" @onclick='() => PtSort("p2","logged")'>Logged</th>
                    </tr></thead>
                    <tbody>
                        @foreach (var bug in PtSorted(_prio2Bugs, "p2"))
                        {
                            var daysOpen = GetDaysOpen(bug);
                            <tr class="sb-row">
                                <td class="sb-td sb-td-pri"><span class="sb-pri-dot @GetPriorityClass(bug.Priority)" title="@bug.Priority"></span></td>
                                <td class="sb-td sb-td-key"><a class="sb-key-link" href="@_jiraBase/browse/@bug.Key" target="_blank" rel="noopener noreferrer">@bug.Key</a></td>
                                <td class="sb-td sb-td-title" title="@bug.Summary">@bug.Summary</td>
                                <td class="sb-td sb-td-customer">@(string.IsNullOrEmpty(bug.Customer) ? "—" : bug.Customer)</td>
                                <td class="sb-td sb-td-assignee">@(bug.Assignee ?? "—")</td>
                                <td class="sb-td sb-td-status"><span class="rpt-status-chip @GetStatusClass(bug.Status)">@(bug.Status ?? "—")</span></td>
                                <td class="sb-td sb-td-est @(daysOpen > 30 ? "kpi-red" : daysOpen > 14 ? "kpi-amber" : "")">@daysOpen d</td>
                                <td class="sb-td sb-td-est">@FormatSeconds(bug.TimeSpentSeconds)</td>
                            </tr>
                        }
                        @if (_prio2Bugs.Count == 0) { <tr><td colspan="8" class="sb-empty">No issues.</td></tr> }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Prio 3 -->
        <div class="sb-section sb-master-section sb-master-p3">
            <div class="sb-section-header" style="cursor:default">
                <span class="sb-master-badge sb-badge-p3">P3</span>
                <span class="sb-section-title">High Priority Pro Bugs</span>
                <span class="sb-section-sub">@_prio3Bugs.Count issue@(_prio3Bugs.Count == 1 ? "" : "s") · Rentway Pro &amp; Integrations · High priority</span>
            </div>
            <div class="sb-table-wrap">
                <table class="sb-table">
                    <thead><tr>
                        <th class="sb-th sb-th-pri sortable @PtSI("p3","pri")" @onclick='() => PtSort("p3","pri")' title="Priority">P</th>
                        <th class="sb-th sb-th-key sortable @PtSI("p3","key")" @onclick='() => PtSort("p3","key")'>Key</th>
                        <th class="sb-th sb-th-title sortable @PtSI("p3","title")" @onclick='() => PtSort("p3","title")'>Title</th>
                        <th class="sb-th sb-th-customer sortable @PtSI("p3","customer")" @onclick='() => PtSort("p3","customer")'>Customer</th>
                        <th class="sb-th sb-th-assignee sortable @PtSI("p3","assignee")" @onclick='() => PtSort("p3","assignee")'>Assignee</th>
                        <th class="sb-th sb-th-status sortable @PtSI("p3","status")" @onclick='() => PtSort("p3","status")'>Status</th>
                        <th class="sb-th sb-th-est sortable @PtSI("p3","days")" @onclick='() => PtSort("p3","days")'>Days Open</th>
                        <th class="sb-th sb-th-est sortable @PtSI("p3","logged")" @onclick='() => PtSort("p3","logged")'>Logged</th>
                    </tr></thead>
                    <tbody>
                        @foreach (var bug in PtSorted(_prio3Bugs, "p3"))
                        {
                            var daysOpen = GetDaysOpen(bug);
                            <tr class="sb-row">
                                <td class="sb-td sb-td-pri"><span class="sb-pri-dot @GetPriorityClass(bug.Priority)" title="@bug.Priority"></span></td>
                                <td class="sb-td sb-td-key"><a class="sb-key-link" href="@_jiraBase/browse/@bug.Key" target="_blank" rel="noopener noreferrer">@bug.Key</a></td>
                                <td class="sb-td sb-td-title" title="@bug.Summary">@bug.Summary</td>
                                <td class="sb-td sb-td-customer">@(string.IsNullOrEmpty(bug.Customer) ? "—" : bug.Customer)</td>
                                <td class="sb-td sb-td-assignee">@(bug.Assignee ?? "—")</td>
                                <td class="sb-td sb-td-status"><span class="rpt-status-chip @GetStatusClass(bug.Status)">@(bug.Status ?? "—")</span></td>
                                <td class="sb-td sb-td-est @(daysOpen > 30 ? "kpi-red" : daysOpen > 14 ? "kpi-amber" : "")">@daysOpen d</td>
                                <td class="sb-td sb-td-est">@FormatSeconds(bug.TimeSpentSeconds)</td>
                            </tr>
                        }
                        @if (_prio3Bugs.Count == 0) { <tr><td colspan="8" class="sb-empty">No issues.</td></tr> }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Watchlist -->
        <div class="sb-section sb-master-section sb-master-watch">
            <div class="sb-section-header" style="cursor:default">
                <span class="sb-master-badge sb-badge-watch">W</span>
                <span class="sb-section-title">Watchlist — Due in 4–7 Days</span>
                <span class="sb-section-sub">@_watchlistBugs.Count issue@(_watchlistBugs.Count == 1 ? "" : "s") · monitor closely</span>
            </div>
            <div class="sb-table-wrap">
                <table class="sb-table">
                    <thead><tr>
                        <th class="sb-th sb-th-pri sortable @PtSI("w","pri")" @onclick='() => PtSort("w","pri")' title="Priority">P</th>
                        <th class="sb-th sb-th-key sortable @PtSI("w","key")" @onclick='() => PtSort("w","key")'>Key</th>
                        <th class="sb-th sb-th-title sortable @PtSI("w","title")" @onclick='() => PtSort("w","title")'>Title</th>
                        <th class="sb-th sb-th-assignee sortable @PtSI("w","assignee")" @onclick='() => PtSort("w","assignee")'>Assignee</th>
                        <th class="sb-th sb-th-status sortable @PtSI("w","status")" @onclick='() => PtSort("w","status")'>Status</th>
                        <th class="sb-th sb-th-due sortable @PtSI("w","due")" @onclick='() => PtSort("w","due")'>Prio Date</th>
                        <th class="sb-th sb-th-est sortable @PtSI("w","days")" @onclick='() => PtSort("w","days")'>Days Open</th>
                        <th class="sb-th sb-th-est sortable @PtSI("w","logged")" @onclick='() => PtSort("w","logged")'>Logged</th>
                    </tr></thead>
                    <tbody>
                        @foreach (var bug in PtSorted(_watchlistBugs, "w"))
                        {
                            var daysOpen = GetDaysOpen(bug);
                            <tr class="sb-row">
                                <td class="sb-td sb-td-pri"><span class="sb-pri-dot @GetPriorityClass(bug.Priority)" title="@bug.Priority"></span></td>
                                <td class="sb-td sb-td-key"><a class="sb-key-link" href="@_jiraBase/browse/@bug.Key" target="_blank" rel="noopener noreferrer">@bug.Key</a></td>
                                <td class="sb-td sb-td-title" title="@bug.Summary">@bug.Summary</td>
                                <td class="sb-td sb-td-assignee">@(bug.Assignee ?? "—")</td>
                                <td class="sb-td sb-td-status"><span class="rpt-status-chip @GetStatusClass(bug.Status)">@(bug.Status ?? "—")</span></td>
                                <td class="sb-td sb-td-due">@FormatPrioDate(bug.PrioListDate)</td>
                                <td class="sb-td sb-td-est @(daysOpen > 30 ? "kpi-red" : daysOpen > 14 ? "kpi-amber" : "")">@daysOpen d</td>
                                <td class="sb-td sb-td-est">@FormatSeconds(bug.TimeSpentSeconds)</td>
                            </tr>
                        }
                        @if (_watchlistBugs.Count == 0) { <tr><td colspan="8" class="sb-empty">No issues.</td></tr> }
                    </tbody>
                </table>
            </div>
        </div>
    }
    } <!-- end priority tab -->

    <!-- ═══════════════════ SLAs TAB ═══════════════════ -->
    @if (_activeTab == "slas")
    {
        if (_slaLoading)
        {
            <div class="sb-section"><div class="sb-empty" style="padding:48px;text-align:center">Loading SLA data…</div></div>
        }
        else if (!string.IsNullOrEmpty(_slaError))
        {
            <div class="sb-section"><div class="sb-empty" style="padding:48px;text-align:center;color:var(--danger)">@_slaError</div></div>
        }
        else
        {
            <div class="sb-sla-toolbar">
                <span class="sb-section-sub">SLA thresholds — P2: 24h · P3: 72h · P4: 2 weeks · P5: 4 weeks · all customers &amp; products · last 3 weeks · click a bar to list tickets</span>
                <button class="btn small" style="margin-left:auto" @onclick="LoadSlaDashboardAsync">↻ Refresh</button>
            </div>

            @foreach (var tier in SlaTiers)
            {
                var tierBugs = SlaBugsFor(tier.Id);
                <div class="sb-section sb-sla-tier">
                    <div class="sb-sla-tier-head">
                        <span class="sb-sla-tier-badge sb-sla-badge-@tier.Id.ToLowerInvariant()">@tier.Num</span>
                        <div class="sb-sla-tier-titles">
                            <span class="sb-sla-tier-title">@tier.Title</span>
                            <span class="sb-sla-tier-sub">@tier.Sub · @tierBugs.Count open now</span>
                        </div>
                        <div class="sb-sla-filters">
                            <span class="sb-sla-filters-label">Open in Jira</span>
                            <a class="sb-sla-filter-link" href="@SlaJiraUrl(SlaOutsideJql(tier))" target="_blank" rel="noopener noreferrer" title="@SlaOutsideJql(tier)">Outside SLA ↗</a>
                            <a class="sb-sla-filter-link" href="@SlaJiraUrl(SlaInsideJql(tier))" target="_blank" rel="noopener noreferrer" title="@SlaInsideJql(tier)">Inside SLA ↗</a>
                            <a class="sb-sla-filter-link" href="@SlaJiraUrl(tier.Jql)" target="_blank" rel="noopener noreferrer" title="@tier.Jql">All open ↗</a>
                        </div>
                    </div>
                    <div class="sb-sla-canvas-wrap">
                        <canvas id="sb-sla-chart-@tier.Id"></canvas>
                    </div>

                    @if (_slaDrillTier == tier.Id && _slaDrillBucket >= 0)
                    {
                        var drill      = SlaDrillBugs(tier, _slaDrillWeek, _slaDrillBucket);
                        var byProduct  = drill.GroupBy(b => string.IsNullOrEmpty(b.Product)  ? "—" : b.Product)
                                              .OrderByDescending(g => g.Count()).ToList();
                        var byCustomer = drill.GroupBy(b => string.IsNullOrEmpty(b.Customer) ? "—" : b.Customer)
                                              .OrderByDescending(g => g.Count()).ToList();
                        <div class="sb-sla-drill">
                            <div class="sb-sla-drill-head">
                                <span class="sb-sla-drill-title">
                                    Drill-down · @tier.Num · @SlaBucketLabel(_slaDrillBucket) · @SlaWeekLabel(_slaDrillWeek)
                                    · <strong>@drill.Count ticket@(drill.Count == 1 ? "" : "s")</strong>
                                </span>
                                <button class="sb-sla-drill-close" title="Close" @onclick="ClearSlaDrill">✕</button>
                            </div>

                            <div class="sb-sla-chips-row">
                                <span class="sb-sla-chips-label">By product</span>
                                @foreach (var g in byProduct)
                                {
                                    <span class="sb-sla-chip">@g.Key: <strong>@g.Count()</strong></span>
                                }
                            </div>
                            <div class="sb-sla-chips-row">
                                <span class="sb-sla-chips-label">By customer</span>
                                @foreach (var g in byCustomer)
                                {
                                    <span class="sb-sla-chip">@g.Key: <strong>@g.Count()</strong></span>
                                }
                            </div>

                            <div class="sb-table-wrap">
                                <table class="sb-table">
                                    <thead><tr>
                                        <th class="sb-th sb-th-key">Key</th>
                                        <th class="sb-th sb-th-title">Summary</th>
                                        <th class="sb-th sb-th-status">Status</th>
                                        <th class="sb-th sb-th-assignee">Assignee</th>
                                        <th class="sb-th">Customer</th>
                                        <th class="sb-th">Product</th>
                                        <th class="sb-th sb-th-est">Age (d)</th>
                                    </tr></thead>
                                    <tbody>
                                        @foreach (var bug in drill)
                                        {
                                            <tr class="sb-row">
                                                <td class="sb-td sb-td-key"><a class="sb-key-link" href="@_jiraBase/browse/@bug.Key" target="_blank" rel="noopener noreferrer">@bug.Key</a></td>
                                                <td class="sb-td sb-td-title" title="@bug.Summary">@bug.Summary</td>
                                                <td class="sb-td sb-td-status"><span class="rpt-status-chip @GetStatusClass(bug.Status)">@(bug.Status ?? "—")</span></td>
                                                <td class="sb-td sb-td-assignee">@(bug.Assignee ?? "—")</td>
                                                <td class="sb-td">@(string.IsNullOrEmpty(bug.Customer) ? "—" : bug.Customer)</td>
                                                <td class="sb-td">@(string.IsNullOrEmpty(bug.Product) ? "—" : bug.Product)</td>
                                                <td class="sb-td sb-td-est">@GetDaysOpen(bug)</td>
                                            </tr>
                                        }
                                        @if (drill.Count == 0) { <tr><td colspan="7" class="sb-empty">No tickets in this bucket.</td></tr> }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }
                </div>
            }
        }
