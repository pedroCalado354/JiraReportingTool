    .qm-page-subtitle { font-size: 14px; color: #6b7280; margin: 0; }

    /* ─── Cards ─────────────────────────────────────────────────────────────── */
    .qm-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
