@page "/quality-metrics"
@rendermode InteractiveServer
@inject IJiraService JiraService
@using JiraReportingTool.Models

<PageTitle>Quality Metrics</PageTitle>

<div class="qm-root">

    <!-- ── Page header ───────────────────────────────────────────────────────── -->
    <div class="qm-page-header">
        <div>
            <h1 class="qm-page-title">Quality Metrics</h1>
            <p class="qm-page-subtitle">Bug rates · fix times · effort distribution · team health</p>
        </div>
    </div>

    <!-- ── Load form ─────────────────────────────────────────────────────────── -->
    <div class="qm-card qm-load-card">
        <div class="qm-load-row">
            <div class="qm-field-group">
                <label class="qm-label">Jira Saved Filter</label>
                <div class="qm-input-row">
                    <select class="qm-select qm-select-wide"
                            @bind="SelectedFilterId"
                            disabled="@(FiltersLoading || !string.IsNullOrEmpty(SprintId))">
                        <option value="">— select a filter —</option>
                        @foreach (var f in MyFilters)
                        {
                            <option value="@f.Id" title="@f.Jql">@f.Name</option>
                        }
                    </select>
                    @if (FiltersLoading) { <span class="qm-spinner"></span> }
                </div>
                @if (!string.IsNullOrEmpty(SelectedFilterJql))
                {
                    <div class="qm-jql-hint" title="@SelectedFilterJql">JQL: @SelectedFilterJql</div>
                }
            </div>

            <div class="qm-or-divider">or</div>

            <div class="qm-field-group">
                <label class="qm-label">Sprint ID</label>
                <input class="qm-input" placeholder="e.g. 6690"
                       @bind="SprintId" @onkeyup="HandleKeyUp"
                       disabled="@(!string.IsNullOrEmpty(SelectedFilterId))" />
            </div>

            <button class="qm-btn-primary" @onclick="LoadData"
                    disabled="@(IsLoading || (string.IsNullOrEmpty(SprintId) && string.IsNullOrEmpty(SelectedFilterId)))">
                @if (IsLoading) { <span class="qm-spinner qm-spinner-sm"></span> }
                Load Data
            </button>
        </div>
    </div>

    @if (ErrorMessage != null)
    {
        <div class="qm-alert">@ErrorMessage</div>
    }

    @if (EpicLoading)
    {
        <div class="qm-loading-row">
            <span class="qm-spinner"></span>
            Loading all issues for <strong>@DrillEpicKey</strong> across all sprints…
        </div>
    }

    @if (SprintData != null)
    {
        <!-- ── Scope breadcrumb ───────────────────────────────────────────────── -->
        @if (DrillEpicKey != null)
        {
            <div class="qm-breadcrumb">
                <button class="qm-btn-back" @onclick="BackToSprint">← Back to Sprint</button>
                <span class="qm-breadcrumb-sep">/</span>
                <span class="qm-breadcrumb-current">@(string.IsNullOrEmpty(DrillEpicName) ? DrillEpicKey : DrillEpicName)</span>
                <span class="qm-chip qm-chip-gray">All issues · all sprints</span>
            </div>
        }
        else if (!string.IsNullOrEmpty(SprintData.SprintName))
        {
            <div class="qm-sprint-label">
                Sprint: <strong>@SprintData.SprintName</strong>
                @if (SprintData.StartDate.HasValue && SprintData.EndDate.HasValue)
                {
                    <span class="qm-sprint-dates">
                        @SprintData.StartDate.Value.ToString("dd MMM") → @SprintData.EndDate.Value.ToString("dd MMM yyyy")
                    </span>
                }
            </div>
        }

        <!-- ── Epic cards ─────────────────────────────────────────────────────── -->
        @if (DrillEpicKey == null && SprintEpics.Any())
        {
            <div class="qm-section-label">Epics in Sprint — click to explore all epic issues</div>
            <div class="qm-epic-grid">
                @foreach (var epic in SprintEpics)
                {
                    var bugRate  = EpicBugRate(epic);
                    var bugCount = EpicBugCount(epic);
                    <div class="qm-epic-card @(bugRate > 50 ? "qm-epic--danger" : bugRate > 25 ? "qm-epic--warn" : "qm-epic--ok")"
                         @onclick="() => DrillIntoEpic(epic)">
                        <div class="qm-epic-top">
                            <span class="qm-epic-name" title="@epic.DisplayName">@epic.DisplayName</span>
                            <span class="qm-chip @(bugRate > 50 ? "qm-chip-red" : bugRate > 25 ? "qm-chip-orange" : "qm-chip-green")">
                                @bugRate.ToString("0")% bugs
                            </span>
                        </div>
                        <div class="qm-epic-key">@epic.Key</div>
                        <div class="qm-epic-stats">
                            <span>@epic.TotalIssues tasks</span>
                            @if (bugCount > 0)
                            { <span class="qm-epic-bug-count">@bugCount bug@(bugCount != 1 ? "s" : "")</span> }
                            else
                            { <span class="qm-epic-ok-text">✓ no bugs</span> }
                        </div>
                        <div class="qm-epic-cta">Explore all issues →</div>
                    </div>
                }
            </div>
        }

        @if (DrillEpicKey == null || (!EpicLoading && EpicAllIssues != null))
        {
            <!-- ── Filter bar ──────────────────────────────────────────────────────── -->
            <div class="qm-filter-bar">
                <div class="qm-filter-controls">
                    <label class="qm-label">Assignee</label>
                    <input class="qm-input qm-input-sm" placeholder="Search…"
                           @bind="AssigneeSearch" @bind:event="oninput" />
                    <select class="qm-select" @bind="FilterAssignee" @bind:after="StateHasChanged">
                        <option value="">All members</option>
                        @foreach (var a in AssigneeOptions)
                        { <option value="@a">@a</option> }
                    </select>
                    @if (!string.IsNullOrEmpty(FilterAssignee))
                    {
                        <button class="qm-btn-ghost" @onclick="ClearFilters">✕ Clear</button>
                    }
                </div>
                <span class="qm-filter-count">
                    @ActiveFilteredIssues.Count of @(ActiveReport?.TotalIssues ?? 0) issues
                </span>
            </div>

            <!-- ── Quality Health Banner ──────────────────────────────────────────── -->
            <div class="qm-health-banner qm-health-@QualityBand">
                <div class="qm-health-score">
                    <div class="qm-health-number">@QualityScore</div>
                    <div class="qm-health-score-label">Quality Score</div>
                </div>
                <div class="qm-health-center">
                    <div class="qm-health-track">
                        <div class="qm-health-fill" style="width:@QualityScore%"></div>
                    </div>
                    <div class="qm-health-desc">@QualityBandLabel</div>
                </div>
                <div class="qm-health-components">
                    <div class="qm-health-comp">
                        <span class="qm-hc-label">Bug Rate</span>
                        <span class="qm-hc-val @BugRateClass(OverallBugRate)">@OverallBugRate.ToString("0.0")%</span>
                    </div>
                    <div class="qm-health-comp">
                        <span class="qm-hc-label">Completion</span>
                        <span class="qm-hc-val @(CompletionRate > 75 ? "qm-green" : CompletionRate > 40 ? "qm-orange" : "qm-red")">
                            @CompletionRate.ToString("0.0")%
                        </span>
                    </div>
                    <div class="qm-health-comp">
                        <span class="qm-hc-label">Effort on Bugs</span>
                        <span class="qm-hc-val @(BugFixEffortRatio < 0 ? "" : BugFixEffortRatio > 40 ? "qm-red" : BugFixEffortRatio > 20 ? "qm-orange" : "qm-green")">
                            @(BugFixEffortRatio < 0 ? "N/A" : BugFixEffortRatio.ToString("0.0") + "%")
                        </span>
                    </div>
                </div>
            </div>

            <!-- ── Core KPIs ──────────────────────────────────────────────────────── -->
            <div class="qm-kpi-grid">
                <div class="qm-kpi">
                    <div class="qm-kpi-value">@ActiveFilteredIssues.Count</div>
                    <div class="qm-kpi-label">Total Issues</div>
                    <div class="qm-kpi-sub">@(ActiveReport?.InProgressCount ?? 0) in progress</div>
                </div>
                <div class="qm-kpi">
                    <div class="qm-kpi-value @(CompletionRate > 75 ? "qm-green" : CompletionRate > 40 ? "qm-orange" : "qm-red")">
                        @CompletionRate.ToString("0.0")%
                    </div>
                    <div class="qm-kpi-label">Completion Rate</div>
                    <div class="qm-kpi-bar-track">
                        <div class="qm-kpi-bar-fill @(CompletionRate > 75 ? "qm-fill-green" : CompletionRate > 40 ? "qm-fill-orange" : "qm-fill-red")"
                             style="width:@Math.Min((int)CompletionRate,100)%"></div>
                    </div>
                    <div class="qm-kpi-sub">@(ActiveFilteredIssues.Count(i => i.StatusCategoryKey == "done")) of @ActiveFilteredIssues.Count done</div>
                </div>
                <div class="qm-kpi">
                    <div class="qm-kpi-value @(ActiveBugCount == 0 ? "qm-green" : "qm-red")">@ActiveBugCount</div>
                    <div class="qm-kpi-label">Total Bugs</div>
                    @if (CriticalHighOpenBugs > 0)
                    {
                        <div class="qm-kpi-alert">⚠ @CriticalHighOpenBugs critical/high open</div>
                    }
                    else
                    {
                        <div class="qm-kpi-sub">@ResolvedBugsWithTime.Count resolved</div>
                    }
                </div>
                <div class="qm-kpi">
                    <div class="qm-kpi-value @BugRateClass(OverallBugRate)">@OverallBugRate.ToString("0.0")%</div>
                    <div class="qm-kpi-label">Bug Rate</div>
                    <div class="qm-kpi-bar-track">
                        <div class="qm-kpi-bar-fill @(OverallBugRate > 50 ? "qm-fill-red" : OverallBugRate > 25 ? "qm-fill-orange" : "qm-fill-green")"
                             style="width:@Math.Min((int)OverallBugRate,100)%"></div>
                    </div>
                    @if (HighBugRateCount > 0)
                    {
                        <div class="qm-kpi-alert">@HighBugRateCount member@(HighBugRateCount != 1 ? "s" : "") >50%</div>
                    }
                </div>
                <div class="qm-kpi">
                    <div class="qm-kpi-value @FixTimeClass(AvgFixTimeHours)">
                        @(AvgFixTimeHours < 0 ? "N/A" : FormatFixTime(AvgFixTimeHours))
                    </div>
                    <div class="qm-kpi-label">Avg Bug Fix Time</div>
                    <div class="qm-kpi-sub">
                        @(ResolvedBugsWithTime.Count > 0 ? $"from {ResolvedBugsWithTime.Count} resolved" : "no resolved bugs")
                    </div>
                </div>
                @if (HasSP)
                {
                    <div class="qm-kpi">
                        <div class="qm-kpi-value">
                            @DoneSP <span class="qm-kpi-of">/ @TotalSP SP</span>
                        </div>
                        <div class="qm-kpi-label">Story Points Done</div>
                        <div class="qm-kpi-bar-track">
                            <div class="qm-kpi-bar-fill qm-fill-blue"
                                 style="width:@(TotalSP == 0 ? 0 : Math.Min(DoneSP * 100 / TotalSP, 100))%"></div>
                        </div>
                        <div class="qm-kpi-sub">@(TotalSP == 0 ? "0" : (DoneSP * 100 / TotalSP).ToString())% velocity</div>
                    </div>
                }
            </div>

            <!-- ── Effort cards ───────────────────────────────────────────────────── -->
            <div class="qm-effort-grid">
                <div class="qm-effort qm-effort-bugs">
                    <div class="qm-effort-value">@FormatHours(BugFixHours)</div>
                    <div class="qm-effort-label">Time on Bugs</div>
                    <div class="qm-effort-sub">@ActiveFilteredIssues.Count(IsBug) bug issues</div>
                </div>
                <div class="qm-effort qm-effort-feat">
                    <div class="qm-effort-value">@FormatHours(FeatureDevHours)</div>
                    <div class="qm-effort-label">Time on Features</div>
                    <div class="qm-effort-sub">@ActiveFilteredIssues.Count(IsFeatureWork) feature issues</div>
                </div>
                <div class="qm-effort">
                    <div class="qm-effort-value @(BugFixEffortRatio < 0 ? "" : BugFixEffortRatio > 40 ? "qm-red" : BugFixEffortRatio > 20 ? "qm-orange" : "qm-green")">
                        @(BugFixEffortRatio < 0 ? "N/A" : BugFixEffortRatio.ToString("0.0") + "%")
                    </div>
                    <div class="qm-effort-label">Bug Effort Ratio</div>
                    <div class="qm-effort-sub">Bug / (Bug + Feature) hrs</div>
                    <div class="qm-kpi-bar-track" style="margin-top:8px">
                        <div class="qm-kpi-bar-fill @(BugFixEffortRatio > 40 ? "qm-fill-red" : BugFixEffortRatio > 20 ? "qm-fill-orange" : "qm-fill-green")"
                             style="width:@(BugFixEffortRatio < 0 ? 0 : Math.Min((int)BugFixEffortRatio, 100))%"></div>
                    </div>
                </div>
                <div class="qm-effort">
                    <div class="qm-effort-value @(BugOverheadPct < 0 ? "" : BugOverheadPct > 50 ? "qm-red" : BugOverheadPct > 25 ? "qm-orange" : "qm-green")">
                        @(BugOverheadPct < 0 ? "N/A" : BugOverheadPct.ToString("0.0") + "%")
                    </div>
                    <div class="qm-effort-label">Bug Overhead</div>
                    <div class="qm-effort-sub">Bug hrs / Feature hrs</div>
                    <div class="qm-kpi-bar-track" style="margin-top:8px">
                        <div class="qm-kpi-bar-fill @(BugOverheadPct > 50 ? "qm-fill-red" : BugOverheadPct > 25 ? "qm-fill-orange" : "qm-fill-green")"
                             style="width:@(BugOverheadPct < 0 ? 0 : Math.Min((int)BugOverheadPct, 100))%"></div>
                    </div>
                </div>
            </div>

            <!-- ── Risk signals ───────────────────────────────────────────────────── -->
            @if (CriticalHighOpenBugs > 0 || StaleBugs.Any() || UnassignedCount > 0 || UnestimatedCount > 0)
            {
                <div class="qm-section-label">Risk Signals</div>
                <div class="qm-risk-grid">
                    @if (CriticalHighOpenBugs > 0)
                    {
                        <div class="qm-risk qm-risk-red">
                            <div class="qm-risk-icon">🔴</div>
                            <div class="qm-risk-value">@CriticalHighOpenBugs</div>
                            <div class="qm-risk-label">Critical / High Bugs Open</div>
                            <div class="qm-risk-sub">Needs immediate attention</div>
                        </div>
                    }
                    @if (StaleBugs.Any())
                    {
                        <div class="qm-risk qm-risk-orange">
                            <div class="qm-risk-icon">⏱</div>
                            <div class="qm-risk-value">@StaleBugs.Count</div>
                            <div class="qm-risk-label">Stale Open Bugs</div>
                            <div class="qm-risk-sub">No activity in 5+ days</div>
                        </div>
                    }
                    @if (UnassignedCount > 0)
                    {
                        <div class="qm-risk qm-risk-yellow">
                            <div class="qm-risk-icon">👤</div>
                            <div class="qm-risk-value">@UnassignedCount</div>
                            <div class="qm-risk-label">Unassigned Issues</div>
                            <div class="qm-risk-sub">No owner assigned</div>
                        </div>
                    }
                    @if (UnestimatedCount > 0)
                    {
                        <div class="qm-risk qm-risk-yellow">
                            <div class="qm-risk-icon">📐</div>
                            <div class="qm-risk-value">@UnestimatedCount</div>
                            <div class="qm-risk-label">Unestimated Issues</div>
                            <div class="qm-risk-sub">No story points or estimate</div>
                        </div>
                    }
                </div>
            }

            <!-- ── Bug Priority Breakdown ──────────────────────────────────────────── -->
            @if (BugsByPriority.Any())
            {
                <div class="qm-section-label">Bug Priority Breakdown</div>
                <div class="qm-card qm-priority-card">
                    @foreach (var p in BugsByPriority)
                    {
                        var total = p.Open + p.InProgress + p.Resolved;
                        <div class="qm-priority-row">
                            <div class="qm-priority-name">
                                <span class="qm-dot @PriorityDotClass(p.Priority)"></span>
                                @p.Priority
                            </div>
                            <div class="qm-priority-bar-wrap">
                                @if (total > 0)
                                {
                                    <div class="qm-priority-bar">
                                        @if (p.Open > 0)       { <div class="qm-ps qm-ps-open"   style="width:@(p.Open * 100 / total)%"       title="Open: @p.Open"></div> }
                                        @if (p.InProgress > 0) { <div class="qm-ps qm-ps-inprog" style="width:@(p.InProgress * 100 / total)%" title="In Progress: @p.InProgress"></div> }
                                        @if (p.Resolved > 0)   { <div class="qm-ps qm-ps-done"   style="width:@(p.Resolved * 100 / total)%"   title="Resolved: @p.Resolved"></div> }
                                    </div>
                                }
                            </div>
                            <div class="qm-priority-counts">
                                <span class="qm-pc open">@p.Open open</span>
                                @if (p.InProgress > 0) { <span class="qm-pc inprog">@p.InProgress in progress</span> }
                                <span class="qm-pc done">@p.Resolved done</span>
                            </div>
                        </div>
                    }
                    <div class="qm-priority-legend">
                        <span class="qm-legend-dot qm-ps-open"></span> Open &nbsp;
                        <span class="qm-legend-dot qm-ps-inprog"></span> In Progress &nbsp;
                        <span class="qm-legend-dot qm-ps-done"></span> Resolved
                    </div>
                </div>
            }

            <!-- ── Bug Rate by Assignee ────────────────────────────────────────────── -->
            <div class="qm-section-label">Bug Rate by Assignee</div>
            <div class="qm-card">
                <div class="qm-table-wrap">
                    <table class="qm-table">
                        <thead>
                            <tr>
                                <th>Assignee</th>
                                <th class="tc">Issues</th>
                                <th class="tc">Bugs</th>
                                <th class="tc">Bug Rate</th>
                                <th class="tc">Avg Fix Time</th>
                                <th class="tc">Stale Bugs</th>
                                <th style="width:130px">Rate Bar</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var m in AssigneeBugRates)
                            {
                                var stale = ActiveBugs.Count(b => b.Assignee == m.Assignee && b.StatusCategoryKey != "done" && b.DaysSinceLastWorklog >= 5);
                                <tr>
                                    <td class="qm-td-name">@m.Assignee</td>
                                    <td class="tc">@m.TotalTasks</td>
                                    <td class="tc @(m.BugCount > 0 ? "qm-red qm-bold" : "qm-muted")">@m.BugCount</td>
                                    <td class="tc">
                                        <span class="qm-chip @(m.BugRate > 50 ? "qm-chip-red" : m.BugRate > 25 ? "qm-chip-orange" : "qm-chip-green")">
                                            @m.BugRate.ToString("0.0")%
                                        </span>
                                    </td>
                                    <td class="tc qm-muted">@(m.AvgFixHours < 0 ? "—" : FormatFixTime(m.AvgFixHours))</td>
                                    <td class="tc @(stale > 0 ? "qm-orange qm-bold" : "qm-muted")">@(stale > 0 ? stale.ToString() : "—")</td>
                                    <td>
                                        <div class="qm-table-bar">
                                            <div style="width:@Math.Min((int)m.BugRate,100)%;height:100%;border-radius:3px"
                                                 class="@(m.BugRate > 50 ? "qm-fill-red" : m.BugRate > 25 ? "qm-fill-orange" : "qm-fill-green")"></div>
                                        </div>
                                    </td>
                                </tr>
                            }
                            @if (!AssigneeBugRates.Any())
                            {
                                <tr><td colspan="7" class="qm-empty-row">No issues match current filters.</td></tr>
                            }
                        </tbody>
                        @if (AssigneeBugRates.Count > 1)
                        {
                            <tfoot>
                                <tr class="qm-tfoot">
                                    <td class="qm-td-name">Total</td>
                                    <td class="tc">@ActiveFilteredIssues.Count</td>
                                    <td class="tc qm-red qm-bold">@ActiveBugCount</td>
                                    <td class="tc">
                                        <span class="qm-chip @(OverallBugRate > 50 ? "qm-chip-red" : OverallBugRate > 25 ? "qm-chip-orange" : "qm-chip-green")">
                                            @OverallBugRate.ToString("0.0")%
                                        </span>
                                    </td>
                                    <td class="tc qm-muted">@(AvgFixTimeHours < 0 ? "—" : FormatFixTime(AvgFixTimeHours))</td>
                                    <td class="tc qm-muted">@(StaleBugs.Count > 0 ? StaleBugs.Count.ToString() : "—")</td>
                                    <td></td>
                                </tr>
                            </tfoot>
                        }
                    </table>
                </div>
            </div>

            <!-- ── Open Bug Age Analysis ───────────────────────────────────────────── -->
            @if (OpenBugAges.Any())
            {
                <div class="qm-section-label">
                    Open Bug Age
                    <span class="qm-section-chip qm-chip-red">@OpenBugAges.Count open</span>
                </div>
                <div class="qm-card">
                    <div class="qm-table-wrap">
                        <table class="qm-table">
                            <thead>
                                <tr>
                                    <th style="width:100px">Key</th>
                                    <th>Summary</th>
                                    <th style="width:80px">Priority</th>
                                    <th style="width:130px">Assignee</th>
                                    <th class="tc" style="width:90px">Age</th>
                                    <th style="width:110px">Status</th>
                                    <th class="tc" style="width:100px">Last Activity</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var (bug, age) in OpenBugAges)
                                {
                                    <tr>
                                        <td class="qm-td-key qm-red">@bug.Key</td>
                                        <td>@bug.Summary</td>
                                        <td><span class="qm-chip @PriorityChipClass(bug.Priority)">@bug.Priority</span></td>
                                        <td class="qm-td-nowrap">@bug.Assignee</td>
                                        <td class="tc">
                                            <span class="qm-chip @(age > 14 ? "qm-chip-red" : age > 7 ? "qm-chip-orange" : "qm-chip-gray")">
                                                @age d
                                            </span>
                                        </td>
                                        <td><span class="qm-chip @StatusChipClass(bug.StatusCategoryKey)">@bug.Status</span></td>
                                        <td class="tc qm-muted">
                                            @(bug.DaysSinceLastWorklog >= 999 ? "Never" : bug.DaysSinceLastWorklog + "d ago")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            <!-- ── Resolved Bugs Fix Time ──────────────────────────────────────────── -->
            @if (ResolvedBugsWithTime.Any())
            {
                <div class="qm-section-label">
                    Bug Fix Time — Resolved
                    <span class="qm-section-chip qm-chip-green">@ResolvedBugsWithTime.Count resolved</span>
                </div>
                <div class="qm-card">
                    <div class="qm-table-wrap">
                        <table class="qm-table">
                            <thead>
                                <tr>
                                    <th style="width:100px">Key</th>
                                    <th>Summary</th>
                                    <th style="width:80px">Priority</th>
                                    <th style="width:130px">Assignee</th>
                                    <th style="width:110px">Reported</th>
                                    <th style="width:110px">Resolved</th>
                                    <th class="tc" style="width:90px">Fix Time</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var (bug, hours) in ResolvedBugsWithTime)
                                {
                                    <tr>
                                        <td class="qm-td-key qm-green">@bug.Key</td>
                                        <td>@bug.Summary</td>
                                        <td><span class="qm-chip @PriorityChipClass(bug.Priority)">@bug.Priority</span></td>
                                        <td class="qm-td-nowrap">@bug.Assignee</td>
                                        <td class="qm-td-nowrap qm-muted">@(bug.Created.HasValue ? bug.Created.Value.ToString("dd MMM yy") : "—")</td>
                                        <td class="qm-td-nowrap qm-muted">@(bug.ResolutionDate.HasValue ? bug.ResolutionDate.Value.ToString("dd MMM yy") : "—")</td>
                                        <td class="tc">
                                            <span class="qm-chip @FixTimeChipClass(hours)">@FormatFixTime(hours)</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            <!-- ── All Bug Issues ──────────────────────────────────────────────────── -->
            <div class="qm-section-label">
                All Bug Issues
                <span class="qm-section-chip qm-chip-red">@ActiveBugs.Count</span>
            </div>
            <div class="qm-card">
                @if (ActiveBugs.Any())
                {
                    <div class="qm-table-wrap">
                        <table class="qm-table">
                            <thead>
                                <tr>
                                    <th style="width:100px">Key</th>
                                    <th>Summary</th>
                                    <th style="width:80px">Priority</th>
                                    <th style="width:110px">Status</th>
                                    <th style="width:130px">Assignee</th>
                                    <th style="width:120px">Epic</th>
                                    <th class="tc" style="width:90px">Fix Time</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var bug in ActiveBugs)
                                {
                                    var fixH = bug.StatusCategoryKey == "done" && bug.ResolutionDate.HasValue && bug.Created.HasValue
                                        ? WorkingHours(bug.Created.Value, bug.ResolutionDate.Value) : (double)-1;
                                    <tr>
                                        <td class="qm-td-key @(bug.StatusCategoryKey == "done" ? "qm-green" : "qm-red")">@bug.Key</td>
                                        <td>@bug.Summary</td>
                                        <td><span class="qm-chip @PriorityChipClass(bug.Priority)">@bug.Priority</span></td>
                                        <td><span class="qm-chip @StatusChipClass(bug.StatusCategoryKey)">@bug.Status</span></td>
                                        <td class="qm-td-nowrap">@bug.Assignee</td>
                                        <td class="qm-muted qm-td-nowrap">@(string.IsNullOrEmpty(bug.EpicKey) ? "—" : bug.EpicKey)</td>
                                        <td class="tc">
                                            @if (fixH >= 0)
                                            { <span class="qm-chip @FixTimeChipClass(fixH)">@FormatFixTime(fixH)</span> }
                                            else
                                            { <span class="qm-muted">—</span> }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="qm-empty-state">No bugs found for the current filters. 🎉</div>
                }
            </div>
        }
    }
</div>

@code {
    // ── State ─────────────────────────────────────────────────────────────────
    private SprintReport? SprintData;
    private SprintReport? EpicAllIssues;
    private bool EpicLoading;
    private string? DrillEpicKey;
    private string? DrillEpicName;
    private string SprintId = "";
    private bool IsLoading;
    private string? ErrorMessage;

    // ── Saved filters ─────────────────────────────────────────────────────────
    private List<JiraFilter> MyFilters = [];
    private bool FiltersLoading;
    private string SelectedFilterId = "";
    private string SelectedFilterJql => MyFilters.FirstOrDefault(f => f.Id == SelectedFilterId)?.Jql ?? "";

    // ── UI filters ────────────────────────────────────────────────────────────
    private string FilterAssignee = "";
    private string AssigneeSearch = "";

    // ── Computed scope ────────────────────────────────────────────────────────
    private SprintReport? ActiveReport => DrillEpicKey != null ? EpicAllIssues : SprintData;

    private IEnumerable<EpicSummary> SprintEpics => SprintData?.EpicSummaries
        .Where(e => !string.IsNullOrEmpty(e.Key)) ?? Enumerable.Empty<EpicSummary>();

    private IEnumerable<string> AssigneeOptions => ActiveReport?.Issues
        .Select(i => i.Assignee).Distinct().Order()
        .Where(a => string.IsNullOrEmpty(AssigneeSearch) || a.Contains(AssigneeSearch, StringComparison.OrdinalIgnoreCase))
        ?? Enumerable.Empty<string>();

    private List<SprintIssue> ActiveFilteredIssues => ActiveReport?.Issues
        .Where(i => string.IsNullOrEmpty(FilterAssignee) || i.Assignee == FilterAssignee)
        .ToList() ?? [];

    // ── Issue type classification ─────────────────────────────────────────────
    private static bool IsBug(SprintIssue i) =>
        i.IssueType.Contains("Bug",    StringComparison.OrdinalIgnoreCase) ||
        i.IssueType.Contains("Defect", StringComparison.OrdinalIgnoreCase);

    private static bool IsFeatureWork(SprintIssue i) =>
        i.IssueType.Contains("Story",       StringComparison.OrdinalIgnoreCase) ||
        i.IssueType.Contains("Task",        StringComparison.OrdinalIgnoreCase) ||
        i.IssueType.Contains("Sub-task",    StringComparison.OrdinalIgnoreCase) ||
        i.IssueType.Contains("Subtask",     StringComparison.OrdinalIgnoreCase) ||
        i.IssueType.Contains("Feature",     StringComparison.OrdinalIgnoreCase) ||
        i.IssueType.Contains("Improvement", StringComparison.OrdinalIgnoreCase) ||
        i.IssueType.Contains("Enhancement", StringComparison.OrdinalIgnoreCase);

    // ── Bug aggregates ────────────────────────────────────────────────────────
    private int ActiveBugCount => ActiveFilteredIssues.Count(IsBug);

    private double OverallBugRate => ActiveFilteredIssues.Count == 0 ? 0
        : (double)ActiveBugCount / ActiveFilteredIssues.Count * 100;

    private List<SprintIssue> ActiveBugs => ActiveFilteredIssues
        .Where(IsBug)
        .OrderBy(i => i.StatusCategoryKey == "done" ? 1 : 0)
        .ThenBy(i => PrioritySortOrder(i.Priority))
        .ToList();

    private double CompletionRate => ActiveFilteredIssues.Count == 0 ? 0
        : (double)ActiveFilteredIssues.Count(i => i.StatusCategoryKey == "done") / ActiveFilteredIssues.Count * 100;

    // ── Risk counters ─────────────────────────────────────────────────────────
    private int CriticalHighOpenBugs => ActiveBugs.Count(b =>
        b.StatusCategoryKey != "done" &&
        (b.Priority is "Critical" or "Highest" or "High"));

    private int UnassignedCount => ActiveFilteredIssues
        .Count(i => string.IsNullOrEmpty(i.Assignee) || i.Assignee == "Unassigned");

    private int UnestimatedCount => ActiveFilteredIssues
        .Count(i => i.OriginalEstimateSeconds == 0 && (i.StoryPoints == null || i.StoryPoints == 0));

    private List<SprintIssue> StaleBugs => ActiveBugs
        .Where(b => b.StatusCategoryKey != "done" && b.DaysSinceLastWorklog >= 5)
        .ToList();

    // ── Story points ──────────────────────────────────────────────────────────
    private bool HasSP => ActiveFilteredIssues.Any(i => i.StoryPoints.HasValue && i.StoryPoints > 0);
    private int TotalSP => ActiveFilteredIssues.Sum(i => i.StoryPoints ?? 0);
    private int DoneSP  => ActiveFilteredIssues.Where(i => i.StatusCategoryKey == "done").Sum(i => i.StoryPoints ?? 0);

    // ── Bug fix time ──────────────────────────────────────────────────────────
    private static double WorkingHours(DateTime from, DateTime to)
    {
        if (to.Date <= from.Date) return 0;
        int days = 0;
        var d = from.Date.AddDays(1);
        while (d <= to.Date)
        {
            if (d.DayOfWeek != DayOfWeek.Saturday && d.DayOfWeek != DayOfWeek.Sunday) days++;
            d = d.AddDays(1);
        }
        return days * 6.0;
    }

    private List<(SprintIssue Bug, double Hours)> ResolvedBugsWithTime =>
        ActiveFilteredIssues
            .Where(b => IsBug(b) && b.StatusCategoryKey == "done" && b.ResolutionDate.HasValue && b.Created.HasValue)
            .Select(b => (b, WorkingHours(b.Created!.Value, b.ResolutionDate!.Value)))
            .Where(x => x.Item2 >= 0)
            .OrderByDescending(x => x.Item2)
            .ToList();

    private double AvgFixTimeHours => ResolvedBugsWithTime.Count > 0
        ? ResolvedBugsWithTime.Average(x => x.Hours) : -1;

    // ── Open bug ages ─────────────────────────────────────────────────────────
    private List<(SprintIssue Bug, int AgeDays)> OpenBugAges => ActiveBugs
        .Where(b => b.StatusCategoryKey != "done" && b.Created.HasValue)
        .Select(b => (b, (int)(DateTime.Today - b.Created!.Value.Date).TotalDays))
        .OrderByDescending(x => x.Item2)
        .ToList();

    // ── Per-assignee stats ────────────────────────────────────────────────────
    private record AssigneeBugMetric(string Assignee, int TotalTasks, int BugCount, double BugRate, double AvgFixHours);

    private List<AssigneeBugMetric> AssigneeBugRates => ActiveFilteredIssues
        .GroupBy(i => i.Assignee)
        .Select(g =>
        {
            var bugs     = g.Where(IsBug).ToList();
            var resolved = bugs.Where(b => b.StatusCategoryKey == "done" && b.ResolutionDate.HasValue && b.Created.HasValue).ToList();
            var total    = g.Count();
            return new AssigneeBugMetric(
                g.Key, total, bugs.Count,
                total == 0 ? 0 : (double)bugs.Count / total * 100,
                resolved.Count > 0 ? resolved.Average(b => WorkingHours(b.Created!.Value, b.ResolutionDate!.Value)) : -1);
        })
        .OrderByDescending(m => m.BugRate).ThenByDescending(m => m.BugCount)
        .ToList();

    private int HighBugRateCount => AssigneeBugRates.Count(m => m.BugRate > 50);

    // ── Bug priority breakdown ────────────────────────────────────────────────
    private record PriorityBucket(string Priority, int Open, int InProgress, int Resolved);

    private List<PriorityBucket> BugsByPriority => ActiveBugs
        .GroupBy(b => NormalizePriority(b.Priority))
        .Select(g => new PriorityBucket(
            g.Key,
            g.Count(b => b.StatusCategoryKey == "new"),
            g.Count(b => b.StatusCategoryKey == "indeterminate"),
            g.Count(b => b.StatusCategoryKey == "done")))
        .OrderBy(p => PrioritySortOrder(p.Priority))
        .ToList();

    private static string NormalizePriority(string p) => p switch
    {
        "Highest" or "Critical" => "Critical",
        "High"                  => "High",
        "Medium"                => "Medium",
        _                       => "Low"
    };

    // ── Effort ────────────────────────────────────────────────────────────────
    private double BugFixHours      => ActiveFilteredIssues.Where(IsBug).Sum(i => i.Worklogs.Sum(w => w.TimeSpentSeconds)) / 3600.0;
    private double FeatureDevHours  => ActiveFilteredIssues.Where(IsFeatureWork).Sum(i => i.Worklogs.Sum(w => w.TimeSpentSeconds)) / 3600.0;
    private double TotalLoggedHours => BugFixHours + FeatureDevHours;
    private double BugFixEffortRatio => TotalLoggedHours == 0 ? -1 : BugFixHours / TotalLoggedHours * 100;
    private double BugOverheadPct   => FeatureDevHours == 0 ? -1 : BugFixHours / FeatureDevHours * 100;

    // ── Quality score (0–100) ─────────────────────────────────────────────────
    private int QualityScore
    {
        get
        {
            if (ActiveFilteredIssues.Count == 0) return 100;
            var bugComp    = (1.0 - Math.Min(OverallBugRate, 100) / 100.0) * 60;
            var effortComp = BugFixEffortRatio < 0 ? 40.0 : (1.0 - Math.Min(BugFixEffortRatio, 100) / 100.0) * 40;
            return Math.Clamp((int)(bugComp + effortComp), 0, 100);
        }
    }

    private string QualityBand      => QualityScore >= 80 ? "good" : QualityScore >= 55 ? "fair" : "poor";
    private string QualityBandLabel => QualityScore >= 80
        ? "Good — low bug density and efficient delivery"
        : QualityScore >= 55 ? "Fair — moderate bug pressure, monitor closely"
        : "Poor — high bug rate or significant effort lost to bugs";

    // ── Epic helpers ──────────────────────────────────────────────────────────
    private static int    EpicBugCount(EpicSummary e) => e.Issues.Count(IsBug);
    private static double EpicBugRate(EpicSummary  e) =>
        e.TotalIssues == 0 ? 0 : (double)EpicBugCount(e) / e.TotalIssues * 100;

    // ── Lifecycle ─────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        FiltersLoading = true;
        try { MyFilters = await JiraService.GetMyFiltersAsync(); }
        finally { FiltersLoading = false; }
    }

    private async Task LoadData()
    {
        IsLoading = true; ErrorMessage = null;
        SprintData = null; EpicAllIssues = null;
        DrillEpicKey = null; DrillEpicName = null;
        FilterAssignee = ""; AssigneeSearch = "";
        try
        {
            if (!string.IsNullOrEmpty(SelectedFilterId))
            {
                var jql = SelectedFilterJql;
                if (string.IsNullOrEmpty(jql)) { ErrorMessage = "Selected filter has no JQL."; return; }
                SprintData = await JiraService.GetDeliveryDataByFilterAsync(jql);
            }
            else if (int.TryParse(SprintId.Trim(), out var id))
                SprintData = await JiraService.GetDeliveryDataAsync(id);
            else
                ErrorMessage = "Enter a valid numeric Sprint ID.";
        }
        catch (Exception ex) { ErrorMessage = $"Failed to load data: {ex.Message}"; }
        finally { IsLoading = false; }
    }

    private async Task DrillIntoEpic(EpicSummary epic)
    {
        DrillEpicKey = epic.Key; DrillEpicName = epic.DisplayName;
        FilterAssignee = ""; AssigneeSearch = "";
        EpicLoading = true; EpicAllIssues = null; ErrorMessage = null;
        StateHasChanged();
        try { EpicAllIssues = await JiraService.GetAllEpicIssuesAsync(epic.Key); }
        catch (Exception ex) { ErrorMessage = $"Failed to load epic issues: {ex.Message}"; }
        finally { EpicLoading = false; }
    }

    private void BackToSprint()
    {
        DrillEpicKey = null; DrillEpicName = null; EpicAllIssues = null;
        FilterAssignee = ""; AssigneeSearch = ""; ErrorMessage = null;
    }

    private async Task HandleKeyUp(KeyboardEventArgs e) { if (e.Key == "Enter") await LoadData(); }

    private void ClearFilters() { FilterAssignee = ""; AssigneeSearch = ""; }

    // ── Display helpers ───────────────────────────────────────────────────────
    private static string BugRateClass(double r)  => r > 50 ? "qm-red" : r > 25 ? "qm-orange" : "qm-green";
    private static string FixTimeClass(double h)   => h < 0 ? "qm-muted" : h > 30 ? "qm-red" : h > 12 ? "qm-orange" : "qm-green";

    private static string PriorityChipClass(string p) => p switch
    {
        "Highest" or "Critical" => "qm-chip-red",
        "High"                  => "qm-chip-orange",
        "Medium"                => "qm-chip-blue",
        _                       => "qm-chip-gray"
    };

    private static string PriorityDotClass(string p) => p switch
    {
        "Critical" => "qm-dot-red",
        "High"     => "qm-dot-orange",
        "Medium"   => "qm-dot-blue",
        _          => "qm-dot-gray"
    };

    private static string StatusChipClass(string k) => k switch
    {
        "done"          => "qm-chip-green",
        "indeterminate" => "qm-chip-blue",
        _               => "qm-chip-gray"
    };

    private static string FixTimeChipClass(double h) =>
        h > 30 ? "qm-chip-red" : h > 12 ? "qm-chip-orange" : "qm-chip-green";

    private static int PrioritySortOrder(string p) => p switch
    {
        "Highest" or "Critical" => 0, "High" => 1, "Medium" => 2, "Low" => 3, "Lowest" => 4, _ => 5
    };

    private static string FormatHours(double h)
    {
        if (h <= 0) return "0h";
        var hh = (int)h; var mm = (int)Math.Round((h - hh) * 60);
        return mm > 0 ? $"{hh}h {mm}m" : $"{hh}h";
    }

    private static string FormatFixTime(double h) =>
        h < 0 ? "N/A" : h == 0 ? "<6h" : $"{(int)h}h";
}

<style>
    /* ─── Root & tokens ─────────────────────────────────────────────────────── */
