    // ── Load ─────────────────────────────────────────────────────────────────
    private async Task LoadData()
    {
        var useFilter = !string.IsNullOrEmpty(SelectedFilterId) && !string.IsNullOrEmpty(SelectedFilterJql);
        var useSprint = !useFilter && int.TryParse(SprintId.Trim(), out _);
        if (!useFilter && !useSprint) return;

        IsLoading     = true;
        ErrorMessage  = null;
        Report        = null;
        FilterAssignee = "";
        FilterEpic     = "";
        FilterType     = "";
        AssigneeSearch = "";
        EpicSearch     = "";
        FilterDateFrom = null;
        FilterDateTo   = null;
        ExpandedMembers.Clear();
        _excludedScopeEpics.Clear();
        _scopeSearch = ""; _scopeFilterStatus = ""; _scopeFilterType = ""; _scopeFilterAssignee = "";

        try
        {
            Report = useFilter
                ? await JiraService.GetDeliveryDataByFilterAsync(SelectedFilterJql)
                : await JiraService.GetDeliveryDataAsync(int.Parse(SprintId.Trim()));
            _renderCharts = true;
        }
        catch (HttpRequestException ex) { ErrorMessage = $"Failed to load data: {ex.Message}"; }
        catch (Exception ex)            { ErrorMessage = $"Unexpected error: {ex.Message}"; }
        finally                         { IsLoading = false; }
    }

