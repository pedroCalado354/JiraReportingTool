    private bool ShowExportModal;
    private bool IsExporting;
    private HashSet<string> ExportSelectedMembers = [];
    private string ExportIgnoredEpicsInput = "";

    private List<string> ExportAllMembers => Report?.Issues
        .Where(i => i.Assignee != "Unassigned")
        .Select(i => i.Assignee).Distinct().Order().ToList() ?? [];

    private void OpenExportModal()
    {
        ExportSelectedMembers = new HashSet<string>(ExportAllMembers);
        ShowExportModal = true;
    }

    private void ToggleExportMember(string member, bool selected)
    {
        if (selected) ExportSelectedMembers.Add(member);
        else          ExportSelectedMembers.Remove(member);
    }

    private async Task ExportToExcel()
    {
        if (Report == null || ExportSelectedMembers.Count == 0) return;

        IsExporting = true;
        StateHasChanged();

        try
        {
            var ignoredEpics = ExportIgnoredEpicsInput
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Select(k => k.ToUpperInvariant())
                .ToHashSet();

            var issues = Report.Issues
                .Where(i => i.StatusCategoryKey != "done"
                         && ExportSelectedMembers.Contains(i.Assignee)
                         && !string.Equals(i.IssueType, "Epic", StringComparison.OrdinalIgnoreCase)
                         && (string.IsNullOrEmpty(FilterEpic) || i.EpicKey == FilterEpic)
                         && (ignoredEpics.Count == 0 || !ignoredEpics.Contains(i.EpicKey.ToUpperInvariant())))
                .OrderBy(i => string.IsNullOrEmpty(i.EpicKey) ? "ZZZ" : i.EpicKey)
                .ThenBy(i => i.Assignee)
                .ThenBy(i => i.StatusCategoryKey switch { "indeterminate" => 0, _ => 1 })
                .ThenByDescending(i => i.RemainingEstimateSeconds)
                .ToList();

            using var wb = new XLWorkbook();
            var ws = wb.Worksheets.Add("Remaining Work");
            ws.Cell(1, 1).Value = "Epic";
            ws.Cell(1, 2).Value = "Key";
            ws.Cell(1, 3).Value = "Summary";
            ws.Cell(1, 4).Value = "Assignee";
            ws.Cell(1, 5).Value = "Status";
            ws.Cell(1, 6).Value = "Type";
            ws.Cell(1, 7).Value = "Priority";
            ws.Cell(1, 8).Value = "Estimate";
            ws.Cell(1, 9).Value = "Logged";
            ws.Cell(1, 10).Value = "Remaining";
            var row = 2;
            foreach (var i in issues)
            {
                ws.Cell(row, 1).Value  = i.EpicKey;
                ws.Cell(row, 2).Value  = i.Key;
                ws.Cell(row, 3).Value  = i.Summary;
                ws.Cell(row, 4).Value  = i.Assignee;
                ws.Cell(row, 5).Value  = i.Status;
                ws.Cell(row, 6).Value  = i.IssueType;
                ws.Cell(row, 7).Value  = i.Priority;
                ws.Cell(row, 8).Value  = i.OriginalEstimate;
                ws.Cell(row, 9).Value  = FmtH(i.TimeSpentSeconds);
                ws.Cell(row, 10).Value = i.RemainingEstimate;
                row++;
            }
            ws.Columns().AdjustToContents();

            using var ms = new System.IO.MemoryStream();
            wb.SaveAs(ms);
            var bytes = ms.ToArray();
            var b64   = Convert.ToBase64String(bytes);
            var fname = $"remaining_{Report.SprintName?.Replace(" ", "_") ?? SprintId}_{DateTime.Today:yyyyMMdd}.xlsx";
            await JS.InvokeVoidAsync("downloadBase64File", b64, fname, "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
        }
        finally
        {
            IsExporting     = false;
            ShowExportModal = false;
        }
    }
