    };

    // ── Shared helpers ───────────────────────────────────────────────────────
    private static string Initials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2 ? $"{parts[0][0]}{parts[^1][0]}".ToUpper()
             : name.Length >= 2  ? name[..2].ToUpper()
             : name.ToUpper();
    }

    private static int Pct(int count, int total) =>
        total == 0 ? 0 : (int)Math.Round((double)count / total * 100);

    private static string FmtH(int seconds) =>
        seconds <= 0 ? "0h" : $"{seconds / 3600.0:0.#}h";

