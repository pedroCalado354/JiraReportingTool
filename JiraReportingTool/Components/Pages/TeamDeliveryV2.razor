    private async Task RenderForecastChart()
    {
        var epics     = FilteredEpics;
        var labels    = epics.Select(e => e.DisplayName.Length > 20 ? e.DisplayName[..20] + "…" : e.DisplayName).ToArray();
        var estimated = epics.Select(e => Math.Round(e.TotalEstimateSeconds / 3600.0, 1)).ToArray();
        var logged    = epics.Select(e => Math.Round(EpicFilteredSpent(e) / 3600.0, 1)).ToArray();
        var remaining = epics.Select(e => Math.Round(e.TotalRemainingSeconds / 3600.0, 1)).ToArray();

        await JS.InvokeVoidAsync("renderChart", "chart-forecast", new
        {
            type = "bar",
            data = new
            {
                labels,
                datasets = new object[]
                {
                    new { label = "Estimated (h)", data = estimated, backgroundColor = "rgba(99,102,241,0.7)",  borderColor = "rgba(99,102,241,1)",  borderWidth = 1 },
                    new { label = "Logged (h)",    data = logged,    backgroundColor = "rgba(34,197,94,0.7)",   borderColor = "rgba(34,197,94,1)",   borderWidth = 1 },
                    new { label = "Remaining (h)", data = remaining, backgroundColor = "rgba(251,191,36,0.7)",  borderColor = "rgba(251,191,36,1)",  borderWidth = 1 }
                }
            },
            options = new
            {
                responsive = true, maintainAspectRatio = true,
                plugins = new { legend = new { position = "top" } },
                scales  = new { y = new { beginAtZero = true, title = new { display = true, text = "Hours" } } }
            }
        });
    }

    private async Task RenderWorkloadChart()
    {
        var people    = WorkloadPeople.ToList();
        var labels    = people.ToArray();
        var logged    = people.Select(p => Math.Round((WorklogSecondsByAuthor.TryGetValue(p, out var s) ? s : 0) / 3600.0, 1)).ToArray();
        var remaining = people.Select(p => Math.Round(FilteredIssues.Where(i => i.Assignee.Equals(p, StringComparison.OrdinalIgnoreCase)).Sum(i => i.RemainingEstimateSeconds) / 3600.0, 1)).ToArray();
        var estimated = people.Select(p => Math.Round(FilteredIssues.Where(i => i.Assignee.Equals(p, StringComparison.OrdinalIgnoreCase)).Sum(i => i.OriginalEstimateSeconds) / 3600.0, 1)).ToArray();

        await JS.InvokeVoidAsync("renderChart", "chart-workload", new
        {
            type = "bar",
            data = new
            {
                labels,
                datasets = new object[]
                {
                    new { label = "Planned (h)",   data = estimated, backgroundColor = "rgba(99,102,241,0.5)", borderColor = "rgba(99,102,241,1)", borderWidth = 1 },
                    new { label = "Logged (h)",    data = logged,    backgroundColor = "rgba(34,197,94,0.7)",  borderColor = "rgba(34,197,94,1)",  borderWidth = 1 },
                    new { label = "Remaining (h)", data = remaining, backgroundColor = "rgba(251,191,36,0.7)", borderColor = "rgba(251,191,36,1)", borderWidth = 1 }
                }
            },
            options = new
            {
                responsive = true, maintainAspectRatio = true,
                plugins = new { legend = new { position = "top" } },
                scales  = new { x = new { stacked = false }, y = new { beginAtZero = true, title = new { display = true, text = "Hours" } } }
            }
        });
    }

    private async Task RenderActivityChart()
    {
        var logs = AllWorklogsFiltered.ToList();
        if (!logs.Any()) return;

        var byDay = logs
            .GroupBy(x => x.Log.Started.Date)
            .OrderBy(g => g.Key)
            .Select(g => new { Label = g.Key.ToString("MMM d"), Hours = Math.Round(g.Sum(x => x.Log.TimeSpentSeconds) / 3600.0, 1) })
            .ToList();

        await JS.InvokeVoidAsync("renderChart", "chart-activity", new
        {
            type = "bar",
            data = new
            {
                labels   = byDay.Select(d => d.Label).ToArray(),
                datasets = new object[]
                {
                    new { label = "Hours logged", data = byDay.Select(d => d.Hours).ToArray(), backgroundColor = "rgba(99,102,241,0.7)", borderColor = "rgba(99,102,241,1)", borderWidth = 1, borderRadius = 4 }
                }
            },
            options = new
            {
                responsive = true, maintainAspectRatio = true,
                plugins = new { legend = new { display = false } },
                scales  = new { y = new { beginAtZero = true, title = new { display = true, text = "Hours" } } }
            }
        });
    }

    // ── Epic helpers ─────────────────────────────────────────────────────────
    private int  EpicFilteredSpent(EpicSummary epic) => epic.Issues.Sum(FilteredSpentSeconds);

    private double EpicFilteredVariancePct(EpicSummary epic)
    {
        if (epic.TotalEstimateSeconds <= 0) return 0;
        return (EpicFilteredSpent(epic) - epic.TotalEstimateSeconds) / (double)epic.TotalEstimateSeconds * 100;
    }

    private bool EpicFilteredIsOverBudget(EpicSummary epic) =>
        epic.TotalEstimateSeconds > 0 && EpicFilteredSpent(epic) > epic.TotalEstimateSeconds;

    private static string EpicState(EpicSummary e) =>
        e.IsOverBudget ? "danger" : e.CompletionPct >= 80 ? "success" : "neutral";

    // ── Issue progress ───────────────────────────────────────────────────────
    private int IssueProgress(SprintIssue issue)
    {
        if (issue.StatusCategoryKey == "done") return 100;
        if (issue.OriginalEstimateSeconds <= 0) return 0;
        return Math.Max(0, (int)Math.Round((double)FilteredSpentSeconds(issue) / issue.OriginalEstimateSeconds * 100));
    }

