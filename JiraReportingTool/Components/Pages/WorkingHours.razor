@page "/working-hours"
@rendermode InteractiveServer
@inject IJiraService JiraService
@inject IJSRuntime JS
@using JiraReportingTool.Models
@using ClosedXML.Excel

<PageTitle>Working Hours</PageTitle>

<div class="wh-root">

    <!-- ═══ HEADER ════════════════════════════════════════════════ -->
    <div class="wh-header">
        <div class="wh-header-left">
            <h1 class="wh-title">Working Hours</h1>
            <span class="wh-subtitle">Sprint worklog analysis</span>
        </div>
        <div class="wh-load-bar">
            <input class="wh-input wh-input-wide" placeholder="Sprint ID(s) — e.g. 6690  or  6690, 6691, 6692"
                   @bind="SprintIdsInput" @onkeyup="HandleKeyUp" />
            <button class="wh-btn wh-btn-primary" @onclick="LoadData" disabled="@IsLoading">
                @if (IsLoading)
                {
                    <span class="wh-spinner"></span>
                }
                Load
            </button>
        </div>
    </div>

    @if (ErrorMessage != null)
    {
        <div class="wh-error">@ErrorMessage</div>
    }

    @if (SprintReports.Count > 0)
    {
        <!-- ═══ STATS STRIP ════════════════════════════════════════ -->
        <div class="wh-stats">
            <div class="whs-item whs-accent">
                <span class="whs-val">@TotalHours.ToString("F1")</span>
                <span class="whs-lbl">Total Hours</span>
            </div>
            <div class="whs-sep"></div>
            <div class="whs-item">
                <span class="whs-val">@ActiveMemberCount</span>
                <span class="whs-lbl">Members</span>
            </div>
            <div class="whs-sep"></div>
            <div class="whs-item">
                <span class="whs-val">@FilteredEntryCount</span>
                <span class="whs-lbl">Log Entries</span>
            </div>
            <div class="whs-sep"></div>
            <div class="whs-item">
                <span class="whs-val">@AvgHoursPerMember.ToString("F1")</span>
                <span class="whs-lbl">Avg / Member</span>
            </div>
            <div class="whs-sep"></div>
            <div class="whs-item">
                <span class="whs-val">@AvgHoursPerDay.ToString("F1")</span>
                <span class="whs-lbl">Avg / Day</span>
            </div>
            <div class="whs-sep"></div>
            <div class="whs-item">
                <span class="whs-val">@MaxDayHours.ToString("F1")</span>
                <span class="whs-lbl">Peak Day</span>
            </div>
            <div class="whs-sep"></div>
            <div class="whs-item">
                <span class="whs-val whs-name">@TopContributor</span>
                <span class="whs-lbl">Top Contributor</span>
            </div>
            <div class="whs-sep"></div>
            <div class="whs-item">
                <span class="whs-val whs-name">@BusiestWeekday</span>
                <span class="whs-lbl">Busiest Day</span>
            </div>
        </div>

        <!-- ═══ FILTERS ═══════════════════════════════════════════ -->
        <div class="wh-filters">
            <div class="wh-filter-col">
                <div class="wh-filter-hdr">
                    <span class="wh-filter-label">Members</span>
                    <div class="wh-filter-actions">
                        <button class="wh-link" @onclick="SelectAllMembers">All</button>
                        <span class="wh-link-sep">·</span>
                        <button class="wh-link" @onclick="ClearMembersFilter">None</button>
                    </div>
                </div>
                <div class="wh-pills">
                    @foreach (var author in AllAuthors)
                    {
                        var a = author;
                        <button class="wh-pill @(SelectedMembers.Contains(a) ? "on" : "")"
                                @onclick="() => ToggleMember(a, !SelectedMembers.Contains(a))">
                            @a
                        </button>
                    }
                </div>
                <span class="wh-filter-count">@SelectedMembers.Count / @AllAuthors.Count selected</span>
            </div>

            <div class="wh-filter-col">
                <div class="wh-filter-hdr">
                    <span class="wh-filter-label">Epics</span>
                    <div class="wh-filter-actions">
                        <button class="wh-link" @onclick="SelectAllEpics">All</button>
                        <span class="wh-link-sep">·</span>
                        <button class="wh-link" @onclick="ClearEpicsFilter">None</button>
                    </div>
                </div>
                <div class="wh-pills">
                    @foreach (var (key, name) in AllEpics)
                    {
                        var k = key; var n = name;
                        <button class="wh-pill @(SelectedEpics.Contains(k) ? "on" : "")" title="@n"
                                @onclick="() => ToggleEpic(k, !SelectedEpics.Contains(k))">
                            @k
                        </button>
                    }
                </div>
                <span class="wh-filter-count">@SelectedEpics.Count / @AllEpics.Count selected</span>
            </div>

            <div class="wh-filter-col wh-filter-col-right">
                <div class="wh-filter-hdr">
                    <span class="wh-filter-label">Date Range</span>
                    @if (DateFrom.HasValue || DateTo.HasValue)
                    {
                        <button class="wh-link" @onclick="ClearDates">Clear</button>
                    }
                </div>
                <div class="wh-date-row">
                    <input type="date" class="wh-input" @bind="DateFrom" @bind:after="OnFilterChanged" />
                    <span class="wh-date-sep">→</span>
                    <input type="date" class="wh-input" @bind="DateTo"   @bind:after="OnFilterChanged" />
                </div>
                <button class="wh-btn wh-btn-export" @onclick="ExportToExcel" disabled="@IsExporting">
                    @if (IsExporting)
                    {
                        <span class="wh-spinner"></span>
                    }
                    else
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5z"/>
                            <path d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708l3 3z"/>
                        </svg>
                    }
                    Export .xlsx
                </button>
            </div>
        </div>

        <!-- ═══ CHARTS ════════════════════════════════════════════ -->
        <div class="wh-charts">
            <div class="wh-chart-card">
                <div class="wh-chart-title">Hours per Member</div>
                <div class="wh-chart-body" style="height:@(Math.Max(160, AllAuthors.Count * 32))px">
                    <canvas id="chart-hours-member"></canvas>
                </div>
            </div>
            <div class="wh-chart-card">
                <div class="wh-chart-title">Hours per Day</div>
                <div class="wh-chart-body" style="height:@(Math.Max(160, AllAuthors.Count * 32))px">
                    <canvas id="chart-hours-day"></canvas>
                </div>
            </div>
            <div class="wh-chart-card wh-chart-card-sm">
                <div class="wh-chart-title">Hours per Epic</div>
                <div class="wh-chart-body" style="height:@(Math.Max(160, AllAuthors.Count * 32))px">
                    <canvas id="chart-hours-epic"></canvas>
                </div>
            </div>
        </div>

        <!-- ═══ TABLE ══════════════════════════════════════════════ -->
        <div class="wh-table-card">
            <div class="wh-table-header">
                <span class="wh-table-title">Worklog Entries</span>
                <span class="wh-table-meta">@FilteredEntryCount entries · @TotalHours.ToString("F1") h</span>
            </div>
            <div class="wh-table-wrap">
                <table class="wh-table">
                    <thead>
                        <tr>
                            <th class="sortable @(SI("Date",    _sortColWH, _sortAscWH))" @onclick='() => SortWH("Date")'>Date</th>
                            <th class="sortable @(SI("Day",     _sortColWH, _sortAscWH))" @onclick='() => SortWH("Day")'>Day</th>
                            <th class="sortable @(SI("Member",  _sortColWH, _sortAscWH))" @onclick='() => SortWH("Member")'>Member</th>
                            <th class="text-right sortable @(SI("Hours",   _sortColWH, _sortAscWH))" @onclick='() => SortWH("Hours")'>Hours</th>
                            <th class="sortable @(SI("Task",    _sortColWH, _sortAscWH))" @onclick='() => SortWH("Task")'>Task</th>
                            <th class="sortable @(SI("Summary", _sortColWH, _sortAscWH))" @onclick='() => SortWH("Summary")'>Summary</th>
                            <th class="sortable @(SI("Epic",    _sortColWH, _sortAscWH))" @onclick='() => SortWH("Epic")'>Epic</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var wl in FilteredWorklogs)
                        {
                            <tr>
                                <td class="wh-td-date">@wl.Date.ToString("yyyy-MM-dd")</td>
                                <td class="wh-td-day">@wl.Date.ToString("ddd")</td>
                                <td class="wh-td-member">@wl.Author</td>
                                <td class="wh-td-hours text-right">@((wl.TimeSpentSeconds / 3600.0).ToString("F2"))</td>
                                <td><span class="wh-issue-badge">@wl.IssueKey</span></td>
                                <td class="wh-td-summary"><span title="@wl.IssueSummary">@wl.IssueSummary</span></td>
                                <td class="wh-td-epic">
                                    @if (!string.IsNullOrEmpty(wl.EpicKey))
                                    {
                                        <span class="wh-epic-key">@wl.EpicKey</span>
                                        @if (!string.IsNullOrEmpty(wl.EpicName) && wl.EpicName != "No Epic")
                                        {
                                            <span class="wh-epic-name">@wl.EpicName</span>
                                        }
                                    }
                                    else { <span class="wh-td-muted">—</span> }
                                </td>
                            </tr>
                        }
                        @if (FilteredEntryCount == 0)
                        {
                            <tr><td colspan="7" class="wh-empty-row">No worklogs match the current filters.</td></tr>
                        }
                    </tbody>
                    @if (FilteredEntryCount > 0)
                    {
                        <tfoot>
                            <tr class="wh-tfoot-row">
                                <td colspan="3">Total</td>
                                <td class="text-right">@TotalHours.ToString("F2")</td>
                                <td colspan="3"></td>
                            </tr>
                        </tfoot>
                    }
                </table>
            </div>
        </div>
    }

</div>

<style>
    /* ─── Reset ─── */
    .wh-root * {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Inter', Roboto, sans-serif;
        box-sizing: border-box;
    }

    .wh-root {
        display: flex;
        flex-direction: column;
        gap: 12px;
        padding: 4px 0;
    }

    /* ─── Header ─── */
    .wh-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
        padding: 14px 20px;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
    }

    .wh-title {
        font-size: 20px;
        font-weight: 700;
        color: #0f172a;
        margin: 0;
        letter-spacing: -0.02em;
    }

    .wh-subtitle {
        font-size: 13px;
        color: #94a3b8;
        margin-top: 2px;
        display: block;
    }

    .wh-load-bar {
        display: flex;
        gap: 8px;
        align-items: center;
    }

    /* ─── Inputs & Buttons ─── */
    .wh-input {
        padding: 7px 11px;
        height: 34px;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        background: #f8fafc;
        font-size: 13px;
        color: #0f172a;
        transition: border-color 0.15s;
    }

    .wh-input:focus { outline: none; border-color: #6366f1; background: #fff; box-shadow: 0 0 0 3px rgba(99,102,241,0.08); }
    .wh-input-wide  { min-width: 340px; }

    .wh-btn {
        padding: 7px 16px;
        height: 34px;
        border-radius: 8px;
        border: 1px solid #e2e8f0;
        background: #f8fafc;
        color: #475569;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.15s;
        white-space: nowrap;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .wh-btn:hover:not(:disabled) { background: #f1f5f9; border-color: #cbd5e1; }
    .wh-btn:disabled { opacity: 0.4; cursor: not-allowed; }

    .wh-btn-primary { background: #6366f1; border-color: #6366f1; color: #fff; }
    .wh-btn-primary:hover:not(:disabled) { background: #4f46e5; border-color: #4f46e5; }

    .wh-btn-export  { background: #f0fdf4; border-color: #a7f3d0; color: #065f46; margin-top: 10px; }
    .wh-btn-export:hover:not(:disabled) { background: #dcfce7; }

    /* ─── Spinner ─── */
    .wh-spinner {
        width: 14px; height: 14px;
        border: 2px solid rgba(255,255,255,0.4);
        border-top-color: #fff;
        border-radius: 50%;
        animation: wh-spin 0.6s linear infinite;
        flex-shrink: 0;
    }

    @@keyframes wh-spin { to { transform: rotate(360deg); } }

    /* ─── Error ─── */
    .wh-error {
        padding: 10px 14px;
        background: #fef2f2;
        border: 1px solid #fca5a5;
        border-radius: 8px;
        color: #dc2626;
        font-size: 13px;
    }

    /* ─── Stats Strip ─── */
    .wh-stats {
        display: flex;
        align-items: stretch;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        overflow: hidden;
    }

    .whs-item {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 12px 10px;
        gap: 2px;
        min-width: 80px;
    }

    .whs-item.whs-accent { background: #eef2ff; }
    .whs-item.whs-accent .whs-val { color: #4338ca; }

    .whs-sep { width: 1px; background: #f1f5f9; align-self: stretch; flex-shrink: 0; }

    .whs-val {
        font-size: 20px;
        font-weight: 700;
        color: #0f172a;
        line-height: 1.2;
    }

    .whs-val.whs-name {
        font-size: 13px;
        font-weight: 700;
        text-align: center;
    }

    .whs-lbl {
        font-size: 10px;
        color: #94a3b8;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    /* ─── Filters ─── */
    .wh-filters {
        display: grid;
        grid-template-columns: 1fr 1fr auto;
        gap: 12px;
        padding: 14px 16px;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
    }

    .wh-filter-col {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .wh-filter-col-right {
        justify-content: flex-start;
        min-width: 200px;
    }

    .wh-filter-hdr {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
    }

    .wh-filter-label {
        font-size: 11px;
        font-weight: 700;
        color: #475569;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .wh-filter-actions { display: flex; align-items: center; gap: 5px; }

    .wh-link {
        background: none;
        border: none;
        padding: 0;
        font-size: 12px;
        color: #6366f1;
        cursor: pointer;
        font-weight: 600;
    }

    .wh-link:hover { color: #4338ca; text-decoration: underline; }
    .wh-link-sep { color: #cbd5e1; font-size: 12px; }

    .wh-filter-count { font-size: 11px; color: #94a3b8; }

    .wh-pills {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
    }

    .wh-pill {
        padding: 3px 10px;
        border-radius: 20px;
        border: 1px solid #e2e8f0;
        background: #f8fafc;
        color: #475569;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.13s;
        white-space: nowrap;
    }

    .wh-pill:hover { background: #eef2ff; border-color: #c7d2fe; color: #4338ca; }
    .wh-pill.on    { background: #6366f1; border-color: #6366f1; color: #fff; }

    .wh-date-row {
        display: flex;
        align-items: center;
        gap: 6px;
        flex-wrap: wrap;
    }

    .wh-date-sep { font-size: 12px; color: #94a3b8; }

    /* ─── Charts ─── */
    .wh-charts {
        display: grid;
        grid-template-columns: 1fr 1fr 280px;
        gap: 12px;
    }

    .wh-chart-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        overflow: hidden;
    }

    .wh-chart-card-sm { }

    .wh-chart-title {
        font-size: 11px;
        font-weight: 700;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        padding: 10px 14px 6px;
        border-bottom: 1px solid #f1f5f9;
    }

    .wh-chart-body {
        padding: 10px 12px;
        position: relative;
    }

    /* ─── Table Card ─── */
    .wh-table-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        overflow: hidden;
    }

    .wh-table-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 16px;
        border-bottom: 1px solid #f1f5f9;
    }

    .wh-table-title { font-size: 13px; font-weight: 700; color: #0f172a; }
    .wh-table-meta  { font-size: 12px; color: #94a3b8; }

    .wh-table-wrap { max-height: 480px; overflow-y: auto; }

    .wh-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
        color: #374151;
    }

    .wh-table thead th {
        position: sticky;
        top: 0;
        background: #f8fafc;
        padding: 8px 12px;
        text-align: left;
        font-size: 11px;
        font-weight: 700;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        border-bottom: 1px solid #e2e8f0;
        white-space: nowrap;
        z-index: 1;
    }

    .wh-table tbody tr:hover { background: #f8fafc; }

    .wh-table tbody td {
        padding: 7px 12px;
        border-bottom: 1px solid #f1f5f9;
        vertical-align: middle;
    }

    .wh-td-date   { color: #94a3b8; white-space: nowrap; font-size: 12px; }
    .wh-td-day    { color: #94a3b8; font-size: 12px; white-space: nowrap; }
    .wh-td-member { font-weight: 600; color: #0f172a; white-space: nowrap; }
    .wh-td-hours  { font-weight: 700; color: #0f172a; white-space: nowrap; }
    .wh-td-muted  { color: #cbd5e1; }

    .wh-td-summary span {
        display: block;
        max-width: 260px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .wh-td-epic {
        white-space: nowrap;
        max-width: 180px;
    }

    .text-right { text-align: right; }

    .wh-issue-badge {
        background: #f1f5f9;
        border: 1px solid #e2e8f0;
        border-radius: 5px;
        padding: 1px 6px;
        font-size: 11px;
        font-weight: 600;
        color: #475569;
        white-space: nowrap;
    }

    .wh-epic-key {
        font-size: 11px;
        font-weight: 700;
        color: #6366f1;
    }

    .wh-epic-name {
        font-size: 11px;
        color: #94a3b8;
        margin-left: 4px;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .wh-empty-row {
        text-align: center;
        color: #94a3b8;
        padding: 32px 12px !important;
        font-size: 13px;
    }

    .wh-tfoot-row td {
        padding: 8px 12px;
        font-weight: 700;
        font-size: 13px;
        background: #f8fafc;
        border-top: 2px solid #e2e8f0;
    }
</style>

@code {
    private string SprintIdsInput = "";
    private bool IsLoading;
    private bool IsExporting;
    private string? ErrorMessage;
    private bool _renderCharts;

    private string _sortColWH = ""; private bool _sortAscWH = true;
    private void SortWH(string c) { if (_sortColWH == c) _sortAscWH = !_sortAscWH; else { _sortColWH = c; _sortAscWH = true; } }
    private static string SI(string c, string sc, bool sa) => sc == c ? (sa ? "sort-asc" : "sort-desc") : "";

    private List<int> ParsedSprintIds = [];
    private List<SprintReport> SprintReports = [];

    // ── Filters ───────────────────────────────────────────────────────────────
    private HashSet<string> SelectedMembers = [];
    private HashSet<string> SelectedEpics   = [];
    private DateTime? DateFrom;
    private DateTime? DateTo;

    // ── Derived: source lists ─────────────────────────────────────────────────
    private List<string> AllAuthors => SprintReports
        .SelectMany(r => r.Issues)
        .SelectMany(i => i.Worklogs)
        .Select(w => w.Author)
        .Where(a => !string.IsNullOrEmpty(a))
        .Distinct().Order().ToList();

    private List<(string Key, string Name)> AllEpics => SprintReports
        .SelectMany(r => r.Issues)
        .Where(i => !string.IsNullOrEmpty(i.EpicKey))
        .Select(i => (i.EpicKey, string.IsNullOrEmpty(i.EpicName) || i.EpicName == "No Epic" ? i.EpicKey : i.EpicName))
        .DistinctBy(e => e.EpicKey)
        .OrderBy(e => e.EpicKey)
        .ToList();

    private sealed record WorklogRow(
        DateTime Date, string Author, int TimeSpentSeconds,
        string IssueKey, string IssueSummary, string IssueType,
        string EpicKey, string EpicName);

    private List<WorklogRow> AllWorklogs => SprintReports
        .SelectMany(r => r.Issues)
        .SelectMany(i => i.Worklogs.Select(w => new WorklogRow(
            w.Started.Date, w.Author, w.TimeSpentSeconds,
            i.Key, i.Summary, i.IssueType, i.EpicKey, i.EpicName)))
        .OrderByDescending(w => w.Date).ThenBy(w => w.Author)
        .ToList();

    private List<WorklogRow> FilteredWorklogs
    {
        get
        {
            var q = AllWorklogs.Where(w =>
                !string.IsNullOrEmpty(w.Author) &&
                (SelectedMembers.Count == 0 || SelectedMembers.Contains(w.Author)) &&
                (SelectedEpics.Count == 0   || SelectedEpics.Contains(w.EpicKey)) &&
                (!DateFrom.HasValue || w.Date >= DateFrom.Value.Date) &&
                (!DateTo.HasValue   || w.Date <= DateTo.Value.Date));
            return (_sortColWH switch
            {
                "Date"    => _sortAscWH ? q.OrderBy(w => w.Date)                : q.OrderByDescending(w => w.Date),
                "Day"     => _sortAscWH ? q.OrderBy(w => (int)w.Date.DayOfWeek) : q.OrderByDescending(w => (int)w.Date.DayOfWeek),
                "Member"  => _sortAscWH ? q.OrderBy(w => w.Author)              : q.OrderByDescending(w => w.Author),
                "Hours"   => _sortAscWH ? q.OrderBy(w => w.TimeSpentSeconds)    : q.OrderByDescending(w => w.TimeSpentSeconds),
                "Task"    => _sortAscWH ? q.OrderBy(w => w.IssueKey)            : q.OrderByDescending(w => w.IssueKey),
                "Summary" => _sortAscWH ? q.OrderBy(w => w.IssueSummary)        : q.OrderByDescending(w => w.IssueSummary),
                "Epic"    => _sortAscWH ? q.OrderBy(w => w.EpicName)            : q.OrderByDescending(w => w.EpicName),
                _         => q.OrderByDescending(w => w.Date).ThenBy(w => w.Author),
            }).ToList();
        }
    }

    // ── KPI properties ────────────────────────────────────────────────────────
    private double TotalHours        => FilteredWorklogs.Sum(w => w.TimeSpentSeconds) / 3600.0;
    private int    ActiveMemberCount => FilteredWorklogs.Select(w => w.Author).Distinct().Count();
    private int    FilteredEntryCount => FilteredWorklogs.Count;
    private double AvgHoursPerMember => ActiveMemberCount > 0 ? TotalHours / ActiveMemberCount : 0;

    private double AvgHoursPerDay => FilteredWorklogs
        .GroupBy(w => w.Date).Any()
        ? TotalHours / FilteredWorklogs.Select(w => w.Date).Distinct().Count()
        : 0;

    private double MaxDayHours => FilteredWorklogs
        .GroupBy(w => w.Date)
        .Select(g => g.Sum(w => w.TimeSpentSeconds) / 3600.0)
        .DefaultIfEmpty(0).Max();

    private string TopContributor => FilteredWorklogs
        .GroupBy(w => w.Author)
        .OrderByDescending(g => g.Sum(w => w.TimeSpentSeconds))
        .Select(g => g.Key)
        .FirstOrDefault() ?? "—";

    private string BusiestWeekday => FilteredWorklogs
        .GroupBy(w => w.Date.DayOfWeek)
        .OrderByDescending(g => g.Sum(w => w.TimeSpentSeconds))
        .Select(g => g.Key.ToString())
        .FirstOrDefault() ?? "—";

    // ── Load ──────────────────────────────────────────────────────────────────
    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await LoadData();
    }

    private async Task LoadData()
    {
        var ids = SprintIdsInput
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(s => int.TryParse(s.Trim(), out var n) ? (int?)n : null)
            .Where(n => n.HasValue).Select(n => n!.Value).Distinct().ToList();

        if (ids.Count == 0) { ErrorMessage = "Enter at least one sprint ID."; return; }

        IsLoading = true; ErrorMessage = null;
        SprintReports.Clear(); SelectedMembers.Clear();
        DateFrom = null; DateTo = null;
        StateHasChanged();

        try
        {
            var results = await Task.WhenAll(ids.Select(id => JiraService.GetDeliveryDataAsync(id)));
            ParsedSprintIds = ids;
            SprintReports   = [.. results];
            SelectedMembers = new HashSet<string>(AllAuthors);
            SelectedEpics   = new HashSet<string>(AllEpics.Select(e => e.Key));
            _renderCharts   = true;
        }
        catch (Exception ex) { ErrorMessage = $"Failed to load sprint data: {ex.Message}"; }
        finally { IsLoading = false; }
    }

    // ── Filter actions ────────────────────────────────────────────────────────
    private void SelectAllMembers()  { SelectedMembers = new HashSet<string>(AllAuthors); OnFilterChanged(); }
    private void ClearMembersFilter() { SelectedMembers.Clear(); OnFilterChanged(); }

    private void ToggleMember(string author, bool selected)
    {
        if (selected) SelectedMembers.Add(author); else SelectedMembers.Remove(author);
        OnFilterChanged();
    }

    private void SelectAllEpics()   { SelectedEpics = new HashSet<string>(AllEpics.Select(e => e.Key)); OnFilterChanged(); }
    private void ClearEpicsFilter()  { SelectedEpics.Clear(); OnFilterChanged(); }

    private void ToggleEpic(string key, bool selected)
    {
        if (selected) SelectedEpics.Add(key); else SelectedEpics.Remove(key);
        OnFilterChanged();
    }

    private void ClearDates()  { DateFrom = null; DateTo = null; OnFilterChanged(); }

    private void OnFilterChanged() { _renderCharts = true; StateHasChanged(); }

    // ── Charts ────────────────────────────────────────────────────────────────
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_renderCharts && SprintReports.Count > 0)
        {
            _renderCharts = false;
            var filtered = FilteredWorklogs;
            await RenderMemberChart(filtered);
            await RenderDayChart(filtered);
            await RenderEpicChart(filtered);
        }
    }

    private async Task RenderMemberChart(List<WorklogRow> filtered)
    {
        var byMember = filtered
            .GroupBy(w => w.Author)
            .Select(g => new { Name = g.Key, Hours = Math.Round(g.Sum(w => w.TimeSpentSeconds) / 3600.0, 1) })
            .OrderByDescending(m => m.Hours).ToList();

        if (byMember.Count == 0) return;

        await JS.InvokeVoidAsync("renderChart", "chart-hours-member", new
        {
            type = "bar",
            data = new
            {
                labels = byMember.Select(m => m.Name).ToArray(),
                datasets = new[]
                {
                    new
                    {
                        label = "Hours",
                        data  = byMember.Select(m => m.Hours).ToArray(),
                        backgroundColor = byMember.Select((_, i) => ChartColor(i, 0.8)).ToArray(),
                        borderColor     = byMember.Select((_, i) => ChartColor(i, 1.0)).ToArray(),
                        borderWidth = 1, borderRadius = 4
                    }
                }
            },
            options = new
            {
                indexAxis = "y", responsive = true, maintainAspectRatio = false,
                plugins = new { legend = new { display = false } },
                scales = new { x = new { beginAtZero = true, grid = new { color = "rgba(0,0,0,0.04)" } } }
            }
        });
    }

    private async Task RenderDayChart(List<WorklogRow> filtered)
    {
        var byDay = filtered
            .GroupBy(w => w.Date)
            .Select(g => new { Date = g.Key, Hours = Math.Round(g.Sum(w => w.TimeSpentSeconds) / 3600.0, 1) })
            .OrderBy(d => d.Date).ToList();

        if (byDay.Count == 0) return;

        await JS.InvokeVoidAsync("renderChart", "chart-hours-day", new
        {
            type = "bar",
            data = new
            {
                labels = byDay.Select(d => d.Date.ToString("MMM d")).ToArray(),
                datasets = new[]
                {
                    new
                    {
                        label = "Hours",
                        data  = byDay.Select(d => d.Hours).ToArray(),
                        backgroundColor = "rgba(99,102,241,0.75)",
                        borderColor     = "rgba(99,102,241,1)",
                        borderWidth = 1, borderRadius = 4
                    }
                }
            },
            options = new
            {
                responsive = true, maintainAspectRatio = false,
                plugins = new { legend = new { display = false } },
                scales = new
                {
                    x = new { grid = new { display = false } },
                    y = new { beginAtZero = true, grid = new { color = "rgba(0,0,0,0.04)" } }
                }
            }
        });
    }

    private async Task RenderEpicChart(List<WorklogRow> filtered)
    {
        var byEpic = filtered
            .Where(w => !string.IsNullOrEmpty(w.EpicKey))
            .GroupBy(w => w.EpicKey)
            .Select(g => new { Epic = g.Key, Hours = Math.Round(g.Sum(w => w.TimeSpentSeconds) / 3600.0, 1) })
            .OrderByDescending(e => e.Hours).Take(10).ToList();

        if (byEpic.Count == 0) return;

        await JS.InvokeVoidAsync("renderChart", "chart-hours-epic", new
        {
            type = "doughnut",
            data = new
            {
                labels = byEpic.Select(e => e.Epic).ToArray(),
                datasets = new[]
                {
                    new
                    {
                        data            = byEpic.Select(e => e.Hours).ToArray(),
                        backgroundColor = byEpic.Select((_, i) => ChartColor(i, 0.8)).ToArray(),
                        borderColor     = byEpic.Select((_, i) => ChartColor(i, 1.0)).ToArray(),
                        borderWidth = 1, hoverOffset = 4
                    }
                }
            },
            options = new
            {
                responsive = true, maintainAspectRatio = false,
                plugins = new
                {
                    legend = new { position = "bottom", labels = new { font = new { size = 11 }, padding = 10 } }
                },
                cutout = "60%"
            }
        });
    }

    private static string ChartColor(int index, double alpha)
    {
        string[] palette =
        [
            $"rgba(99,102,241,{alpha:F2})",
            $"rgba(6,214,160,{alpha:F2})",
            $"rgba(251,133,0,{alpha:F2})",
            $"rgba(155,93,229,{alpha:F2})",
            $"rgba(239,35,60,{alpha:F2})",
            $"rgba(56,176,0,{alpha:F2})",
            $"rgba(255,183,3,{alpha:F2})",
            $"rgba(17,138,178,{alpha:F2})",
            $"rgba(233,104,36,{alpha:F2})",
            $"rgba(0,169,165,{alpha:F2})",
        ];
        return palette[index % palette.Length];
    }

    // ── Export ────────────────────────────────────────────────────────────────
    private async Task ExportToExcel()
    {
        var filtered = FilteredWorklogs;
        if (filtered.Count == 0) return;

        IsExporting = true; StateHasChanged();

        try
        {
            using var wb = new XLWorkbook();
            var ws = wb.Worksheets.Add("Working Hours");

            void Meta(int row, string label, string value)
            {
                ws.Cell(row, 1).Value = label;
                ws.Cell(row, 1).Style.Font.Bold = true;
                ws.Cell(row, 1).Style.Font.FontColor = XLColor.FromHtml("#6c757d");
                ws.Cell(row, 2).Value = value;
            }

            var sprintNames = SprintReports.Where(r => !string.IsNullOrEmpty(r.SprintName))
                .Select(r => r.SprintName).Distinct();
            var sprintLabel = sprintNames.Any()
                ? string.Join(", ", sprintNames)
                : string.Join(", ", ParsedSprintIds);

            Meta(1, "Sprint(s)",   sprintLabel);
            Meta(2, "Members",     string.Join(", ", SelectedMembers.Order()));
            Meta(3, "Date Range",
                DateFrom.HasValue || DateTo.HasValue
                    ? $"{(DateFrom.HasValue ? DateFrom.Value.ToString("yyyy-MM-dd") : "—")} → {(DateTo.HasValue ? DateTo.Value.ToString("yyyy-MM-dd") : "—")}"
                    : "All dates");
            Meta(4, "Exported", DateTime.Now.ToString("yyyy-MM-dd HH:mm"));

            var headers = new[] { "Date", "Day of the Week", "Team Member", "Logged Hours" };
            for (int i = 0; i < headers.Length; i++)
            {
                var hc = ws.Cell(6, i + 1);
                hc.Value = headers[i];
                hc.Style.Font.Bold = true;
                hc.Style.Fill.BackgroundColor = XLColor.FromHtml("#1e3a5f");
                hc.Style.Font.FontColor = XLColor.White;
                hc.Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;
            }
            ws.SheetView.FreezeRows(6);

            var sorted = filtered.OrderBy(w => w.Date).ThenBy(w => w.Author).ToList();
            int row = 7;
            foreach (var wl in sorted)
            {
                if (row % 2 == 0)
                    ws.Row(row).Style.Fill.BackgroundColor = XLColor.FromHtml("#f8f9fa");
                ws.Cell(row, 1).Value = wl.Date.ToString("yyyy-MM-dd");
                ws.Cell(row, 2).Value = wl.Date.ToString("dddd");
                ws.Cell(row, 3).Value = wl.Author;
                ws.Cell(row, 4).Value = Math.Round(wl.TimeSpentSeconds / 3600.0, 2);
                ws.Cell(row, 4).Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;
                row++;
            }

            ws.Cell(row, 1).Value = "TOTAL";
            ws.Cell(row, 1).Style.Font.Bold = true;
            ws.Cell(row, 4).Value = Math.Round(sorted.Sum(w => w.TimeSpentSeconds) / 3600.0, 2);
            ws.Cell(row, 4).Style.Font.Bold = true;
            ws.Row(row).Style.Fill.BackgroundColor = XLColor.FromHtml("#e9ecef");
            ws.Columns().AdjustToContents();
            ws.Row(6).Height = 22;

            // Summary sheet
            var wsSummary = wb.Worksheets.Add("Summary by Member");
            void MetaS(int r, string label, string value)
            {
                wsSummary.Cell(r, 1).Value = label;
                wsSummary.Cell(r, 1).Style.Font.Bold = true;
                wsSummary.Cell(r, 1).Style.Font.FontColor = XLColor.FromHtml("#6c757d");
                wsSummary.Cell(r, 2).Value = value;
            }
            MetaS(1, "Sprint(s)", sprintLabel);
            MetaS(2, "Exported",  DateTime.Now.ToString("yyyy-MM-dd HH:mm"));

            var members = filtered.Select(w => w.Author).Distinct().Order().ToList();
            var dayMap  = filtered.GroupBy(w => w.Author).ToDictionary(
                g => g.Key,
                g => g.GroupBy(w => w.Date.DayOfWeek).ToDictionary(d => d.Key, d => d.Sum(w => w.TimeSpentSeconds) / 3600.0));

            DayOfWeek[] orderedDays = [DayOfWeek.Monday, DayOfWeek.Tuesday, DayOfWeek.Wednesday,
                                       DayOfWeek.Thursday, DayOfWeek.Friday, DayOfWeek.Saturday, DayOfWeek.Sunday];

            wsSummary.Cell(4, 1).Value = "Day";
            wsSummary.Cell(4, 1).Style.Font.Bold = true;
            wsSummary.Cell(4, 1).Style.Fill.BackgroundColor = XLColor.FromHtml("#1e3a5f");
            wsSummary.Cell(4, 1).Style.Font.FontColor = XLColor.White;
            for (int m = 0; m < members.Count; m++)
            {
                var hc = wsSummary.Cell(4, m + 2);
                hc.Value = members[m];
                hc.Style.Font.Bold = true;
                hc.Style.Fill.BackgroundColor = XLColor.FromHtml("#1e3a5f");
                hc.Style.Font.FontColor = XLColor.White;
                hc.Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;
            }
            var totalHc = wsSummary.Cell(4, members.Count + 2);
            totalHc.Value = "Total"; totalHc.Style.Font.Bold = true;
            totalHc.Style.Fill.BackgroundColor = XLColor.FromHtml("#1e3a5f");
            totalHc.Style.Font.FontColor = XLColor.White;
            totalHc.Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;
            wsSummary.SheetView.FreezeRows(4);

            int sRow = 5;
            foreach (var day in orderedDays)
            {
                if (sRow % 2 == 0)
                    wsSummary.Row(sRow).Style.Fill.BackgroundColor = XLColor.FromHtml("#f8f9fa");
                wsSummary.Cell(sRow, 1).Value = day.ToString(); wsSummary.Cell(sRow, 1).Style.Font.Bold = true;
                double rowTotal = 0;
                for (int m = 0; m < members.Count; m++)
                {
                    double hours = dayMap.TryGetValue(members[m], out var daysForMember)
                                   && daysForMember.TryGetValue(day, out var h) ? h : 0;
                    rowTotal += hours;
                    if (hours > 0)
                    {
                        var dc = wsSummary.Cell(sRow, m + 2);
                        dc.Value = Math.Round(hours, 2);
                        dc.Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;
                    }
                }
                var rtc = wsSummary.Cell(sRow, members.Count + 2);
                rtc.Value = Math.Round(rowTotal, 2); rtc.Style.Font.Bold = true;
                rtc.Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;
                sRow++;
            }

            wsSummary.Cell(sRow, 1).Value = "TOTAL"; wsSummary.Cell(sRow, 1).Style.Font.Bold = true;
            wsSummary.Row(sRow).Style.Fill.BackgroundColor = XLColor.FromHtml("#e9ecef");
            for (int m = 0; m < members.Count; m++)
            {
                double memberTotal = dayMap.TryGetValue(members[m], out var dm) ? dm.Values.Sum() : 0;
                var tc = wsSummary.Cell(sRow, m + 2);
                tc.Value = Math.Round(memberTotal, 2); tc.Style.Font.Bold = true;
                tc.Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;
            }
            var grandTotal = wsSummary.Cell(sRow, members.Count + 2);
            grandTotal.Value = Math.Round(filtered.Sum(w => w.TimeSpentSeconds) / 3600.0, 2);
            grandTotal.Style.Font.Bold = true;
            grandTotal.Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;
            wsSummary.Columns().AdjustToContents(); wsSummary.Row(4).Height = 22;

            using var ms = new MemoryStream();
            wb.SaveAs(ms);
            var base64   = Convert.ToBase64String(ms.ToArray());
            var fileLabel = sprintLabel.Replace(" ", "_").Replace("/", "-").Replace(",", "");
            var fileName  = $"WorkingHours_{fileLabel}_{DateTime.Today:yyyyMMdd}.xlsx";
            const string mime = "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet";
            await JS.InvokeVoidAsync("downloadBase64File", base64, fileName, mime);
        }
        catch (Exception ex) { ErrorMessage = $"Export failed: {ex.Message}"; }
        finally { IsExporting = false; }
    }
}
