@page "/support-analytics"
@rendermode InteractiveServer
@using JiraReportingTool.Models
@inject IJiraService JiraService
@inject SprintConfigService SprintConfigService
@inject IConfiguration Config
@inject IJSRuntime JS

<PageTitle>Support Analytics</PageTitle>

<div class="v2-root">

    <!-- ═══ HERO ═══════════════════════════════════════════════════════════════ -->
    <div class="v2-hero">
        <div class="v2-hero-row">
            <div class="v2-hero-icon"><i class="bi bi-clipboard-data"></i></div>
            <div class="v2-hero-titles">
                <span class="v2-eyebrow">Reporting</span>
                <h1 class="v2-hero-title">Support Analytics</h1>
                <span class="v2-hero-sub">
                    @if (_selected is not null)
                    {
                        <strong>@_selected.Name</strong>
                        <span> · @_sprintStart.ToString("MMM d") – @_sprintEnd.ToString("MMM d, yyyy")</span>
                        @if (!string.IsNullOrEmpty(_selected.EpicKey))
                        {
                            <span> · epic </span>
                            <a class="sa-epic-link" href="@_jiraBase/browse/@_selected.EpicKey" target="_blank" rel="noopener noreferrer">@_selected.EpicKey ↗</a>
                        }
                    }
                    else
                    {
                        <span>Bug lifecycle, effort, SLA &amp; breakdowns — scoped to a configured sprint</span>
                    }
                </span>
            </div>
            <div class="v2-hero-spacer"></div>
            <div class="v2-hero-actions sa-controls">
                <label class="sa-ctl-label">Sprint</label>
                <select class="sa-select" value="@_selectedConfigId" @onchange="OnConfigChanged" disabled="@_loading">
                    @if (_configs.Count == 0)
                    {
                        <option value="0">No sprints configured</option>
                    }
                    @foreach (var c in _configs)
                    {
                        <option value="@c.Id">@c.Name@(IsCurrent(c) ? "  ·  current" : "")</option>
                    }
                </select>
                <button class="v2-btn v2-btn-ghost" @onclick="LoadAsync" disabled="@(_loading || _selected is null)" title="Reload">
                    @if (_loading) { <span class="v2-spin"></span> } else { <i class="bi bi-arrow-repeat"></i> }
                </button>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="sa-banner sa-banner-danger"><i class="bi bi-exclamation-triangle"></i> @_error</div>
    }

    @if (_configs.Count == 0)
    {
        <div class="sa-empty">
            <i class="bi bi-sliders2"></i>
            <p>No sprints are configured yet. Add one on the <a href="config">Dashboard Config</a> page.</p>
        </div>
    }
    else if (_loading && _bugs.Count == 0)
    {
        <div class="sa-empty"><span class="v2-spin"></span><p>Loading bugs for @_selected?.EpicKey…</p></div>
    }
    else if (_bugs.Count == 0)
    {
        <div class="sa-empty">
            <i class="bi bi-inbox"></i>
            <p>No bugs found for epic <strong>@_selected?.EpicKey</strong> in this sprint.</p>
        </div>
    }
    else
    {
        <!-- ═══ 1. LIFECYCLE / THROUGHPUT ═════════════════════════════════════ -->
        <div class="v2-section"><span class="v2-section-title"><i class="bi bi-arrow-repeat"></i> Lifecycle &amp; Throughput</span></div>
        <div class="v2-kpi-grid">

            <div class="v2-kpi v2-kpi-neutral">
                <div class="v2-kpi-head"><i class="bi bi-collection"></i>Bugs in Epic</div>
                <div class="v2-kpi-value">@_bugs.Count</div>
                <div class="v2-kpi-sub">@OpenCount open · @DoneCount done</div>
            </div>

            <div class="v2-kpi v2-kpi-neutral">
                <div class="v2-kpi-head"><i class="bi bi-plus-circle"></i>Created This Sprint</div>
                <div class="v2-kpi-value">@CreatedThisSprintCount</div>
                <div class="v2-kpi-sub">new bugs raised in window</div>
            </div>

            <div class="v2-kpi v2-kpi-neutral">
                <div class="v2-kpi-head"><i class="bi bi-hammer"></i>Worked On</div>
                <div class="v2-kpi-value">@WorkedOnCount</div>
                <div class="v2-kpi-sub">@StartedThisSprintCount started this sprint</div>
            </div>

            <div class="v2-kpi v2-kpi-success">
                <div class="v2-kpi-head"><i class="bi bi-check2-circle"></i>Closed This Sprint</div>
                <div class="v2-kpi-value">@ClosedThisSprintCount</div>
                <div class="v2-bar" style="margin-top:8px"><div class="v2-bar-fill v2-bar-fill-success" style="width:@Pct(ClosedThisSprintCount, Math.Max(1, WorkedOnCount))%"></div></div>
                <div class="v2-kpi-sub">resolved within window</div>
            </div>

            <div class="v2-kpi v2-kpi-success">
                <div class="v2-kpi-head"><i class="bi bi-lightning-charge"></i>Started &amp; Closed</div>
                <div class="v2-kpi-value">@StartedAndClosedCount<span class="v2-kpi-of">of @ClosedThisSprintCount</span></div>
                <div class="v2-kpi-sub">picked up &amp; finished same sprint</div>
            </div>

            <div class="v2-kpi @(CarriedOverOpenCount == 0 ? "v2-kpi-neutral" : "v2-kpi-warn")">
                <div class="v2-kpi-head"><i class="bi bi-arrow-left-right"></i>Carried Over</div>
                <div class="v2-kpi-value">@CarriedOverOpenCount</div>
                <div class="v2-kpi-sub">created before sprint · still open</div>
            </div>

            <div class="v2-kpi @(ReopenedCount == 0 ? "v2-kpi-neutral" : "v2-kpi-danger")">
                <div class="v2-kpi-head"><i class="bi bi-arrow-counterclockwise"></i>QA Rejected</div>
                <div class="v2-kpi-value">@ReopenedCount</div>
                <div class="v2-kpi-sub">bugs bounced back from QA</div>
            </div>

            <div class="v2-kpi v2-kpi-neutral">
                <div class="v2-kpi-head"><i class="bi bi-graph-up"></i>Net Flow</div>
                @{ var net = ClosedThisSprintCount - CreatedThisSprintCount; }
                <div class="v2-kpi-value @(net >= 0 ? "v2-text-success" : "v2-text-danger")">@(net >= 0 ? "+" : "")@net</div>
                <div class="v2-kpi-sub">closed − created</div>
            </div>

        </div>

        <!-- ═══ 2. EFFORT & TIME ══════════════════════════════════════════════ -->
        <div class="v2-section"><span class="v2-section-title"><i class="bi bi-stopwatch"></i> Effort &amp; Time</span></div>
        <div class="v2-kpi-grid">

            <div class="v2-kpi v2-kpi-neutral">
                <div class="v2-kpi-head"><i class="bi bi-stopwatch"></i>Logged This Sprint</div>
                <div class="v2-kpi-value">@FmtHM(SprintLoggedSeconds)</div>
                <div class="v2-kpi-sub">across @SprintWorklogCount worklog@(SprintWorklogCount == 1 ? "" : "s")</div>
            </div>

            <div class="v2-kpi v2-kpi-neutral">
                <div class="v2-kpi-head"><i class="bi bi-clock-history"></i>Total Logged</div>
                <div class="v2-kpi-value">@FmtHM(TotalLoggedSeconds)</div>
                <div class="v2-kpi-sub">+ @FmtHM(RemainingSeconds) remaining</div>
            </div>

            <div class="v2-kpi v2-kpi-neutral">
                <div class="v2-kpi-head"><i class="bi bi-speedometer"></i>Daily Burn</div>
                <div class="v2-kpi-value">@($"{DailyBurnHours:0.0}")<span class="v2-kpi-of">h / day</span></div>
                <div class="v2-kpi-sub">@WeekdaysElapsed of @TotalWeekdays weekdays elapsed</div>
            </div>

            <div class="v2-kpi v2-kpi-neutral">
                <div class="v2-kpi-head"><i class="bi bi-hourglass-split"></i>Avg Time to Resolve</div>
                <div class="v2-kpi-value">@(AvgResolveDays.HasValue ? $"{AvgResolveDays:0.0}" : "—")<span class="v2-kpi-of">days</span></div>
                <div class="v2-kpi-sub">create → resolve (closed this sprint)</div>
            </div>

            <div class="v2-kpi v2-kpi-neutral">
                <div class="v2-kpi-head"><i class="bi bi-clock"></i>Avg Logged / Bug</div>
                <div class="v2-kpi-value">@FmtHM(AvgLoggedPerBugSeconds)</div>
                <div class="v2-kpi-sub">bugs with time logged</div>
            </div>

            <div class="v2-kpi @(BugsNoTimeOpen == 0 ? "v2-kpi-success" : "v2-kpi-warn")">
                <div class="v2-kpi-head"><i class="bi bi-slash-circle"></i>Open · No Time</div>
                <div class="v2-kpi-value">@BugsNoTimeOpen</div>
                <div class="v2-kpi-sub">open bugs with zero logged</div>
            </div>

        </div>

        <!-- ═══ 3. HEALTH, SLA & AGING ════════════════════════════════════════ -->
        <div class="v2-section"><span class="v2-section-title"><i class="bi bi-shield-check"></i> Health, SLA &amp; Aging</span></div>
        <div class="v2-kpi-grid">

            <div class="v2-kpi @(OverdueCount == 0 ? "v2-kpi-success" : "v2-kpi-danger")">
                <div class="v2-kpi-head"><i class="bi bi-exclamation-triangle"></i>Overdue</div>
                <div class="v2-kpi-value">@OverdueCount</div>
                <div class="v2-kpi-sub">@AtRiskCount at risk · @OnTrackCount on track</div>
            </div>

            <div class="v2-kpi @(StaleCount == 0 ? "v2-kpi-success" : "v2-kpi-warn")">
                <div class="v2-kpi-head"><i class="bi bi-hourglass-split"></i>Stale</div>
                <div class="v2-kpi-value">@StaleCount<span class="v2-kpi-of">of @InProgressCount active</span></div>
                <div class="v2-kpi-sub">in-progress, no log 24h+</div>
            </div>

            <div class="v2-kpi @(SlaBreachedCount == 0 ? "v2-kpi-success" : "v2-kpi-danger")">
                <div class="v2-kpi-head"><i class="bi bi-flag"></i>SLA Breached</div>
                <div class="v2-kpi-value">@SlaBreachedCount<span class="v2-kpi-of">of @OpenCount open</span></div>
                <div class="v2-kpi-sub">past priority SLA window</div>
            </div>

            <div class="v2-kpi @(AvgOpenAgeDays >= 60 ? "v2-kpi-danger" : AvgOpenAgeDays >= 30 ? "v2-kpi-warn" : "v2-kpi-success")">
                <div class="v2-kpi-head"><i class="bi bi-calendar-x"></i>Avg Open Age</div>
                <div class="v2-kpi-value">@($"{AvgOpenAgeDays:0}")<span class="v2-kpi-of">days</span></div>
                <div class="v2-kpi-sub">@NoDueDateCount with no due date</div>
            </div>

        </div>

        <!-- SLA by priority + age buckets -->
        <div class="v2-grid-2">
            <div class="v2-card">
                <div class="sa-card-title"><i class="bi bi-flag"></i> SLA status by priority</div>
                <div class="v2-table-wrap" style="margin:0">
                    <table class="v2-table" style="font-size:12px">
                        <thead><tr><th>Priority</th><th class="v2-table-num">SLA</th><th class="v2-table-num">Open</th><th class="v2-table-num">Inside</th><th class="v2-table-num">Breached</th></tr></thead>
                        <tbody>
                            @foreach (var p in SlaByPriority)
                            {
                                <tr>
                                    <td><span class="v2-pill @PriorityPill(p.Name)">@p.Name</span></td>
                                    <td class="v2-table-num">@p.SlaDays d</td>
                                    <td class="v2-table-num">@p.Open</td>
                                    <td class="v2-table-num v2-text-success">@p.Inside</td>
                                    <td class="v2-table-num @(p.Breached > 0 ? "v2-text-danger" : "")">@p.Breached</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="v2-card">
                <div class="sa-card-title"><i class="bi bi-bar-chart-steps"></i> Open bug age</div>
                <div class="sa-chart-box"><canvas id="sa-chart-age"></canvas></div>
            </div>
        </div>

        <!-- Oldest open bugs -->
        <div class="v2-card" style="margin-top:16px">
            <div class="sa-card-title"><i class="bi bi-clock-history"></i> Oldest open bugs</div>
            <div class="v2-table-wrap" style="margin:0">
                <table class="v2-table">
                    <thead><tr><th>Key</th><th>Summary</th><th>Assignee</th><th>Priority</th><th class="v2-table-num">Age</th><th>SLA</th></tr></thead>
                    <tbody>
                        @foreach (var b in OldestOpen)
                        {
                            var breached = GetSlaBucket(b) != "inside" && GetSlaBucket(b) != "done";
                            <tr>
                                <td class="v2-table-key"><a href="@_jiraBase/browse/@b.Key" target="_blank" class="sa-key">@b.Key</a></td>
                                <td class="sa-trunc" title="@b.Summary">@b.Summary</td>
                                <td class="sa-trunc" style="max-width:130px">@b.Assignee</td>
                                <td><span class="v2-pill @PriorityPill(b.Priority)">@b.Priority</span></td>
                                <td class="v2-table-num">@GetDaysOpen(b) d</td>
                                <td>@if (breached) { <span class="v2-pill v2-pill-danger">breached</span> } else { <span class="v2-pill v2-pill-success">inside</span> }</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- ═══ 4. CHARTS ═════════════════════════════════════════════════════ -->
        <div class="v2-section"><span class="v2-section-title"><i class="bi bi-graph-up"></i> Trends</span></div>
        <div class="v2-grid-2">
            <div class="v2-card">
                <div class="sa-card-title"><i class="bi bi-funnel"></i> Throughput funnel</div>
                <div class="sa-chart-box"><canvas id="sa-chart-funnel"></canvas></div>
            </div>
            <div class="v2-card">
                <div class="sa-card-title"><i class="bi bi-calendar3"></i> Resolutions per day</div>
                <div class="sa-chart-box"><canvas id="sa-chart-resolved"></canvas></div>
            </div>
        </div>

        <!-- ═══ 5. BREAKDOWNS ═════════════════════════════════════════════════ -->
        <div class="v2-section"><span class="v2-section-title"><i class="bi bi-diagram-3"></i> Breakdowns</span></div>

        <div class="v2-grid-2">
            <!-- By customer -->
            <div class="v2-card">
                <div class="sa-card-title"><i class="bi bi-building"></i> By customer</div>
                <div class="v2-table-wrap" style="margin:0">
                    <table class="v2-table" style="font-size:12px">
                        <thead><tr><th>Customer</th><th class="v2-table-num">Bugs</th><th class="v2-table-num">Closed</th><th class="v2-table-num">Logged</th></tr></thead>
                        <tbody>
                            @foreach (var c in ByCustomer)
                            {
                                <tr>
                                    <td class="sa-trunc" title="@c.Name">@c.Name</td>
                                    <td class="v2-table-num">@c.Total</td>
                                    <td class="v2-table-num v2-text-success">@c.Closed</td>
                                    <td class="v2-table-num">@FmtHM(c.LoggedSeconds)</td>
                                </tr>
                            }
                            @if (!ByCustomer.Any()) { <tr><td colspan="4" class="sa-muted">No customer data</td></tr> }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- By label -->
            <div class="v2-card">
                <div class="sa-card-title"><i class="bi bi-tags"></i> By label</div>
                <div class="v2-table-wrap" style="margin:0">
                    <table class="v2-table" style="font-size:12px">
                        <thead><tr><th>Label</th><th class="v2-table-num">Bugs</th><th class="v2-table-num">Closed</th><th class="v2-table-num">Logged</th></tr></thead>
                        <tbody>
                            @foreach (var l in ByLabel)
                            {
                                <tr>
                                    <td class="sa-trunc" title="@l.Name">@l.Name</td>
                                    <td class="v2-table-num">@l.Total</td>
                                    <td class="v2-table-num v2-text-success">@l.Closed</td>
                                    <td class="v2-table-num">@FmtHM(l.LoggedSeconds)</td>
                                </tr>
                            }
                            @if (!ByLabel.Any()) { <tr><td colspan="4" class="sa-muted">No labels</td></tr> }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- By assignee / contributors -->
        <div class="v2-card" style="margin-top:16px">
            <div class="sa-card-title"><i class="bi bi-people"></i> By assignee · contribution this sprint</div>
            <div class="v2-table-wrap" style="margin:0">
                <table class="v2-table">
                    <thead><tr><th>Member</th><th class="v2-table-num">Worked</th><th class="v2-table-num">Closed</th><th class="v2-table-num">Logged (sprint)</th><th class="v2-table-num">Days active</th></tr></thead>
                    <tbody>
                        @foreach (var m in ByContributor)
                        {
                            <tr>
                                <td>
                                    <div style="display:flex;align-items:center;gap:8px">
                                        <span class="v2-avatar v2-avatar-sm @AvatarGrad(m.Name)">@Initials(m.Name)</span>
                                        <span class="sa-trunc" style="max-width:160px" title="@m.Name">@m.Name</span>
                                    </div>
                                </td>
                                <td class="v2-table-num">@m.BugsWorked</td>
                                <td class="v2-table-num v2-text-success">@m.Closed</td>
                                <td class="v2-table-num">@FmtHM(m.LoggedSeconds)</td>
                                <td class="v2-table-num">@m.DaysActive</td>
                            </tr>
                        }
                        @if (!ByContributor.Any()) { <tr><td colspan="5" class="sa-muted">No worklog activity in this sprint window</td></tr> }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private List<SprintConfig> _configs = new();
    private int _selectedConfigId = 0;
    private SprintConfig? _selected => _configs.FirstOrDefault(c => c.Id == _selectedConfigId);

    private List<SprintIssue> _bugs = new();
    private DateOnly _sprintStart = DateOnly.FromDateTime(DateTime.Today.AddDays(-13));
    private DateOnly _sprintEnd   = DateOnly.FromDateTime(DateTime.Today);
    private bool _loading;
    private string _error = "";
    private bool _chartsNeedRender;
    private string _jiraBase => Config["Jira:BaseUrl"]?.TrimEnd('/') ?? "";

    // ── Lifecycle ───────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        _configs = await SprintConfigService.GetAllAsync();
        var current = await SprintConfigService.GetCurrentAsync();
        _selectedConfigId = current?.Id ?? _configs.FirstOrDefault()?.Id ?? 0;
        if (_selected is not null) await LoadAsync();
    }

    private async Task OnConfigChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var id))
        {
            _selectedConfigId = id;
            await LoadAsync();
        }
    }

    private async Task LoadAsync()
    {
        if (_selected is null || string.IsNullOrWhiteSpace(_selected.EpicKey))
        {
            _error = _selected is null ? "" : "This sprint has no epic key configured.";
            _bugs = new();
            return;
        }
        _loading = true;
        _error = "";
        _bugs = new();
        _sprintStart = _selected.StartDate;
        _sprintEnd   = _selected.EndDate;
        StateHasChanged();
        try
        {
            var report = await JiraService.GetEpicBugsAsync(_selected.EpicKey.Trim().ToUpperInvariant());
            _bugs = report.Issues ?? new();
            _chartsNeedRender = true;
        }
        catch (Exception ex)
        {
            _error = $"Failed to load bugs for {_selected.EpicKey}: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_chartsNeedRender && _bugs.Count > 0)
        {
            _chartsNeedRender = false;
            await RenderChartsAsync();
        }
    }

    // ── Window helpers ──────────────────────────────────────────────────────
    private bool InWindow(DateTime? d) =>
        d.HasValue && DateOnly.FromDateTime(d.Value) >= _sprintStart && DateOnly.FromDateTime(d.Value) <= _sprintEnd;

    private bool IsInSprintPeriod(WorklogEntry w) => InWindow(w.Started);
    private int GetSprintTimeSeconds(SprintIssue b) => b.Worklogs.Where(IsInSprintPeriod).Sum(w => w.TimeSpentSeconds);
    private List<WorklogEntry> SprintWorklogs(SprintIssue b) => b.Worklogs.Where(IsInSprintPeriod).ToList();
    private static DateTime? LastActivity(SprintIssue b) => b.Worklogs.Count > 0 ? b.Worklogs.Max(w => w.Started) : null;

    private static bool IsDone(SprintIssue b) =>
        b.StatusCategoryKey == "done" || string.Equals(b.Status, "done", StringComparison.OrdinalIgnoreCase);
    private static bool IsInProgress(SprintIssue b) =>
        b.StatusCategoryKey == "indeterminate" || string.Equals(b.Status, "in progress", StringComparison.OrdinalIgnoreCase);
    private bool IsStale(SprintIssue b) =>
        IsInProgress(b) && (LastActivity(b) is null || (DateTime.Now - LastActivity(b)!.Value).TotalHours > 24);

    private bool WorkedOnThisSprint(SprintIssue b) => b.Worklogs.Any(IsInSprintPeriod);
    private bool StartedThisSprint(SprintIssue b) =>
        b.Worklogs.Count > 0 && InWindow(b.Worklogs.Min(w => w.Started));
    private bool CreatedThisSprint(SprintIssue b) => InWindow(b.Created);
    private bool ClosedThisSprint(SprintIssue b) => InWindow(b.ResolutionDate);

    private static int GetDaysOpen(SprintIssue b) =>
        b.Created.HasValue ? Math.Max(0, (int)(DateTime.Today - b.Created.Value.Date).TotalDays) : 0;

    private string GetHealth(SprintIssue b)
    {
        if (IsDone(b)) return "done";
        if (!b.DueDate.HasValue) return "no-due-date";
        if (b.DueDate.Value.Date <= DateTime.Today) return "overdue";
        return (b.DueDate.Value.Date - DateTime.Today).Days <= 7 ? "at-risk" : "on-track";
    }

    private static int GetSlaDays(SprintIssue b) => b.Priority?.ToLowerInvariant() switch
    {
        "critical" or "highest" => 1,
        "high"                  => 7,
        "medium"                => 14,
        _                       => 30
    };
    private string GetSlaBucket(SprintIssue b)
    {
        if (IsDone(b)) return "done";
        return GetDaysOpen(b) - GetSlaDays(b) <= 0 ? "inside" : "breached";
    }

    // ── Lifecycle metrics ───────────────────────────────────────────────────
    private int OpenCount               => _bugs.Count(b => !IsDone(b));
    private int DoneCount               => _bugs.Count(IsDone);
    private int InProgressCount         => _bugs.Count(IsInProgress);
    private int CreatedThisSprintCount  => _bugs.Count(CreatedThisSprint);
    private int WorkedOnCount           => _bugs.Count(WorkedOnThisSprint);
    private int StartedThisSprintCount  => _bugs.Count(StartedThisSprint);
    private int ClosedThisSprintCount   => _bugs.Count(ClosedThisSprint);
    private int StartedAndClosedCount   => _bugs.Count(b => ClosedThisSprint(b) && StartedThisSprint(b));
    private int CarriedOverOpenCount    => _bugs.Count(b => !IsDone(b) && b.Created.HasValue && DateOnly.FromDateTime(b.Created.Value) < _sprintStart);
    private int ReopenedCount           => _bugs.Count(b => b.QaRejectedCount > 0);

    // ── Effort metrics ──────────────────────────────────────────────────────
    private int SprintLoggedSeconds     => _bugs.Sum(GetSprintTimeSeconds);
    private int TotalLoggedSeconds      => _bugs.Sum(b => b.TimeSpentSeconds);
    private int RemainingSeconds        => _bugs.Where(b => !IsDone(b)).Sum(b => b.ComputedRemainingSeconds);
    private int SprintWorklogCount      => _bugs.Sum(b => b.Worklogs.Count(IsInSprintPeriod));
    private int BugsNoTimeOpen          => _bugs.Count(b => !IsDone(b) && b.TimeSpentSeconds == 0);

    private int AvgLoggedPerBugSeconds
    {
        get { var w = _bugs.Where(b => b.TimeSpentSeconds > 0).ToList(); return w.Count == 0 ? 0 : (int)w.Average(b => b.TimeSpentSeconds); }
    }

    private double? AvgResolveDays
    {
        get
        {
            var closed = _bugs.Where(b => ClosedThisSprint(b) && b.Created.HasValue).ToList();
            if (closed.Count == 0) return null;
            return closed.Average(b => (b.ResolutionDate!.Value.Date - b.Created!.Value.Date).TotalDays);
        }
    }

    private int TotalWeekdays   => CountWeekdays(_sprintStart, _sprintEnd);
    private int WeekdaysElapsed
    {
        get { var today = DateOnly.FromDateTime(DateTime.Today); var end = today < _sprintEnd ? today : _sprintEnd; return end < _sprintStart ? 0 : CountWeekdays(_sprintStart, end); }
    }
    private double DailyBurnHours => WeekdaysElapsed <= 0 ? 0 : SprintLoggedSeconds / 3600.0 / WeekdaysElapsed;

    // ── Health / SLA / aging ────────────────────────────────────────────────
    private int OverdueCount    => _bugs.Count(b => GetHealth(b) == "overdue");
    private int AtRiskCount     => _bugs.Count(b => GetHealth(b) == "at-risk");
    private int OnTrackCount    => _bugs.Count(b => GetHealth(b) == "on-track");
    private int NoDueDateCount  => _bugs.Count(b => GetHealth(b) == "no-due-date");
    private int StaleCount      => _bugs.Count(IsStale);
    private int SlaBreachedCount => _bugs.Count(b => GetSlaBucket(b) == "breached");
    private double AvgOpenAgeDays
    {
        get { var open = _bugs.Where(b => !IsDone(b)).ToList(); return open.Count == 0 ? 0 : open.Average(GetDaysOpen); }
    }
    private IEnumerable<SprintIssue> OldestOpen =>
        _bugs.Where(b => !IsDone(b)).OrderByDescending(GetDaysOpen).Take(10);

    // ── Breakdowns ──────────────────────────────────────────────────────────
    private record CustomerStat(string Name, int Total, int Closed, int LoggedSeconds);
    private IEnumerable<CustomerStat> ByCustomer =>
        _bugs.Where(b => !string.IsNullOrWhiteSpace(b.Customer))
             .GroupBy(b => b.Customer)
             .Select(g => new CustomerStat(g.Key, g.Count(), g.Count(IsDone), g.Sum(b => b.TimeSpentSeconds)))
             .OrderByDescending(c => c.Total).Take(12);

    private record LabelStat(string Name, int Total, int Closed, int LoggedSeconds);
    private IEnumerable<LabelStat> ByLabel =>
        _bugs.SelectMany(b => (b.Labels ?? new()).Select(l => (Label: l, Bug: b)))
             .Where(x => !string.IsNullOrWhiteSpace(x.Label))
             .GroupBy(x => x.Label)
             .Select(g => new LabelStat(g.Key, g.Count(), g.Count(x => IsDone(x.Bug)), g.Sum(x => x.Bug.TimeSpentSeconds)))
             .OrderByDescending(l => l.Total).Take(12);

    private record PriorityStat(string Name, int SlaDays, int Open, int Inside, int Breached);
    private static readonly string[] PriorityOrder = { "Critical", "Highest", "High", "Medium", "Low", "Lowest" };
    private IEnumerable<PriorityStat> SlaByPriority =>
        _bugs.GroupBy(b => string.IsNullOrWhiteSpace(b.Priority) ? "Medium" : b.Priority)
             .Select(g => new PriorityStat(
                 g.Key,
                 GetSlaDays(g.First()),
                 g.Count(b => !IsDone(b)),
                 g.Count(b => GetSlaBucket(b) == "inside"),
                 g.Count(b => GetSlaBucket(b) == "breached")))
             .OrderBy(p => { var i = Array.IndexOf(PriorityOrder, p.Name); return i < 0 ? 99 : i; });

    private record ContributorStat(string Name, int BugsWorked, int Closed, int LoggedSeconds, int DaysActive);
    private IEnumerable<ContributorStat> ByContributor
    {
        get
        {
            return _bugs
                .SelectMany(b => SprintWorklogs(b).Select(w => (Bug: b, Wl: w)))
                .GroupBy(x => string.IsNullOrWhiteSpace(x.Wl.Author) ? "Unknown" : x.Wl.Author)
                .Select(g => new ContributorStat(
                    g.Key,
                    g.Select(x => x.Bug.Key).Distinct().Count(),
                    g.Where(x => ClosedThisSprint(x.Bug)).Select(x => x.Bug.Key).Distinct().Count(),
                    g.Sum(x => x.Wl.TimeSpentSeconds),
                    g.Select(x => DateOnly.FromDateTime(x.Wl.Started)).Distinct().Count()))
                .OrderByDescending(c => c.LoggedSeconds);
        }
    }

    // ── Charts ──────────────────────────────────────────────────────────────
    private async Task RenderChartsAsync()
    {
        foreach (var id in new[] { "sa-chart-funnel", "sa-chart-resolved", "sa-chart-age" })
            await JS.InvokeVoidAsync("destroyChart", id);

        // Funnel
        await JS.InvokeVoidAsync("renderChart", "sa-chart-funnel", new
        {
            type = "bar",
            data = new
            {
                labels = new[] { "Created", "Worked on", "Started", "Closed", "Start+Close" },
                datasets = new[] { new
                {
                    label = "Bugs",
                    data = new[] { CreatedThisSprintCount, WorkedOnCount, StartedThisSprintCount, ClosedThisSprintCount, StartedAndClosedCount },
                    backgroundColor = new[] { "#94a3b8", "#2563eb", "#6366f1", "#16a34a", "#0ea5e9" },
                    borderRadius = 4
                }}
            },
            options = new
            {
                responsive = true,
                maintainAspectRatio = false,
                plugins = new { legend = new { display = false } },
                scales = new { y = new { beginAtZero = true, ticks = new { precision = 0 } } }
            }
        });

        // Resolutions per day
        var days = Enumerable.Range(0, Math.Max(1, _sprintEnd.DayNumber - _sprintStart.DayNumber + 1))
                             .Select(i => _sprintStart.AddDays(i)).ToList();
        var dayLabels = days.Select(d => d.ToString("MMM d")).ToArray();
        var resolved  = days.Select(d => _bugs.Count(b => b.ResolutionDate.HasValue && DateOnly.FromDateTime(b.ResolutionDate.Value) == d)).ToArray();
        await JS.InvokeVoidAsync("renderChart", "sa-chart-resolved", new
        {
            type = "bar",
            data = new
            {
                labels = dayLabels,
                datasets = new[] { new
                {
                    label = "Resolved",
                    data = resolved,
                    backgroundColor = "#16a34a",
                    borderRadius = 3
                }}
            },
            options = new
            {
                responsive = true,
                maintainAspectRatio = false,
                plugins = new { legend = new { display = false } },
                scales = new { y = new { beginAtZero = true, ticks = new { precision = 0 } } }
            }
        });

        // Age buckets (open only)
        var open = _bugs.Where(b => !IsDone(b)).ToList();
        await JS.InvokeVoidAsync("renderChart", "sa-chart-age", new
        {
            type = "bar",
            data = new
            {
                labels = new[] { "Fresh <7d", "Recent 7–30d", "Aging 30–90d", "Old >90d" },
                datasets = new[] { new
                {
                    label = "Open bugs",
                    data = new[]
                    {
                        open.Count(b => GetDaysOpen(b) < 7),
                        open.Count(b => GetDaysOpen(b) >= 7  && GetDaysOpen(b) < 30),
                        open.Count(b => GetDaysOpen(b) >= 30 && GetDaysOpen(b) < 90),
                        open.Count(b => GetDaysOpen(b) >= 90)
                    },
                    backgroundColor = new[] { "#16a34a", "#2563eb", "#b45309", "#b91c1c" },
                    borderRadius = 4
                }}
            },
            options = new
            {
                responsive = true,
                maintainAspectRatio = false,
                plugins = new { legend = new { display = false } },
                scales = new { y = new { beginAtZero = true, ticks = new { precision = 0 } } }
            }
        });
    }

    // ── Formatting helpers ──────────────────────────────────────────────────
    private static int CountWeekdays(DateOnly from, DateOnly to)
    {
        if (to < from) return 0;
        int count = 0;
        for (var d = from; d <= to; d = d.AddDays(1))
            if (d.DayOfWeek != DayOfWeek.Saturday && d.DayOfWeek != DayOfWeek.Sunday) count++;
        return count;
    }

    private static string FmtHM(int seconds)
    {
        if (seconds <= 0) return "0h";
        var h = seconds / 3600; var m = (seconds % 3600) / 60;
        if (h == 0) return $"{m}m";
        return m > 0 ? $"{h}h {m}m" : $"{h}h";
    }

    private static int Pct(int part, int whole) => whole <= 0 ? 0 : Math.Min(100, part * 100 / whole);

    private bool IsCurrent(SprintConfig c)
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        return c.StartDate <= today && c.EndDate >= today;
    }

    private static string PriorityPill(string? p) => p?.ToLowerInvariant() switch
    {
        "critical" or "highest" => "v2-pill-danger",
        "high"                  => "v2-pill-warn",
        "medium"                => "v2-pill-brand",
        _                       => "v2-pill-neutral"
    };

    private static string AvatarGrad(string name) => $"v2-avatar-grad-{1 + (Math.Abs(name.GetHashCode()) % 5)}";
    private static string Initials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0) return "?";
        return parts.Length == 1 ? parts[0][..1].ToUpper() : (parts[0][..1] + parts[^1][..1]).ToUpper();
    }
}

