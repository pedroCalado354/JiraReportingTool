    private async Task BuildCompactSheetAsync(XLWorkbook wb, string sprintLabel, string dateRangeLabel, string productLabel, string exportedAt)
    {
        var ws = wb.Worksheets.Add("Summary");
        int row = 1;

        void Meta(string label, string value)
        {
            var lc = ws.Cell(row, 1); lc.Value = label; StyleMetaLabel(lc);
            ws.Cell(row, 2).Value = value;
            row++;
        }

        void SectionTitle(string title)
        {
            var c = ws.Cell(row, 1); c.Value = title; c.Style.Font.Bold = true; c.Style.Font.FontSize = 13;
            row++;
        }

        Meta("Sprint", sprintLabel);
        Meta("Date Range", dateRangeLabel);
        Meta("Products", productLabel);
        Meta("Exported", exportedAt);
        row++;

        if (AllBugSplit is not null)
        {
            SectionTitle("Bug vs Feature Split");
            Meta("Bug %", $"{AllBugSplit.BugPct:F0}%");
            Meta("Bugs", $"{AllBugSplit.BugCount} issues · {AllBugSplit.BugHours:F0}h logged");
            Meta("Feature / Task", $"{AllBugSplit.FeatureCount} issues · {AllBugSplit.FeatureHours:F0}h logged");
            row++;
        }

        if (AllBugOriginSplit is not null && (AllBugOriginSplit.SupportLinkedCount + AllBugOriginSplit.FeatureFoundCount) > 0)
        {
            SectionTitle("Bug Origin");
            Meta("Support-linked %", $"{AllBugOriginSplit.SupportLinkedPct:F0}%");
            Meta("JSSUPPORT-linked", $"{AllBugOriginSplit.SupportLinkedCount} bugs · {AllBugOriginSplit.SupportLinkedHours:F0}h logged");
            Meta("Feature-found", $"{AllBugOriginSplit.FeatureFoundCount} bugs · {AllBugOriginSplit.FeatureFoundHours:F0}h logged");
            row++;
        }

        if (TaskMetrics is not null)
        {
            var t = TaskMetrics;
            var delta = t.SprintWindowLoggedHours - t.PlannedHours;
            var deltaPct = t.PlannedHours > 0 ? Math.Abs(delta) / t.PlannedHours * 100 : 0;
            SectionTitle("Planned vs Worked — Delivery Work");
            Meta("Planned", $"{t.PlannedHours:F0}h");
            Meta("Logged", $"{t.SprintWindowLoggedHours:F0}h");
            Meta("Delta", delta > 0 ? $"+{delta:F0}h ({deltaPct:F0}% over)" : delta < 0 ? $"{delta:F0}h ({deltaPct:F0}% under)" : "on plan");
            row++;
        }

        SectionTitle("Delivery Burndown — Delivery Work");
        string? dataUrl = null;
        try { dataUrl = await JS.InvokeAsync<string?>("getChartImage", "chart-burndown-task"); } catch { }

        if (!string.IsNullOrEmpty(dataUrl))
        {
            var comma = dataUrl.IndexOf(',');
            var base64Img = comma >= 0 ? dataUrl[(comma + 1)..] : dataUrl;
            var bytes = Convert.FromBase64String(base64Img);
            using var imgStream = new MemoryStream(bytes);
            ws.AddPicture(imgStream, XLPictureFormat.Png)
              .MoveTo(ws.Cell(row, 1))
              .WithSize(640, 340);
        }
        else
        {
            ws.Cell(row, 1).Value = "(chart not available — no data for current filters)";
        }

        ws.Columns().AdjustToContents();
    }

    private void BuildOverviewSheet(XLWorkbook wb, string sprintLabel, string dateRangeLabel, string productLabel, string sprintFilterLabel, string exportedAt)
    {
        var ws = wb.Worksheets.Add("Overview");
        int row = 1;
        void Meta(string label, string value)
        {
            var lc = ws.Cell(row, 1); lc.Value = label; StyleMetaLabel(lc);
            ws.Cell(row, 2).Value = value;
            row++;
        }

        Meta("Sprint", sprintLabel);
        Meta("Date Range", dateRangeLabel);
        Meta("Products", productLabel);
        Meta("Sprint Filter", sprintFilterLabel);
        Meta("Exported", exportedAt);
        row++;

        var h1 = ws.Cell(row, 1); h1.Value = "Metric";           StyleHeaderCell(h1);
        var h2 = ws.Cell(row, 2); h2.Value = "Delivery Work";    StyleHeaderCell(h2);
        var h3 = ws.Cell(row, 3); h3.Value = "All Issue Types";  StyleHeaderCell(h3);
        row++;

        void Kpi(string label, string taskVal, string allVal)
        {
            ws.Cell(row, 1).Value = label; ws.Cell(row, 1).Style.Font.Bold = true;
            ws.Cell(row, 2).Value = taskVal;
            ws.Cell(row, 3).Value = allVal;
            row++;
        }

        var t = TaskMetrics!; var a = AllMetrics!;
        Kpi("Sprint Health Score",         $"{t.Score} ({t.Band})", $"{a.Score} ({a.Band})");
        Kpi("Message",                     t.Message, a.Message);
        Kpi("Time Elapsed",                $"{t.TimeElapsedPct:F0}%", $"{a.TimeElapsedPct:F0}%");
        Kpi("Completion",                  $"{t.CompletionPct:F0}%", $"{a.CompletionPct:F0}%");
        Kpi("Done / In Progress / To Do",  $"{t.DoneCount} / {t.InProgressCount} / {t.ToDoCount}", $"{a.DoneCount} / {a.InProgressCount} / {a.ToDoCount}");
        Kpi("Planned Hours",               $"{t.PlannedHours:F0}h", $"{a.PlannedHours:F0}h");
        Kpi("Full-Sprint Capacity",        $"{t.FullSprintCapacityHours:F0}h", $"{a.FullSprintCapacityHours:F0}h");
        Kpi("Remaining Capacity",          $"{t.CapacityHours:F0}h", $"{a.CapacityHours:F0}h");
        Kpi("Remaining Work",              $"{t.RemainingHours:F0}h", $"{a.RemainingHours:F0}h");
        Kpi("Logged Hours (window)",       $"{t.SprintWindowLoggedHours:F0}h", $"{a.SprintWindowLoggedHours:F0}h");
        Kpi("Hours / Workday",             $"{t.HoursLoggedPerWorkday:F1}h", $"{a.HoursLoggedPerWorkday:F1}h");
        Kpi("Projected Finish",            $"{t.ProjectedFinishHours:F0}h", $"{a.ProjectedFinishHours:F0}h");
        Kpi("Idle Tasks",                  $"{t.IdleActiveCount} of {t.InProgressCount}", $"{a.IdleActiveCount} of {a.InProgressCount}");
        Kpi("Stale (2d+ no worklog)",      t.StaleCount.ToString(), a.StaleCount.ToString());
        Kpi("Velocity / day (needed)",     $"{t.ThroughputPerDay:F1} ({t.NeededThroughputPerDay:F1})", $"{a.ThroughputPerDay:F1} ({a.NeededThroughputPerDay:F1})");
        Kpi("Unassigned",                  t.UnassignedCount.ToString(), a.UnassignedCount.ToString());
        Kpi("Estimation Coverage",         $"{t.EstimationCoveragePct:F0}%", $"{a.EstimationCoveragePct:F0}%");
        if (AllScopeAdded is not null)
        {
            var pctUnplanned = a.FullSprintCapacityHours > 0 ? AllScopeAdded.TimeLoggedHours / a.FullSprintCapacityHours * 100 : 0;
            Kpi("Cost of Unplanned Work",  "—", $"{AllScopeAdded.TimeLoggedHours:F0}h ({pctUnplanned:F0}% of capacity)");
        }

        ws.Columns().AdjustToContents();
    }

    private async Task BuildChartsSheetAsync(XLWorkbook wb)
    {
        var ws = wb.Worksheets.Add("Charts");
        int row = 1;
        foreach (var (canvasId, title) in ChartExports)
        {
            var titleCell = ws.Cell(row, 1);
            titleCell.Value = title;
            titleCell.Style.Font.Bold = true;
            titleCell.Style.Font.FontSize = 13;
            row++;

            string? dataUrl = null;
            try { dataUrl = await JS.InvokeAsync<string?>("getChartImage", canvasId); } catch { }

            if (!string.IsNullOrEmpty(dataUrl))
            {
                var comma = dataUrl.IndexOf(',');
                var base64Img = comma >= 0 ? dataUrl[(comma + 1)..] : dataUrl;
                var bytes = Convert.FromBase64String(base64Img);
                using var imgStream = new MemoryStream(bytes);
                ws.AddPicture(imgStream, XLPictureFormat.Png)
                  .MoveTo(ws.Cell(row, 1))
                  .WithSize(640, 340);
                row += 18;
            }
            else
            {
                ws.Cell(row, 1).Value = "(chart not available — no data for current filters)";
                row += 1;
            }
            row += 2;
        }
        ws.Column(1).Width = 16;
    }

    private void BuildProductsSheet(XLWorkbook wb)
    {
        var ws = wb.Worksheets.Add("Products");
        var h1 = ws.Cell(1, 1); h1.Value = "Product"; StyleHeaderCell(h1);
        var h2 = ws.Cell(1, 2); h2.Value = "Tickets";  StyleHeaderCell(h2);
        ws.SheetView.FreezeRows(1);

        int row = 2;
        foreach (var (name, count) in AllProducts)
        {
            if (row % 2 == 0) ws.Row(row).Style.Fill.BackgroundColor = XLColor.FromHtml("#f8f9fa");
            ws.Cell(row, 1).Value = name;
            ws.Cell(row, 1).Style.Font.Bold = SelectedProducts.Contains(name);
            ws.Cell(row, 2).Value = count;
            row++;
        }
        if (AllProducts.Count > 0)
        {
            ws.Cell(row, 1).Value = "TOTAL"; ws.Cell(row, 1).Style.Font.Bold = true;
            ws.Cell(row, 2).Value = AllProducts.Sum(p => p.Count); ws.Cell(row, 2).Style.Font.Bold = true;
            ws.Row(row).Style.Fill.BackgroundColor = XLColor.FromHtml("#e9ecef");
        }
        ws.Columns().AdjustToContents();
        ws.Row(1).Height = 22;
    }

