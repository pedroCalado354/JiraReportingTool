@page "/delivery-reports"
@rendermode InteractiveServer
@inject IJiraService JiraService
@inject SprintConfigService SprintConfigService
@inject TeamRosterService RosterService
@inject IJSRuntime JS
@inject IConfiguration Config
@using JiraReportingTool.Models
@using ClosedXML.Excel
@using ClosedXML.Excel.Drawings

<PageTitle>Delivery Reports</PageTitle>

<div class="v2-root" id="dr-report-root">

    <!-- ═══ HERO ═════════════════════════════════════════════════════════════ -->
    <div class="v2-hero">
        <div class="v2-hero-row">
            <div class="v2-hero-icon"><i class="bi bi-file-earmark-bar-graph"></i></div>
            <div class="v2-hero-titles">
                <span class="v2-eyebrow">Executive Summary</span>
                <h1 class="v2-hero-title">Delivery Reports</h1>
                <span class="v2-hero-sub">
                    @if (Report is not null)
                    {
                        <strong>@(Report.SprintName is { Length: > 0 } sn ? sn : "Sprint")</strong>
                        @if (Report.StartDate.HasValue && Report.EndDate.HasValue)
                        {
                            <span> · @Report.StartDate.Value.ToString("MMM d") – @Report.EndDate.Value.ToString("MMM d, yyyy")</span>
                        }
                    }
                    else
                    {
                        <span>Sprint status, delivery, hours, velocity and scope — at a glance</span>
                    }
                </span>
            </div>
            <div class="v2-hero-spacer"></div>
            @if (Report is not null)
            {
                <span class="v2-pill v2-pill-neutral"><i class="bi bi-calendar3"></i> @Report.DaysRemaining d left</span>
            }
        </div>
    </div>

    <!-- ═══ SPRINT PICKER ═══════════════════════════════════════════════════ -->
    <div class="v2-control-bar dr-export-skip">
        <div class="v2-field" style="min-width:280px">
            <label class="v2-label">Sprint</label>
            <select class="v2-select" @bind="SprintId" @bind:after="OnSprintPicked">
                <option value="">— pick a sprint —</option>
                @foreach (var s in _knownSprints)
                {
                    <option value="@s.SprintId">@SprintLabel(s)</option>
                }
            </select>
        </div>
        <div class="v2-hero-spacer"></div>
        @if (Report is not null)
        {
            <button class="dr-export-btn" @onclick="ExportToExcel" disabled="@IsExporting">
                @if (IsExporting) { <span class="v2-spin" style="width:12px;height:12px"></span> }
                else { <i class="bi bi-download"></i> }
                Export .xlsx
            </button>
            <button class="dr-export-btn" @onclick="ExportToHtml" disabled="@IsExportingHtml">
                @if (IsExportingHtml) { <span class="v2-spin" style="width:12px;height:12px"></span> }
                else { <i class="bi bi-filetype-html"></i> }
                Export .html
            </button>
            <button class="dr-export-btn dr-export-btn-compact" @onclick="ExportToExcelCompact" disabled="@IsExportingCompact" title="Bug vs Feature Split, Bug Origin, Planned vs Worked and Delivery Burndown for Delivery Work only">
                @if (IsExportingCompact) { <span class="v2-spin" style="width:12px;height:12px"></span> }
                else { <i class="bi bi-file-earmark-spreadsheet"></i> }
                Export Compact
            </button>
        }
    </div>

    @if (IsLoading)
    {
        <div class="v2-card" style="margin-bottom:16px;display:flex;align-items:center;gap:14px">
            <span class="v2-spin" style="border-color:rgba(99,102,241,0.20);border-top-color:var(--v2-brand);width:20px;height:20px"></span>
            <div>
                <div style="font-weight:700;font-size:13px;color:var(--v2-ink-1)">Loading sprint data…</div>
                <div class="v2-hint">@(_loadingStatus ?? "Working…")</div>
            </div>
        </div>
    }

    @if (ErrorMessage != null)
    {
        <div class="v2-alert v2-alert-error"><i class="bi bi-exclamation-triangle-fill"></i> @ErrorMessage</div>
    }

    @if (Report is null && !IsLoading)
    {
        <div class="v2-empty">
            <div class="v2-empty-icon"><i class="bi bi-file-earmark-bar-graph"></i></div>
            <div class="v2-empty-title">Pick a sprint to build the report</div>
            <div>A director-facing summary of sprint status, delivery, logged hours, velocity and scope change — for Delivery Work and All Issue Types.</div>
        </div>
    }

    @if (Report is not null && AllProducts.Count > 0)
    {
        <div class="v2-card" style="margin-top:16px">
            <div class="v2-section-title"><i class="bi bi-grid-fill"></i>Product <span class="v2-section-note">by worklog date within @(Report.StartDate?.ToString("MMM d")) – @(Report.EndDate?.ToString("MMM d")), not Jira sprint membership — filter, or leave all selected to view every product merged</span></div>
            <div class="dr-chip-row dr-export-skip">
                @foreach (var (name, count) in AllProducts)
                {
                    var n = name;
                    <button type="button" class="dr-chip @(SelectedProducts.Contains(n) ? "dr-chip-on" : "")" @onclick="() => ToggleProduct(n)">
                        @if (SelectedProducts.Contains(n)) { <i class="bi bi-check2"></i> }
                        @n <span class="dr-chip-n">@count</span>
                    </button>
                }
            </div>
            <div class="v2-hint" style="margin-top:8px;display:flex;align-items:center;gap:10px;flex-wrap:wrap">
                <span>@SelectedProducts.Count of @AllProducts.Count selected@(SelectedProducts.Count == AllProducts.Count ? " — all products merged" : "")</span>
                <button type="button" class="dr-link-btn dr-export-skip" @onclick="SelectAllProducts">All</button>
                <span class="dr-dot-sep dr-export-skip">·</span>
                <button type="button" class="dr-link-btn dr-export-skip" @onclick="ClearProducts">None</button>
                <span class="dr-dot-sep dr-export-skip">·</span>
                <button type="button" class="dr-link-btn dr-export-skip" @onclick="OpenTicketsModal"><i class="bi bi-table"></i> View @FilteredIssues.Count ticket@(FilteredIssues.Count == 1 ? "" : "s")</button>
            </div>

            @if (AvailableSprints.Count > 0 || NoSprintIssueCount > 0)
            {
                <div class="dr-export-skip" style="margin-top:12px;padding-top:12px;border-top:1px solid var(--v2-divider);display:flex;align-items:center;gap:10px;flex-wrap:wrap">
                    <label class="v2-label" style="margin:0">Sprint</label>
                    <select class="v2-select v2-input-sm" style="max-width:320px" @onchange="OnSprintFilterChanged">
                        <option value="">All sprints in this window</option>
                        @foreach (var s in AvailableSprints)
                        {
                            <option value="@s.Id" selected="@(SelectedSprintId == s.Id)">@s.Name@(s.StartDate.HasValue ? $" ({s.StartDate:MMM d}–{s.EndDate:MMM d})" : "")</option>
                        }
                        @if (NoSprintIssueCount > 0)
                        {
                            <option value="0" selected="@(SelectedSprintId == 0)">No sprint (@NoSprintIssueCount) — never added to a sprint</option>
                        }
                    </select>
                    <span class="v2-hint">real Jira sprints found on the selected product(s)' issues — narrows further within the window above@(NoSprintIssueCount > 0 ? $"; {NoSprintIssueCount} ticket{(NoSprintIssueCount == 1 ? "" : "s")} logged time here with no sprint at all" : "")</span>
                </div>
            }
        </div>
    }

    @if (Report is not null && AllBugSplit is not null)
    {
        <div class="v2-card" style="margin-top:16px">
            <div class="v2-section-title"><i class="bi bi-bug-fill" style="color:var(--v2-danger)"></i>Bug vs Feature Split <span class="v2-section-note">firefighting vs building — All Issue Types, current product filter</span></div>
            <div style="display:flex;align-items:center;gap:28px;flex-wrap:wrap">
                <div class="v2-donut v2-donut-lg" style="--p:@(AllBugSplit.BugPct.ToString(System.Globalization.CultureInfo.InvariantCulture));--c1:var(--v2-danger)">
                    <span>@AllBugSplit.BugPct.ToString("F0")%</span>
                </div>
                <div style="display:flex;flex-direction:column;gap:8px">
                    <div class="v2-row"><span class="v2-chip v2-chip-bug">Bug</span><span class="v2-row-value">@AllBugSplit.BugCount issues &middot; @AllBugSplit.BugHours.ToString("F0")h logged</span></div>
                    <div class="v2-row"><span class="v2-chip v2-chip-story">Feature / Task</span><span class="v2-row-value">@AllBugSplit.FeatureCount issues &middot; @AllBugSplit.FeatureHours.ToString("F0")h logged</span></div>
                </div>
                <div class="v2-hint" style="max-width:260px">@(AllBugSplit.BugPct >= 40 ? "A large share of logged time is going to bugs — the team may be firefighting more than building." : "Most logged time is going toward feature/task work.")</div>
            </div>

            @if (BugsByEpic.Count > 0)
            {
                @RenderEpicTable("Bugs by Epic", "closed this sprint vs still open, avg effort per issue", BugsByEpic, skipInHtmlExport: true)
            }
            @if (FeaturesByEpic.Count > 0)
            {
                @RenderEpicTable("Tasks by Epic", "closed this sprint vs still open, avg effort per issue", FeaturesByEpic, skipInHtmlExport: true)
            }

            @if (AllBugOriginSplit is not null && (AllBugOriginSplit.SupportLinkedCount + AllBugOriginSplit.FeatureFoundCount) > 0)
            {
                <div class="v2-divider"></div>
                <div class="v2-section-title" style="margin-top:4px">
                    <i class="bi bi-pie-chart-fill" style="color:var(--v2-info)"></i>Bug Origin
                    <span class="v2-section-note">JSSUPPORT-linked vs feature-found, of the @(AllBugOriginSplit.SupportLinkedCount + AllBugOriginSplit.FeatureFoundCount) bugs above</span>
                </div>
                <div style="display:flex;align-items:center;gap:28px;flex-wrap:wrap">
                    <div class="v2-donut v2-donut-lg" style="--p:@(AllBugOriginSplit.SupportLinkedPct.ToString(System.Globalization.CultureInfo.InvariantCulture));--c1:var(--v2-danger)">
                        <span>@AllBugOriginSplit.SupportLinkedPct.ToString("F0")%</span>
                    </div>
                    <div style="display:flex;flex-direction:column;gap:8px">
                        <div class="v2-row"><span class="v2-chip v2-chip-bug">JSSUPPORT-linked</span><span class="v2-row-value">@AllBugOriginSplit.SupportLinkedCount bugs &middot; @AllBugOriginSplit.SupportLinkedHours.ToString("F0")h logged</span></div>
                        <div class="v2-row"><span class="v2-chip v2-chip-task">Feature-found</span><span class="v2-row-value">@AllBugOriginSplit.FeatureFoundCount bugs &middot; @AllBugOriginSplit.FeatureFoundHours.ToString("F0")h logged</span></div>
                    </div>
                    <div class="v2-hint" style="max-width:260px">@AllBugOriginSplit.SupportLinkedPct.ToString("F0")% of bugs trace back to a customer-reported JSSUPPORT ticket rather than being found during feature work.</div>
                </div>

                @if (SupportBugsByEpic.Count > 0)
                {
                    @RenderEpicTable("JSSUPPORT-linked Bugs by Epic", "closed this sprint vs still open, hours logged, avg effort per issue", SupportBugsByEpic)
                }

                @if (SupportBugTypeSplitStat is not null)
                {
                    <div class="v2-kpi-grid" style="margin-top:12px;margin-bottom:0">
                        <div class="v2-kpi v2-kpi-neutral">
                            <div class="v2-kpi-head"><i class="bi bi-stopwatch"></i>Avg Effort per Issue</div>
                            <div style="display:flex;gap:20px;flex-wrap:wrap;margin-top:2px">
                                <div>
                                    <div class="v2-kpi-value" style="font-size:22px">@SupportBugAvgEffortHours.ToString("F1")h</div>
                                    <div class="v2-kpi-sub">to conclude (closed)</div>
                                </div>
                                <div>
                                    <div class="v2-kpi-value" style="font-size:22px">@SupportBugAvgEffortOngoingHours.ToString("F1")h</div>
                                    <div class="v2-kpi-sub">ongoing (still open)</div>
                                </div>
                            </div>
                        </div>
                        <div class="v2-kpi v2-kpi-neutral">
                            <div class="v2-kpi-head"><i class="bi bi-flag"></i>Priority Breakdown</div>
                            <div style="display:flex;flex-wrap:wrap;gap:6px;margin-top:6px">
                                @foreach (var p in SupportBugPriorityBreakdown)
                                {
                                    <span class="v2-chip v2-chip-pri-@(p.Priority.ToLower())">@p.Priority (@p.Count)</span>
                                }
                            </div>
                        </div>
                        <div class="v2-kpi v2-kpi-neutral">
                            <div class="v2-kpi-head"><i class="bi bi-bug"></i>Bug vs Redesign</div>
                            <div style="display:flex;gap:8px;margin-top:6px;flex-wrap:wrap">
                                <span class="v2-chip v2-chip-bug">Bug (@SupportBugTypeSplitStat.BugTypeCount)</span>
                                <span class="v2-chip" style="background:#f3e8ff;color:#7c3aed">Redesign (@SupportBugTypeSplitStat.RedesignTypeCount)</span>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    }

    @if (Report is not null && EpicBreadth is not null)
    {
        <div class="v2-card" style="margin-top:16px">
            <div class="v2-section-title"><i class="bi bi-diagram-3-fill" style="color:var(--v2-brand)"></i>Epic Coverage <span class="v2-section-note">breadth of epics the team actively logged time on — All Issue Types, current product filter</span></div>
            <div style="display:flex;align-items:baseline;gap:28px;flex-wrap:wrap">
                <div class="v2-gauge-score">@EpicBreadth.EpicCount</div>
                <div class="v2-hint" style="max-width:420px">
                    @EpicBreadth.PctOfContributors.ToString("F0")% of the team (@EpicBreadth.ContributorsOnEpics of @EpicBreadth.TotalContributors contributors who logged time) worked in @EpicBreadth.EpicCount epic@(EpicBreadth.EpicCount == 1 ? "" : "s") this sprint.
                </div>
            </div>
            <div class="v2-row" style="margin-top:12px;padding-top:12px;border-top:1px solid var(--v2-divider)">
                <span class="v2-chip v2-chip-task">Focused</span>
                <span class="v2-row-value">@EpicBreadth.PctFocused.ToString("F0")% of the team (@EpicBreadth.FocusedContributors) worked in exactly 1 epic</span>
            </div>
            <div class="v2-row" style="margin-top:6px">
                <span class="v2-chip v2-chip-pri-high">Spread</span>
                <span class="v2-row-value">@EpicBreadth.PctSpread.ToString("F0")% of the team (@EpicBreadth.SpreadContributors) worked in 2 epics</span>
            </div>
            <div class="v2-row" style="margin-top:6px">
                <span class="v2-chip v2-chip-pri-highest">Critical</span>
                <span class="v2-row-value">@EpicBreadth.PctCritical.ToString("F0")% of the team (@EpicBreadth.CriticalContributors) worked in 3+ epics</span>
            </div>
            <div class="v2-hint" style="margin-top:8px">avg @EpicBreadth.AvgEpicsPerContributor.ToString("F1") epics per contributor</div>
        </div>
    }

    @if (Report is not null && TaskMetrics is not null && AllMetrics is not null)
    {
        @RenderSection("Delivery Work", "Task issue type only", TaskMetrics, TaskScopeAdded, TaskVelocitySparkline, TaskProductBreakdown, "task")
        @RenderSection("All Issue Types", "Every issue in the sprint", AllMetrics, AllScopeAdded, AllVelocitySparkline, null, "all")

        @if (AllScopeAdded is not null)
        {
            var pctUnplanned = AllMetrics.FullSprintCapacityHours > 0
                ? AllScopeAdded.TimeLoggedHours / AllMetrics.FullSprintCapacityHours * 100 : 0;
            var pctPlanned = AllMetrics.FullSprintCapacityHours > 0
                ? AllMetrics.PlannedHours / AllMetrics.FullSprintCapacityHours * 100 : 0;
            <div class="v2-card" style="margin-top:12px">
                <div class="v2-section-title"><i class="bi bi-cash-coin" style="color:var(--v2-danger)"></i>Cost &amp; Capacity <span class="v2-section-note">opportunity cost of unplanned work, in hours — All Issue Types, current product filter</span></div>
                <div class="v2-kpi-grid" style="margin-top:12px;margin-bottom:0">
                    <div class="v2-kpi v2-kpi-neutral">
                        <div class="v2-kpi-head"><i class="bi bi-clock-history"></i>Full-Sprint Capacity</div>
                        <div class="v2-kpi-value">@($"{AllMetrics.FullSprintCapacityHours:F0}h")</div>
                        <div class="v2-kpi-sub">total team hours available this sprint</div>
                    </div>
                    <div class="v2-kpi v2-kpi-neutral">
                        <div class="v2-kpi-head"><i class="bi bi-clipboard-check"></i>Planned Work</div>
                        <div class="v2-kpi-value">@($"{AllMetrics.PlannedHours:F0}h")</div>
                        <div class="v2-kpi-sub">@pctPlanned.ToString("F0")% of capacity committed to planned scope</div>
                    </div>
                    <div class="v2-kpi @(pctUnplanned > 25 ? "v2-kpi-danger" : pctUnplanned > 10 ? "v2-kpi-warn" : "v2-kpi-success")">
                        <div class="v2-kpi-head"><i class="bi bi-exclamation-triangle"></i>Cost of Unplanned Work</div>
                        <div class="v2-kpi-value">@($"{AllScopeAdded.TimeLoggedHours:F0}h")</div>
                        <div class="v2-kpi-sub">@pctUnplanned.ToString("F0")% of full-sprint capacity spent on added-scope work instead of planned scope</div>
                    </div>
                </div>
            </div>
        }
    }

    @if (_showTicketsModal)
    {
        <div class="v2-modal-overlay dr-export-skip" @onclick="CloseTicketsModal">
            <div class="v2-modal" style="max-width:1200px" @onclick:stopPropagation="true">
                <div class="v2-modal-head">
                    <div>
                        <div class="v2-modal-title"><i class="bi bi-table"></i> Tickets — @FilteredIssues.Count in current filter</div>
                        <div class="v2-modal-sub">@SelectedProducts.Count of @AllProducts.Count product(s) selected@(SelectedSprintId.HasValue ? $" · sprint: {SprintFilterLabel()}" : "")</div>
                    </div>
                    <button class="v2-modal-close" @onclick="CloseTicketsModal" title="Close">&times;</button>
                </div>
                <div class="v2-modal-body">
                    @if (FilteredIssues.Count == 0)
                    {
                        <div class="v2-empty" style="padding:24px">No tickets match the current filter.</div>
                    }
                    else
                    {
                        <div class="v2-table-wrap" style="margin:0">
                            <table class="v2-table">
                                <thead>
                                    <tr>
                                        <th>Key</th><th>Epic</th><th>Summary</th><th>Product</th><th>Type</th>
                                        <th>Status</th><th>Assignee</th><th>Priority</th><th class="v2-table-num">Hours</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var i in FilteredIssues.OrderBy(i => i.EpicName).ThenBy(i => i.Key))
                                    {
                                        <tr class="@(i.StatusCategoryKey == "done" ? "is-done" : "")">
                                            <td class="v2-table-key"><a href="@(Config["Jira:BaseUrl"]?.TrimEnd('/'))/browse/@i.Key" target="_blank" class="v2-key-link">@i.Key</a></td>
                                            <td class="v2-truncate" style="max-width:200px" title="@i.EpicName">@i.EpicName</td>
                                            <td class="v2-truncate" style="max-width:320px" title="@i.Summary">@i.Summary</td>
                                            <td>@ProductOf(i)</td>
                                            <td><span class="v2-chip v2-chip-@(i.IssueType.ToLower())">@i.IssueType</span></td>
                                            <td><span class="v2-pill v2-pill-@(i.StatusCategoryKey == "done" ? "success" : i.StatusCategoryKey == "indeterminate" ? "brand" : "neutral")" style="font-size:10px;padding:1px 6px">@i.Status</span></td>
                                            <td class="v2-truncate" style="max-width:160px">@i.Assignee</td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(i.Priority))
                                                {
                                                    <span class="v2-chip v2-chip-pri-@(i.Priority.ToLower())">@i.Priority</span>
                                                }
                                                else { <span class="v2-text-muted">—</span> }
                                            </td>
                                            <td class="v2-table-num">@IssueWindowHours(i).ToString("F1")h</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    private SprintReport? Report;
    private List<SprintConfig> _knownSprints = [];
    private List<RosterMember> _roster = [];
    private List<RosterVacation> _vacations = [];
    private string SprintId = "";
    private bool IsLoading;
    private string? _loadingStatus;
    private string? ErrorMessage;
    private bool _renderCharts;

    private DeliveryHealthMetrics? TaskMetrics;
    private DeliveryHealthMetrics? AllMetrics;
    private DeliveryHealthCalculator.ScopeAddedStats? TaskScopeAdded;
    private DeliveryHealthCalculator.ScopeAddedStats? AllScopeAdded;
    private DeliveryHealthCalculator.EpicBreadthStats? EpicBreadth;
    private List<(DateTime Date, double RemainingHours)> TaskBurndown = [];
    private List<(DateTime Date, double RemainingHours)> AllBurndown = [];
    private List<(DateTime Date, double IdealRemainingHours)> TaskIdealBurndown = [];
    private List<(DateTime Date, double IdealRemainingHours)> AllIdealBurndown = [];
    private List<(DateTime Date, double Hours)> TaskHoursPerDay = [];
    private List<(DateTime Date, double Hours)> AllHoursPerDay = [];
    private List<DeliveryHealthCalculator.EstimationPoint> TaskEstimationPoints = [];
    private List<DeliveryHealthCalculator.EstimationPoint> AllEstimationPoints = [];
    private List<double> TaskVelocitySparkline = [];
    private List<double> AllVelocitySparkline = [];
    private List<(string Product, int Total, int Done)> TaskProductBreakdown = [];
    private DeliveryHealthCalculator.BugFeatureSplit? AllBugSplit;
    private DeliveryHealthCalculator.BugOriginSplit? AllBugOriginSplit;
    // Bug vs Feature Split detail: per-epic breakdown of the Bug (Bug ∪ Redesign) and Feature
    // (Task-only) populations that make up the split above.
    private List<DeliveryHealthCalculator.EpicBreakdownRow> BugsByEpic = [];
    private List<DeliveryHealthCalculator.EpicBreakdownRow> FeaturesByEpic = [];

    // Bug Origin detail: scoped to JSSUPPORT-linked bugs only (not the Feature-found half),
    // since Bug Origin is specifically about customer-reported/support-driven bug load.
    private List<DeliveryHealthCalculator.EpicBreakdownRow> SupportBugsByEpic = [];
    private double SupportBugAvgEffortHours;
    private double SupportBugAvgEffortOngoingHours;
    private List<DeliveryHealthCalculator.PriorityCount> SupportBugPriorityBreakdown = [];
    private DeliveryHealthCalculator.BugTypeSplit? SupportBugTypeSplitStat;

    // The fully filtered (products + sprint) issue set currently driving every metric on the
    // page — kept around so the "view tickets" popup can list exactly what's being measured.
    private List<SprintIssue> FilteredIssues = [];
    private bool _showTicketsModal;
    private bool IsExporting;
    private bool IsExportingHtml;
    private bool IsExportingCompact;

    // ── Product filter ── "JS Project[Radio Buttons]" field; empty selection means "no filter"
    // (same convention as Working Hours' product filter), so clearing chips shows everything merged.
    private HashSet<string> SelectedProducts = [];

    // Each product's true issue set for the loaded sprint's date window, fetched independently
    // by product + worklog date rather than by Jira "Sprint" field membership — some products
    // (e.g. Integrations) log work continuously without every ticket being added to this
    // sprint, so relying on sprint membership undercounts them. Keyed by product name (or
    // DeliveryHealthCalculator.NoProductLabel), populated by LoadProductIssuesAsync.
    private Dictionary<string, List<SprintIssue>> _productIssues = [];

    // Narrows the current product selection down to one real Jira sprint (from the issues'
    // own sprint history) — null means "every issue in the sprint's date window".
    private int? SelectedSprintId;

    private static string ProductOf(SprintIssue i) => DeliveryHealthCalculator.ProductOf(i);

    private List<(string Name, int Count)> AllProducts => _productIssues
        .Select(kv => (Name: kv.Key, Count: kv.Value.Count))
        .OrderBy(g => g.Name == DeliveryHealthCalculator.NoProductLabel ? 1 : 0)
        .ThenByDescending(g => g.Count)
        .ToList();

    // Real Jira sprints found across the currently-selected product(s)' issues — populates the
    // Sprint dropdown so the merged, date-scoped view can be narrowed to one specific sprint.
    // A ticket's Sprints list is its full cumulative sprint history (every sprint it was ever
    // added to, per Jira's sprint field) — not just sprints relevant now — so a long-lived
    // carried-over ticket would otherwise drag in sprints from months earlier. Restrict to
    // sprints whose own date range actually overlaps the loaded report window.
    private List<IssueSprint> AvailableSprints => _productIssues
        .Where(kv => SelectedProducts.Count == 0 || SelectedProducts.Contains(kv.Key))
        .SelectMany(kv => kv.Value)
        .SelectMany(i => i.Sprints)
        .Where(s => s.Id != 0 && SprintOverlapsWindow(s, Report?.StartDate, Report?.EndDate))
        .DistinctBy(s => s.Id)
        .OrderByDescending(s => s.StartDate)
        .ToList();

    private static bool SprintOverlapsWindow(IssueSprint s, DateTime? winStart, DateTime? winEnd)
    {
        if (winStart is null || winEnd is null) return true;
        if (s.StartDate is null || s.EndDate is null) return false;
        return s.StartDate.Value.Date <= winEnd.Value.Date && s.EndDate.Value.Date >= winStart.Value.Date;
    }

    // Issues pulled in by the per-product/worklog-date-range fetch (LoadProductIssuesAsync) that
    // have NEVER been added to any Jira sprint (i.SprintsCount == 0 — not just "not in the
    // window", but zero sprint history) yet still logged time in this window for a selected
    // product. These are counted in every metric on the page by default (the per-product fetch
    // has no sprint clause at all) — surfaced here so the Sprint sub-filter can isolate or
    // exclude them instead of silently blending them into "All sprints in this window".
    private int NoSprintIssueCount => _productIssues
        .Where(kv => SelectedProducts.Count == 0 || SelectedProducts.Contains(kv.Key))
        .SelectMany(kv => kv.Value)
        .Count(i => i.Sprints.Count == 0);

    // Display label for the current Sprint sub-filter value — handles the "0" sentinel
    // (no-sprint tickets) separately since AvailableSprints excludes Id 0 by construction.
    private string SprintFilterLabel() => SelectedSprintId switch
    {
        null => "All sprints in window",
        0    => "No sprint",
        _    => AvailableSprints.FirstOrDefault(s => s.Id == SelectedSprintId)?.Name ?? "—"
    };

