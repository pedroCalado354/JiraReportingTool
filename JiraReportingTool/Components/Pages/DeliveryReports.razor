@page "/delivery-reports"
@rendermode InteractiveServer
@inject IJiraService JiraService
@inject SprintConfigService SprintConfigService
@inject TeamRosterService RosterService
@inject IJSRuntime JS
@inject IConfiguration Config
@using JiraReportingTool.Models
@using ClosedXML.Excel
@using ClosedXML.Excel.Drawings
@using System.Text.RegularExpressions

<PageTitle>Delivery Reports</PageTitle>

<div class="v2-root" id="dr-report-root">

    <!-- ═══ HERO ═════════════════════════════════════════════════════════════ -->
    <div class="v2-hero">
        <div class="v2-hero-row">
            <div class="v2-hero-icon"><i class="bi bi-file-earmark-bar-graph"></i></div>
            <div class="v2-hero-titles">
                <span class="v2-eyebrow">Executive Summary</span>
                <h1 class="v2-hero-title">Delivery Reports</h1>
                <span class="v2-hero-sub">
                    @if (Report is not null)
                    {
                        <strong>@(Report.SprintName is { Length: > 0 } sn ? sn : "Sprint")</strong>
                        @if (Report.StartDate.HasValue && Report.EndDate.HasValue)
                        {
                            <span> · @Report.StartDate.Value.ToString("MMM d") – @Report.EndDate.Value.ToString("MMM d, yyyy")</span>
                        }
                        @if (Report.SyncedAt.HasValue)
                        {
                            <span> · data as of @Report.SyncedAt.Value.ToLocalTime().ToString("dd-MMM HH:mm")</span>
                        }
                    }
                    else
                    {
                        <span>Sprint status, delivery, hours, velocity and scope — at a glance</span>
                    }
                </span>
            </div>
            <div class="v2-hero-spacer"></div>
            @if (Report is not null)
            {
                <div class="v2-hero-actions">
                    <button class="v2-btn v2-btn-ghost" @onclick="Reload"
                            disabled="@(IsLoading || Report.IsFrozen)"
                            title="@(Report.IsFrozen ? "This sprint is closed and frozen — its snapshot is permanent, nothing to reload" : "Reload — merges only recently-updated issues from Jira over the stored snapshot")">
                        @if (IsLoading) { <span class="v2-spin"></span> }
                        else { <i class="bi bi-arrow-repeat"></i> }
                    </button>
                    <button class="v2-btn v2-btn-ghost" @onclick="HardRefresh"
                            disabled="@(IsLoading || Report.IsFrozen)"
                            title="@(Report.IsFrozen ? "This sprint is closed and frozen — its snapshot is permanent and can no longer be overwritten from Jira" : "Force full re-fetch from Jira (rebuilds the cache — slow)")">
                        <i class="bi bi-cloud-arrow-down"></i>
                    </button>
                    @if (Report.IsFrozen)
                    {
                        <span class="v2-pill v2-pill-info" title="Sprint closed — this is its permanent end-of-sprint snapshot, last synced @Report.SyncedAt!.Value.ToLocalTime().ToString("dd-MMM HH:mm")">
                            <i class="bi bi-lock-fill"></i> Frozen
                        </span>
                    }
                    <span class="v2-pill v2-pill-neutral"><i class="bi bi-calendar3"></i> @Report.DaysRemaining d left</span>
                </div>
            }
        </div>
    </div>

    <!-- ═══ SPRINT PICKER ═══════════════════════════════════════════════════ -->
    <div class="v2-control-bar dr-export-skip">
        <div class="v2-field" style="min-width:280px">
            <label class="v2-label">Sprint</label>
            <select class="v2-select" @bind="SprintId" @bind:after="OnSprintPicked">
                <option value="">— pick a sprint —</option>
                @foreach (var s in _knownSprints)
                {
                    <option value="@s.SprintId">@SprintLabel(s)</option>
                }
            </select>
        </div>
        <div class="v2-hero-spacer"></div>
        @if (Report is not null)
        {
            <button class="dr-export-btn" @onclick='() => OpenExportNotesModal("excel")' disabled="@IsExporting">
                @if (IsExporting) { <span class="v2-spin" style="width:12px;height:12px"></span> }
                else { <i class="bi bi-download"></i> }
                Export .xlsx
            </button>
            <button class="dr-export-btn" @onclick='() => OpenExportNotesModal("html")' disabled="@IsExportingHtml">
                @if (IsExportingHtml) { <span class="v2-spin" style="width:12px;height:12px"></span> }
                else { <i class="bi bi-filetype-html"></i> }
                Export .html
            </button>
            <button class="dr-export-btn dr-export-btn-compact" @onclick='() => OpenExportNotesModal("compact")' disabled="@IsExportingCompact" title="Bug vs Feature Split, Bug Origin, Planned vs Worked and Delivery Burndown for Delivery Work only">
                @if (IsExportingCompact) { <span class="v2-spin" style="width:12px;height:12px"></span> }
                else { <i class="bi bi-file-earmark-spreadsheet"></i> }
                Export Compact
            </button>
        }
    </div>

    @if (IsLoading)
    {
        <div class="v2-card" style="margin-bottom:16px;display:flex;align-items:center;gap:14px">
            <span class="v2-spin" style="border-color:rgba(99,102,241,0.20);border-top-color:var(--v2-brand);width:20px;height:20px"></span>
            <div>
                <div style="font-weight:700;font-size:13px;color:var(--v2-ink-1)">Loading sprint data…</div>
                <div class="v2-hint">@(_loadingStatus ?? "Working…")</div>
            </div>
        </div>
    }

    @if (ErrorMessage != null)
    {
        <div class="v2-alert v2-alert-error"><i class="bi bi-exclamation-triangle-fill"></i> @ErrorMessage</div>
    }

    @if (Report is null && !IsLoading)
    {
        <div class="v2-empty">
            <div class="v2-empty-icon"><i class="bi bi-file-earmark-bar-graph"></i></div>
            <div class="v2-empty-title">Pick a sprint to build the report</div>
            <div>A director-facing summary of sprint status, delivery, logged hours, velocity and scope change — for Delivery Work and All Issue Types.</div>
        </div>
    }

    @if (Report is not null && AllProducts.Count > 0)
    {
        <div class="v2-card" style="margin-top:16px">
            <div class="v2-section-title"><i class="bi bi-grid-fill"></i>Product <span class="v2-section-note">by worklog date within @(Report.StartDate?.ToString("MMM d")) – @(Report.EndDate?.ToString("MMM d")), not Jira sprint membership — filter, or leave all selected to view every product merged</span></div>
            <div class="dr-chip-row dr-export-skip">
                @foreach (var (name, count) in AllProducts)
                {
                    var n = name;
                    <button type="button" class="dr-chip @(SelectedProducts.Contains(n) ? "dr-chip-on" : "")" @onclick="() => ToggleProduct(n)">
                        @if (SelectedProducts.Contains(n)) { <i class="bi bi-check2"></i> }
                        @n <span class="dr-chip-n">@count</span>
                    </button>
                }
            </div>
            <div class="v2-hint" style="margin-top:8px;display:flex;align-items:center;gap:10px;flex-wrap:wrap">
                <span>@SelectedProducts.Count of @AllProducts.Count selected@(SelectedProducts.Count == AllProducts.Count ? " — all products merged" : "")</span>
                <button type="button" class="dr-link-btn dr-export-skip" @onclick="SelectAllProducts">All</button>
                <span class="dr-dot-sep dr-export-skip">·</span>
                <button type="button" class="dr-link-btn dr-export-skip" @onclick="ClearProducts">None</button>
                <span class="dr-dot-sep dr-export-skip">·</span>
                <button type="button" class="dr-link-btn dr-export-skip" @onclick="OpenTicketsModal"><i class="bi bi-table"></i> View @FilteredIssues.Count ticket@(FilteredIssues.Count == 1 ? "" : "s")</button>
            </div>

            @if (AvailableSprints.Count > 0 || NoSprintIssueCount > 0)
            {
                <div class="dr-export-skip" style="margin-top:12px;padding-top:12px;border-top:1px solid var(--v2-divider)">
                    <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px">
                        <label class="v2-label" style="margin:0">Sprint</label>
                        <span class="v2-hint">real Jira sprints found on the selected product(s)' issues — narrows further within the window above, or select none for every sprint@(NoSprintIssueCount > 0 ? $"; {NoSprintIssueCount} ticket{(NoSprintIssueCount == 1 ? "" : "s")} logged time here with no sprint at all" : "")</span>
                    </div>
                    <div class="dr-chip-row dr-export-skip">
                        @foreach (var s in AvailableSprints)
                        {
                            var sid = s.Id;
                            <button type="button" class="dr-chip @(SelectedSprintIds.Contains(sid) ? "dr-chip-on" : "")" @onclick="() => ToggleSprintFilter(sid)">
                                @if (SelectedSprintIds.Contains(sid)) { <i class="bi bi-check2"></i> }
                                @s.Name@(s.StartDate.HasValue ? $" ({s.StartDate:MMM d}–{s.EndDate:MMM d})" : "")
                            </button>
                        }
                        @if (NoSprintIssueCount > 0)
                        {
                            <button type="button" class="dr-chip @(SelectedSprintIds.Contains(0) ? "dr-chip-on" : "")" @onclick="() => ToggleSprintFilter(0)">
                                @if (SelectedSprintIds.Contains(0)) { <i class="bi bi-check2"></i> }
                                No sprint <span class="dr-chip-n">@NoSprintIssueCount</span>
                            </button>
                        }
                    </div>
                    <div class="v2-hint" style="margin-top:8px;display:flex;align-items:center;gap:10px;flex-wrap:wrap">
                        <span>@(SelectedSprintIds.Count == 0 ? "All sprints in this window" : $"{SelectedSprintIds.Count} sprint{(SelectedSprintIds.Count == 1 ? "" : "s")} selected")</span>
                        <button type="button" class="dr-link-btn dr-export-skip" @onclick="ClearSprintFilter">All</button>
                    </div>
                </div>
            }
        </div>
    }

    @if (Report is not null && AllBugSplit is not null)
    {
        <div class="v2-card" style="margin-top:16px">
            <div class="v2-grid-2">
                <div id="html-export-bugsplit">
                    <div class="v2-section-title"><i class="bi bi-bug-fill" style="color:var(--v2-danger)"></i>Bug vs Feature Split <span class="v2-section-note">firefighting vs building — All Issue Types, current product filter</span></div>
                    <div style="display:flex;align-items:center;gap:20px;flex-wrap:wrap">
                        <div class="v2-donut v2-donut-lg" style="--p:@(AllBugSplit.BugPct.ToString(System.Globalization.CultureInfo.InvariantCulture));--c1:var(--v2-danger)">
                            <span>@AllBugSplit.BugPct.ToString("F0")%</span>
                        </div>
                        <div style="display:flex;flex-direction:column;gap:8px">
                            <div class="v2-row"><span class="v2-chip v2-chip-bug">Bug</span><span class="v2-row-value">@AllBugSplit.BugCount total &middot; @AllBugSplit.BugWorkedOnCount issues worked on &middot; @AllBugSplit.BugHours.ToString("F0")h logged</span></div>
                            <div class="v2-row"><span class="v2-chip v2-chip-story">Feature / Task</span><span class="v2-row-value">@AllBugSplit.FeatureCount total &middot; @AllBugSplit.FeatureWorkedOnCount issues worked on &middot; @AllBugSplit.FeatureHours.ToString("F0")h logged</span></div>
                        </div>
                    </div>
                    <div class="v2-hint" style="margin-top:8px">@(AllBugSplit.BugPct >= 40 ? "A large share of logged time is going to bugs — the team may be firefighting more than building." : "Most logged time is going toward feature/task work.")</div>
                </div>

                @if (AllBugOriginSplit is not null && (AllBugOriginSplit.SupportLinkedCount + AllBugOriginSplit.FeatureFoundCount) > 0)
                {
                    <div id="html-export-bugorigin">
                        <div class="v2-section-title">
                            <i class="bi bi-pie-chart-fill" style="color:var(--v2-info)"></i>Bug Origin
                            <span class="v2-section-note">JSSUPPORT-linked vs feature-found, of the @(AllBugOriginSplit.SupportLinkedCount + AllBugOriginSplit.FeatureFoundCount) bugs above</span>
                        </div>
                        <div style="display:flex;align-items:center;gap:20px;flex-wrap:wrap">
                            <div class="v2-donut v2-donut-lg" style="--p:@(AllBugOriginSplit.SupportLinkedPct.ToString(System.Globalization.CultureInfo.InvariantCulture));--c1:var(--v2-danger)">
                                <span>@AllBugOriginSplit.SupportLinkedPct.ToString("F0")%</span>
                            </div>
                            <div style="display:flex;flex-direction:column;gap:10px">
                                <div>
                                    <div class="v2-row"><span class="v2-chip v2-chip-bug">JSSUPPORT-linked</span><span class="v2-row-value">@AllBugOriginSplit.SupportLinkedCount total &middot; @AllBugOriginSplit.SupportLinkedWorkedOnCount worked on &middot; @AllBugOriginSplit.SupportLinkedHours.ToString("F0")h logged</span></div>
                                    @if (SupportLinkedOriginBreakdown is not null)
                                    {
                                        <div class="v2-hint" style="margin-top:-2px">@SupportLinkedOriginBreakdown.ClosedCount closed &middot; Bug @SupportLinkedOriginBreakdown.BugHours.ToString("F0")h &middot; Redesign @SupportLinkedOriginBreakdown.RedesignHours.ToString("F0")h</div>
                                    }
                                </div>
                                <div>
                                    <div class="v2-row"><span class="v2-chip v2-chip-task">Feature-found</span><span class="v2-row-value">@AllBugOriginSplit.FeatureFoundCount total &middot; @AllBugOriginSplit.FeatureFoundWorkedOnCount worked on &middot; @AllBugOriginSplit.FeatureFoundHours.ToString("F0")h logged</span></div>
                                    @if (FeatureFoundOriginBreakdown is not null)
                                    {
                                        <div class="v2-hint" style="margin-top:-2px">@FeatureFoundOriginBreakdown.ClosedCount closed &middot; Bug @FeatureFoundOriginBreakdown.BugHours.ToString("F0")h &middot; Redesign @FeatureFoundOriginBreakdown.RedesignHours.ToString("F0")h</div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (BugsByEpic.Count > 0)
            {
                @RenderEpicTable("Bugs by Epic", "closed this sprint vs still open, avg effort per issue", BugsByEpic, BugsByEpicIssues, skipInHtmlExport: true)
            }
            @if (FeaturesByEpic.Count > 0)
            {
                @RenderEpicTable("Tasks by Epic", "closed this sprint vs still open, avg effort per issue", FeaturesByEpic, FeaturesByEpicIssues, skipInHtmlExport: true)
            }

            @if (SupportBugTypeSplitStat is not null && (SupportBugTypeSplitStat.BugTypeCount + SupportBugTypeSplitStat.RedesignTypeCount) > 0)
            {
                var supportBugRedesignTotal = SupportBugTypeSplitStat.BugTypeCount + SupportBugTypeSplitStat.RedesignTypeCount;
                var supportBugTypePct = supportBugRedesignTotal > 0 ? SupportBugTypeSplitStat.BugTypeCount * 100.0 / supportBugRedesignTotal : 0;
                <div class="v2-divider"></div>
                <div id="html-export-bugorigin-jssupport">
                    <div class="v2-section-title" style="margin-top:4px">
                        <i class="bi bi-pie-chart-fill" style="color:var(--v2-danger)"></i>Bug Origin JSSUPPORT
                        <span class="v2-section-note">Bug vs Redesign, of the @supportBugRedesignTotal JSSUPPORT-linked bugs above</span>
                    </div>
                    <div style="display:flex;align-items:center;gap:20px;flex-wrap:wrap">
                        <div style="display:flex;flex-direction:column;align-items:center;gap:6px">
                            <div class="v2-donut v2-donut-lg" style="--p:@(supportBugTypePct.ToString(System.Globalization.CultureInfo.InvariantCulture));--c1:var(--v2-danger)">
                                <span>@supportBugTypePct.ToString("F0")%</span>
                            </div>
                            @if (SupportLinkedOriginBreakdown is not null)
                            {
                                var totalHours = SupportLinkedOriginBreakdown.BugHours + SupportLinkedOriginBreakdown.RedesignHours;
                                <span class="dr-hours-link" @onclick="OpenJsSupportPersonHoursModal" title="Click to see hours logged per person">@totalHours.ToString("F0")h total</span>
                            }
                        </div>
                        <div style="display:flex;flex-direction:column;gap:10px">
                            <div>
                                <div class="v2-row">
                                    <span class="v2-chip v2-chip-bug">Bug</span><span class="v2-row-value">@SupportBugTypeSplitStat.BugTypeCount total &middot; @SupportBugTypeSplitStat.BugTypeWorkedOnCount worked on</span>
                                    @if (SupportLinkedOriginBreakdown is not null)
                                    {
                                        <span class="dr-hours-link" @onclick='() => OpenJsSupportHoursModal("Bug", SupportLinkedOriginBreakdown.BugHours, SupportBugTypeHoursPerDay)' title="Click to see hours logged per day">@SupportLinkedOriginBreakdown.BugHours.ToString("F0")h logged</span>
                                    }
                                </div>
                            </div>
                            <div>
                                <div class="v2-row">
                                    <span class="v2-chip" style="background:#f3e8ff;color:#7c3aed">Redesign</span><span class="v2-row-value">@SupportBugTypeSplitStat.RedesignTypeCount total &middot; @SupportBugTypeSplitStat.RedesignTypeWorkedOnCount worked on</span>
                                    @if (SupportLinkedOriginBreakdown is not null)
                                    {
                                        <span class="dr-hours-link" @onclick='() => OpenJsSupportHoursModal("Redesign", SupportLinkedOriginBreakdown.RedesignHours, SupportRedesignTypeHoursPerDay)' title="Click to see hours logged per day">@SupportLinkedOriginBreakdown.RedesignHours.ToString("F0")h logged</span>
                                    }
                                </div>
                            </div>
                        </div>
                        @if (SupportBugPriorityBreakdown.Count > 0)
                        {
                            <div style="display:flex;flex-direction:column;gap:6px">
                                <div class="v2-hint" style="font-weight:600;color:var(--v2-ink-3)"><i class="bi bi-flag"></i> Priority Breakdown</div>
                                <div style="display:flex;flex-wrap:wrap;gap:6px;max-width:220px">
                                    @foreach (var p in SupportBugPriorityBreakdown)
                                    {
                                        <span class="v2-chip v2-chip-pri-@(p.Priority.ToLower())">@p.Priority (@p.Count)</span>
                                    }
                                </div>
                            </div>
                        }
                        @if (SupportBugsByProductType.Count > 0)
                        {
                            <div class="dr-product-table-wrap" style="flex:0 0 auto;width:370px">
                                <div class="v2-hint" style="font-weight:600;color:var(--v2-ink-3);margin-bottom:6px"><i class="bi bi-people"></i> By Product</div>
                                <div class="v2-table-wrap" style="margin:0;max-height:200px;overflow:auto">
                                    <table class="v2-table dr-product-table">
                                        <thead>
                                            <tr>
                                                <th>Product</th>
                                                <th>Type</th>
                                                <th class="v2-table-num" title="Distinct assignees">Staff</th>
                                                <th class="v2-table-num">Logged</th>
                                                <th class="v2-table-num">Closed</th>
                                                <th class="v2-table-num" title="Avg hours logged to close, among closed issues">Avg</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var r in SupportBugsByProductType)
                                            {
                                                <tr>
                                                    <td class="v2-truncate" style="max-width:90px" title="@r.Product">@r.Product</td>
                                                    <td><span class="v2-chip @(r.IssueType.Equals("Bug", StringComparison.OrdinalIgnoreCase) ? "v2-chip-bug" : "")" style="@(r.IssueType.Equals("Bug", StringComparison.OrdinalIgnoreCase) ? "" : "background:#f3e8ff;color:#7c3aed")">@r.IssueType</span></td>
                                                    <td class="v2-table-num">@r.StaffCount</td>
                                                    <td class="v2-table-num">@r.LoggedHours.ToString("F0")h</td>
                                                    <td class="v2-table-num" title="@r.ClosedCount of @r.TotalCount closed">@r.ClosedCount/@r.TotalCount</td>
                                                    <td class="v2-table-num">@(r.ClosedCount > 0 ? $"{r.AvgHoursToClose:F1}h" : "—")</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                @if (SupportBugsByEpic.Count > 0)
                {
                    @RenderEpicTable("JSSUPPORT-linked Bugs by Epic", "closed this sprint vs still open, hours logged, avg effort per issue", SupportBugsByEpic, SupportBugsByEpicIssues)
                }
            }
        </div>
    }

    @if (Report is not null && EpicBreadth is not null)
    {
        <div class="v2-card" style="margin-top:16px">
            <div class="v2-section-title"><i class="bi bi-diagram-3-fill" style="color:var(--v2-brand)"></i>Epic Coverage <span class="v2-section-note">breadth of epics the team actively logged time on — All Issue Types, current product filter</span></div>
            <div style="display:flex;align-items:baseline;gap:28px;flex-wrap:wrap">
                <div class="v2-gauge-score">@EpicBreadth.EpicCount</div>
                <div class="v2-hint" style="max-width:420px">
                    @EpicBreadth.PctOfContributors.ToString("F0")% of the team (@EpicBreadth.ContributorsOnEpics of @EpicBreadth.TotalContributors contributors who logged time) worked in @EpicBreadth.EpicCount epic@(EpicBreadth.EpicCount == 1 ? "" : "s") this sprint.
                </div>
            </div>
            <div class="v2-row" style="margin-top:12px;padding-top:12px;border-top:1px solid var(--v2-divider)">
                <span class="v2-chip v2-chip-task">Focused</span>
                <span class="v2-row-value">@EpicBreadth.PctFocused.ToString("F0")% of the team (@EpicBreadth.FocusedContributors) worked in exactly 1 epic</span>
            </div>
            <div class="v2-row" style="margin-top:6px">
                <span class="v2-chip v2-chip-pri-high">Spread</span>
                <span class="v2-row-value">@EpicBreadth.PctSpread.ToString("F0")% of the team (@EpicBreadth.SpreadContributors) worked in 2 epics</span>
            </div>
            <div class="v2-row" style="margin-top:6px">
                <span class="v2-chip v2-chip-pri-highest">Critical</span>
                <span class="v2-row-value">@EpicBreadth.PctCritical.ToString("F0")% of the team (@EpicBreadth.CriticalContributors) worked in 3+ epics</span>
            </div>
            <div class="v2-hint" style="margin-top:8px">avg @EpicBreadth.AvgEpicsPerContributor.ToString("F1") epics per contributor</div>
        </div>
    }

    @if (Report is not null && TaskMetrics is not null && AllMetrics is not null)
    {
        @RenderSection("Delivery Work", "Task issue type only", TaskMetrics, TaskScopeAdded, TaskVelocitySparkline, TaskProductBreakdown, "task")
        @RenderSection("All Issue Types", "Every issue in the sprint", AllMetrics, AllScopeAdded, AllVelocitySparkline, null, "all")

        @if (AllScopeAdded is not null)
        {
            var pctUnplanned = AllMetrics.FullSprintCapacityHours > 0
                ? AllScopeAdded.TimeLoggedHours / AllMetrics.FullSprintCapacityHours * 100 : 0;
            var pctPlanned = AllMetrics.FullSprintCapacityHours > 0
                ? AllMetrics.PlannedHours / AllMetrics.FullSprintCapacityHours * 100 : 0;
            <div class="v2-card" style="margin-top:12px">
                <div class="v2-section-title"><i class="bi bi-cash-coin" style="color:var(--v2-danger)"></i>Cost &amp; Capacity <span class="v2-section-note">opportunity cost of unplanned work, in hours — All Issue Types, current product filter</span></div>
                <div class="v2-kpi-grid" style="margin-top:12px;margin-bottom:0">
                    <div class="v2-kpi v2-kpi-neutral">
                        <div class="v2-kpi-head"><i class="bi bi-clock-history"></i>Full-Sprint Capacity</div>
                        <div class="v2-kpi-value">@($"{AllMetrics.FullSprintCapacityHours:F0}h")</div>
                        <div class="v2-kpi-sub">total team hours available this sprint</div>
                    </div>
                    <div class="v2-kpi v2-kpi-neutral">
                        <div class="v2-kpi-head"><i class="bi bi-clipboard-check"></i>Planned Work</div>
                        <div class="v2-kpi-value">@($"{AllMetrics.PlannedHours:F0}h")</div>
                        <div class="v2-kpi-sub">@pctPlanned.ToString("F0")% of capacity committed to planned scope</div>
                    </div>
                    <div class="v2-kpi @(pctUnplanned > 25 ? "v2-kpi-danger" : pctUnplanned > 10 ? "v2-kpi-warn" : "v2-kpi-success")">
                        <div class="v2-kpi-head"><i class="bi bi-exclamation-triangle"></i>Cost of Unplanned Work</div>
                        <div class="v2-kpi-value">@($"{AllScopeAdded.TimeLoggedHours:F0}h")</div>
                        <div class="v2-kpi-sub">@pctUnplanned.ToString("F0")% of full-sprint capacity spent on added-scope work instead of planned scope</div>
                    </div>
                </div>
            </div>
        }
    }

