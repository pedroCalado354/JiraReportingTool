            Meta("Feature-found", $"{AllBugOriginSplit.FeatureFoundCount} bugs · {AllBugOriginSplit.FeatureFoundHours:F0}h logged");
        }
        row++;

        void EpicTable(string title, List<DeliveryHealthCalculator.EpicBreakdownRow> rows)
        {
            if (rows.Count == 0) return;
            var titleCell = ws.Cell(row, 1); titleCell.Value = title; titleCell.Style.Font.Bold = true; titleCell.Style.Font.FontSize = 13;
            row++;
            var hc1 = ws.Cell(row, 1); hc1.Value = "Epic";                 StyleHeaderCell(hc1);
            var hc2 = ws.Cell(row, 2); hc2.Value = "Closed";               StyleHeaderCell(hc2);
            var hc3 = ws.Cell(row, 3); hc3.Value = "Avg Effort (Closed)";  StyleHeaderCell(hc3);
            var hc4 = ws.Cell(row, 4); hc4.Value = "Open";                 StyleHeaderCell(hc4);
            var hc5 = ws.Cell(row, 5); hc5.Value = "Avg Effort (Open)";    StyleHeaderCell(hc5);
            var hc6 = ws.Cell(row, 6); hc6.Value = "Hours";                StyleHeaderCell(hc6);
            row++;
            foreach (var r in rows)
            {
                ws.Cell(row, 1).Value = string.IsNullOrEmpty(r.EpicKey) ? r.EpicName : $"{r.EpicKey} {r.EpicName}";
                ws.Cell(row, 2).Value = r.ClosedCount;
                if (r.ClosedCount == 0) ws.Cell(row, 3).Value = ""; else ws.Cell(row, 3).Value = Math.Round(r.AvgEffortClosed, 1);
                ws.Cell(row, 4).Value = r.OpenCount;
                if (r.OpenCount == 0) ws.Cell(row, 5).Value = ""; else ws.Cell(row, 5).Value = Math.Round(r.AvgEffortOpen, 1);
                ws.Cell(row, 6).Value = Math.Round(r.HoursLogged, 1);
                row++;
            }
            row++;
        }

        EpicTable("Bugs by Epic", BugsByEpic);
        EpicTable("Tasks by Epic", FeaturesByEpic);
        EpicTable("JSSUPPORT-linked Bugs by Epic", SupportBugsByEpic);

        if (SupportBugTypeSplitStat is not null)
        {
            Meta("Avg Effort to Conclude", $"{SupportBugAvgEffortHours:F1}h");
            Meta("Avg Effort Ongoing (still open)", $"{SupportBugAvgEffortOngoingHours:F1}h");
            Meta("Bug vs Redesign", $"Bug {SupportBugTypeSplitStat.BugTypeCount} · Redesign {SupportBugTypeSplitStat.RedesignTypeCount}");
            if (SupportBugPriorityBreakdown.Count > 0)
                Meta("Priority Breakdown", string.Join(", ", SupportBugPriorityBreakdown.Select(p => $"{p.Priority} ({p.Count})")));
        }

        ws.Columns().AdjustToContents();
    }

    private void BuildTicketsSheet(XLWorkbook wb)
    {
        var ws = wb.Worksheets.Add("Tickets");
        var headers = new[] { "Key", "Epic", "Summary", "Product", "Type", "Status", "Assignee", "Priority", "Hours" };
        for (int i = 0; i < headers.Length; i++) { var hc = ws.Cell(1, i + 1); hc.Value = headers[i]; StyleHeaderCell(hc); }
        ws.SheetView.FreezeRows(1);

        var baseUrl = Config["Jira:BaseUrl"]?.TrimEnd('/');
        int row = 2;
        foreach (var i in FilteredIssues.OrderBy(i => i.EpicName).ThenBy(i => i.Key))
        {
            if (row % 2 == 0) ws.Row(row).Style.Fill.BackgroundColor = XLColor.FromHtml("#f8f9fa");
            var keyCell = ws.Cell(row, 1);
            keyCell.Value = i.Key;
            if (!string.IsNullOrEmpty(baseUrl)) keyCell.SetHyperlink(new XLHyperlink($"{baseUrl}/browse/{i.Key}"));
            ws.Cell(row, 2).Value = i.EpicName;
            ws.Cell(row, 3).Value = i.Summary;
            ws.Cell(row, 4).Value = ProductOf(i);
            ws.Cell(row, 5).Value = i.IssueType;
            ws.Cell(row, 6).Value = i.Status;
            ws.Cell(row, 7).Value = i.Assignee;
            ws.Cell(row, 8).Value = i.Priority;
            ws.Cell(row, 9).Value = Math.Round(IssueWindowHours(i), 1);
            row++;
        }
        ws.Columns().AdjustToContents();
        ws.Row(1).Height = 22;
    }

    private static void StyleHeaderCell(IXLCell cell)
    {
        cell.Style.Font.Bold = true;
        cell.Style.Fill.BackgroundColor = XLColor.FromHtml("#1e3a5f");
        cell.Style.Font.FontColor = XLColor.White;
        cell.Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;
    }

    private static void StyleMetaLabel(IXLCell cell)
    {
        cell.Style.Font.Bold = true;
        cell.Style.Font.FontColor = XLColor.FromHtml("#6c757d");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_renderCharts && Report is not null && TaskMetrics is not null && AllMetrics is not null)
        {
            _renderCharts = false;
            await RenderStatusDonut("chart-status-task", TaskMetrics);
            await RenderStatusDonut("chart-status-all", AllMetrics);
            await RenderBurndownChart("chart-burndown-task", TaskBurndown, TaskIdealBurndown);
            await RenderBurndownChart("chart-burndown-all", AllBurndown, AllIdealBurndown);
            await RenderHoursPerDayChart("chart-hours-task", TaskHoursPerDay);
            await RenderHoursPerDayChart("chart-hours-all", AllHoursPerDay);
            await RenderEstimationScatter("chart-estimation-task", TaskEstimationPoints);
            await RenderEstimationScatter("chart-estimation-all", AllEstimationPoints);
        }
    }

    private async Task RenderStatusDonut(string canvasId, DeliveryHealthMetrics m)
    {
        await JS.InvokeVoidAsync("renderChart", canvasId, new
        {
            type = "doughnut",
            data = new
            {
                labels = new[] { "Done", "In Progress", "To Do" },
                datasets = new object[]
                {
                    new
                    {
                        data = new[] { m.DoneCount, m.InProgressCount, m.ToDoCount },
                        backgroundColor = new[] { "rgba(22,163,74,0.85)", "rgba(37,99,235,0.85)", "rgba(148,163,184,0.6)" },
                        borderColor     = new[] { "rgba(21,128,61,1)", "rgba(29,78,216,1)", "rgba(100,116,139,1)" },
                        borderWidth = 1
                    }
                }
            },
            options = new
            {
                responsive = true, maintainAspectRatio = false,
                plugins = new { legend = new { display = true, position = "bottom", labels = new { font = new { size = 11 }, boxWidth = 12, padding = 8 } } }
            }
        });
    }

    private async Task RenderBurndownChart(string canvasId, List<(DateTime Date, double RemainingHours)> actual,
        List<(DateTime Date, double IdealRemainingHours)> ideal)
    {
        if (actual.Count == 0 && ideal.Count == 0) return;

        // Ideal always spans the full sprint (start..end); actual is capped at "today". Use the
        // ideal series for the x-axis so the reference line renders even for days still to come.
        var labelDates = (ideal.Count > 0 ? ideal.Select(p => p.Date) : actual.Select(p => p.Date)).ToArray();
        var actualByDate = actual.ToDictionary(p => p.Date, p => (double?)Math.Round(p.RemainingHours, 1));
        var idealByDate  = ideal.ToDictionary(p => p.Date, p => (double?)Math.Round(p.IdealRemainingHours, 1));

        await JS.InvokeVoidAsync("renderChart", canvasId, new
        {
            type = "line",
            data = new
            {
                labels   = labelDates.Select(d => d.ToString("MMM d")).ToArray(),
                datasets = new object[]
                {
                    new
                    {
                        label = "Actual remaining",
                        data = labelDates.Select(d => actualByDate.TryGetValue(d, out var v) ? v : null).ToArray(),
                        borderColor = "rgba(37,99,235,0.9)",
                        backgroundColor = "rgba(37,99,235,0.12)",
                        borderWidth = 2, pointRadius = 2, fill = true, tension = 0.15
                    },
                    new
                    {
                        label = "Ideal",
                        data = labelDates.Select(d => idealByDate.TryGetValue(d, out var v) ? v : null).ToArray(),
                        borderColor = "rgba(148,163,184,0.9)",
                        backgroundColor = "transparent",
                        borderDash = new[] { 6, 4 },
                        borderWidth = 2, pointRadius = 0, fill = false, tension = (double)0
                    }
                }
            },
            options = new
            {
                responsive = true, maintainAspectRatio = false,
                plugins = new { legend = new { display = true, position = "top", labels = new { font = new { size = 11 }, boxWidth = 12, padding = 8 } } },
                scales  = new
                {
                    x = new { grid = new { display = false } },
                    y = new { beginAtZero = true, grid = new { color = "rgba(0,0,0,0.04)" } }
                }
            }
        });
    }

    private async Task RenderHoursPerDayChart(string canvasId, List<(DateTime Date, double Hours)> series)
    {
        if (series.Count == 0) return;
        await JS.InvokeVoidAsync("renderChart", canvasId, new
        {
            type = "bar",
            data = new
            {
                labels   = series.Select(p => p.Date.ToString("MMM d")).ToArray(),
                datasets = new object[]
                {
                    new
                    {
                        label = "Hours logged",
                        data  = series.Select(p => Math.Round(p.Hours, 1)).ToArray(),
                        backgroundColor = series.Select(p => p.Date.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday
                                            ? "rgba(217,119,6,0.55)" : "rgba(99,102,241,0.82)").ToArray(),
                        borderColor     = series.Select(p => p.Date.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday
                                            ? "rgba(217,119,6,1)" : "rgba(79,70,229,1)").ToArray(),
                        borderWidth = 1, borderRadius = 4
                    }
                }
            },
            options = new
            {
                responsive = true, maintainAspectRatio = false,
                plugins = new { legend = new { display = false } },
                scales  = new
                {
                    x = new { grid = new { display = false } },
                    y = new { beginAtZero = true, grid = new { color = "rgba(0,0,0,0.04)" } }
                }
            }
        });
    }

    private async Task RenderEstimationScatter(string canvasId, List<DeliveryHealthCalculator.EstimationPoint> points)
    {
        if (points.Count == 0) return;
        var maxVal = Math.Max(1, points.Select(p => Math.Max(p.PlannedHours, p.ActualHours)).Max());
        var diagMax = Math.Ceiling(maxVal / 5.0) * 5;

        await JS.InvokeVoidAsync("renderChart", canvasId, new
        {
            type = "scatter",
            data = new
            {
                datasets = new object[]
                {
                    new
                    {
                        type = "scatter",
                        label = "Issues",
                        data = points.Select(p => new { x = Math.Round(p.PlannedHours, 1), y = Math.Round(p.ActualHours, 1) }).ToArray(),
                        backgroundColor = "rgba(37,99,235,0.65)",
                        borderColor = "rgba(29,78,216,0.9)",
                        pointRadius = 5, pointHoverRadius = 7
                    },
                    new
                    {
                        type = "line",
                        label = "Perfect estimate (y = x)",
                        data = new[] { new { x = 0.0, y = 0.0 }, new { x = diagMax, y = diagMax } },
                        borderColor = "rgba(148,163,184,0.9)",
                        backgroundColor = "transparent",
                        borderDash = new[] { 6, 4 },
                        pointRadius = 0, borderWidth = 2, fill = false
                    }
                }
            },
            options = new
            {
                responsive = true, maintainAspectRatio = false,
                plugins = new { legend = new { display = true, position = "top", labels = new { font = new { size = 11 }, boxWidth = 12, padding = 8 } } },
                scales = new
                {
                    x = new { type = "linear", beginAtZero = true, title = new { display = true, text = "Planned (h)" }, grid = new { color = "rgba(0,0,0,0.04)" } },
                    y = new { type = "linear", beginAtZero = true, title = new { display = true, text = "Actual (h)" }, grid = new { color = "rgba(0,0,0,0.04)" } }
                }
            }
        });
    }

    // Mirrors the sparkline pattern used on delivery-v3's Burn Rate card — kept as a local copy
    // since the two pages have no shared code path by design (see DeliveryHealthCalculator.cs).
    private static MarkupString SparklineSvg(List<double> values, string color)
    {
        if (values.Count < 2) return new MarkupString("");
        var max = values.Max();
        var min = values.Min();
        var range = Math.Max(0.001, max - min);
        const double w = 200, h = 36;
        var step = w / (values.Count - 1);
        var inv = System.Globalization.CultureInfo.InvariantCulture;
        var pts = string.Join(" ", values.Select((v, i) =>
            $"{(i * step).ToString("F1", inv)},{(h - (v - min) / range * h).ToString("F1", inv)}"));
        return new MarkupString(
            $"<svg class=\"v2-spark\" viewBox=\"0 0 {w} {h}\" preserveAspectRatio=\"none\">" +
            $"<polyline fill=\"none\" stroke=\"{color}\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" points=\"{pts}\"/>" +
            $"<polyline fill=\"{color}\" fill-opacity=\"0.10\" stroke=\"none\" points=\"0,{h} {pts} {w},{h}\"/>" +
            $"</svg>");
    }

    private RenderFragment RenderEpicTable(string title, string note, List<DeliveryHealthCalculator.EpicBreakdownRow> rows, bool skipInHtmlExport = false) =>
    @<text>
        <div class="@(skipInHtmlExport ? "dr-export-skip" : "")">
            <div class="v2-divider"></div>
            <div class="v2-section-title" style="margin-top:4px"><i class="bi bi-diagram-2" style="color:var(--v2-brand)"></i>@title <span class="v2-section-note">@note</span></div>
            <div class="v2-table-wrap" style="max-height:260px;overflow-y:auto">
                <table class="v2-table">
                    <thead>
                        <tr>
                            <th>Epic</th>
                            <th class="v2-table-num">Closed</th>
                            <th class="v2-table-num">Open</th>
                            <th class="v2-table-num">Hours</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in rows)
                        {
                            <tr>
                                <td class="v2-truncate" style="max-width:320px" title="@row.EpicName">@(string.IsNullOrEmpty(row.EpicKey) ? row.EpicName : $"{row.EpicKey} {row.EpicName}")</td>
                                <td class="v2-table-num">@row.ClosedCount@(row.ClosedCount == 0 ? "" : $" ({row.AvgEffortClosed:F1}h avg)")</td>
                                <td class="v2-table-num">@row.OpenCount@(row.OpenCount == 0 ? "" : $" ({row.AvgEffortOpen:F1}h avg)")</td>
                                <td class="v2-table-num">@row.HoursLogged.ToString("F0")h</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </text>;

    private RenderFragment RenderSection(string title, string note, DeliveryHealthMetrics m, DeliveryHealthCalculator.ScopeAddedStats? scopeAdded, List<double> velocitySparkline, List<(string Product, int Total, int Done)>? productBreakdown, string idSuffix) =>
    @<text>
        <div class="v2-section-title" style="margin-top:20px"><i class="bi bi-collection"></i>@title <span class="v2-section-note">@note</span></div>

        <div class="v2-gauge">
            <div class="v2-gauge-score @($"v2-gauge-score-{m.Band}")">@m.Score</div>
            <div class="v2-gauge-mid">
                <div class="v2-gauge-label">Sprint Health Score</div>
                <div class="v2-gauge-track">
                    <div class="v2-gauge-marker" style="left:@m.Score%;"></div>
                </div>
                <div class="v2-gauge-desc">@m.Message</div>
            </div>
            <div class="v2-gauge-side">
                <div class="v2-gauge-side-stat">
                    <div class="v2-gauge-side-val">@((int)m.TimeElapsedPct)%</div>
                    <div class="v2-gauge-side-lbl">Time elapsed</div>
                </div>
                <div class="v2-gauge-side-stat">
                    <div class="v2-gauge-side-val @(m.CompletionBehind ? "v2-text-danger" : "v2-text-success")">@((int)m.CompletionPct)%</div>
                    <div class="v2-gauge-side-lbl">Work done</div>
                </div>
                <div class="v2-gauge-side-stat">
                    <div class="v2-gauge-side-val @(m.PlanOverCommit ? "v2-text-danger" : "")">@($"{m.PlannedHours:F0}h")</div>
                    <div class="v2-gauge-side-lbl">Planned</div>
                </div>
                <div class="v2-gauge-side-stat">
                    <div class="v2-gauge-side-val @(m.OverCapacity ? "v2-text-danger" : "")">@($"{m.RemainingHours:F0}h")</div>
                    <div class="v2-gauge-side-lbl">Remaining</div>
                </div>
                <div class="v2-gauge-side-stat">
                    <div class="v2-gauge-side-val">@($"{m.CapacityHours:F0}h")</div>
                    <div class="v2-gauge-side-lbl">Capacity</div>
                </div>
            </div>
        </div>

        <div class="v2-kpi-grid">
            <div class="v2-kpi @(m.CompletionBehind ? "v2-kpi-warn" : "v2-kpi-success")">
                <div class="v2-kpi-head"><i class="bi bi-check2-circle"></i>Completion</div>
                <div class="v2-kpi-value">@((int)m.CompletionPct)%</div>
                <div class="v2-bar" style="margin-top:8px">
                    <div class="v2-bar-fill @(m.CompletionBehind ? "v2-bar-fill-warn" : "v2-bar-fill-success")" style="width:@Math.Min((int)m.CompletionPct, 100)%"></div>
                </div>
                <div class="v2-kpi-sub">@m.DoneCount of @m.TotalCount done · @m.InProgressCount active · @m.ToDoCount pending</div>
                @if (productBreakdown is { Count: > 0 })
                {
                    <div style="display:flex;flex-direction:column;gap:4px;margin-top:10px;padding-top:10px;border-top:1px solid var(--v2-divider)">
                        @foreach (var p in productBreakdown)
                        {
                            <div style="display:flex;justify-content:space-between;gap:8px;font-size:11.5px;color:var(--v2-ink-3)">
                                <span class="v2-truncate" style="max-width:140px">@p.Product</span>
                                <span style="font-weight:600;color:var(--v2-ink-2)">@p.Done of @p.Total done</span>
                            </div>
                        }
                    </div>
                }
            </div>

            @{
                var pwDelta = m.SprintWindowLoggedHours - m.PlannedHours; // positive = over plan, negative = under
                var pwDeltaPct = m.PlannedHours > 0 ? Math.Abs(pwDelta) / m.PlannedHours * 100 : 0;
                var pwBand = m.PlannedHours <= 0 ? "neutral"
                    : m.SprintWindowLoggedHours > m.PlannedHours * 1.15 ? "danger"
                    : m.SprintWindowLoggedHours > m.PlannedHours ? "warn" : "success";
            }
            <div class="v2-kpi @(pwBand == "neutral" ? "v2-kpi-neutral" : $"v2-kpi-{pwBand}")">
                <div class="v2-kpi-head"><i class="bi bi-clipboard-data"></i>Planned vs Worked</div>
                <div class="v2-kpi-value">@($"{m.PlannedHours:F0}h")<span class="v2-kpi-of">planned</span></div>
                <div class="v2-bar" style="margin-top:8px">
                    <div class="v2-bar-fill v2-bar-fill-@(pwBand == "neutral" ? "success" : pwBand)" style="width:@(m.PlannedHours > 0 ? Math.Min((int)(m.SprintWindowLoggedHours / m.PlannedHours * 100), 100) : 0)%"></div>
                </div>
                <div class="v2-kpi-sub">@($"{m.SprintWindowLoggedHours:F0}h") logged · @(pwDelta > 0 ? $"+{pwDelta:F0}h ({pwDeltaPct:F0}% over)" : pwDelta < 0 ? $"{pwDelta:F0}h ({pwDeltaPct:F0}% under)" : "on plan")</div>
            </div>

            <div class="v2-kpi @(m.ThroughputBehind ? "v2-kpi-warn" : "v2-kpi-success")">
                <div class="v2-kpi-head"><i class="bi bi-speedometer2"></i>Velocity</div>
                <div class="v2-kpi-value">@m.ThroughputPerDay.ToString("F1")<span class="v2-kpi-of">of @m.NeededThroughputPerDay.ToString("F1") needed / day</span></div>
                @if (velocitySparkline.Count > 1)
                {
                    @SparklineSvg(velocitySparkline, m.ThroughputBehind ? "#b45309" : "#16a34a")
                }
                <div class="v2-kpi-sub">@(m.ThroughputBehind ? "behind the pace needed to finish" : "on pace to finish")</div>
            </div>
        </div>

        <div class="v2-grid-2" style="margin-top:16px">
            <div class="v2-card">
                <div class="v2-section-title"><i class="bi bi-pie-chart" style="color:var(--v2-brand)"></i>Sprint Status</div>
                <div style="height:240px;position:relative">
                    <canvas id="chart-status-@idSuffix"></canvas>
                </div>
            </div>
            <div class="v2-card">
                <div class="v2-section-title"><i class="bi bi-arrows-collapse" style="color:#0ea5e9"></i>Scope Added <span class="v2-section-note">work added after the sprint started</span></div>
                @if (scopeAdded is not null)
                {
                    <div style="display:flex;flex-direction:column;gap:10px;margin-top:10px">
                        <div class="v2-row">
                            <span class="v2-chip v2-chip-pri-high">Tasks Added</span>
                            <span class="v2-row-value">@scopeAdded.AddedCount &middot; @scopeAdded.PctOfSprintScope.ToString("F0")% of sprint scope</span>
                        </div>
                        @if (scopeAdded.TypeBreakdown.Count > 0)
                        {
                            <div style="display:flex;flex-wrap:wrap;gap:6px">
                                @foreach (var t in scopeAdded.TypeBreakdown)
                                {
                                    <span class="v2-chip v2-chip-@(t.IssueType.ToLower())">@t.IssueType @t.Count</span>
                                }
                            </div>
                        }
                        <div class="v2-row"><span class="v2-chip v2-chip-story">Added Scope (h)</span><span class="v2-row-value">@($"{scopeAdded.AddedScopeHours:F0}h") planned</span></div>
                        <div class="v2-row"><span class="v2-chip v2-chip-task">Time Logged</span><span class="v2-row-value">@($"{scopeAdded.TimeLoggedHours:F0}h") logged on added-scope issues</span></div>
                    </div>
                }
            </div>
        </div>

        <div class="v2-grid-2" style="margin-top:12px">
            <div class="v2-card">
                <div class="v2-section-title">
                    <i class="bi bi-graph-down-arrow" style="color:var(--v2-brand-3)"></i>Delivery Burndown <span class="v2-section-note">remaining estimate — actual vs ideal</span>
                    <i class="bi bi-info-circle dr-info-icon" title="Remaining = each issue's original estimate minus hours already logged against it (never below zero), dropping to zero once the issue is marked Done. It's not a straight subtraction of total hours logged — an issue's remaining only falls when work is logged on that specific issue, or the issue resolves."></i>
                </div>
                <div style="height:240px;position:relative">
                    <canvas id="chart-burndown-@idSuffix"></canvas>
                </div>
            </div>
            <div class="v2-card">
                <div class="v2-section-title"><i class="bi bi-calendar-event" style="color:var(--v2-brand-2)"></i>Hours Logged per Day</div>
                <div style="height:240px;position:relative">
                    <canvas id="chart-hours-@idSuffix"></canvas>
                </div>
            </div>
        </div>

        <div class="v2-card" style="margin-top:12px">
            <div class="v2-section-title"><i class="bi bi-graph-up" style="color:var(--v2-brand)"></i>Estimation Accuracy <span class="v2-section-note">planned vs actual hours per issue — above the diagonal = underestimated</span></div>
            <div style="height:300px;position:relative">
                <canvas id="chart-estimation-@idSuffix"></canvas>
            </div>
        </div>
    </text>;
}

