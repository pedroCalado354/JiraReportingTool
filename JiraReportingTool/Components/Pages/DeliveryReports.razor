</div>

@code {
    private SprintReport? Report;
    private List<SprintConfig> _knownSprints = [];
    private List<RosterMember> _roster = [];
    private List<RosterVacation> _vacations = [];
    private string SprintId = "";
    private bool IsLoading;
    private string? _loadingStatus;
    private string? ErrorMessage;
    private bool _renderCharts;

    private DeliveryHealthMetrics? TaskMetrics;
    private DeliveryHealthMetrics? AllMetrics;
    private DeliveryHealthCalculator.ScopeAddedStats? TaskScopeAdded;
    private DeliveryHealthCalculator.ScopeAddedStats? AllScopeAdded;
    private DeliveryHealthCalculator.EpicBreadthStats? EpicBreadth;
    private List<(DateTime Date, double RemainingHours)> TaskBurndown = [];
    private List<(DateTime Date, double RemainingHours)> AllBurndown = [];
    private List<(DateTime Date, double IdealRemainingHours)> TaskIdealBurndown = [];
    private List<(DateTime Date, double IdealRemainingHours)> AllIdealBurndown = [];
    private List<(DateTime Date, int RemainingCount)> TaskCountBurndown = [];
    private List<(DateTime Date, int RemainingCount)> AllCountBurndown = [];
    private List<(DateTime Date, double IdealRemainingCount)> TaskIdealCountBurndown = [];
    private List<(DateTime Date, double IdealRemainingCount)> AllIdealCountBurndown = [];
    private List<(DateTime Date, double Hours)> TaskHoursPerDay = [];
    private List<(DateTime Date, double Hours)> AllHoursPerDay = [];
    private List<DeliveryHealthCalculator.EstimationPoint> TaskEstimationPoints = [];
    private List<DeliveryHealthCalculator.EstimationPoint> AllEstimationPoints = [];
    private List<double> TaskVelocitySparkline = [];
    private List<double> AllVelocitySparkline = [];
    private record ProductSprintBreakdownRow(string SprintName, int Total, int Done);
    private record ProductBreakdownRow(string Product, int Total, int Done, List<ProductSprintBreakdownRow> BySprint);
    private List<ProductBreakdownRow> TaskProductBreakdown = [];
    private DeliveryHealthCalculator.BugFeatureSplit? AllBugSplit;
    private DeliveryHealthCalculator.BugOriginSplit? AllBugOriginSplit;
    // Bug vs Feature Split detail: per-epic breakdown of the Bug (Bug ∪ Redesign) and Feature
    // (Task-only) populations that make up the split above.
    private List<DeliveryHealthCalculator.EpicBreakdownRow> BugsByEpic = [];
    private List<DeliveryHealthCalculator.EpicBreakdownRow> FeaturesByEpic = [];

    // Underlying issues behind BugsByEpic / FeaturesByEpic / SupportBugsByEpic — kept alongside
    // the aggregated rows so a table row click can pull up the actual tickets for that epic
    // (RenderEpicTable groups by the same EpicKey/EpicName pair as ComputeIssuesByEpic).
    private List<SprintIssue> BugsByEpicIssues = [];
    private List<SprintIssue> FeaturesByEpicIssues = [];
    private List<SprintIssue> SupportBugsByEpicIssues = [];

    // Bug Origin detail: scoped to JSSUPPORT-linked bugs only (not the Feature-found half),
    // since Bug Origin is specifically about customer-reported/support-driven bug load.
    private List<DeliveryHealthCalculator.EpicBreakdownRow> SupportBugsByEpic = [];
    private double SupportBugAvgEffortHours;
    private double SupportBugAvgEffortOngoingHours;
    private int SupportBugClosedCount;
    private double FeatureFoundBugAvgEffortHours;
    private double FeatureFoundBugAvgEffortOngoingHours;
    private List<DeliveryHealthCalculator.PriorityCount> SupportBugPriorityBreakdown = [];
    private DeliveryHealthCalculator.BugTypeSplit? SupportBugTypeSplitStat;

    // Bug Origin JSSUPPORT detail table: per-product, per-issue-type (Bug/Redesign) breakdown
    // of the JSSUPPORT-linked bugs — staff involved, hours logged, closed count and average
    // hours to close. Replaces the plain "logged"/"closed" figures that used to sit inline
    // next to the Bug Origin JSSUPPORT donut with a product-level view.
    private record SupportProductTypeRow(string Product, string IssueType, int TotalCount, int ClosedCount, double LoggedHours, double AvgHoursToClose, int StaffCount);
    private List<SupportProductTypeRow> SupportBugsByProductType = [];

    // Day-by-day logged-hours series per issue type (Bug / Redesign) within the JSSUPPORT-linked
    // population — feeds the popup chart opened by clicking either type's "Xh logged" stat,
    // right in front of that type's issue count. Same renderer as the Delivery Work "Hours
    // Logged per Day" chart.
    private List<(DateTime Date, double Hours)> SupportBugTypeHoursPerDay = [];
    private List<(DateTime Date, double Hours)> SupportRedesignTypeHoursPerDay = [];
    private bool _showJsSupportHoursModal;
    private bool _renderJsSupportHoursChart;
    private string _jsSupportHoursModalTitle = "";
    private double _jsSupportHoursModalTotalHours;
    private List<(DateTime Date, double Hours)> _jsSupportHoursModalSeries = [];

    // Hours logged across all JSSUPPORT-linked bugs (Bug + Redesign combined), by worklog
    // author — feeds the "Total Hours" stat next to the Bug Origin donut and its per-person
    // drilldown chart, opened by clicking that stat.
    private List<(string Person, double Hours)> SupportLinkedHoursPerPerson = [];
    private bool _showJsSupportPersonHoursModal;
    private bool _renderJsSupportPersonHoursChart;
    private double _jsSupportPersonHoursModalTotalHours;
    private List<(string Person, double Hours)> _jsSupportPersonHoursModalSeries = [];

    // Per-origin-row summary for the Bug Origin donut: closed count + hours split by
    // issue type (Bug/Redesign), shown right next to each row instead of only further down.
    private DeliveryHealthCalculator.OriginTypeBreakdown? SupportLinkedOriginBreakdown;
    private DeliveryHealthCalculator.OriginTypeBreakdown? FeatureFoundOriginBreakdown;

    // The fully filtered (products + sprint) issue set currently driving every metric on the
    // page — kept around so the "view tickets" popup can list exactly what's being measured.
    private List<SprintIssue> FilteredIssues = [];
    private bool _showTicketsModal;
    private bool IsExporting;
    private bool IsExportingHtml;
    private bool IsExportingCompact;

    // Notes popup shown before any export — lets the user add free-form context (bullet
    // points, bold, color) that gets embedded in the exported file. _pendingExportKind records
    // which of the three export buttons triggered the popup so the right export resumes once
    // the user confirms or skips.
    private bool _showExportNotesModal;
    private bool _clearNotesEditorPending;
    private string _pendingExportKind = "";
    private string _exportNotesHtml = "";
    private static readonly string[] NotesColorSwatches = ["#dc2626", "#d97706", "#16a34a", "#2563eb", "#7c3aed", "#111827"];

    // ── Product filter ── "JS Project[Radio Buttons]" field; empty selection means "no filter"
    // (same convention as Working Hours' product filter), so clearing chips shows everything merged.
    private HashSet<string> SelectedProducts = [];

    // Each product's true issue set for the loaded sprint's date window, fetched independently
    // by product + worklog date rather than by Jira "Sprint" field membership — some products
    // (e.g. Integrations) log work continuously without every ticket being added to this
    // sprint, so relying on sprint membership undercounts them. Keyed by product name (or
    // DeliveryHealthCalculator.NoProductLabel), populated by LoadProductIssuesAsync.
    private Dictionary<string, List<SprintIssue>> _productIssues = [];

    // Narrows the current product selection down to one or more real Jira sprints (from the
    // issues' own sprint history) — empty means "every issue in the sprint's date window".
    // Id 0 is the "no sprint at all" sentinel (see NoSprintIssueCount below).
    private HashSet<int> SelectedSprintIds = new();

    private static string ProductOf(SprintIssue i) => DeliveryHealthCalculator.ProductOf(i);

    // Per-product Done/Total breakdown for the Completion KPI. When more than one sprint is
    // selected in the Sprint sub-filter, each product row also gets a per-sprint breakdown
    // underneath it so "tickets closed per product per sprint" is visible at a glance.
    private List<ProductBreakdownRow> ComputeProductBreakdown(List<SprintIssue> issues)
    {
        var showSprintSplit = SelectedSprintIds.Count > 1;
        var sprintOrder = AvailableSprints
            .Where(s => SelectedSprintIds.Contains(s.Id))
            .Select(s => (s.Id, s.Name))
            .ToList();
        if (SelectedSprintIds.Contains(0)) sprintOrder.Add((0, "No sprint"));

        return issues
            .GroupBy(ProductOf)
            .Select(g =>
            {
                var bySprint = new List<ProductSprintBreakdownRow>();
                if (showSprintSplit)
                {
                    foreach (var sp in sprintOrder)
                    {
                        var matched = sp.Id == 0
                            ? g.Where(i => i.Sprints.Count == 0).ToList()
                            : g.Where(i => i.Sprints.Any(s => s.Id == sp.Id)).ToList();
                        if (matched.Count > 0)
                            bySprint.Add(new ProductSprintBreakdownRow(sp.Name, matched.Count, matched.Count(i => i.StatusCategoryKey == "done")));
                    }
                }
                return new ProductBreakdownRow(g.Key, g.Count(), g.Count(i => i.StatusCategoryKey == "done"), bySprint);
            })
            .OrderByDescending(r => r.Total)
            .ToList();
    }

    private List<(string Name, int Count)> AllProducts => _productIssues
        .Select(kv => (Name: kv.Key, Count: kv.Value.Count))
        .OrderBy(g => g.Name == DeliveryHealthCalculator.NoProductLabel ? 1 : 0)
        .ThenByDescending(g => g.Count)
        .ToList();

    // Real Jira sprints found across the currently-selected product(s)' issues — populates the
    // Sprint dropdown so the merged, date-scoped view can be narrowed to one specific sprint.
    // A ticket's Sprints list is its full cumulative sprint history (every sprint it was ever
    // added to, per Jira's sprint field) — not just sprints relevant now — so a long-lived
    // carried-over ticket would otherwise drag in sprints from months earlier. Restrict to
    // sprints whose own date range actually overlaps the loaded report window.
    private List<IssueSprint> AvailableSprints => _productIssues
        .Where(kv => SelectedProducts.Count == 0 || SelectedProducts.Contains(kv.Key))
        .SelectMany(kv => kv.Value)
        .SelectMany(i => i.Sprints)
        .Where(s => s.Id != 0 && SprintOverlapsWindow(s, Report?.StartDate, Report?.EndDate))
        .DistinctBy(s => s.Id)
        .OrderByDescending(s => s.StartDate)
        .ToList();

    private static bool SprintOverlapsWindow(IssueSprint s, DateTime? winStart, DateTime? winEnd)
    {
        if (winStart is null || winEnd is null) return true;
        if (s.StartDate is null || s.EndDate is null) return false;
        return s.StartDate.Value.Date <= winEnd.Value.Date && s.EndDate.Value.Date >= winStart.Value.Date;
    }

    // Issues pulled in by the per-product/worklog-date-range fetch (LoadProductIssuesAsync) that
    // have NEVER been added to any Jira sprint (i.SprintsCount == 0 — not just "not in the
    // window", but zero sprint history) yet still logged time in this window for a selected
    // product. These are counted in every metric on the page by default (the per-product fetch
    // has no sprint clause at all) — surfaced here so the Sprint sub-filter can isolate or
    // exclude them instead of silently blending them into "All sprints in this window".
    private int NoSprintIssueCount => _productIssues
        .Where(kv => SelectedProducts.Count == 0 || SelectedProducts.Contains(kv.Key))
        .SelectMany(kv => kv.Value)
        .Count(i => i.Sprints.Count == 0);

    // Display label for the current Sprint sub-filter value — handles the "0" sentinel
    // (no-sprint tickets) separately since AvailableSprints excludes Id 0 by construction.
    private string SprintFilterLabel() => SelectedSprintIds.Count == 0
        ? "All sprints in window"
        : string.Join(", ", SelectedSprintIds.Select(id => id == 0 ? "No sprint" : AvailableSprints.FirstOrDefault(s => s.Id == id)?.Name ?? "—"));

    // Short code for a sprint name (e.g. "Pro 26.13 (Jul 6-Jul 17)" -> "26.13"), for compact
    // file names — falls back to a filename-sanitized version of the full name.
    private static string SprintCode(string name)
    {
        var m = System.Text.RegularExpressions.Regex.Match(name, @"\d+(?:\.\d+)?");
        return m.Success ? m.Value : name.Replace(" ", "_").Replace("/", "-").Replace(",", "");
    }

    // File-name label for the sprint(s) in scope: the sprint sub-filter when one or more is
    // selected (joined with "_" for multiple, e.g. "26.12_26.13"), otherwise the main sprint.
    private string ExportSprintLabel()
    {
        if (SelectedSprintIds.Count > 0)
        {
            var codes = SelectedSprintIds
                .OrderBy(id => id)
                .Select(id => id == 0 ? "NoSprint" : SprintCode(AvailableSprints.FirstOrDefault(s => s.Id == id)?.Name ?? "Sprint"))
                .Distinct();
            return string.Join("_", codes);
        }
        var sprintLabel = Report!.SprintName is { Length: > 0 } sn ? sn : $"Sprint {Report.JiraSprintId}";
        return sprintLabel.Replace(" ", "_").Replace("/", "-").Replace(",", "");
    }

    protected override async Task OnInitializedAsync()
    {
        try { _roster = (await RosterService.GetActiveAsync()).Where(m => m.IncludeInDeliveryReports).ToList(); } catch { _roster = []; }
        try { _vacations = await RosterService.GetVacationsAsync(); } catch { _vacations = []; }

        _knownSprints = (await SprintConfigService.GetAllAsync())
            .OrderByDescending(c => c.StartDate)
            .ToList();

        var current = await SprintConfigService.GetCurrentAsync();
        if (current is not null && string.IsNullOrEmpty(SprintId))
            SprintId = current.SprintId.ToString();
    }

    private string SprintLabel(SprintConfig s)
    {
        var name = string.IsNullOrEmpty(s.Name) ? $"Sprint {s.SprintId}" : s.Name;
        return $"{name} ({s.StartDate:MMM d} – {s.EndDate:MMM d})";
    }

    private async Task OnSprintPicked()
    {
        if (!string.IsNullOrEmpty(SprintId)) await LoadData(resetFilters: true);
    }

    // resetFilters is true when switching to a (possibly new) sprint from the picker, so the
    // product/sprint sub-filters start fresh — false for Reload/HardRefresh, which refresh the
    // currently loaded sprint's data in place without discarding what the user has selected.
    private async Task LoadData(bool forceRefresh = false, bool resetFilters = true)
    {
        if (!int.TryParse(SprintId.Trim(), out var sprintId)) return;

        IsLoading = true; ErrorMessage = null; Report = null;
        _productIssues.Clear();
        if (resetFilters) SelectedSprintIds.Clear();
        _loadingStatus = "Loading sprint report…";
        StateHasChanged();

        try
        {
            var report = await JiraService.GetDeliveryDataAsync(sprintId, bypassCache: forceRefresh);
            Report = report;

            await LoadProductIssuesAsync();
            if (resetFilters) SelectedProducts = new HashSet<string>(AllProducts.Select(p => p.Name));

            RecomputeMetrics();
            _renderCharts = true;
        }
        catch (Exception ex) { ErrorMessage = $"Failed to load: {ex.Message}"; }
        finally { IsLoading = false; _loadingStatus = null; }
    }

    // Reload — re-runs LoadData without bypassing the cache. For a sprint loaded by ID this
    // routes through JiraCacheService's sprint-aware cache: a closed/frozen sprint is served
    // straight from the DB (no Jira call), an open one merges only recently-updated issues.
    private async Task Reload()
    {
        if (IsLoading || Report is { IsFrozen: true }) return;
        await LoadData(forceRefresh: false, resetFilters: false);
    }

    // Hard refresh — re-fetch the currently loaded sprint fresh from Jira, bypassing the DB
    // cache. Blocked once a sprint is frozen (closed + synced on/after its end date) — that
    // snapshot is the permanent historical record and must never be overwritten.
    private async Task HardRefresh()
    {
        if (IsLoading || Report is { IsFrozen: true }) return;
        await LoadData(forceRefresh: true, resetFilters: false);
    }

    private async Task LoadProductIssuesAsync()
    {
        if (Report is null || Report.StartDate is null || Report.EndDate is null) return;
        var start = Report.StartDate.Value;
        var end = Report.EndDate.Value;

        // Native sprint-membership issues (this sprint's own "sprint = X" fetch), grouped by
        // product — the correct population for whichever product this sprint actually belongs
        // to, since it includes backlog/To Do items that haven't logged any time yet (the
        // worklog-date fetch below would drop those, since it requires at least one worklog
        // in the window).
        var nativeByProduct = DeliveryHealthCalculator.ActiveIssues(Report)
            .GroupBy(ProductOf)
            .ToDictionary(g => g.Key, g => g.ToList());

        // Every configured product (e.g. Digital Journey, Integrations, Rentway Legacy, Rentway
        // Pro), not just the ones this epic's own sprint happens to touch — so the Product
        // filter always offers the same full set regardless of which epic is loaded, matching
        // Support Trends' cross-epic view. GetJsProjectFieldOptionsAsync hits Jira's field-context
        // API, which needs Jira Administrator permission and 403s for a regular API token — when
        // that happens it returns an empty list, so DeliveryHealthCalculator.KnownProducts is the
        // real source of truth and the API result is only an (often-empty) bonus on top.
        var fieldOptions = await JiraService.GetJsProjectFieldOptionsAsync();
        var products = DeliveryHealthCalculator.KnownProducts
            .Union(fieldOptions)
            .Union(nativeByProduct.Keys)
            .ToList();
        var byProduct = new Dictionary<string, List<SprintIssue>>();
        for (var idx = 0; idx < products.Count; idx++)
        {
            var product = products[idx];
            _loadingStatus = $"Fetching {product} ({idx + 1} of {products.Count})…";
            StateHasChanged();

            // Union with a worklog-date + product fetch (itself now OR'd with native sprint
            // membership server-side, so zero-worklog backlog issues come back too — not just
            // for the epic's own product) so cross-sprint work is still counted for products
            // that aren't this sprint's own (e.g. Integrations logs continuously without every
            // ticket being added to this sprint). Neither worklog-date nor sprint membership
            // alone is complete; the union is.
            var fetched = await JiraService.GetIssuesByProductInRangeAsync(product, start, end, Report.JiraSprintId);
            var worklogScoped = DeliveryHealthCalculator.FilterActive(fetched.Issues);

            byProduct[product] = worklogScoped
                .Concat(nativeByProduct.GetValueOrDefault(product, []))
                .DistinctBy(i => i.Key)
                .ToList();
        }
        _productIssues = byProduct;
    }

    private void RecomputeMetrics()
    {
        if (Report is null) return;
        var report = Report;
        var effectiveDaysRemaining = report.DaysRemaining;

        var combined = _productIssues
            .Where(kv => SelectedProducts.Count == 0 || SelectedProducts.Contains(kv.Key))
            .SelectMany(kv => kv.Value)
            .Where(i => SelectedSprintIds.Count == 0
                || (i.Sprints.Count == 0 && SelectedSprintIds.Contains(0))
                || i.Sprints.Any(s => SelectedSprintIds.Contains(s.Id)))
            .DistinctBy(i => i.Key)
            .ToList();

        var taskIssues = combined.Where(DeliveryHealthCalculator.IsDeliveryType).ToList();
        var allIssues  = combined;
        FilteredIssues = combined;

        TaskProductBreakdown = ComputeProductBreakdown(taskIssues);

        TaskMetrics = DeliveryHealthCalculator.ComputeForIssues(report, taskIssues, effectiveDaysRemaining, isTaskOnly: true, _roster, _vacations);
        AllMetrics  = DeliveryHealthCalculator.ComputeForIssues(report, allIssues, effectiveDaysRemaining, isTaskOnly: false, _roster, _vacations);
        TaskScopeAdded = DeliveryHealthCalculator.ComputeScopeAddedStats(report, taskIssues);
        AllScopeAdded  = DeliveryHealthCalculator.ComputeScopeAddedStats(report, allIssues);
        EpicBreadth    = DeliveryHealthCalculator.ComputeEpicBreadthStats(report, allIssues);
        TaskBurndown      = DeliveryHealthCalculator.ComputeBurndown(report, taskIssues);
        AllBurndown       = DeliveryHealthCalculator.ComputeBurndown(report, allIssues);
        TaskIdealBurndown = DeliveryHealthCalculator.ComputeIdealBurndown(report, taskIssues);
        AllIdealBurndown  = DeliveryHealthCalculator.ComputeIdealBurndown(report, allIssues);
        TaskCountBurndown = DeliveryHealthCalculator.ComputeTaskCountBurndown(report, taskIssues);
        AllCountBurndown  = DeliveryHealthCalculator.ComputeTaskCountBurndown(report, allIssues);
        TaskIdealCountBurndown = DeliveryHealthCalculator.ComputeIdealTaskCountBurndown(report, taskIssues);
        AllIdealCountBurndown  = DeliveryHealthCalculator.ComputeIdealTaskCountBurndown(report, allIssues);
        TaskHoursPerDay   = DeliveryHealthCalculator.ComputeHoursPerDay(report, taskIssues);
        AllHoursPerDay    = DeliveryHealthCalculator.ComputeHoursPerDay(report, allIssues);
        TaskEstimationPoints = DeliveryHealthCalculator.ComputeEstimationPoints(taskIssues);
        AllEstimationPoints  = DeliveryHealthCalculator.ComputeEstimationPoints(allIssues);
        TaskVelocitySparkline = DeliveryHealthCalculator.ComputeVelocitySparkline(report, taskIssues);
        AllVelocitySparkline  = DeliveryHealthCalculator.ComputeVelocitySparkline(report, allIssues);
        AllBugSplit       = DeliveryHealthCalculator.ComputeBugFeatureSplit(report, allIssues);
        AllBugOriginSplit = DeliveryHealthCalculator.ComputeBugOriginSplit(report, allIssues);

        // A ticket can carry this sprint's Jira Sprint-field tag from anywhere in its history
        // (e.g. added to the sprint once, long since re-parented to a later sprint's epic) with
        // no actual work done during the sprint's own dates. The epic/support breakdowns below
        // want tickets that were genuinely worked in this window, not just historically tagged.
        var bugsInScope = allIssues.Where(DeliveryHealthCalculator.IsBugLike)
            .Where(i => HasActivityInSprintWindow(i, report.StartDate, report.EndDate)).ToList();
        var featuresInScope = allIssues.Where(DeliveryHealthCalculator.IsDeliveryType)
            .Where(i => HasActivityInSprintWindow(i, report.StartDate, report.EndDate)).ToList();
        BugsByEpic     = DeliveryHealthCalculator.ComputeIssuesByEpic(report, bugsInScope);
        FeaturesByEpic = DeliveryHealthCalculator.ComputeIssuesByEpic(report, featuresInScope);
        BugsByEpicIssues     = bugsInScope;
        FeaturesByEpicIssues = featuresInScope;

        // Unlike bugsInScope above, the JSSUPPORT-linked / feature-found split is NOT narrowed
        // to bugs with activity this exact window — it's every in-scope bug (matching "Bug
        // Origin"'s SupportLinkedCount/FeatureFoundCount above), so this section's own total
        // reconciles with that one instead of silently dropping untouched-this-window bugs.
        // *WorkedOnCount (Bug Origin) and BugTypeWorkedOnCount/RedesignTypeWorkedOnCount (Bug
        // Origin JSSUPPORT) still surface the activity-filtered subset alongside the true total.
        var allBugsInScope = allIssues.Where(DeliveryHealthCalculator.IsBugLike).ToList();
        var supportLinkedBugs = allBugsInScope.Where(DeliveryHealthCalculator.IsSupportLinkedBug).ToList();
        var featureFoundBugs  = allBugsInScope.Where(i => !DeliveryHealthCalculator.IsSupportLinkedBug(i)).ToList();
        SupportBugsByEpicIssues     = supportLinkedBugs;
        SupportBugsByEpic           = DeliveryHealthCalculator.ComputeIssuesByEpic(report, supportLinkedBugs);
        SupportBugAvgEffortHours    = DeliveryHealthCalculator.AvgHoursToConclude(report, supportLinkedBugs);
        SupportBugAvgEffortOngoingHours = DeliveryHealthCalculator.AvgHoursOngoing(report, supportLinkedBugs);
        SupportBugClosedCount       = supportLinkedBugs.Count(i => i.StatusCategoryKey == "done");
        FeatureFoundBugAvgEffortHours = DeliveryHealthCalculator.AvgHoursToConclude(report, featureFoundBugs);
        FeatureFoundBugAvgEffortOngoingHours = DeliveryHealthCalculator.AvgHoursOngoing(report, featureFoundBugs);
        SupportBugPriorityBreakdown = DeliveryHealthCalculator.ComputePriorityBreakdown(supportLinkedBugs);
        SupportBugTypeSplitStat     = DeliveryHealthCalculator.ComputeBugVsRedesignSplit(report, supportLinkedBugs);

        SupportBugsByProductType = supportLinkedBugs
            .GroupBy(i => (Product: ProductOf(i), Type: i.IssueType))
            .Select(g =>
            {
                var closed = g.Where(i => i.StatusCategoryKey == "done").ToList();
                var loggedHours = DeliveryHealthCalculator.SprintWindowHours(g, report.StartDate, report.EndDate);
                var closedHours = DeliveryHealthCalculator.SprintWindowHours(closed, report.StartDate, report.EndDate);
                var staffCount = g.Select(i => i.Assignee).Where(a => !string.IsNullOrWhiteSpace(a)).Distinct().Count();
                return new SupportProductTypeRow(
                    Product: g.Key.Product,
                    IssueType: g.Key.Type,
                    TotalCount: g.Count(),
                    ClosedCount: closed.Count,
                    LoggedHours: loggedHours,
                    AvgHoursToClose: closed.Count == 0 ? 0 : closedHours / closed.Count,
                    StaffCount: staffCount);
            })
            .OrderBy(r => r.Product).ThenBy(r => r.IssueType)
            .ToList();

        SupportBugTypeHoursPerDay = DeliveryHealthCalculator.ComputeHoursPerDay(report,
            supportLinkedBugs.Where(i => string.Equals(i.IssueType, "Bug", StringComparison.OrdinalIgnoreCase)).ToList());
        SupportRedesignTypeHoursPerDay = DeliveryHealthCalculator.ComputeHoursPerDay(report,
            supportLinkedBugs.Where(i => string.Equals(i.IssueType, "Redesign", StringComparison.OrdinalIgnoreCase)).ToList());
        SupportLinkedHoursPerPerson = DeliveryHealthCalculator.ComputeHoursPerPerson(report, supportLinkedBugs);

        SupportLinkedOriginBreakdown = DeliveryHealthCalculator.ComputeOriginTypeBreakdown(report, supportLinkedBugs);
        FeatureFoundOriginBreakdown  = DeliveryHealthCalculator.ComputeOriginTypeBreakdown(report, featureFoundBugs);
    }

    // True if the issue had real activity (a worklog, or was created/resolved) between the
    // sprint's own dates — as opposed to merely carrying that sprint's Jira Sprint-field tag
    // from some point in its history. Unknown sprint dates never filter anything out.
    private static bool HasActivityInSprintWindow(SprintIssue i, DateTime? start, DateTime? end)
    {
        if (!start.HasValue || !end.HasValue) return true;
        bool InWin(DateTime? d) => d.HasValue && d.Value >= start.Value && d.Value <= end.Value;
        return i.Worklogs.Any(w => InWin(w.Started)) || InWin(i.Created) || InWin(i.ResolutionDate);
    }

