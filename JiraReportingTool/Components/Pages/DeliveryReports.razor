    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_renderCharts && Report is not null && TaskMetrics is not null && AllMetrics is not null)
        {
            _renderCharts = false;
            await RenderStatusDonut("chart-status-task", TaskMetrics);
            await RenderStatusDonut("chart-status-all", AllMetrics);
            await RenderBurndownChart("chart-burndown-task", TaskBurndown, TaskIdealBurndown);
            await RenderBurndownChart("chart-burndown-all", AllBurndown, AllIdealBurndown);
            await RenderCountBurndownChart("chart-count-burndown-task", TaskCountBurndown, TaskIdealCountBurndown);
            await RenderCountBurndownChart("chart-count-burndown-all", AllCountBurndown, AllIdealCountBurndown);
            await RenderHoursPerDayChart("chart-hours-task", TaskHoursPerDay);
            await RenderHoursPerDayChart("chart-hours-all", AllHoursPerDay);
            await RenderEstimationScatter("chart-estimation-task", TaskEstimationPoints);
            await RenderEstimationScatter("chart-estimation-all", AllEstimationPoints);
        }

        if (_renderJsSupportHoursChart && _showJsSupportHoursModal && _jsSupportHoursModalSeries.Count > 0)
        {
            _renderJsSupportHoursChart = false;
            await RenderHoursPerDayChart("chart-hours-jssupport", _jsSupportHoursModalSeries);
        }

        if (_renderJsSupportPersonHoursChart && _showJsSupportPersonHoursModal && _jsSupportPersonHoursModalSeries.Count > 0)
        {
            _renderJsSupportPersonHoursChart = false;
            await RenderHoursPerPersonChart("chart-hours-jssupport-person", _jsSupportPersonHoursModalSeries);
        }

        if (_clearNotesEditorPending && _showExportNotesModal)
        {
            _clearNotesEditorPending = false;
            await JS.InvokeVoidAsync("clearNotesEditor");
        }
    }

