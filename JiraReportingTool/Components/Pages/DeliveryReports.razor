    private async Task ExportToExcel()
    {
        if (Report is null || TaskMetrics is null || AllMetrics is null) return;

        IsExporting = true; StateHasChanged();
        try
        {
            using var wb = new XLWorkbook();
            var sprintLabel = Report.SprintName is { Length: > 0 } sn ? sn : $"Sprint {Report.JiraSprintId}";
            var dateRangeLabel = Report.StartDate.HasValue && Report.EndDate.HasValue
                ? $"{Report.StartDate:MMM d, yyyy} – {Report.EndDate:MMM d, yyyy}"
                : "—";
            var productLabel = SelectedProducts.Count == AllProducts.Count
                ? "All products"
                : (SelectedProducts.Count == 0 ? "(none selected)" : string.Join(", ", SelectedProducts.Order()));
            var sprintFilterLabel = SprintFilterLabel();
            var exportedAt = DateTime.Now.ToString("yyyy-MM-dd HH:mm");

            BuildOverviewSheet(wb, sprintLabel, dateRangeLabel, productLabel, sprintFilterLabel, exportedAt);
            await BuildChartsSheetAsync(wb);
            BuildProductsSheet(wb);
            BuildBugFeatureSheet(wb);
            BuildTicketsSheet(wb);

            using var ms = new MemoryStream();
            wb.SaveAs(ms);
            var base64 = Convert.ToBase64String(ms.ToArray());
            var fileLabel = sprintLabel.Replace(" ", "_").Replace("/", "-").Replace(",", "");
            var fileName = $"DeliveryReport_{fileLabel}_{DateTime.Today:yyyyMMdd}.xlsx";
            const string mime = "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet";
            await JS.InvokeVoidAsync("downloadBase64File", base64, fileName, mime);
        }
        catch (Exception ex) { ErrorMessage = $"Export failed: {ex.Message}"; }
        finally { IsExporting = false; }
    }

    // Snapshots the report body (everything but the sprint/product/sprint-filter controls,
