    private RenderFragment RenderSection(string title, string note, DeliveryHealthMetrics m, DeliveryHealthCalculator.ScopeAddedStats? scopeAdded, List<double> velocitySparkline, List<ProductBreakdownRow>? productBreakdown, string idSuffix) =>
    @<text>
        <div class="v2-section-title" style="margin-top:20px"><i class="bi bi-collection"></i>@title <span class="v2-section-note">@note</span></div>

        <div class="v2-gauge">
            <div class="v2-gauge-score @($"v2-gauge-score-{m.Band}")">@m.Score</div>
            <div class="v2-gauge-mid">
                <div class="v2-gauge-label">Sprint Health Score</div>
                <div class="v2-gauge-track">
                    <div class="v2-gauge-marker" style="left:@m.Score%;"></div>
                </div>
                <div class="v2-gauge-desc">@m.Message</div>
            </div>
            <div class="v2-gauge-side">
                <div class="v2-gauge-side-stat">
                    <div class="v2-gauge-side-val">@((int)m.TimeElapsedPct)%</div>
                    <div class="v2-gauge-side-lbl">Time elapsed</div>
                </div>
                <div class="v2-gauge-side-stat">
                    <div class="v2-gauge-side-val @(m.CompletionBehind ? "v2-text-danger" : "v2-text-success")">@((int)m.CompletionPct)%</div>
                    <div class="v2-gauge-side-lbl">Work done</div>
                </div>
                <div class="v2-gauge-side-stat">
                    <div class="v2-gauge-side-val @(m.PlanOverCommit ? "v2-text-danger" : "")">@($"{m.PlannedHours:F0}h")</div>
                    <div class="v2-gauge-side-lbl">Planned</div>
                </div>
                <div class="v2-gauge-side-stat">
                    <div class="v2-gauge-side-val @(m.OverCapacity ? "v2-text-danger" : "")">@($"{m.RemainingHours:F0}h")</div>
                    <div class="v2-gauge-side-lbl">Remaining</div>
                </div>
                <div class="v2-gauge-side-stat">
                    <div class="v2-gauge-side-val">@($"{m.CapacityHours:F0}h")</div>
                    <div class="v2-gauge-side-lbl">Capacity</div>
                </div>
            </div>
        </div>

        <div class="v2-kpi-grid">
            @* display:contents on the live page lets these two cards sit as plain siblings in the
               parent's auto-fit grid (alongside Velocity) — but the HTML export grabs this div's
               outerHTML in isolation, and display:contents produces no layout of its own once
               detached from that parent grid, so exported Completion/Planned vs Worked used to
               stack instead of sitting side by side. grid-column:span 2 keeps this div occupying
               the same two-column width it always did inside the live 3-up grid, while its own
               nested 1fr/1fr grid gives the export a self-contained side-by-side layout. *@
            <div id="@(idSuffix == "task" ? "html-export-delivery-kpis" : null)" style="display:grid;grid-template-columns:1fr 1fr;gap:14px;grid-column:span 2">
            <div class="v2-kpi @(m.CompletionBehind ? "v2-kpi-warn" : "v2-kpi-success")">
                <div class="v2-kpi-head"><i class="bi bi-check2-circle"></i>Completion</div>
                <div class="v2-kpi-value">@((int)m.CompletionPct)%</div>
                <div class="v2-bar" style="margin-top:8px">
                    <div class="v2-bar-fill @(m.CompletionBehind ? "v2-bar-fill-warn" : "v2-bar-fill-success")" style="width:@Math.Min((int)m.CompletionPct, 100)%"></div>
                </div>
                <div class="v2-kpi-sub">@m.DoneCount of @m.TotalCount done · @m.InProgressCount active · @m.ToDoCount pending</div>
                @if (productBreakdown is { Count: > 0 })
                {
                    <div style="display:flex;flex-direction:column;gap:4px;margin-top:10px;padding-top:10px;border-top:1px solid var(--v2-divider)">
                        @foreach (var p in productBreakdown)
                        {
                            var pPct = p.Total > 0 ? p.Done * 100 / p.Total : 0;
                            var hasSprintSplit = p.BySprint.Count > 0;
                            <div style="display:flex;justify-content:space-between;gap:8px;font-size:11.5px;color:var(--v2-ink-3)">
                                <span class="v2-truncate" style="max-width:140px;@(hasSprintSplit ? "font-weight:600;color:var(--v2-ink-2)" : "")">@p.Product</span>
                                <span style="font-weight:600;color:var(--v2-ink-2)">@pPct% · @p.Done of @p.Total done</span>
                            </div>
                            @if (hasSprintSplit)
                            {
                                @foreach (var sp in p.BySprint)
                                {
                                    var spPct = sp.Total > 0 ? sp.Done * 100 / sp.Total : 0;
                                    <div style="display:flex;justify-content:space-between;gap:8px;font-size:11px;color:var(--v2-ink-4);padding-left:14px">
                                        <span class="v2-truncate" style="max-width:130px">@sp.SprintName</span>
                                        <span>@spPct% · @sp.Done of @sp.Total done</span>
                                    </div>
                                }
                            }
                        }
                    </div>
                }
            </div>

            @{
                var pwDelta = m.SprintWindowLoggedHours - m.PlannedHours; // positive = over plan, negative = under
                var pwDeltaPct = m.PlannedHours > 0 ? Math.Abs(pwDelta) / m.PlannedHours * 100 : 0;
                var pwBand = m.PlannedHours <= 0 ? "neutral"
                    : m.SprintWindowLoggedHours > m.PlannedHours * 1.15 ? "danger"
                    : m.SprintWindowLoggedHours > m.PlannedHours ? "warn" : "success";
            }
            <div class="v2-kpi @(pwBand == "neutral" ? "v2-kpi-neutral" : $"v2-kpi-{pwBand}")">
                <div class="v2-kpi-head"><i class="bi bi-clipboard-data"></i>Planned vs Worked</div>
                <div class="v2-kpi-value">@($"{m.PlannedHours:F0}h")<span class="v2-kpi-of">planned</span></div>
                <div class="v2-bar" style="margin-top:8px">
                    <div class="v2-bar-fill v2-bar-fill-@(pwBand == "neutral" ? "success" : pwBand)" style="width:@(m.PlannedHours > 0 ? Math.Min((int)(m.SprintWindowLoggedHours / m.PlannedHours * 100), 100) : 0)%"></div>
                </div>
                <div class="v2-kpi-sub">@($"{m.SprintWindowLoggedHours:F0}h") logged · @(pwDelta > 0 ? $"+{pwDelta:F0}h ({pwDeltaPct:F0}% over)" : pwDelta < 0 ? $"{pwDelta:F0}h ({pwDeltaPct:F0}% under)" : "on plan")</div>
            </div>
            </div>

            <div class="v2-kpi @(m.ThroughputBehind ? "v2-kpi-warn" : "v2-kpi-success")">
                <div class="v2-kpi-head"><i class="bi bi-speedometer2"></i>Velocity</div>
                <div class="v2-kpi-value">@m.ThroughputPerDay.ToString("F1")<span class="v2-kpi-of">of @m.NeededThroughputPerDay.ToString("F1") needed / day</span></div>
                @if (velocitySparkline.Count > 1)
                {
                    @SparklineSvg(velocitySparkline, m.ThroughputBehind ? "#b45309" : "#16a34a")
                }
                <div class="v2-kpi-sub">@(m.ThroughputBehind ? "behind the pace needed to finish" : "on pace to finish")</div>
            </div>
        </div>

        <div class="v2-grid-2" style="margin-top:16px">
            <div class="v2-card">
                <div class="v2-section-title"><i class="bi bi-pie-chart" style="color:var(--v2-brand)"></i>Sprint Status</div>
                <div style="height:240px;position:relative">
                    <canvas id="chart-status-@idSuffix"></canvas>
                </div>
            </div>
            <div class="v2-card">
                <div class="v2-section-title"><i class="bi bi-arrows-collapse" style="color:#0ea5e9"></i>Scope Added <span class="v2-section-note">work added after the sprint started</span></div>
                @if (scopeAdded is not null)
                {
                    <div style="display:flex;flex-direction:column;gap:10px;margin-top:10px">
                        <div class="v2-row">
                            <span class="v2-chip v2-chip-pri-high">Tasks Added</span>
                            <span class="v2-row-value">@scopeAdded.AddedCount &middot; @scopeAdded.PctOfSprintScope.ToString("F0")% of sprint scope</span>
                        </div>
                        @if (scopeAdded.TypeBreakdown.Count > 0)
                        {
                            <div style="display:flex;flex-wrap:wrap;gap:6px">
                                @foreach (var t in scopeAdded.TypeBreakdown)
                                {
                                    <span class="v2-chip v2-chip-@(t.IssueType.ToLower())">@t.IssueType @t.Count</span>
                                }
                            </div>
                        }
                        <div class="v2-row"><span class="v2-chip v2-chip-story">Added Scope (h)</span><span class="v2-row-value">@($"{scopeAdded.AddedScopeHours:F0}h") planned</span></div>
                        <div class="v2-row"><span class="v2-chip v2-chip-task">Time Logged</span><span class="v2-row-value">@($"{scopeAdded.TimeLoggedHours:F0}h") logged on added-scope issues</span></div>
                    </div>
                }
            </div>
        </div>

        <div class="v2-grid-3" style="margin-top:12px">
            <div id="@(idSuffix == "task" ? "html-export-burndown" : null)" style="display:grid;grid-template-columns:1fr 1fr;gap:16px;grid-column:span 2">
            <div class="v2-card">
                <div class="v2-section-title">
                    <i class="bi bi-graph-down-arrow" style="color:var(--v2-brand-3)"></i>Delivery Burndown <span class="v2-section-note">remaining estimate — actual vs ideal</span>
                    <i class="bi bi-info-circle dr-info-icon" title="Remaining = each issue's original estimate minus hours already logged against it (never below zero), dropping to zero once the issue is marked Done. It's not a straight subtraction of total hours logged — an issue's remaining only falls when work is logged on that specific issue, or the issue resolves."></i>
                </div>
                <div style="height:240px;position:relative">
                    <canvas id="chart-burndown-@idSuffix"></canvas>
                </div>
            </div>
            <div class="v2-card">
                <div class="v2-section-title">
                    <i class="bi bi-list-check" style="color:var(--v2-success)"></i>Task Burndown <span class="v2-section-note">issue count — actual vs ideal</span>
                    <i class="bi bi-info-circle dr-info-icon" title="Number of issues not yet marked Done as of each day, regardless of estimate size — complements the hours-based Delivery Burndown for tracking raw task count instead of effort."></i>
                </div>
                <div style="height:240px;position:relative">
                    <canvas id="chart-count-burndown-@idSuffix"></canvas>
                </div>
            </div>
            </div>
            <div class="v2-card">
                <div class="v2-section-title"><i class="bi bi-calendar-event" style="color:var(--v2-brand-2)"></i>Hours Logged per Day</div>
                <div style="height:240px;position:relative">
                    <canvas id="chart-hours-@idSuffix"></canvas>
                </div>
            </div>
        </div>

        <div class="v2-card" style="margin-top:12px">
            <div class="v2-section-title"><i class="bi bi-graph-up" style="color:var(--v2-brand)"></i>Estimation Accuracy <span class="v2-section-note">planned vs actual hours per issue — above the diagonal = underestimated</span></div>
            <div style="height:300px;position:relative">
                <canvas id="chart-estimation-@idSuffix"></canvas>
            </div>
        </div>
    </text>;
}

<style>
    .dr-chip-row { display:flex; flex-wrap:wrap; gap:8px; }
    .dr-chip {
        display:inline-flex; align-items:center; gap:6px;
        padding:7px 12px; border-radius:20px;
        border:1px solid var(--v2-border); background:var(--v2-surface-2);
        font-size:12.5px; color:var(--v2-ink-3); cursor:pointer; user-select:none;
        transition: background 0.12s, border-color 0.12s, color 0.12s;
    }
    .dr-chip:hover { border-color:var(--v2-border-strong); }
    .dr-chip-on { background:var(--v2-brand-soft); border-color:var(--v2-brand); color:var(--v2-brand); font-weight:600; }
    .dr-chip-n  { font-size:11px; font-weight:700; color:var(--v2-ink-4); }
    .dr-chip-on .dr-chip-n { color:var(--v2-brand); }

    .dr-link-btn  { background:none; border:none; cursor:pointer; font-size:11px; font-weight:600; color:var(--v2-brand); padding:0; }
    .dr-link-btn:hover { text-decoration:underline; }
    .dr-dot-sep   { font-size:10px; color:var(--v2-ink-4); }

    .dr-export-btn {
        background: var(--v2-success-soft); border: 1px solid var(--v2-success-border); cursor: pointer;
        font-size: 12px; font-weight: 600; color: #15803d;
        padding: 7px 14px; border-radius: 8px; display: flex; align-items: center; gap: 6px;
    }
    .dr-export-btn:hover:not(:disabled) { background: #d1fae5; }
    .dr-export-btn:disabled { opacity: .5; cursor: default; }
    .dr-export-btn .v2-spin { border-color: rgba(21,128,61,0.25); border-top-color: #15803d; }
    .dr-export-btn-compact { background: var(--v2-brand-soft); border-color: var(--v2-brand); color: var(--v2-brand); }
    .dr-export-btn-compact:hover:not(:disabled) { background: var(--v2-brand-soft); filter: brightness(0.97); }
    .dr-export-btn-compact .v2-spin { border-color: rgba(99,102,241,0.25); border-top-color: var(--v2-brand); }

    .dr-info-icon { color:var(--v2-ink-4); cursor:help; font-size:12px; margin-left:2px; }
    .dr-info-icon:hover { color:var(--v2-brand); }

    .dr-collapsible-head { cursor:pointer; user-select:none; }
    .dr-collapsible-head:hover { color:var(--v2-brand); }
    .dr-collapse-chevron { font-size:10px; color:var(--v2-ink-4); width:10px; display:inline-block; }

    .dr-product-table { font-size:10.5px; }
    .dr-product-table thead th { padding:6px 8px; font-size:9.5px; }
    .dr-product-table tbody td { padding:5px 8px; }
    .dr-product-table .v2-chip { font-size:9.5px; padding:1px 6px; }

    .dr-hours-link {
        margin-left:8px; cursor:pointer; user-select:none; font-size:11.5px; font-weight:600;
        color:var(--v2-brand); padding:2px 8px; border-radius:6px; border:1px solid transparent;
    }
    .dr-hours-link:hover { background:var(--v2-brand-soft); border-color:var(--v2-brand); }

    .dr-epic-row { cursor:pointer; }
    .dr-epic-row:hover { background:var(--v2-brand-soft); }

    .dr-notes-toolbar { display:flex; align-items:center; gap:6px; margin-bottom:8px; }
    .dr-notes-btn {
        width:28px; height:28px; border-radius:6px; border:1px solid var(--v2-divider);
        background:var(--v2-surface); cursor:pointer; display:flex; align-items:center; justify-content:center;
        font-size:12px; color:var(--v2-ink-2);
    }
    .dr-notes-btn:hover { background:var(--v2-brand-soft); border-color:var(--v2-brand); }
    .dr-notes-toolbar-sep { width:1px; height:20px; background:var(--v2-divider); margin:0 2px; }
    .dr-notes-swatch {
        width:20px; height:20px; border-radius:50%; border:1px solid var(--v2-divider); cursor:pointer; padding:0;
    }
    .dr-notes-swatch:hover { transform:scale(1.15); }
    .dr-notes-editor {
        min-height:160px; max-height:320px; overflow-y:auto; border:1px solid var(--v2-divider);
        border-radius:8px; padding:10px 12px; font-size:13px; color:var(--v2-ink-1); line-height:1.5;
    }
    .dr-notes-editor:focus { outline:none; border-color:var(--v2-brand); }
    .dr-notes-editor ul { margin:4px 0 4px 18px; padding:0; }
    .dr-notes-editor a { color:var(--v2-brand); text-decoration:underline; }
</style>
