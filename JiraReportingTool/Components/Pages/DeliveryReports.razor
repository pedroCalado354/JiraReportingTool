        ("chart-status-task",   "Sprint Status — Delivery Work"),
        ("chart-status-all",    "Sprint Status — All Issue Types"),
        ("chart-burndown-task", "Delivery Burndown — Delivery Work"),
        ("chart-burndown-all",  "Delivery Burndown — All Issue Types"),
        ("chart-hours-task",    "Hours Logged per Day — Delivery Work"),
