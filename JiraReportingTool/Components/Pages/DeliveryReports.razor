        IsExportingCompact = true; StateHasChanged();
        try
        {
            using var wb = new XLWorkbook();
            var sprintLabel = Report.SprintName is { Length: > 0 } sn ? sn : $"Sprint {Report.JiraSprintId}";
            var dateRangeLabel = Report.StartDate.HasValue && Report.EndDate.HasValue
                ? $"{Report.StartDate:MMM d, yyyy} – {Report.EndDate:MMM d, yyyy}"
                : "—";
            var productLabel = SelectedProducts.Count == AllProducts.Count
                ? "All products"
                : (SelectedProducts.Count == 0 ? "(none selected)" : string.Join(", ", SelectedProducts.Order()));
            var exportedAt = DateTime.Now.ToString("yyyy-MM-dd HH:mm");

            await BuildCompactSheetAsync(wb, sprintLabel, dateRangeLabel, productLabel, exportedAt);

            using var ms = new MemoryStream();
            wb.SaveAs(ms);
            var base64 = Convert.ToBase64String(ms.ToArray());
            var fileLabel = sprintLabel.Replace(" ", "_").Replace("/", "-").Replace(",", "");
            var fileName = $"DeliveryReport_Compact_{fileLabel}_{DateTime.Today:yyyyMMdd}.xlsx";
            const string mime = "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet";
            await JS.InvokeVoidAsync("downloadBase64File", base64, fileName, mime);
        }
        catch (Exception ex) { ErrorMessage = $"Compact export failed: {ex.Message}"; }
        finally { IsExportingCompact = false; }
    }

    private async Task BuildCompactSheetAsync(XLWorkbook wb, string sprintLabel, string dateRangeLabel, string productLabel, string exportedAt)
    {
        var ws = wb.Worksheets.Add("Summary");
        int row = 1;

        void Meta(string label, string value)
        {
            var lc = ws.Cell(row, 1); lc.Value = label; StyleMetaLabel(lc);
            ws.Cell(row, 2).Value = value;
            row++;
        }

        void SectionTitle(string title)
        {
            var c = ws.Cell(row, 1); c.Value = title; c.Style.Font.Bold = true; c.Style.Font.FontSize = 13;
            row++;
        }

        Meta("Sprint", sprintLabel);
        Meta("Date Range", dateRangeLabel);
        Meta("Products", productLabel);
        Meta("Exported", exportedAt);
        row++;

        row = WriteNotesSection(ws, row, _exportNotesHtml);

        if (AllBugSplit is not null)
        {
            SectionTitle("Bug vs Feature Split");
            Meta("Bug %", $"{AllBugSplit.BugPct:F0}%");
            Meta("Bugs", $"{AllBugSplit.BugCount} total · {AllBugSplit.BugWorkedOnCount} worked on · {AllBugSplit.BugHours:F0}h logged");
            Meta("Feature / Task", $"{AllBugSplit.FeatureCount} total · {AllBugSplit.FeatureWorkedOnCount} worked on · {AllBugSplit.FeatureHours:F0}h logged");
            row++;
        }

        if (AllBugOriginSplit is not null && (AllBugOriginSplit.SupportLinkedCount + AllBugOriginSplit.FeatureFoundCount) > 0)
        {
            SectionTitle("Bug Origin");
            Meta("Support-linked %", $"{AllBugOriginSplit.SupportLinkedPct:F0}%");
            Meta("JSSUPPORT-linked", $"{AllBugOriginSplit.SupportLinkedCount} total · {AllBugOriginSplit.SupportLinkedWorkedOnCount} worked on · {AllBugOriginSplit.SupportLinkedHours:F0}h logged");
            Meta("Feature-found", $"{AllBugOriginSplit.FeatureFoundCount} total · {AllBugOriginSplit.FeatureFoundWorkedOnCount} worked on · {AllBugOriginSplit.FeatureFoundHours:F0}h logged");
            row++;
        }

        if (TaskMetrics is not null)
        {
            var t = TaskMetrics;
            var delta = t.SprintWindowLoggedHours - t.PlannedHours;
            var deltaPct = t.PlannedHours > 0 ? Math.Abs(delta) / t.PlannedHours * 100 : 0;
            SectionTitle("Planned vs Worked — Delivery Work");
            Meta("Planned", $"{t.PlannedHours:F0}h");
            Meta("Logged", $"{t.SprintWindowLoggedHours:F0}h");
            Meta("Delta", delta > 0 ? $"+{delta:F0}h ({deltaPct:F0}% over)" : delta < 0 ? $"{delta:F0}h ({deltaPct:F0}% under)" : "on plan");
            row++;
        }

        SectionTitle("Delivery Burndown — Delivery Work");
        string? dataUrl = null;
        try { dataUrl = await JS.InvokeAsync<string?>("getChartImage", "chart-burndown-task"); } catch { }

        if (!string.IsNullOrEmpty(dataUrl))
        {
            var comma = dataUrl.IndexOf(',');
            var base64Img = comma >= 0 ? dataUrl[(comma + 1)..] : dataUrl;
            var bytes = Convert.FromBase64String(base64Img);
            using var imgStream = new MemoryStream(bytes);
            ws.AddPicture(imgStream, XLPictureFormat.Png)
              .MoveTo(ws.Cell(row, 1))
              .WithSize(640, 340);
        }
        else
        {
            ws.Cell(row, 1).Value = "(chart not available — no data for current filters)";
        }

        ws.Columns().AdjustToContents();
    }

