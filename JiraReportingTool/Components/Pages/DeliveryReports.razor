    private sealed record NoteLine(string Text, bool Bold, string? ColorHex, string? Url);

    // execCommand-produced markup wraps each new line in <div>/<p>, and bullet items in <li> —
    // block tags act as line breaks. Bold/color/link are approximated per-line (good enough for
    // short report notes) rather than parsed as nested runs, to avoid pulling in a full HTML
    // parser for what's meant to be a few bullet points, not a document.
    private static List<NoteLine> ParseNotesHtml(string html)
    {
        var lines = new List<NoteLine>();
        if (string.IsNullOrWhiteSpace(html)) return lines;

        var blockified = Regex.Replace(html, "(?i)<(div|p|li|br)[^>]*>", "\n$0");
        var blocks = blockified.Split('\n', StringSplitOptions.RemoveEmptyEntries);

        foreach (var block in blocks)
        {
            var isBullet = Regex.IsMatch(block, "(?i)<li[^>]*>");
            var isBold = Regex.IsMatch(block, "(?i)<(b|strong)[^>]*>");
            string? color = null;
            var colorMatch = Regex.Match(block, "(?i)color:\\s*(#[0-9a-f]{3,6}|rgb\\([^)]+\\))");
            if (colorMatch.Success) color = NormalizeNoteColor(colorMatch.Groups[1].Value);

            string? url = null;
            var linkMatch = Regex.Match(block, "(?is)<a\\s+[^>]*href=[\"']([^\"']+)[\"']");
            if (linkMatch.Success) url = System.Net.WebUtility.HtmlDecode(linkMatch.Groups[1].Value);

            var text = System.Net.WebUtility.HtmlDecode(Regex.Replace(block, "<[^>]+>", "")).Trim();
            if (text.Length == 0) continue;

            lines.Add(new NoteLine(isBullet ? $"• {text}" : text, isBold, color, url));
        }
        return lines;
    }

    private static string? NormalizeNoteColor(string raw)
    {
        if (raw.StartsWith('#'))
            return raw.Length == 4 ? $"#{raw[1]}{raw[1]}{raw[2]}{raw[2]}{raw[3]}{raw[3]}" : raw;
        var m = Regex.Match(raw, @"rgb\((\d+),\s*(\d+),\s*(\d+)\)");
        if (!m.Success) return null;
        return $"#{int.Parse(m.Groups[1].Value):X2}{int.Parse(m.Groups[2].Value):X2}{int.Parse(m.Groups[3].Value):X2}";
    }

    // Writes a "Notes" section starting at row, returns the next free row. No-op (returns row
    // unchanged) when there's nothing to write.
    private static int WriteNotesSection(IXLWorksheet ws, int row, string notesHtml)
    {
        var lines = ParseNotesHtml(notesHtml);
        if (lines.Count == 0) return row;

        var header = ws.Cell(row, 1); header.Value = "Notes"; header.Style.Font.Bold = true; header.Style.Font.FontSize = 13;
        row++;
        foreach (var line in lines)
        {
            var cell = ws.Cell(row, 1);
            cell.Value = line.Text;
            if (line.Bold) cell.Style.Font.Bold = true;
            if (line.ColorHex is not null) cell.Style.Font.FontColor = XLColor.FromHtml(line.ColorHex);
            if (line.Url is not null)
            {
                cell.SetHyperlink(new XLHyperlink(line.Url));
                cell.Style.Font.FontColor = XLColor.FromHtml("#0d6efd");
                cell.Style.Font.Underline = XLFontUnderlineValues.Single;
            }
            row++;
        }
        row++;
        return row;
    }

    private async Task ExportToExcel()
    {
        if (Report is null || TaskMetrics is null || AllMetrics is null) return;

        IsExporting = true; StateHasChanged();
        try
        {
            using var wb = new XLWorkbook();
            var sprintLabel = Report.SprintName is { Length: > 0 } sn ? sn : $"Sprint {Report.JiraSprintId}";
            var dateRangeLabel = Report.StartDate.HasValue && Report.EndDate.HasValue
                ? $"{Report.StartDate:MMM d, yyyy} – {Report.EndDate:MMM d, yyyy}"
                : "—";
            var productLabel = SelectedProducts.Count == AllProducts.Count
                ? "All products"
                : (SelectedProducts.Count == 0 ? "(none selected)" : string.Join(", ", SelectedProducts.Order()));
            var exportedAt = DateTime.Now.ToString("yyyy-MM-dd HH:mm");

            await BuildHtmlMatchedSheetAsync(wb, sprintLabel, dateRangeLabel, productLabel, exportedAt);

            using var ms = new MemoryStream();
            wb.SaveAs(ms);
            var base64 = Convert.ToBase64String(ms.ToArray());
            var fileLabel = sprintLabel.Replace(" ", "_").Replace("/", "-").Replace(",", "");
            var fileName = $"DeliveryReport_{fileLabel}_{DateTime.Today:yyyyMMdd}.xlsx";
            const string mime = "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet";
            await JS.InvokeVoidAsync("downloadBase64File", base64, fileName, mime);
        }
        catch (Exception ex) { ErrorMessage = $"Export failed: {ex.Message}"; }
        finally { IsExporting = false; }
    }

    // Mirrors exactly the sections the "Export .html" button captures (HtmlExportSectionIds):
    // Bug vs Feature Split, Bug Origin JSSUPPORT (donut, priority breakdown, by-product table),
    // Delivery Work's Completion + Planned vs Worked KPIs, and its two burndown charts — so the
    // .xlsx and .html exports carry the same data.
    private async Task BuildHtmlMatchedSheetAsync(XLWorkbook wb, string sprintLabel, string dateRangeLabel, string productLabel, string exportedAt)
    {
        var ws = wb.Worksheets.Add("Summary");
        int row = 1;

        void Meta(string label, string value)
        {
            var lc = ws.Cell(row, 1); lc.Value = label; StyleMetaLabel(lc);
            ws.Cell(row, 2).Value = value;
            row++;
        }

        void SectionTitle(string title)
        {
            var c = ws.Cell(row, 1); c.Value = title; c.Style.Font.Bold = true; c.Style.Font.FontSize = 13;
            row++;
        }

        Meta("Sprint", sprintLabel);
        Meta("Date Range", dateRangeLabel);
        Meta("Products", productLabel);
        Meta("Exported", exportedAt);
        row++;

        row = WriteNotesSection(ws, row, _exportNotesHtml);

        if (AllBugSplit is not null)
        {
            SectionTitle("Bug vs Feature Split");
            Meta("Bug %", $"{AllBugSplit.BugPct:F0}%");
            Meta("Bugs", $"{AllBugSplit.BugCount} total · {AllBugSplit.BugWorkedOnCount} worked on · {AllBugSplit.BugHours:F0}h logged");
            Meta("Feature / Task", $"{AllBugSplit.FeatureCount} total · {AllBugSplit.FeatureWorkedOnCount} worked on · {AllBugSplit.FeatureHours:F0}h logged");
            row++;
        }

        if (SupportBugTypeSplitStat is not null && (SupportBugTypeSplitStat.BugTypeCount + SupportBugTypeSplitStat.RedesignTypeCount) > 0)
        {
            var supportBugRedesignTotal = SupportBugTypeSplitStat.BugTypeCount + SupportBugTypeSplitStat.RedesignTypeCount;
            var supportBugTypePct = supportBugRedesignTotal > 0 ? SupportBugTypeSplitStat.BugTypeCount * 100.0 / supportBugRedesignTotal : 0;

            SectionTitle("Bug Origin JSSUPPORT");
            Meta("Bug %", $"{supportBugTypePct:F0}%");
            if (SupportLinkedOriginBreakdown is not null)
                Meta("Total Hours Logged", $"{(SupportLinkedOriginBreakdown.BugHours + SupportLinkedOriginBreakdown.RedesignHours):F0}h");
            Meta("Bug", $"{SupportBugTypeSplitStat.BugTypeCount} total · {SupportBugTypeSplitStat.BugTypeWorkedOnCount} worked on" +
                (SupportLinkedOriginBreakdown is not null ? $" · {SupportLinkedOriginBreakdown.BugHours:F0}h logged" : ""));
            Meta("Redesign", $"{SupportBugTypeSplitStat.RedesignTypeCount} total · {SupportBugTypeSplitStat.RedesignTypeWorkedOnCount} worked on" +
                (SupportLinkedOriginBreakdown is not null ? $" · {SupportLinkedOriginBreakdown.RedesignHours:F0}h logged" : ""));
            if (SupportBugPriorityBreakdown.Count > 0)
                Meta("Priority Breakdown", string.Join(", ", SupportBugPriorityBreakdown.Select(p => $"{p.Priority} ({p.Count})")));
            row++;

            if (SupportBugsByProductType.Count > 0)
            {
                var headers = new[] { "Product", "Type", "Staff", "Logged", "Closed", "Avg" };
                for (int i = 0; i < headers.Length; i++) { var hc = ws.Cell(row, i + 1); hc.Value = headers[i]; StyleHeaderCell(hc); }
                row++;
                foreach (var r in SupportBugsByProductType)
                {
                    ws.Cell(row, 1).Value = r.Product;
                    ws.Cell(row, 2).Value = r.IssueType;
                    ws.Cell(row, 3).Value = r.StaffCount;
                    ws.Cell(row, 4).Value = $"{r.LoggedHours:F0}h";
                    ws.Cell(row, 5).Value = $"{r.ClosedCount}/{r.TotalCount}";
                    ws.Cell(row, 6).Value = r.ClosedCount > 0 ? $"{r.AvgHoursToClose:F1}h" : "—";
                    row++;
                }
                row++;
            }
        }

        if (TaskMetrics is not null)
        {
            var t = TaskMetrics;
            SectionTitle("Delivery Work — Completion");
            Meta("Completion", $"{t.CompletionPct:F0}%");
            Meta("Done / In Progress / To Do", $"{t.DoneCount} / {t.InProgressCount} / {t.ToDoCount}");
            if (TaskProductBreakdown.Count > 0)
                Meta("By Product", string.Join(" · ", TaskProductBreakdown.Select(p => $"{p.Product} {(p.Total > 0 ? p.Done * 100 / p.Total : 0)}% ({p.Done}/{p.Total})")));
            row++;

            var delta = t.SprintWindowLoggedHours - t.PlannedHours;
            var deltaPct = t.PlannedHours > 0 ? Math.Abs(delta) / t.PlannedHours * 100 : 0;
            SectionTitle("Delivery Work — Planned vs Worked");
            Meta("Planned", $"{t.PlannedHours:F0}h");
            Meta("Logged", $"{t.SprintWindowLoggedHours:F0}h");
            Meta("Delta", delta > 0 ? $"+{delta:F0}h ({deltaPct:F0}% over)" : delta < 0 ? $"{delta:F0}h ({deltaPct:F0}% under)" : "on plan");
            row++;
        }

        async Task AddBurndownChart(string title, string canvasId)
        {
            SectionTitle(title);
            string? dataUrl = null;
            try { dataUrl = await JS.InvokeAsync<string?>("getChartImage", canvasId); } catch { }

            if (!string.IsNullOrEmpty(dataUrl))
            {
                var comma = dataUrl.IndexOf(',');
                var base64Img = comma >= 0 ? dataUrl[(comma + 1)..] : dataUrl;
                var bytes = Convert.FromBase64String(base64Img);
                using var imgStream = new MemoryStream(bytes);
                ws.AddPicture(imgStream, XLPictureFormat.Png)
                  .MoveTo(ws.Cell(row, 1))
                  .WithSize(640, 340);
                row += 18;
            }
            else
            {
                ws.Cell(row, 1).Value = "(chart not available — no data for current filters)";
                row += 1;
            }
            row += 2;
        }

        if (TaskMetrics is not null)
        {
            await AddBurndownChart("Delivery Burndown — Delivery Work", "chart-burndown-task");
            await AddBurndownChart("Task Burndown — Delivery Work", "chart-count-burndown-task");
        }

        ws.Columns().AdjustToContents();
    }

    // Snapshots just the Bug vs Feature Split, Bug Origin JSSUPPORT (donut, Priority Breakdown,
