@page "/epic-planning"
@using System.Globalization
@rendermode InteractiveServer
@using JiraReportingTool.Models
@using System.Text.RegularExpressions
@inject IJiraService JiraService
@inject IJSRuntime JS
@using ClosedXML.Excel

<h3>Sprint Planning Dashboard</h3>

<div class="toolbar">
    <div class="toolbar-group">
        <label>From</label>
        <InputDate @bind-Value="FromDateTime" class="input" />
    </div>

    <div class="toolbar-group">
        <label>To</label>
        <InputDate @bind-Value="ToDateTime" class="input" />
    </div>

    <div class="toolbar-group">
        <button class="btn" @onclick="ApplyDateRange">Apply Range</button>
    </div>

    <div class="toolbar-group epic-box">
        <label>Epic</label>
        <input class="input" placeholder="e.g. JM-15977"
               @bind="EpicKey" @bind:event="oninput" />
        <button class="btn primary" @onclick="LoadEpicTasks">Load Tasks</button>
    </div>

    <div class="toolbar-group">
        <label>Time Off</label>
        <button class="btn @(TimeOffMode ? "btn-timeoff-active" : "")"
                @onclick="ToggleTimeOffMode"
                title="Toggle Time Off Mode: click member cells to mark days off; click date headers to mark holidays">
            @(TimeOffMode ? "Exit Time-Off Mode" : "Manage Time Off")
        </button>
    </div>

    <div class="toolbar-group epic-box">
        <button class="btn btn-outline-success" @onclick="ExportToExcel"
                disabled="@(Report == null)"
                title="Export remaining work to Excel">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16" class="me-1">
                <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5z" />
                <path d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708l3 3z" />
            </svg>
            Export .xlsx
        </button>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(InfoMessage))
{
    <div class="info">@InfoMessage</div>
}

@if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="error">@ErrorMessage</div>
}

<div class="layout">
    <!-- LEFT: Task list -->
    <div class="panel">
        <div class="panel-header">
            <strong>Tasks in Epic: </strong> @(!string.IsNullOrWhiteSpace(EpicKey) ? EpicKey : "(none)")
        </div>

        <div class="panel-body">
            @if (AvailableTasks.Count == 0)
            {
                <div class="muted">Load an epic to list tasks.</div>
            }
            else
            {
                @foreach (var group in GetTasksGroupedByStatus())
                {
                    <div class="task-group-header status-@group.Key">
                        @GetStatusGroupLabel(group.Key) <span class="task-group-count">@group.Count()</span>
                    </div>
                    <ul class="task-list">
                        @foreach (var t in group.OrderBy(x => x.Key))
                        {
                            var isSelected = SelectedTask?.Id == t.Id;
                            var assignmentInfo = GetTaskAssignmentInfo(t.Id);
                            var isAssigned = assignmentInfo.Count > 0;

                            <li class="task-item @(isSelected ? "selected" : "") @(isAssigned ? "assigned" : "")"
                                @onclick="() => SelectTask(t)">
                                <div class="task-header">
                                    <div class="task-title">@t.Key - @t.Summary</div>
                                    @if (isAssigned)
                                    {
                                        <span class="task-assigned-badge">✓ Assigned</span>
                                    }
                                </div>
                                <div class="task-meta">
                                    <span>@t.IssueType</span>
                                    <span>•</span>
                                    <span>@t.Status</span>
                                    <span>•</span>
                                    <span>@t.Assignee</span>
                                    <span>•</span>
                                    <span><strong>Est:</strong> @FormatEstimateHours(t.OriginalEstimate)</span>
                                </div>
                                @if (isAssigned)
                                {
                                    <div class="task-assignments">
                                        @foreach (var info in assignmentInfo)
                                        {
                                            <div class="task-assignment-chip">
                                                <span class="chip-team">@info.Team</span>
                                                <span class="chip-name">@info.MemberName</span>
                                                <span class="chip-dates">@info.From.ToString("dd-MMM") → @info.To.ToString("dd-MMM")</span>
                                            </div>
                                        }
                                    </div>
                                }
                            </li>
                        }
                    </ul>
                }
            }
        </div>

        <div class="panel-footer">
            <div class="muted">
                <strong>How to schedule:</strong>
                Select a task → click a cell to set the start date → click again on the same row to auto-schedule.
                Tasks split automatically across days (max @(MaxHoursPerDay)h/day per member).
            </div>
        </div>
    </div>

    <!-- RIGHT: Calendar -->
    <div class="calendar-container">
        <div class="calendar-help">
            <strong>Selected Task:</strong>
            <span class="pill">
                @((SelectedTask is null)
                    ? "None"
                    : $"{SelectedTask.Key} - {SelectedTask.Summary} (Est: {SelectedTask.OriginalEstimate})")
            </span>

            @if (PendingPlacement is not null)
            {
                <span class="pill warn">
                    Placing for: @TeamMembers.First(x => x.Id == PendingPlacement.TeamMemberId).Name
                    | Start: @PendingPlacement.Start.ToString("dd-MMM")
                    (click again to auto-schedule from here)
                </span>
                <button class="btn small" @onclick="CancelPlacement">Cancel</button>
            }
        </div>

        <div class="calendar-scroll">
            <table class="calendar">
                <thead>
                    <tr>
                        <th class="sticky-col">Team Member</th>
                        @foreach (var d in VisibleDates)
                        {
                            var isHol = IsHoliday(d);
                            <th class="date-col @(IsWeekend(d) ? "weekend-col" : "") @(isHol ? "holiday-col" : "")"
                                style="cursor: @(TimeOffMode ? "pointer" : "default");"
                                title="@(TimeOffMode ? (isHol ? "Click to remove holiday" : "Click to mark as holiday") : d.ToString("dddd, dd MMM yyyy"))"
                                @onclick="() => OnDateHeaderClicked(d)">
                                @d.ToString("dd-MMM", CultureInfo.InvariantCulture)
                                @if (isHol) { <span class="holiday-star">H</span> }
                            </th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var teamGroup in TeamMembers.GroupBy(m => m.Team))
                    {
                        <tr class="team-group-row">
                            <td class="sticky-col team-group-label" colspan="@(VisibleDates.Count + 1)">
                                @teamGroup.Key
                            </td>
                        </tr>

                        @foreach (var member in teamGroup)
                        {
                            var lanedBlocks = GetLanedBlocks(member.Id);
                            var maxLanes    = GetMaxLanes(member.Id);
                            var rowHeight   = Math.Max(70, maxLanes * 34 + 30);

                            <tr style="height: @(rowHeight)px;">
                                <td class="sticky-col member-col">
                                    <div class="member-info">
                                        <span class="member-name">@member.Name</span>
                                        <span class="member-hours">@GetMemberTotalEstimateHours(member.Id)</span>
                                    </div>
                                </td>
                                @for (int i = 0; i < VisibleDates.Count; i++)
                                {
                                    var currentDate = VisibleDates[i];

                                    @* Blocks whose visible start date (clamped to range) falls on currentDate *@
                                    var cellBlocks = lanedBlocks
                                        .Where(lb =>
                                        {
                                            var clampedFrom = lb.Block.From < FromDate ? FromDate : lb.Block.From;
                                            return clampedFrom == currentDate;
                                        })
                                        .ToList();

                                    var allocated      = GetAllocatedHours(member.Id, currentDate);
                                    var remaining      = GetRemainingHours(member.Id, currentDate);
                                    var usagePercent   = MaxHoursPerDay > 0 ? (allocated / MaxHoursPerDay) * 100m : 0m;
                                    var isWeekendDay   = IsWeekend(currentDate);
                                    var isMemberOff    = IsMemberTimeOff(member.Id, currentDate);
                                    var isHolidayDay   = IsHoliday(currentDate);
                                    var isDayOffCell   = isMemberOff || isHolidayDay;
                                    var weekendClass   = isWeekendDay ? " weekend-cell" : "";
                                    var cellClass      = isDayOffCell
                                                       ? "cell stacked-cell cell-dayoff" + weekendClass
                                                       : (allocated == 0m   ? "cell stacked-cell"
                                                         : allocated >= MaxHoursPerDay ? "cell stacked-cell cell-full"
                                                         : "cell stacked-cell cell-partial") + weekendClass;
                                    var cellTitle      = isDayOffCell
                                                       ? (isHolidayDay ? "Holiday — no capacity" : "Time off — no capacity")
                                                       : $"{allocated:0.#}h / {MaxHoursPerDay}h ({remaining:0.#}h remaining)";

                                    <td class="@cellClass"
                                        title="@cellTitle"
                                        @onclick="() => OnCalendarCellClicked(member.Id, currentDate)">

                                        @* Time-off indicator label (non-weekend only, weekend already greyed) *@
                                        @if (isDayOffCell && !isWeekendDay)
                                        {
                                            <div class="cell-dayoff-label">
                                                @(isHolidayDay ? "holiday" : "off")
                                            </div>
                                        }

                                        @* Background capacity usage bar *@
                                        @if (allocated > 0 && !isDayOffCell)
                                        {
                                            <div class="cell-usage-bar" style="height: @(usagePercent)%;"></div>
                                        }

                                        @* Actual daily allocation label *@
                                        @if (allocated > 0 && !isDayOffCell)
                                        {
                                            <div class="cell-hours-label @(allocated >= MaxHoursPerDay ? "full" : "")">
                                                @($"{allocated:0.#}h")
                                            </div>
                                        }

                                        @* Render a stacked block for each group starting on this date *@
                                        @foreach (var (block, lane) in cellBlocks)
                                        {
                                            var span       = GetBlockVisibleSpan(block);
                                            var topOffset  = lane * 34 + 22;  // leave room for the hours label
                                            var widthPct   = span * 100;
                                            // Actual hours for this block on today's date (shows split correctly)
                                            var blockToday = GetBlockHoursOnDate(block, currentDate);

                                            <div class="stacked-block"
                                                 style="top: @(topOffset)px; width: calc(@(widthPct)% - 6px);"
                                                 title="@($"{GetTaskLabel(block.TaskId)} — {blockToday:0.#}h today")"
                                                 @onclick:stopPropagation="true">
                                                <div class="stacked-block-content">
                                                    <span class="stacked-block-title">
                                                        @GetTaskLabel(block.TaskId)
                                                    </span>
                                                    <span class="stacked-block-range">
                                                        @($"{blockToday:0.#}h/d")
                                                    </span>
                                                </div>
                                                <button class="btn-remove"
                                                        title="Remove"
                                                        @onclick="() => RemoveBlock(block.GroupId)"
                                                        @onclick:stopPropagation="true">
                                                    ✕
                                                </button>
                                            </div>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code
{
    // ───────────────────────────────────────────────────────────
    // Domain / View Models
    // ───────────────────────────────────────────────────────────
    public record TeamMemberDto(Guid Id, string Name, string Team);

    /// <summary>
    /// Stores one calendar day's scheduled hours for a single (task, member) pair.
    /// Multiple TaskAllocations sharing the same GroupId represent a task that was
    /// split across several days by the scheduling engine.
    /// Example — 20 h task free each day:
    ///   Day 1 → 6 h | Day 2 → 6 h | Day 3 → 6 h | Day 4 → 2 h
    ///   All four records share the same GroupId and are shown as one visual block.
    /// </summary>
    public class TaskAllocation
    {
        public Guid AllocationId { get; set; } = Guid.NewGuid();
        /// <summary>Links all day-segments that belong to one "assign task" action.</summary>
        public Guid GroupId { get; set; }
        public int TaskId { get; set; }
        public Guid TeamMemberId { get; set; }
        public DateOnly Date { get; set; }
        public decimal HoursAllocated { get; set; }
    }

    /// <summary>
    /// Derived visual block for calendar rendering.
    /// Computed from TaskAllocation groups (one block per GroupId); never stored directly.
    /// From = earliest allocated date in the group, To = latest.
    /// </summary>
    private sealed class CalendarBlock
    {
        public Guid GroupId { get; init; }
        public int TaskId { get; init; }
        public Guid TeamMemberId { get; init; }
        public DateOnly From { get; init; }
        public DateOnly To { get; init; }
    }

    private class PendingPlacementState
    {
        public Guid TeamMemberId { get; set; }
        public DateOnly Start { get; set; }
    }

    // -----------------------------
    // UI State
    // -----------------------------
    private DateTime? FromDateTime { get; set; } = DateTime.Today.AddDays(-3);
    private DateTime? ToDateTime { get; set; } = DateTime.Today.AddDays(7);

    private DateOnly FromDate { get; set; }
    private DateOnly ToDate { get; set; }

    private string EpicKey { get; set; } = "";
    private List<JiraIssueModel> AvailableTasks { get; set; } = new();
    private JiraIssueModel? SelectedTask { get; set; }

    private List<TeamMemberDto> TeamMembers { get; set; } = new();
    /// <summary>
    /// Source of truth for all scheduled work.
    /// One entry per (task, member, day) tuple — replaces the old range-based CalendarAssignment list.
    /// Visual blocks and capacity totals are derived from this list on every render.
    /// </summary>
    private List<TaskAllocation> Allocations { get; set; } = new();

    /// <summary>
    /// Persists task metadata across epic loads so that calendar blocks for previously
    /// loaded epics retain their labels after switching to a different epic.
    /// Key = JiraIssueModel.Id (DB auto-increment ID, stable within a session).
    /// </summary>
    private Dictionary<int, JiraIssueModel> _taskCache = new();

    // ── Time Off / Holidays ──
    /// <summary>Global holidays — these dates count as off for ALL team members.</summary>
    private HashSet<DateOnly> Holidays { get; set; } = new();
    /// <summary>Per-member time off — individual dates a specific member is unavailable.</summary>
    private Dictionary<Guid, HashSet<DateOnly>> MemberTimeOff { get; set; } = new();
    /// <summary>When true, cell clicks mark/unmark time off instead of scheduling tasks.</summary>
    private bool TimeOffMode { get; set; } = false;

    private List<DateOnly> VisibleDates { get; set; } = new();

    private PendingPlacementState? PendingPlacement { get; set; }

    private string? ErrorMessage { get; set; }
    private string? InfoMessage { get; set; }

    protected override void OnInitialized()
    {
        // Setup initial date range
        ApplyDateRange();

        // Demo team members (replace with your data)
        TeamMembers = new()
    {
        // Backend
        new TeamMemberDto(Guid.NewGuid(), "Duarte", "Backend"),
        new TeamMemberDto(Guid.NewGuid(), "Freire", "Backend"),
        new TeamMemberDto(Guid.NewGuid(), "Amado", "Backend"),
        new TeamMemberDto(Guid.NewGuid(), "Rosa", "Backend"),
        new TeamMemberDto(Guid.NewGuid(), "Patrick", "Backend"),
        new TeamMemberDto(Guid.NewGuid(), "Rui", "Backend"),
        new TeamMemberDto(Guid.NewGuid(), "Mateus", "Backend"),
        new TeamMemberDto(Guid.NewGuid(), "Dasa", "Backend"),
        new TeamMemberDto(Guid.NewGuid(), "Shashank", "Backend"),
        new TeamMemberDto(Guid.NewGuid(), "Sangram", "Backend"),
        new TeamMemberDto(Guid.NewGuid(), "Ranjit", "Backend"),

        // Frontend
        new TeamMemberDto(Guid.NewGuid(), "Bruno", "Frontend"),
        new TeamMemberDto(Guid.NewGuid(), "Samuel", "Frontend"),
        new TeamMemberDto(Guid.NewGuid(), "Murilo", "Frontend"),
        new TeamMemberDto(Guid.NewGuid(), "Omar", "Frontend"),
        new TeamMemberDto(Guid.NewGuid(), "Vinicius", "Frontend"),
        new TeamMemberDto(Guid.NewGuid(), "Ronit", "Frontend"),
        new TeamMemberDto(Guid.NewGuid(), "Tanaya", "Frontend"),
        new TeamMemberDto(Guid.NewGuid(), "Vijay", "Frontend"),
        new TeamMemberDto(Guid.NewGuid(), "Bhavini", "Frontend"),

        // QA
        new TeamMemberDto(Guid.NewGuid(), "Daria", "QA"),
        new TeamMemberDto(Guid.NewGuid(), "Daniel", "QA"),
        new TeamMemberDto(Guid.NewGuid(), "Jessica", "QA"),
        new TeamMemberDto(Guid.NewGuid(), "Katarina", "QA"),
        new TeamMemberDto(Guid.NewGuid(), "Tejaswini", "QA"),
        new TeamMemberDto(Guid.NewGuid(), "Anushka", "QA"),
        new TeamMemberDto(Guid.NewGuid(), "Muskan", "QA"),
    };
    }

    // -----------------------------
    // Date Range
    // -----------------------------
    private void ApplyDateRange()
    {
        ErrorMessage = null;
        InfoMessage = null;

        var from = FromDateTime?.Date ?? DateTime.Today;
        var to = ToDateTime?.Date ?? DateTime.Today;

        if (to < from)
        {
            ErrorMessage = "Invalid date range: 'To' must be after 'From'.";
            return;
        }

        FromDate = DateOnly.FromDateTime(from);
        ToDate = DateOnly.FromDateTime(to);

        VisibleDates = Enumerable.Range(0, ToDate.DayNumber - FromDate.DayNumber + 1)
            .Select(i => FromDate.AddDays(i))
            .ToList();
    }

    // -----------------------------
    // Epic & Tasks
    // -----------------------------
    private JiraEpicReport? Report;

    private async Task LoadEpicTasks()
    {
        ErrorMessage = null;
        InfoMessage = null;

        if (string.IsNullOrWhiteSpace(EpicKey))
        {
            ErrorMessage = "Please enter an Epic key (e.g., JM-15977).";
            return;
        }

        var epic = EpicKey.Trim().ToUpperInvariant();

        Report = await JiraService.GetEpicReportAsync(epic);

        // Bind real issues from the report
        AvailableTasks = Report?.Issues?
            .OrderBy(i => i.Key)
            .ToList()
            ?? new List<JiraIssueModel>();

        // BUG FIX: accumulate all loaded tasks in a persistent cache so that
        // calendar blocks for previously loaded epics keep their labels after
        // switching to a different epic. Allocations are NOT cleared here.
        foreach (var t in AvailableTasks)
            _taskCache[t.Id] = t;

        SelectedTask = null;
        PendingPlacement = null;

        InfoMessage = $"Loaded {AvailableTasks.Count} issues for epic {epic}.";
    }

    private void SelectTask(JiraIssueModel task)
    {
        ErrorMessage = null;
        InfoMessage = null;

        SelectedTask = task;
        PendingPlacement = null;
    }

    private void ToggleTimeOffMode()
    {
        TimeOffMode = !TimeOffMode;
        InfoMessage = TimeOffMode
            ? "Time Off Mode ON — click member cells to mark/unmark days off; click date headers to mark holidays."
            : "Time Off Mode OFF.";
    }

    // Groups AvailableTasks by StatusCategoryKey in priority order for the task list panel.
    private IEnumerable<IGrouping<string, JiraIssueModel>> GetTasksGroupedByStatus()
        => AvailableTasks
            .GroupBy(t => (t.StatusCategoryKey ?? "new").ToLower())
            .OrderBy(g => g.Key switch
            {
                "indeterminate" => 0,   // In Progress — most actionable, show first
                "new"           => 1,   // To Do
                "done"          => 2,   // Done — show last
                _               => 99
            });

    private static string GetStatusGroupLabel(string statusKey) => statusKey switch
    {
        "indeterminate" => "In Progress",
        "new"           => "To Do",
        "done"          => "Done",
        _               => statusKey
    };

    // -----------------------------
    // Calendar interactions
    // -----------------------------
    private void CancelPlacement()
    {
        PendingPlacement = null;
        InfoMessage = "Placement cancelled.";
    }// -----------------------------
     // Capacity constants
     // -----------------------------
    private const decimal MaxHoursPerDay = 6m;

    // ───────────────────────────────────────────────────────────
    // Capacity helpers
    // ───────────────────────────────────────────────────────────

    /// <summary>
    /// Returns the total hours already allocated to a member on a specific day
    /// from any arbitrary allocation list (committed or provisional).
    /// Static so the scheduling engine can call it without a component reference.
    /// </summary>
    private static decimal GetAllocatedHoursFromList(
        Guid memberId, DateOnly date, IEnumerable<TaskAllocation> list)
        => list
            .Where(a => a.TeamMemberId == memberId && a.Date == date)
            .Sum(a => a.HoursAllocated);

    /// <summary>Returns committed allocated hours for a member on a specific date.</summary>
    private decimal GetAllocatedHours(Guid memberId, DateOnly date)
        => GetAllocatedHoursFromList(memberId, date, Allocations);

    private decimal GetRemainingHours(Guid memberId, DateOnly date)
    {
        // Days off (weekends, holidays, member time off) have zero capacity
        if (IsDayOff(memberId, date)) return 0m;
        return Math.Max(0m, MaxHoursPerDay - GetAllocatedHours(memberId, date));
    }

    // ───────────────────────────────────────────────────────────
    // Time Off / Holiday helpers
    // ───────────────────────────────────────────────────────────

    private bool IsHoliday(DateOnly date)       => Holidays.Contains(date);
    private bool IsMemberTimeOff(Guid memberId, DateOnly date)
        => MemberTimeOff.TryGetValue(memberId, out var days) && days.Contains(date);

    /// <summary>Returns true if this day is unavailable for a given member:
    /// weekend, global holiday, or individual time off.</summary>
    private bool IsDayOff(Guid memberId, DateOnly date)
        => IsWeekend(date) || IsHoliday(date) || IsMemberTimeOff(memberId, date);

    private void ToggleHoliday(DateOnly date)
    {
        if (Holidays.Contains(date)) Holidays.Remove(date);
        else                         Holidays.Add(date);
        InfoMessage = Holidays.Contains(date)
            ? $"{date:dd-MMM} marked as holiday."
            : $"{date:dd-MMM} holiday removed.";
    }

    private void ToggleMemberTimeOff(Guid memberId, DateOnly date)
    {
        if (!MemberTimeOff.ContainsKey(memberId))
            MemberTimeOff[memberId] = new HashSet<DateOnly>();

        var memberName = TeamMembers.FirstOrDefault(m => m.Id == memberId)?.Name ?? "Member";
        if (MemberTimeOff[memberId].Contains(date))
        {
            MemberTimeOff[memberId].Remove(date);
            InfoMessage = $"Removed time off for {memberName} on {date:dd-MMM}.";
        }
        else
        {
            MemberTimeOff[memberId].Add(date);
            InfoMessage = $"Marked {memberName} as off on {date:dd-MMM}.";
        }
    }

    private void OnDateHeaderClicked(DateOnly date)
    {
        if (!TimeOffMode) return;
        ToggleHoliday(date);
    }

    // ───────────────────────────────────────────────────────────
    // Scheduling Engine
    // ───────────────────────────────────────────────────────────

    /// <summary>
    /// Core task-splitting scheduler.
    ///
    /// Allocates <paramref name="totalHours"/> for a (task, member) pair, starting at
    /// <paramref name="startDate"/> and advancing one calendar day at a time.  Each day
    /// absorbs up to <see cref="MaxHoursPerDay"/> minus whatever the member already has
    /// committed.  Days that are completely full are skipped — the task "spills" forward.
    ///
    /// Example — 20 h task, member free every day (6 h/day cap):
    ///   Day 1 → 6 h  |  Day 2 → 6 h  |  Day 3 → 6 h  |  Day 4 → 2 h  (total 4 days)
    ///
    /// All returned allocations share a single GroupId so the calendar can render them
    /// as one continuous visual block even when days are non-consecutive.
    ///
    /// The optional <paramref name="provisional"/> list lets the caller pass allocations
    /// not yet committed to <see cref="Allocations"/> but that should count as consumed
    /// capacity (useful for bulk-scheduling multiple tasks in one call).
    /// </summary>
    private List<TaskAllocation> ScheduleTask(
        int taskId,
        Guid memberId,
        decimal totalHours,
        DateOnly startDate,
        List<TaskAllocation>? provisional = null)
    {
        var result  = new List<TaskAllocation>();
        var groupId = Guid.NewGuid();
        var remaining = totalHours;
        var date = startDate;
        const int maxDaysForward = 365; // safety guard: never loop more than a year

        for (int daysAdvanced = 0; remaining > 0m && daysAdvanced < maxDaysForward; daysAdvanced++)
        {
            // Skip weekends, holidays, and member-specific time off — no capacity on these days
            if (!IsDayOff(memberId, date))
            {
                // Capacity = MaxHoursPerDay − already committed − provisional (not yet in Allocations)
                var committed = GetAllocatedHoursFromList(memberId, date, Allocations);
                var pending   = provisional is not null
                                ? GetAllocatedHoursFromList(memberId, date, provisional)
                                : 0m;
                var capacity  = Math.Max(0m, MaxHoursPerDay - committed - pending);

                if (capacity > 0m)
                {
                    var hours = Math.Min(remaining, capacity);
                    result.Add(new TaskAllocation
                    {
                        GroupId        = groupId,
                        TaskId         = taskId,
                        TeamMemberId   = memberId,
                        Date           = date,
                        HoursAllocated = hours
                    });
                    remaining -= hours;
                }
                // capacity == 0 → day is full, advance without recording
            }
            // IsDayOff → silently skip, task hours spill to the next working day

            date = date.AddDays(1);
        }

        return result;
    }
    private void OnCalendarCellClicked(Guid memberId, DateOnly date)
    {
        ErrorMessage = null;
        InfoMessage = null;

        // In Time Off Mode: toggle member time off, don't schedule tasks
        if (TimeOffMode)
        {
            ToggleMemberTimeOff(memberId, date);
            return;
        }

        if (SelectedTask is null)
        {
            ErrorMessage = "Select a task first.";
            return;
        }

        // First click: record start date and wait for the confirmation click
        if (PendingPlacement is null)
        {
            PendingPlacement = new PendingPlacementState
            {
                TeamMemberId = memberId,
                Start = date
            };
            return;
        }

        // Second click: must be on the same member row
        if (PendingPlacement.TeamMemberId != memberId)
        {
            ErrorMessage = "Confirmation click must be on the same team member row.";
            return;
        }

        // Use the earlier of the two clicked dates as the scheduling start date
        var startDate = date < PendingPlacement.Start ? date : PendingPlacement.Start;

        var totalHours = ParseJiraDurationToHours(SelectedTask.OriginalEstimate);
        if (totalHours <= 0m)
        {
            ErrorMessage = $"Task {SelectedTask.Key} has no estimate — cannot auto-schedule.";
            PendingPlacement = null;
            return;
        }

        // ── Run the scheduling engine ──
        // Fills up to MaxHoursPerDay per calendar day, advancing to the next day when full.
        // A 20 h task with a free member → Day 1: 6 h, Day 2: 6 h, Day 3: 6 h, Day 4: 2 h.
        var newAllocations = ScheduleTask(SelectedTask.Id, memberId, totalHours, startDate);

        if (newAllocations.Count == 0)
        {
            ErrorMessage = $"Could not schedule {SelectedTask.Key}: no available capacity " +
                           $"from {startDate:dd-MMM} within the next 365 days.";
            PendingPlacement = null;
            return;
        }

        // Commit to the per-day allocation store
        Allocations.AddRange(newAllocations);

        var lastDate   = newAllocations.Max(a => a.Date);
        var dayCount   = newAllocations.Count;
        var memberName = TeamMembers.First(x => x.Id == memberId).Name;

        InfoMessage = $"Scheduled {SelectedTask.Key} for {memberName}: " +
                      $"{totalHours:0.#}h split across {dayCount} day(s) " +
                      $"({startDate:dd-MMM} → {lastDate:dd-MMM}).";

        SelectedTask = null;
        PendingPlacement = null;
    }
    // Total scheduled hours per member — sums the actual allocated day-buckets
    // (more accurate than re-summing estimates, since partial-day allocations are exact)
    private string GetMemberTotalEstimateHours(Guid memberId)
    {
        var total = Allocations
            .Where(a => a.TeamMemberId == memberId)
            .Sum(a => a.HoursAllocated);

        if (total <= 0m) return "0h";
        var rounded = total % 1m == 0m ? decimal.Round(total, 0) : decimal.Round(total, 1);
        return $"{rounded.ToString(CultureInfo.InvariantCulture)}h";
    }

    /// <summary>Removes all day-allocations belonging to the given visual block (identified by GroupId).</summary>
    private void RemoveBlock(Guid groupId)
    {
        Allocations.RemoveAll(a => a.GroupId == groupId);
        InfoMessage = "Assignment removed.";
    }

    // ───────────────────────────────────────────────────────────
    // Visual span helpers for CalendarBlock (calendar rendering + Excel export)
    // ───────────────────────────────────────────────────────────

    private int GetBlockVisibleSpan(CalendarBlock block)
    {
        var clampedFrom = block.From < FromDate ? FromDate : block.From;
        var clampedTo   = block.To   > ToDate   ? ToDate   : block.To;
        return Math.Max(1, clampedTo.DayNumber - clampedFrom.DayNumber + 1);
    }

    private int GetBlockVisibleStartCol(CalendarBlock block)
    {
        var clampedFrom = block.From < FromDate ? FromDate : block.From;
        return VisibleDates.IndexOf(clampedFrom);
    }

    /// <summary>
    /// Returns the actual hours scheduled for a specific block on a specific date.
    /// For split tasks this gives the correct per-day value (e.g. 6 h on Day 1, 2 h on Day 4)
    /// rather than a misleading average.
    /// </summary>
    private decimal GetBlockHoursOnDate(CalendarBlock block, DateOnly date)
        => Allocations
            .Where(a => a.GroupId == block.GroupId && a.Date == date)
            .Sum(a => a.HoursAllocated);

    // Resolves a task label from the persistent cache so blocks from previously
    // loaded epics remain readable after switching to a new epic.
    private string GetTaskLabel(int taskId)
    {
        if (!_taskCache.TryGetValue(taskId, out var t)) return $"Task #{taskId}";
        return $"{t.Key} - {t.Summary} (Est: {t.OriginalEstimate})";
    }

    // Same cache lookup used by Excel export
    private JiraIssueModel? FindTask(int taskId)
        => _taskCache.TryGetValue(taskId, out var t) ? t : null;

    private static bool RangesOverlap(DateOnly aFrom, DateOnly aTo, DateOnly bFrom, DateOnly bTo)
        => aFrom <= bTo && bFrom <= aTo;

    private RenderFragment RenderCellHint(Guid memberId, DateOnly date) => builder =>
    {
        // Show a subtle hint if placement is pending on this row
        if (PendingPlacement is not null && PendingPlacement.TeamMemberId == memberId)
        {
            if (date == PendingPlacement.Start)
            {
                builder.AddContent(0, "Start");
            }
            else
            {
                builder.AddContent(1, "•");
            }
        }
    };

    // -----------------------------
    // Estimate formatting (Jira -> Hours)
    // Rule: 1d = 6h
    // Optional: 1w = 5d (so 1w = 30h)
    // -----------------------------
    private const decimal HoursPerDay = 6m;
    private const decimal DaysPerWeek = 5m;

    private static string FormatEstimateHours(string? jiraEstimate)
    {
        var hours = ParseJiraDurationToHours(jiraEstimate);

        if (hours <= 0m) return "-";

        // If it's effectively whole hours, show without decimals; otherwise show 1 decimal.
        var rounded = (hours % 1m == 0m)
            ? decimal.Round(hours, 0)
            : decimal.Round(hours, 1);

        return $"{rounded.ToString(CultureInfo.InvariantCulture)}h";
    }

    private static decimal ParseJiraDurationToHours(string? input)
    {
        if (string.IsNullOrWhiteSpace(input) || input.Trim() == "-")
            return 0m;

        // Jira strings commonly look like: "1w 2d 3h 30m" (sometimes without spaces)
        // We'll support units: w, d, h, m
        var matches = Regex.Matches(input, @"(\d+(?:[.,]\d+)?)\s*([wdhm])", RegexOptions.IgnoreCase);

        if (matches.Count == 0)
            return 0m;

        decimal totalHours = 0m;

        foreach (Match m in matches)
        {
            // Accept "1,5h" or "1.5h"
            var numberRaw = m.Groups[1].Value.Replace(',', '.');
            if (!decimal.TryParse(numberRaw, NumberStyles.Number, CultureInfo.InvariantCulture, out var value))
                continue;

            var unit = char.ToLowerInvariant(m.Groups[2].Value[0]);

            switch (unit)
            {
                case 'w':
                    totalHours += value * DaysPerWeek * HoursPerDay;
                    break;
                case 'd':
                    totalHours += value * HoursPerDay;
                    break;
                case 'h':
                    totalHours += value;
                    break;
                case 'm':
                    totalHours += value / 60m;
                    break;
            }
        }

        return totalHours;
    }
    // -----------------------------
    // Excel Export
    // -----------------------------
    private async Task ExportToExcel()
    {
        ErrorMessage = null;
        InfoMessage = null;

        try
        {
            using var workbook = new ClosedXML.Excel.XLWorkbook();

            // ── Sheet 1: Tasks ──
            var tasksSheet = workbook.Worksheets.Add("Tasks");

            // Header row
            var taskHeaders = new[] { "Key", "Summary", "Issue Type", "Status", "Assignee", "Estimate (hours)" };
            for (int col = 0; col < taskHeaders.Length; col++)
            {
                var cell = tasksSheet.Cell(1, col + 1);
                cell.Value = taskHeaders[col];
                cell.Style.Font.Bold = true;
                cell.Style.Fill.BackgroundColor = ClosedXML.Excel.XLColor.FromHtml("#EEF2FF");
                cell.Style.Font.FontColor = ClosedXML.Excel.XLColor.FromHtml("#4338CA");
                cell.Style.Border.BottomBorder = ClosedXML.Excel.XLBorderStyleValues.Thin;
                cell.Style.Border.BottomBorderColor = ClosedXML.Excel.XLColor.FromHtml("#D1D5DB");
            }

            for (int i = 0; i < AvailableTasks.Count; i++)
            {
                var t = AvailableTasks[i];
                var row = i + 2;
                tasksSheet.Cell(row, 1).Value = t.Key;
                tasksSheet.Cell(row, 2).Value = t.Summary;
                tasksSheet.Cell(row, 3).Value = t.IssueType;
                tasksSheet.Cell(row, 4).Value = t.Status;
                tasksSheet.Cell(row, 5).Value = t.Assignee;
                tasksSheet.Cell(row, 6).Value = FormatEstimateHours(t.OriginalEstimate);
            }

            tasksSheet.Columns().AdjustToContents();
            tasksSheet.Column(2).Width = 50; // Summary column wider

            // ── Sheet 2: Planning Calendar ──
            var planSheet = workbook.Worksheets.Add("Planning");

            // Header row: "Team" | "Team Member" | dates...
            planSheet.Cell(1, 1).Value = "Team";
            planSheet.Cell(1, 2).Value = "Team Member";
            for (int col = 0; col < VisibleDates.Count; col++)
            {
                planSheet.Cell(1, col + 3).Value = VisibleDates[col].ToString("dd-MMM-yyyy", CultureInfo.InvariantCulture);
            }

            // Style header row
            for (int col = 1; col <= VisibleDates.Count + 2; col++)
            {
                var cell = planSheet.Cell(1, col);
                cell.Style.Font.Bold = true;
                cell.Style.Fill.BackgroundColor = ClosedXML.Excel.XLColor.FromHtml("#EEF2FF");
                cell.Style.Font.FontColor = ClosedXML.Excel.XLColor.FromHtml("#4338CA");
                cell.Style.Border.BottomBorder = ClosedXML.Excel.XLBorderStyleValues.Thin;
                cell.Style.Border.BottomBorderColor = ClosedXML.Excel.XLColor.FromHtml("#D1D5DB");
                cell.Style.Alignment.Horizontal = ClosedXML.Excel.XLAlignmentHorizontalValues.Center;
            }
            var excelRow = 2;
            foreach (var teamGroup in TeamMembers.GroupBy(m => m.Team))
            {
                foreach (var member in teamGroup)
                {
                    var lanedBlocks = GetLanedBlocks(member.Id);
                    var maxLanes    = GetMaxLanes(member.Id);

                    // One Excel row per lane
                    for (int lane = 0; lane < maxLanes; lane++)
                    {
                        planSheet.Cell(excelRow, 1).Value = teamGroup.Key;
                        planSheet.Cell(excelRow, 2).Value = lane == 0 ? member.Name : "";

                        planSheet.Cell(excelRow, 1).Style.Font.Bold = true;
                        planSheet.Cell(excelRow, 1).Style.Font.FontColor = ClosedXML.Excel.XLColor.FromHtml("#4338CA");

                        if (lane == 0)
                        {
                            planSheet.Cell(excelRow, 2).Style.Font.Bold = true;
                        }

                        var laneBlocks = lanedBlocks
                            .Where(lb => lb.Lane == lane)
                            .Select(lb => lb.Block)
                            .OrderBy(b => b.From)
                            .ToList();

                        foreach (var block in laneBlocks)
                        {
                            var task = FindTask(block.TaskId);
                            var label = task is not null
                                ? $"{task.Key} - {task.Summary}"
                                : block.TaskId.ToString();

                            var startCol  = GetBlockVisibleStartCol(block);
                            var spanCount = GetBlockVisibleSpan(block);

                            if (startCol < 0) continue;

                            var startCell = planSheet.Cell(excelRow, startCol + 3);
                            startCell.Value = label;

                            if (spanCount > 1)
                            {
                                var endCell = planSheet.Cell(excelRow, startCol + 3 + spanCount - 1);
                                planSheet.Range(startCell, endCell).Merge();
                            }

                            var mergedEnd = planSheet.Cell(excelRow, startCol + 3 + spanCount - 1);
                            var mergedRange = planSheet.Range(startCell, mergedEnd);

                            mergedRange.Style.Fill.BackgroundColor = ClosedXML.Excel.XLColor.FromHtml("#3B82F6");
                            mergedRange.Style.Font.FontColor = ClosedXML.Excel.XLColor.White;
                            mergedRange.Style.Font.Bold = true;
                            mergedRange.Style.Font.FontSize = 10;
                            mergedRange.Style.Alignment.Horizontal = ClosedXML.Excel.XLAlignmentHorizontalValues.Center;
                            mergedRange.Style.Alignment.Vertical = ClosedXML.Excel.XLAlignmentVerticalValues.Center;
                        }

                        excelRow++;
                    }
                }
            }

            planSheet.Columns().AdjustToContents();
            planSheet.Column(1).Width = 12;
            planSheet.Column(2).Width = 18;

            // ── Sheet 3: Assignments Summary ──
            var summarySheet = workbook.Worksheets.Add("Assignments");

            var summaryHeaders = new[] { "Task Key", "Task Summary", "Team", "Assigned To", "From", "To", "Days", "Estimate (hours)" };
            for (int col = 0; col < summaryHeaders.Length; col++)
            {
                var cell = summarySheet.Cell(1, col + 1);
                cell.Value = summaryHeaders[col];
                cell.Style.Font.Bold = true;
                cell.Style.Fill.BackgroundColor = ClosedXML.Excel.XLColor.FromHtml("#EEF2FF");
                cell.Style.Font.FontColor = ClosedXML.Excel.XLColor.FromHtml("#4338CA");
                cell.Style.Border.BottomBorder = ClosedXML.Excel.XLBorderStyleValues.Thin;
                cell.Style.Border.BottomBorderColor = ClosedXML.Excel.XLColor.FromHtml("#D1D5DB");
            }

            // Build the summary from allocation groups (one row per GroupId = one scheduled block)
            var assignmentGroups = Allocations
                .GroupBy(a => (a.TeamMemberId, a.GroupId))
                .Select(g => new
                {
                    TaskId       = g.First().TaskId,
                    TeamMemberId = g.Key.TeamMemberId,
                    From         = g.Min(a => a.Date),
                    To           = g.Max(a => a.Date),
                    TotalHours   = g.Sum(a => a.HoursAllocated),
                    DayCount     = g.Count()
                })
                .OrderBy(a =>
                {
                    var m = TeamMembers.FirstOrDefault(x => x.Id == a.TeamMemberId);
                    return m?.Team ?? "";
                })
                .ThenBy(a =>
                {
                    var m = TeamMembers.FirstOrDefault(x => x.Id == a.TeamMemberId);
                    return m?.Name ?? "";
                })
                .ThenBy(a => a.From)
                .ToList();

            for (int i = 0; i < assignmentGroups.Count; i++)
            {
                var a      = assignmentGroups[i];
                var row    = i + 2;
                var task   = FindTask(a.TaskId);
                var member = TeamMembers.FirstOrDefault(x => x.Id == a.TeamMemberId);

                summarySheet.Cell(row, 1).Value = task?.Key ?? "-";
                summarySheet.Cell(row, 2).Value = task?.Summary ?? "-";
                summarySheet.Cell(row, 3).Value = member?.Team ?? "-";
                summarySheet.Cell(row, 4).Value = member?.Name ?? "-";
                summarySheet.Cell(row, 5).Value = a.From.ToString("dd-MMM-yyyy", CultureInfo.InvariantCulture);
                summarySheet.Cell(row, 6).Value = a.To.ToString("dd-MMM-yyyy", CultureInfo.InvariantCulture);
                summarySheet.Cell(row, 7).Value = a.DayCount;
                summarySheet.Cell(row, 8).Value = $"{a.TotalHours:0.#}h";
            }

            summarySheet.Columns().AdjustToContents();
            summarySheet.Column(2).Width = 50;

            // ── Generate file bytes and trigger download ──
            using var stream = new System.IO.MemoryStream();
            workbook.SaveAs(stream);
            var fileBytes = stream.ToArray();
            var base64 = Convert.ToBase64String(fileBytes);

            var fileName = $"EpicPlanning_{(!string.IsNullOrWhiteSpace(EpicKey) ? EpicKey.Trim() : "Export")}_{DateTime.Now:yyyyMMdd_HHmmss}.xlsx";
            const string mime = "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet";

            await JS.InvokeVoidAsync("downloadBase64File", base64, fileName, mime);

            var exportedGroups = Allocations.Select(a => a.GroupId).Distinct().Count();
            InfoMessage = $"Exported {AvailableTasks.Count} tasks and {exportedGroups} assignment(s) to {fileName}.";
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Export failed: {ex.Message}";
        }
    }
    // ───────────────────────────────────────────────────────────
    // Visual layout — derive CalendarBlocks from TaskAllocations,
    // then assign stacking lanes so overlapping blocks don't collide.
    // ───────────────────────────────────────────────────────────

    /// <summary>
    /// Groups committed TaskAllocations into CalendarBlocks (one per GroupId),
    /// then assigns each block a vertical "lane" using a greedy first-fit algorithm
    /// so that blocks whose date spans overlap are pushed to separate rows.
    ///
    /// Design note: a split task (e.g. Days 1-3, then Day 5) has From=Day1, To=Day5.
    /// The visual block stretches across that range; per-day labels show actual hours.
    /// </summary>
    private List<(CalendarBlock Block, int Lane)> GetLanedBlocks(Guid memberId)
    {
        // Derive one CalendarBlock per (member, GroupId) pair
        var blocks = Allocations
            .Where(a => a.TeamMemberId == memberId)
            .GroupBy(a => a.GroupId)
            .Select(g => new CalendarBlock
            {
                GroupId      = g.Key,
                TaskId       = g.First().TaskId,
                TeamMemberId = memberId,
                From         = g.Min(a => a.Date),
                To           = g.Max(a => a.Date)
            })
            .OrderBy(b => b.From)
            .ThenBy(b => b.To)
            .ToList();

        var result   = new List<(CalendarBlock, int)>();
        // laneEnds[i] = last "To" date used by lane i
        var laneEnds = new List<DateOnly>();

        foreach (var block in blocks)
        {
            int lane = -1;
            for (int i = 0; i < laneEnds.Count; i++)
            {
                if (block.From > laneEnds[i])  // fits in lane i — no overlap
                {
                    lane        = i;
                    laneEnds[i] = block.To;
                    break;
                }
            }
            if (lane == -1)                    // no free lane — open a new one
            {
                lane = laneEnds.Count;
                laneEnds.Add(block.To);
            }
            result.Add((block, lane));
        }

        return result;
    }

    private int GetMaxLanes(Guid memberId)
    {
        var laned = GetLanedBlocks(memberId);
        return laned.Count == 0 ? 1 : laned.Max(x => x.Lane) + 1;
    }
    // Task assignment info used by the left-panel chips — one entry per (member, GroupId) pair
    private List<(string MemberName, string Team, DateOnly From, DateOnly To)> GetTaskAssignmentInfo(int taskId)
    {
        return Allocations
            .Where(a => a.TaskId == taskId)
            .GroupBy(a => (a.TeamMemberId, a.GroupId))
            .Select(g =>
            {
                var member = TeamMembers.FirstOrDefault(m => m.Id == g.Key.TeamMemberId);
                return (
                    MemberName: member?.Name ?? "Unknown",
                    Team:        member?.Team ?? "",
                    From:        g.Min(a => a.Date),
                    To:          g.Max(a => a.Date)
                );
            })
            .OrderBy(x => x.From)
            .ToList();
    }
    private static bool IsWeekend(DateOnly date)
    {
        return date.DayOfWeek == DayOfWeek.Saturday || date.DayOfWeek == DayOfWeek.Sunday;
    }
