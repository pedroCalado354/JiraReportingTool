        color: #065f46;
        border-radius: 10px;
        padding: 0 6px;
        font-size: 11px;
        font-weight: 700;
    }

    .task-est-label {
        margin-left: auto;
        font-size: 11px;
        color: #6b7280;
        font-weight: 600;
    }

    .task-summary-text {
        font-size: 12px;
        color: #374151;
        line-height: 1.35;
        margin-bottom: 4px;
