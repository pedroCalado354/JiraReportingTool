    private sealed class ReportRow
    {
        public bool   IsCustom                { get; init; }
        public string Key                     { get; init; } = "";
        public string Title                   { get; init; } = "";
        public string Status                  { get; init; } = "";
        public string StatusCategoryKey       { get; init; } = "";
        public string OriginalEstimate        { get; init; } = "";
        public int    OriginalEstimateSeconds { get; init; }
        public string RemainingEstimate       { get; init; } = "";
        public int    ComputedRemainingSeconds { get; init; }
        public string    TimeSpent               { get; init; } = "";
        public int       TimeSpentSeconds        { get; init; }
        public DateTime? LastActivityDate        { get; init; }
        public string    CustomColor             { get; init; } = "";
        public string    CustomCategory          { get; init; } = "";
        public decimal   CustomHours             { get; init; }
        public int       SupportBugLoggedSeconds  { get; init; }
        public DateTime? SupportBugLastActivity   { get; init; }
        public string    FeatureBugEpicKey        { get; init; } = "";
        public int       BugTotalEstimateSeconds  { get; init; }
        public int       BugTotalLoggedSeconds    { get; init; }

        // ── Capacity-aware feasibility (set per member after rows are built) ──
        /// <summary>Assignee's remaining sprint capacity in seconds (working days left × 6h, excluding their days off).</summary>
        public long MemberRemainingCapacitySeconds { get; set; }
        /// <summary>Sum of remaining work across all of the assignee's incomplete Jira tasks.</summary>
        public long MemberTotalRemainingSeconds    { get; set; }
    }

    private List<ReportRow> GetReportRowsForMember(Guid memberId)
    {
        var rows = new List<ReportRow>();
        var assignedGroups = Allocations
            .Where(a => a.TeamMemberId == memberId)
            .GroupBy(a => a.GroupId)
            .Select(g => g.First().TaskId)
            .Distinct();

        var memberName = TeamMembers.FirstOrDefault(m => m.Id == memberId)?.Name ?? "";

        foreach (var taskId in assignedGroups)
        {
            if (taskId < 0)
            {
                if (_customTasks.TryGetValue(taskId, out var ct))
                {
                    if (ct.Category == "Support Bug")
                    {
                        rows.Add(new ReportRow
                        {
                            IsCustom = true, Title = ct.Name,
                            CustomColor = ct.Color, CustomCategory = ct.Category, CustomHours = ct.Hours,
                            SupportBugLoggedSeconds = GetSupportBugLoggedSeconds(memberName),
                            SupportBugLastActivity  = GetSupportBugLastActivity(memberName),
                            BugTotalEstimateSeconds = GetSupportBugTotalEstimateSeconds(),
                            BugTotalLoggedSeconds   = GetSupportBugTotalLoggedAllSeconds()
                        });
                    }
                    else if (ct.Category == "Feature Bug")
                    {
                        var epicKey = GetCustomTaskEpicKey(ct);
                        rows.Add(new ReportRow
                        {
                            IsCustom = true, Title = ct.Name,
                            CustomColor = ct.Color, CustomCategory = ct.Category, CustomHours = ct.Hours,
                            FeatureBugEpicKey       = epicKey ?? "",
                            SupportBugLoggedSeconds = epicKey != null ? GetFeatureBugLoggedSeconds(memberName, epicKey) : 0,
                            SupportBugLastActivity  = epicKey != null ? GetFeatureBugLastActivity(memberName, epicKey) : null,
                            BugTotalEstimateSeconds = epicKey != null ? GetFeatureBugTotalEstimateSeconds(epicKey) : 0,
                            BugTotalLoggedSeconds   = epicKey != null ? GetFeatureBugTotalLoggedAllSeconds(epicKey) : 0
                        });
                    }
                    else
                    {
                        rows.Add(new ReportRow
                        {
                            IsCustom = true, Title = ct.Name,
                            CustomColor = ct.Color, CustomCategory = ct.Category, CustomHours = ct.Hours
                        });
                    }
                }
                continue;
            }

            var jiraKey = GetJiraKeyForTaskId(taskId);

            // Primary: fresh data fetched into _reportIssues on view switch
            SprintIssue? issue = null;
            if (jiraKey != null) _reportIssues.TryGetValue(jiraKey, out issue);

            // Fallback: data from initial epic load (may be stale / have empty Status)
            if (issue == null) _taskCache.TryGetValue(taskId, out issue);

            if (issue != null)
            {
                rows.Add(new ReportRow
                {
                    IsCustom = false,
                    Key = issue.Key, Title = issue.Summary,
                    Status = issue.Status, StatusCategoryKey = issue.StatusCategoryKey,
                    OriginalEstimate = issue.OriginalEstimate,
                    OriginalEstimateSeconds = issue.OriginalEstimateSeconds,
                    RemainingEstimate = issue.RemainingEstimate,
                    ComputedRemainingSeconds = issue.ComputedRemainingSeconds,
                    TimeSpent = issue.TimeSpent,
                    TimeSpentSeconds = issue.TimeSpentSeconds,
                    LastActivityDate = issue.Worklogs.Count > 0
                        ? issue.Worklogs.Max(w => w.Started)
                        : (!string.IsNullOrEmpty(issue.Key) && _reportIssues.TryGetValue(issue.Key, out var ri) && ri.Worklogs.Count > 0
                           ? ri.Worklogs.Max(w => w.Started)
                           : (DateTime?)null),
                });
            }
            else if (jiraKey != null || _taskLabelFallback.ContainsKey(taskId))
            {
                // Key known but no Jira data available (Jira unreachable, etc.)
                var label = _taskLabelFallback.GetValueOrDefault(taskId, $"Task #{taskId}");
                // Parse title from "KEY - SUMMARY (Est: X)" format
                var di = label.IndexOf(" - ", StringComparison.Ordinal);
                var rawTitle = di > 0 ? label[(di + 3)..] : label;
                var ei = rawTitle.LastIndexOf(" (Est:", StringComparison.Ordinal);
                var title = ei > 0 ? rawTitle[..ei].Trim() : rawTitle.Trim();
                rows.Add(new ReportRow { IsCustom = false, Key = jiraKey ?? "", Title = title });
            }
        }

        // Annotate every row with this member's capacity vs. total remaining work,
        // so feasibility reflects collective overbooking — not each task in isolation.
        var capSec = GetMemberRemainingCapacitySeconds(memberId);
        var totalRemaining = rows
            .Where(r => !r.IsCustom && !string.Equals(r.StatusCategoryKey, "done", StringComparison.OrdinalIgnoreCase))
            .Sum(r => (long)r.ComputedRemainingSeconds);
        foreach (var r in rows)
        {
            r.MemberRemainingCapacitySeconds = capSec;
            r.MemberTotalRemainingSeconds    = totalRemaining;
        }

        return rows
            .OrderBy(r => r.IsCustom ? 3 : r.StatusCategoryKey switch
            {
                "indeterminate" => 0,
                "new"           => 1,
                "done"          => 2,
                _               => 1
            })
            .ToList();
    }

    /// <summary>Remaining sprint capacity for a member, in seconds: working days from
    /// today (or sprint start, whichever is later) to sprint end, excluding that member's
    /// days off, multiplied by the 6h/day limit.</summary>
    private long GetMemberRemainingCapacitySeconds(Guid memberId)
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        if (SprintEnd == default || SprintEnd < today) return 0;
        var from = today > SprintStart ? today : SprintStart;
        var workingDays = Enumerable.Range(0, SprintEnd.DayNumber - from.DayNumber + 1)
            .Select(i => from.AddDays(i))
            .Count(d => !IsDayOff(memberId, d));
        return (long)(workingDays * GetMemberDailyHours(memberId) * 3600m);
    }

    private int GetSupportBugLoggedSeconds(string memberName)
    {
        if (_supportBugIssues.Count == 0 || string.IsNullOrEmpty(memberName)) return 0;
        var sprintStart = SprintStart.ToDateTime(TimeOnly.MinValue);
        return _supportBugIssues.Values
            .SelectMany(i => i.Worklogs)
            .Where(w => w.Started >= sprintStart
                     && WorklogByMember(w, memberName))
            .Sum(w => w.TimeSpentSeconds);
    }

    private DateTime? GetSupportBugLastActivity(string memberName)
    {
        if (_supportBugIssues.Count == 0 || string.IsNullOrEmpty(memberName)) return null;
        var sprintStart = SprintStart.ToDateTime(TimeOnly.MinValue);
        var worklogs = _supportBugIssues.Values
            .SelectMany(i => i.Worklogs)
            .Where(w => w.Started >= sprintStart
                     && WorklogByMember(w, memberName))
            .ToList();
        return worklogs.Count > 0 ? worklogs.Max(w => w.Started) : (DateTime?)null;
    }

    // Extracts the first Jira-style key (e.g. JM-12345) from a string such as "JM-12345 - feature context"
    private static string? ExtractEpicKeyFromTitle(string title)
    {
        var match = System.Text.RegularExpressions.Regex.Match(title, @"\b([A-Z]+-\d+)\b");
        return match.Success ? match.Groups[1].Value : null;
    }

    // Feature Bug epic: the stored EpicKey field, falling back to a key embedded in the
    // name for plans created before the field existed.
    private static string? GetCustomTaskEpicKey(CustomTaskEntry ct)
        => !string.IsNullOrWhiteSpace(ct.EpicKey) ? ct.EpicKey : ExtractEpicKeyFromTitle(ct.Name);

    private int GetFeatureBugLoggedSeconds(string memberName, string epicKey)
    {
        if (!_featureBugIssuesByEpic.TryGetValue(epicKey, out var issues) || string.IsNullOrEmpty(memberName)) return 0;
        var sprintStart = SprintStart.ToDateTime(TimeOnly.MinValue);
        return issues
            .SelectMany(i => i.Worklogs)
            .Where(w => w.Started >= sprintStart
                     && WorklogByMember(w, memberName))
            .Sum(w => w.TimeSpentSeconds);
    }

    private DateTime? GetFeatureBugLastActivity(string memberName, string epicKey)
    {
        if (!_featureBugIssuesByEpic.TryGetValue(epicKey, out var issues) || string.IsNullOrEmpty(memberName)) return null;
        var sprintStart = SprintStart.ToDateTime(TimeOnly.MinValue);
        var worklogs = issues
            .SelectMany(i => i.Worklogs)
            .Where(w => w.Started >= sprintStart
                     && WorklogByMember(w, memberName))
            .ToList();
        return worklogs.Count > 0 ? worklogs.Max(w => w.Started) : (DateTime?)null;
    }

