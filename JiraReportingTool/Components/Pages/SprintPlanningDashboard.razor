    // ── Daily metrics helpers ──

    private sealed class DailyMetrics
    {
        public int    TotalCount       { get; init; }
        public int    DoneCount        { get; init; }
        public double TaskPct          { get; init; }
        public double HoursPct         { get; init; }
        public int    NoRemainingCount { get; init; }
        public int    BlockedCount     { get; init; }
        public Dictionary<string, int> ByStatus    { get; init; } = new();
        public List<SprintIssue>       UntouchedTasks   { get; init; } = new();
        public List<SprintIssue>       NoRemainingTasks { get; init; } = new();
        public List<SprintIssue>       BlockedTasks     { get; init; } = new();
    }

    private DailyMetrics GetDailyMetrics()
    {
        var assignedTaskIds = Allocations.Select(a => a.TaskId).Distinct().ToHashSet();

        // Use _reportIssues (fresh data) when available; fall back to _taskCache
        var jiraTasks = assignedTaskIds
            .Where(id => id > 0)
            .Select(id =>
            {
                var key = GetJiraKeyForTaskId(id);
                if (key != null && _reportIssues.TryGetValue(key, out var ri)) return ri;
                return _taskCache.TryGetValue(id, out var ci) ? ci : null;
            })
            .Where(t => t != null)
            .Select(t => t!)
            .ToList();

        var customCount = assignedTaskIds.Count(id => id < 0);

        int totalCount = jiraTasks.Count + customCount;
        int doneCount  = jiraTasks.Count(t => t.StatusCategoryKey == "done");
        double taskPct = totalCount == 0 ? 0 : (double)doneCount / totalCount * 100;

        var jiraWithEst = jiraTasks.Where(t => t.OriginalEstimateSeconds > 0).ToList();
        long totalOrigSec = jiraWithEst.Sum(t => (long)t.OriginalEstimateSeconds);
        long totalRemSec  = jiraWithEst.Sum(t => (long)t.ComputedRemainingSeconds);
        double hoursPct   = totalOrigSec == 0 ? 0
            : Math.Clamp((double)(totalOrigSec - totalRemSec) / totalOrigSec * 100, 0, 100);

        var byStatus = jiraTasks
            .GroupBy(t => string.IsNullOrEmpty(t.Status) ? "Unknown" : t.Status)
            .ToDictionary(g => g.Key, g => g.Count());

        var activeTasks = jiraTasks.Where(t => t.StatusCategoryKey != "done").ToList();

        var noRemainingTasks = activeTasks
            .Where(t => t.ComputedRemainingSeconds == 0 && t.OriginalEstimateSeconds > 0)
            .OrderBy(t => t.Assignee).ThenBy(t => t.Key)
            .ToList();

        var untouchedTasks = activeTasks
            .Where(t => t.OriginalEstimateSeconds > 0 &&
                        t.ComputedRemainingSeconds == t.OriginalEstimateSeconds)
            .OrderBy(t => t.Assignee).ThenBy(t => t.Key)
            .ToList();

        var blockedTasks = jiraTasks
            .Where(t => string.Equals(t.Status, "On Hold", StringComparison.OrdinalIgnoreCase))
            .OrderBy(t => t.Assignee).ThenBy(t => t.Key)
            .ToList();

        return new DailyMetrics
        {
            TotalCount       = totalCount,
            DoneCount        = doneCount,
            TaskPct          = taskPct,
            HoursPct         = hoursPct,
            NoRemainingCount = noRemainingTasks.Count,
            BlockedCount     = blockedTasks.Count,
            ByStatus         = byStatus,
            UntouchedTasks   = untouchedTasks,
            NoRemainingTasks = noRemainingTasks,
            BlockedTasks     = blockedTasks,
        };
    }

    // ───────────────────────────────────────────────────────────
    // Visual layout (CalendarBlocks + lane packing)
    // ───────────────────────────────────────────────────────────
    private List<(CalendarBlock Block, int Lane)> GetLanedBlocks(Guid memberId)
    {
        var blocks = Allocations
            .Where(a => a.TeamMemberId == memberId)
            .GroupBy(a => a.GroupId)
            .Select(g => new CalendarBlock
            {
                GroupId = g.Key, TaskId = g.First().TaskId, TeamMemberId = memberId,
                From = g.Min(a => a.Date), To = g.Max(a => a.Date)
            })
            .Where(b => BlockPassesEpicFilter(b.TaskId))
            .OrderBy(b => b.From).ThenBy(b => b.To)
            .ToList();

        var result   = new List<(CalendarBlock, int)>();
        var laneEnds = new List<DateOnly>();

        foreach (var block in blocks)
        {
            int lane = -1;
            for (int i = 0; i < laneEnds.Count; i++)
                if (block.From > laneEnds[i]) { lane = i; laneEnds[i] = block.To; break; }
            if (lane == -1) { lane = laneEnds.Count; laneEnds.Add(block.To); }
            result.Add((block, lane));
        }
        return result;
    }

    private int GetMaxLanes(Guid memberId)
    {
        var laned = GetLanedBlocks(memberId);
        return laned.Count == 0 ? 1 : laned.Max(x => x.Lane) + 1;
    }

    private List<CalendarBlock> GetMemberAssignedBlocks(Guid memberId)
        => Allocations
            .Where(a => a.TeamMemberId == memberId)
            .GroupBy(a => a.GroupId)
            .Select(g => new CalendarBlock
            {
                GroupId = g.Key, TaskId = g.First().TaskId, TeamMemberId = memberId,
                From = g.Min(a => a.Date), To = g.Max(a => a.Date)
            })
            .OrderBy(b => b.From)
            .ToList();

    // ── Drag-to-reschedule ──
    private void OnBlockDragStart(Guid groupId) => _dragGroupId = groupId;

    // Drop a dragged block onto another member/day: move the whole task group there,
    // preserving its total hours and re-splitting across days from the new start date.
    private void OnCellDrop(Guid memberId, DateOnly date)
    {
        var groupId = _dragGroupId;
        _dragGroupId = null;
        if (groupId is null || TimeOffMode) return;

        var groupAllocs = Allocations.Where(a => a.GroupId == groupId.Value).ToList();
        if (groupAllocs.Count == 0) return;

        var taskId     = groupAllocs[0].TaskId;
        var totalHours = groupAllocs.Sum(a => a.HoursAllocated);
        var currentStart = groupAllocs.Min(a => a.Date);

        // No-op when dropped on its existing member + start day.
        if (groupAllocs[0].TeamMemberId == memberId && currentStart == date) return;

        Allocations.RemoveAll(a => a.GroupId == groupId.Value);

        var moved = ScheduleTask(taskId, memberId, totalHours, date);
        if (moved.Sum(a => a.HoursAllocated) < totalHours)   // not enough free capacity → force the full move
            moved = ScheduleTask(taskId, memberId, totalHours, date, forceOverCapacity: true);
        Allocations.AddRange(moved);

        var memberName = TeamMembers.FirstOrDefault(m => m.Id == memberId)?.Name ?? "member";
        InfoMessage = $"Moved '{GetTaskShortLabel(taskId)}' to {memberName} starting {date:dd-MMM}.";
    }

    private void RemoveBlock(Guid groupId)
    {
        var sample = Allocations.FirstOrDefault(a => a.GroupId == groupId);
        if (sample is null) return;

        // No version history means the sprint is still being planned for the first time —
        // remove silently without prompting for a reason or writing a log entry.
        if (_planVersions.Count == 0)
        {
            Allocations.RemoveAll(a => a.GroupId == groupId);
            InfoMessage = "Assignment removed.";
            return;
        }

        _removalPendingGroupId    = groupId;
        _removalPendingTaskLabel  = GetTaskLabel(sample.TaskId);
        _removalPendingMemberName = TeamMembers.FirstOrDefault(m => m.Id == sample.TeamMemberId)?.Name ?? "Unknown";
        _showRemovalDialog = true;
        _removalReason = "";
    }

    private async Task ConfirmRemovalAsync()
    {
        _showRemovalDialog = false;

        if (_currentPlanId.HasValue)
        {
            var log = await PlanService.LogRemovalAsync(new SprintPlanRemovalLog
            {
                SprintPlanId = _currentPlanId.Value,
                GroupId      = _removalPendingGroupId,
                TaskLabel    = _removalPendingTaskLabel,
                MemberName   = _removalPendingMemberName,
                Reason       = _removalReason,
            });
            _removalLogs.Insert(0, log);
        }

        Allocations.RemoveAll(a => a.GroupId == _removalPendingGroupId);
        InfoMessage = "Assignment removed.";
    }

    private void CancelRemoval()
    {
        _showRemovalDialog = false;
        _removalReason     = "";
    }

    private async Task OpenRemovalLogsAsync()
    {
        if (!_currentPlanId.HasValue) return;
        _isLoadingLogs         = true;
        _showRemovalLogsDialog = true;
        _removalLogs = await PlanService.GetRemovalLogsAsync(_currentPlanId.Value);
        _isLoadingLogs = false;
    }

    private void CloseRemovalLogs() => _showRemovalLogsDialog = false;

