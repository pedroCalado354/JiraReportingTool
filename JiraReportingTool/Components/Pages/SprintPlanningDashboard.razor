    // ───────────────────────────────────────────────────────────
    // Sprint Plan CRUD
    // ───────────────────────────────────────────────────────────
    private async Task SavePlanAsync()
    {
        ErrorMessage = null;

        // Concurrency guard: warn if the stored plan was updated elsewhere since we loaded it.
        if (_currentPlanId.HasValue && !_forceSaveOverwrite)
        {
            var current = await PlanService.GetUpdatedAtAsync(_currentPlanId.Value);
            if (current.HasValue && _loadedUpdatedAt.HasValue && current.Value > _loadedUpdatedAt.Value)
            {
                _forceSaveOverwrite = true;
                ErrorMessage = $"This plan was changed elsewhere at {current.Value.ToLocalTime():dd-MMM HH:mm} "
                             + "(possibly another tab/user). Click Save again to overwrite with your version, "
                             + "or reload it from the dropdown to keep theirs.";
                return;
            }
        }

        _isSaving = true;
        _busyMessage = "Saving sprint plan…";
        StateHasChanged();
        await Task.Yield();   // paint the overlay before the save round-trip
        try
        {
            var epicKeys = string.Join(",", LoadedEpics.Keys);
            var supportBugEpicKeys = string.Join(",", LoadedSupportBugEpics.Keys);
            var taskKeys = string.Join(",", LoadedTasks.Keys);
            var plan = new SprintPlanHeader
            {
                Id            = _currentPlanId ?? 0,
                Name          = string.IsNullOrWhiteSpace(SprintName) ? $"Sprint {DateTime.Today:yyyy-MM-dd}" : SprintName,
                SprintStart   = SprintStart,
                SprintEnd     = SprintEnd,
                LoadedEpicKeys     = epicKeys,
                LoadedTaskKeys     = taskKeys,
                SupportBugEpicKeys = supportBugEpicKeys,
                Allocations   = Allocations.Select(a => new SprintPlanAllocation
                {
                    SprintPlanId   = _currentPlanId ?? 0,
                    TaskId         = a.TaskId,
                    TaskLabel      = GetTaskLabel(a.TaskId),
                    EpicKey        = GetEpicKeyForAllocation(a.TaskId),
                    MemberId       = a.TeamMemberId,
                    MemberName     = TeamMembers.FirstOrDefault(m => m.Id == a.TeamMemberId)?.Name ?? "",
                    Date           = a.Date,
                    HoursAllocated = a.HoursAllocated,
                    GroupId        = a.GroupId,
                }).ToList(),
                CustomTasks = _customTasks.Values.Select(ct => new SprintPlanCustomTask
                {
                    SprintPlanId = _currentPlanId ?? 0,
                    LocalId      = ct.Id,
                    Name         = ct.Name,
                    Category     = ct.Category,
                    Hours        = ct.Hours,
                    Color        = ct.Color,
                    EpicKey      = ct.EpicKey,
                }).ToList(),
                Holidays = Holidays.Select(d => new SprintPlanHoliday
                {
                    SprintPlanId = _currentPlanId ?? 0,
                    Date         = d,
                }).ToList(),
                TimeOffs = MemberTimeOff.SelectMany(kvp => kvp.Value.Select(d => new SprintPlanTimeOff
                {
                    SprintPlanId = _currentPlanId ?? 0,
                    MemberId     = kvp.Key,
                    Date         = d,
                })).ToList(),
            };

            var saved = await PlanService.UpsertByNameAsync(plan);
            _currentPlanId      = saved.Id;
            _savedPlans         = await PlanService.GetAllAsync();
            _planVersions       = await PlanService.GetVersionsAsync(saved.Id);
            _loadedUpdatedAt    = saved.UpdatedAt;
            _forceSaveOverwrite = false;
            ResetDirtyBaseline();
            InfoMessage = $"Plan '{saved.Name}' saved (#{saved.Id}).";
        }
        catch (Exception ex) { ErrorMessage = $"Save failed: {ex.Message}"; }
        finally { _isSaving = false; _busyMessage = null; }
    }

    private async Task OnSprintDropdownChanged(ChangeEventArgs e)
    {
        if (!int.TryParse(e.Value?.ToString(), out var id) || id == 0) return;
        if (IsDirty && !await ConfirmDiscardAsync())
        {
            StateHasChanged();   // revert the dropdown to the current plan
            return;
        }
        await LoadPlanAsync(id);
    }

    // Native browser confirm before discarding unsaved changes.
    private async Task<bool> ConfirmDiscardAsync()
    {
        try
        {
            return await JS.InvokeAsync<bool>("confirm",
                "You have unsaved changes that will be lost. Continue without saving?");
        }
        catch { return true; }   // if JS is unavailable, don't block the action
    }

    private async Task NewSprint()
    {
        if (IsDirty && !await ConfirmDiscardAsync()) return;

        _currentPlanId    = null;
        _loadedUpdatedAt  = null;
        _forceSaveOverwrite = false;
        SprintName        = "";
        LoadedEpics.Clear();
        LoadedTasks.Clear();
        LoadedSupportBugEpics.Clear();
        _taskCache.Clear();
        _taskLabelFallback.Clear();
        _reportIssues.Clear();
        _supportBugIssues.Clear();
        _featureBugIssuesByEpic.Clear();
        Allocations.Clear();
        _customTasks.Clear();
        Holidays.Clear();
        MemberTimeOff.Clear();
        _nextCustomTaskId = -1;
        SelectedTask      = null;
        SelectedCustomTaskId = null;
        PendingPlacement  = null;
        _planVersions     = new();
        _showVersionsPanel = false;
        ResetTeamMembersToActive();
        ResetDirtyBaseline();
        InfoMessage = "New sprint ready — set the sprint name and dates, then load epics.";
    }

    private async Task LoadPlanAsync(int id)
    {
        _isSaving = true;
        ErrorMessage = null;
        _busyMessage = "Loading sprint plan…";
        StateHasChanged();
        await Task.Yield();   // paint the overlay before the (epic-heavy) load begins
        try
        {
            var plan = await PlanService.GetAsync(id);
            if (plan is null) { ErrorMessage = $"Plan #{id} not found."; return; }
            await ApplyPlanAsync(plan);
            _planVersions    = await PlanService.GetVersionsAsync(id);
            _loadedUpdatedAt = plan.UpdatedAt;
            ResetDirtyBaseline();
            InfoMessage = $"Plan '{plan.Name}' loaded — {plan.Allocations.Count} allocations.";
        }
        catch (Exception ex) { ErrorMessage = $"Load failed: {ex.Message}"; }
        finally { _isSaving = false; _busyMessage = null; }
    }

    // Applies a SprintPlanHeader to the in-memory state. When keepId=true the
    // current _currentPlanId is preserved (used when restoring a version).
    private async Task ApplyPlanAsync(SprintPlanHeader plan, bool keepId = false)
    {
        if (!keepId)
            _currentPlanId = plan.Id > 0 ? plan.Id : _currentPlanId;

        SprintName          = plan.Name;
        SprintStartDateTime = plan.SprintStart.ToDateTime(TimeOnly.MinValue);
        SprintEndDateTime   = plan.SprintEnd.ToDateTime(TimeOnly.MinValue);
        ApplySprintRange();

        // Start from the active roster, then re-add any inactive members this plan references.
        ResetTeamMembersToActive();
        MergePlanMembers(plan);

        // Reload epics from cache/Jira
        LoadedEpics.Clear();
        LoadedTasks.Clear();
        LoadedSupportBugEpics.Clear();
        _taskCache.Clear();
        _taskLabelFallback.Clear();
        _reportIssues.Clear();
        _supportBugIssues.Clear();
        _featureBugIssuesByEpic.Clear();
        var epicKeys = plan.LoadedEpicKeys.Split(',', StringSplitOptions.RemoveEmptyEntries);
        for (var i = 0; i < epicKeys.Length; i++)
        {
            _busyMessage = $"Loading epic {epicKeys[i]} ({i + 1}/{epicKeys.Length})…";
            StateHasChanged();
            await LoadEpicByKey(epicKeys[i]);
        }

        var taskKeys = (plan.LoadedTaskKeys ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries);
        if (taskKeys.Length > 0)
        {
            _busyMessage = $"Loading {taskKeys.Length} task(s)…";
            StateHasChanged();
            await LoadTasksByKeys(taskKeys);
        }

        var supportBugEpicKeys = plan.SupportBugEpicKeys.Split(',', StringSplitOptions.RemoveEmptyEntries);
        for (var i = 0; i < supportBugEpicKeys.Length; i++)
        {
            _busyMessage = $"Loading support bugs {supportBugEpicKeys[i]} ({i + 1}/{supportBugEpicKeys.Length})…";
            StateHasChanged();
            await LoadSupportBugEpicByKey(supportBugEpicKeys[i]);
        }

        // Seed fallback labels from persisted allocations so tasks missing from _taskCache still display correctly.
        foreach (var a in plan.Allocations)
            if (a.TaskId > 0 && !string.IsNullOrWhiteSpace(a.TaskLabel) && !_taskLabelFallback.ContainsKey(a.TaskId))
                _taskLabelFallback[a.TaskId] = a.TaskLabel;

        // Restore custom tasks
        _customTasks.Clear();
        foreach (var ct in plan.CustomTasks)
            _customTasks[ct.LocalId] = new CustomTaskEntry
            {
                Id = ct.LocalId, Name = ct.Name,
                Category = ct.Category, Hours = ct.Hours, Color = ct.Color,
                EpicKey = ct.EpicKey
            };
        _nextCustomTaskId = _customTasks.Count > 0 ? _customTasks.Keys.Min() - 1 : -1;

        // Restore allocations (match member by stable Guid, fallback to name lookup)
        Allocations.Clear();
        foreach (var a in plan.Allocations)
        {
            var memberId = TeamMembers.Any(m => m.Id == a.MemberId)
                ? a.MemberId
                : TeamMembers.FirstOrDefault(m => m.Name == a.MemberName)?.Id ?? a.MemberId;
            Allocations.Add(new TaskAllocation
            {
                TaskId = a.TaskId, TeamMemberId = memberId,
                Date = a.Date, HoursAllocated = a.HoursAllocated, GroupId = a.GroupId
            });
        }

        // Restore holidays & time-off
        Holidays = plan.Holidays.Select(h => h.Date).ToHashSet();
        MemberTimeOff.Clear();
        foreach (var to in plan.TimeOffs)
        {
            if (!MemberTimeOff.ContainsKey(to.MemberId))
                MemberTimeOff[to.MemberId] = new HashSet<DateOnly>();
            MemberTimeOff[to.MemberId].Add(to.Date);
        }
    }

    private async Task RestoreVersionAsync(SprintPlanVersion version)
    {
        _isSaving = true;
        ErrorMessage = null;
        _busyMessage = $"Restoring version {version.VersionNumber}…";
        StateHasChanged();
        await Task.Yield();   // paint the overlay before the (epic-heavy) restore begins
        try
        {
            var plan = System.Text.Json.JsonSerializer.Deserialize<SprintPlanHeader>(version.DataJson);
            if (plan is null) { ErrorMessage = "Failed to read version data."; return; }
            await ApplyPlanAsync(plan, keepId: true);
            _showVersionsPanel = false;
            InfoMessage = $"Restored version {version.VersionNumber} (saved {version.SavedAt.ToLocalTime():dd-MMM-yyyy HH:mm}). Save to keep this state.";
        }
        catch (Exception ex) { ErrorMessage = $"Restore failed: {ex.Message}"; }
        finally { _isSaving = false; _busyMessage = null; }
    }

    private async Task DeletePlanAsync()
    {
        if (!_currentPlanId.HasValue) return;
        _isSaving = true;
        ErrorMessage = null;
        try
        {
            await PlanService.DeleteAsync(_currentPlanId.Value);
            InfoMessage    = $"Plan #{_currentPlanId} deleted.";
            _currentPlanId = null;
            _savedPlans    = await PlanService.GetAllAsync();
        }
        catch (Exception ex) { ErrorMessage = $"Delete failed: {ex.Message}"; }
        finally { _isSaving = false; }
    }

