    // Support-bug hours allocated to a team's members within the current sprint window.
    // Mirrors SupportBugAllocatedHours' filters, so the team rows sum to that headline total.
    private decimal GetTeamSupportBugHours(string team)
    {
        var memberIds = TeamMembers.Where(m => m.Team == team).Select(m => m.Id).ToHashSet();
        var supportBugIds = _customTasks.Values
            .Where(ct => ct.Category == "Support Bug")
            .Select(ct => ct.Id)
            .ToHashSet();
        return Allocations
            .Where(a => supportBugIds.Contains(a.TaskId)
                && memberIds.Contains(a.TeamMemberId)
                && !IsDayOff(a.TeamMemberId, a.Date)
                && a.Date >= SprintStart && a.Date <= SprintEnd)
            .Sum(a => a.HoursAllocated);
    }

    private sealed record TeamTaskLoad(int TaskId, string Label, bool IsCustom, decimal Hours);

    // Per-task hours allocated to a team's members within the current sprint window,
    // ordered by hours descending. Drives the Team Load breakdown popup.
    private List<TeamTaskLoad> GetTeamTaskBreakdown(string team)
    {
        var memberIds = TeamMembers.Where(m => m.Team == team).Select(m => m.Id).ToHashSet();
        var rows = Allocations
            .Where(a => memberIds.Contains(a.TeamMemberId) && a.Date >= SprintStart && a.Date <= SprintEnd)
            .GroupBy(a => a.TaskId)
            .Select(g => new TeamTaskLoad(
                g.Key,
                GetTaskShortLabel(g.Key),
                _customTasks.ContainsKey(g.Key),
                g.Sum(a => a.HoursAllocated)))
            .Where(r => r.Hours > 0m)
            .ToList();

        // Collapse all "Support Bug" custom tasks into a single combined row so the
        // breakdown shows total support-bug load rather than one line per bug task.
        var supportBugIds = _customTasks.Values
            .Where(ct => ct.Category == "Support Bug")
            .Select(ct => ct.Id)
            .ToHashSet();
        var supportBugRows = rows.Where(r => supportBugIds.Contains(r.TaskId)).ToList();
        if (supportBugRows.Count > 1)
        {
            rows.RemoveAll(r => supportBugIds.Contains(r.TaskId));
            rows.Add(new TeamTaskLoad(
                0,
                $"Support Bug ({supportBugRows.Count} items)",
                true,
                supportBugRows.Sum(r => r.Hours)));
        }

        return rows.OrderByDescending(r => r.Hours).ToList();
    }

