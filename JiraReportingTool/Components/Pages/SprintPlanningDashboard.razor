    // ───────────────────────────────────────────────────────────
    // Sprint configuration
    // ───────────────────────────────────────────────────────────
    private void ApplySprintRange()
    {
        ErrorMessage = null;
        InfoMessage = null;

        var from = SprintStartDateTime?.Date ?? DateTime.Today;
        var to   = SprintEndDateTime?.Date   ?? DateTime.Today.AddDays(13);

        if (to < from) { ErrorMessage = "Sprint end must be after sprint start."; return; }

        SprintStart = DateOnly.FromDateTime(from);
        SprintEnd   = DateOnly.FromDateTime(to);

        var allDates = Enumerable.Range(0, SprintEnd.DayNumber - SprintStart.DayNumber + 1)
            .Select(i => SprintStart.AddDays(i))
            .ToList();

        VisibleDates = ShowWeekends
            ? allDates
            : allDates.Where(d => !IsWeekend(d)).ToList();

        InfoMessage = $"Sprint applied: {SprintStart:dd-MMM} → {SprintEnd:dd-MMM} ({WorkingDaysCount} working days).";
    }

    private void ToggleWeekends()
    {
        ShowWeekends = !ShowWeekends;
        ApplySprintRange();
        InfoMessage = ShowWeekends ? "Weekends shown." : "Weekends hidden.";
    }

    // ───────────────────────────────────────────────────────────
    // Epic loading / management
    // ───────────────────────────────────────────────────────────
    private async Task LoadEpic()
    {
        ErrorMessage = null;
        InfoMessage = null;

        var key = EpicKeyInput.Trim().ToUpperInvariant();
        if (string.IsNullOrWhiteSpace(key)) { ErrorMessage = "Enter an epic key."; return; }
        if (LoadedEpics.ContainsKey(key)) { InfoMessage = $"Epic {key} is already loaded."; return; }

        LoadedEpics[key] = new EpicLoadState { EpicKey = key, IsLoading = true };
        EpicKeyInput = "";
        StateHasChanged();

        var report = await JiraService.GetEpicReportAsync(key);
        var tasks  = report?.Issues?.OrderBy(i => i.Key).ToList() ?? new List<SprintIssue>();

        foreach (var t in tasks) _taskCache[t.Id] = t;

        LoadedEpics[key].Tasks     = tasks;
        LoadedEpics[key].IsLoading = false;
        InfoMessage = $"Loaded {tasks.Count} tasks from epic {key}.";
    }

    private async Task OnEpicInputKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await LoadEpic();
    }

    private void RemoveEpic(string epicKey)
    {
        LoadedEpics.Remove(epicKey);
        InfoMessage = $"Epic {epicKey} removed.";
    }

    private void ToggleEpic(string epicKey)
    {
        if (LoadedEpics.TryGetValue(epicKey, out var epic))
            epic.IsExpanded = !epic.IsExpanded;
    }

    // Helper used by plan loading — load an epic by key without touching EpicKeyInput
    private async Task LoadEpicByKey(string key)
    {
        if (string.IsNullOrWhiteSpace(key) || LoadedEpics.ContainsKey(key)) return;
        LoadedEpics[key] = new EpicLoadState { EpicKey = key, IsLoading = true };
        var report = await JiraService.GetEpicReportAsync(key);
        var tasks  = report?.Issues?.OrderBy(i => i.Key).ToList() ?? new List<SprintIssue>();
        foreach (var t in tasks) _taskCache[t.Id] = t;
        LoadedEpics[key].Tasks     = tasks;
        LoadedEpics[key].IsLoading = false;
    }

    // ───────────────────────────────────────────────────────────
