@page "/sprint-planning"
@using System.Globalization
@rendermode InteractiveServer
@using JiraReportingTool.Models
@using System.Text.RegularExpressions
@inject IJiraService JiraService
@inject IJSRuntime JS
@inject ISprintPlanService PlanService
@inject TeamRosterService RosterService
@inject IConfiguration Config
@using ClosedXML.Excel

<div class="spd-root">

    <!-- ═══ GLOBAL BUSY OVERLAY ═══════════════════════════════════════ -->
    @if (_busyMessage is not null)
    {
        <div class="spd-busy-overlay">
            <div class="spd-busy-card">
                <div class="spd-busy-spinner"></div>
                <span class="spd-busy-text">@_busyMessage</span>
            </div>
        </div>
    }

    <!-- ═══ HEADER ════════════════════════════════════════════════════ -->
    <div class="spd-header">
        <div class="spd-title-block">
            <h2 class="spd-page-title">Sprint Planning Dashboard</h2>
            @if (!string.IsNullOrWhiteSpace(SprintName))
            {
                <span class="spd-sprint-badge">@SprintName</span>
            }
            @if (SprintEnd >= SprintStart && SprintStart != default)
            {
                <span class="spd-sprint-dates">
                    @SprintStart.ToString("dd MMM") → @SprintEnd.ToString("dd MMM yyyy")
                    · @WorkingDaysCount working days
                </span>
            }
        </div>
        <input class="spd-sprint-name-input" placeholder="Sprint name (e.g. Sprint 42)..." @bind="SprintName" @bind:event="oninput" />
    </div>

    <!-- ═══ CONFIG BAR ════════════════════════════════════════════════ -->
    <div class="spd-config-bar">
        <div class="cfg-group">
            <label>Sprint Start</label>
            <InputDate @bind-Value="SprintStartDateTime" class="input" />
        </div>
        <div class="cfg-group">
            <label>Sprint End</label>
            <InputDate @bind-Value="SprintEndDateTime" class="input" />
        </div>
        <div class="cfg-group">
            <button class="btn primary" @onclick="ApplySprintRange">Apply Sprint</button>
        </div>
        <div class="cfg-divider"></div>
        <div class="cfg-group cfg-epic-group">
            <label>Load Epic</label>
            <div class="cfg-epic-row">
                <input class="input" placeholder="Epic key (e.g. JM-15977)"
                       @bind="EpicKeyInput" @bind:event="oninput"
                       @onkeypress="OnEpicInputKeyPress" />
                <button class="btn primary" @onclick="LoadEpic">Load</button>
            </div>
        </div>
        <div class="cfg-group cfg-epic-group">
            <label>Load Tasks</label>
            <div class="cfg-epic-row">
                <input class="input" placeholder="Task keys (e.g. JM-123, JM-456)"
                       @bind="TaskKeysInput" @bind:event="oninput"
                       @onkeypress="OnTaskInputKeyPress" />
                <button class="btn primary" @onclick="LoadTasks" disabled="@_isLoadingTasks">
                    @(_isLoadingTasks ? "…" : "Load")
                </button>
            </div>
        </div>
        <div class="cfg-group cfg-epic-group">
            <label>🐛 Bug Epic</label>
            <div class="cfg-epic-row">
                <input class="input" placeholder="Support bug epic key..."
                       @bind="SupportBugEpicKeyInput" @bind:event="oninput"
                       @onkeypress="OnSupportBugEpicInputKeyPress" />
                <button class="btn primary" @onclick="LoadSupportBugEpic">Load</button>
            </div>
        </div>
        <div class="cfg-divider"></div>
        <div class="cfg-group">
            <label>Weekends</label>
            <button class="btn toggle-btn @(ShowWeekends ? "toggle-on" : "")" @onclick="ToggleWeekends">
                @(ShowWeekends ? "Shown" : "Hidden")
            </button>
        </div>
        <div class="cfg-group">
            <label>Time Off</label>
            <button class="btn toggle-btn @(TimeOffMode ? "toggle-on" : "")" @onclick="ToggleTimeOffMode">
                @(TimeOffMode ? "Exit Mode" : "Manage")
            </button>
        </div>
        <div class="cfg-group">
            <button class="btn" @onclick="ExportToExcel" disabled="@(Allocations.Count == 0)" title="Export to Excel">
                ↓ Export .xlsx
            </button>
        </div>
    </div>

    @if (LoadedSupportBugEpics.Count > 0)
    {
        <div class="spd-info" style="display:flex;gap:0.5rem;flex-wrap:wrap;align-items:center;">
            <span style="font-weight:600;color:#b91c1c;">🐛 Bug Epics:</span>
            @foreach (var sb in LoadedSupportBugEpics)
            {
                var sbKey = sb.Key;
                var sbState = sb.Value;
                <span style="display:inline-flex;align-items:center;gap:0.3rem;background:#fee2e2;color:#b91c1c;border-radius:4px;padding:2px 8px;font-size:0.8rem;font-weight:500;">
                    @sbKey
                    @if (sbState.IsLoading)
                    {
                        <span>…</span>
                    }
                    else
                    {
                        <span>(@sbState.Tasks.Count bugs)</span>
                    }
                    <button style="background:none;border:none;cursor:pointer;color:#b91c1c;padding:0 0 0 2px;font-size:0.85rem;line-height:1;" @onclick="() => RemoveSupportBugEpic(sbKey)">✕</button>
                </span>
            }
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(InfoMessage))
    {
        <div class="spd-info">@InfoMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="spd-error">@ErrorMessage</div>
    }

    <!-- ═══ STATS STRIP ═══════════════════════════════════════════════ -->
    <div class="spd-stats">
        <div class="stat-card">
            <div class="stat-value">@ScheduledTotalCount</div>
            <div class="stat-label">Sprint Tasks</div>
            <div class="stat-sub">@ScheduledJiraTaskCount Jira · @ScheduledCustomTaskCount custom</div>
        </div>
        <div class="stat-card @GetDonePctClass()">
            <div class="stat-value">@(ScheduledJiraTaskCount > 0 ? $"{DonePct:0}%" : "—")</div>
            <div class="stat-label">Done</div>
            <div class="stat-sub">@DoneTaskCount of @ScheduledJiraTaskCount tasks</div>
        </div>
        <div class="stat-card @(AtRiskCount > 0 ? "stat-amber" : (ScheduledJiraTaskCount > 0 ? "stat-green" : ""))">
            <div class="stat-value">@AtRiskCount</div>
            <div class="stat-label">At Risk</div>
            <div class="stat-sub">@RemainingWorkingDays working days left</div>
        </div>
        <div class="stat-card @(BlockedStatCount > 0 ? "stat-red" : (ScheduledJiraTaskCount > 0 ? "stat-green" : ""))">
            <div class="stat-value">@BlockedStatCount</div>
            <div class="stat-label">On Hold</div>
            <div class="stat-sub">status = On Hold</div>
        </div>
        <div class="stat-card">
            <div class="stat-value">@InProgressCount</div>
            <div class="stat-label">In Progress</div>
            <div class="stat-sub">actively being worked on</div>
        </div>
        <div class="stat-card @(MissingEstCount > 0 ? "stat-amber" : "")">
            <div class="stat-value">@MissingEstCount</div>
            <div class="stat-label">Missing Est.</div>
            <div class="stat-sub">active, no remaining est.</div>
        </div>
        <div class="stat-card stat-clickable @(SupportBugAllocatedHours > 0 ? "stat-red" : "")"
             @onclick="OpenSupportBugDetail"
             title="Click for the per-team support-bug split and solvable-ticket estimate">
            <div class="stat-value">@(SupportBugAllocatedHours > 0 ? $"{SupportBugAllocatedHours:0.#}h" : "—")</div>
            <div class="stat-label">Bug Hours</div>
            <div class="stat-sub">allocated for support bugs</div>
        </div>
    </div>

    <!-- ═══ TEAM CAPACITY BANNER ══════════════════════════════════════ -->
    @if (SprintEnd >= SprintStart && SprintStart != default)
    {
        <div class="spd-cap-banner">
            <span class="cap-banner-label">Team Load</span>
            @foreach (var team in GetAllTeams())
            {
                var capH   = GetTeamCapacityHours(team);
                var allocH = GetTeamAllocatedHours(team);
                var pct    = capH > 0m ? (double)(allocH / capH * 100m) : 0.0;
                var teamName = team;
                <div class="cap-team cap-team-clickable @GetCapacityLoadClass(pct)"
                     @onclick="() => OpenTeamLoadDetail(teamName)"
                     title="@team — @($"{allocH:0.#}h allocated of {capH:0.#}h capacity ({pct:0}%)") · click for breakdown">
                    <div class="cap-team-top">
                        <span class="cap-team-name">@team</span>
                        <span class="cap-team-pct">@($"{pct:0}%")</span>
                    </div>
                    <div class="cap-team-bar-wrap">
                        <div class="cap-team-bar" style="width:@(Math.Min(pct, 100).ToString("F1", CultureInfo.InvariantCulture))%;"></div>
                    </div>
                    <div class="cap-team-sub">@($"{allocH:0.#}h / {capH:0.#}h") · @GetTeamMemberCount(team) ppl</div>
                </div>
            }
        </div>
    }

    <!-- ═══ PLAN CRUD BAR ═══════════════════════════════════════════════ -->
    <div class="spd-plan-bar">
        <div class="plan-bar-left">
            <span class="plan-bar-label">Sprint:</span>
            <select class="input plan-select" disabled="@_isSaving"
                    @onchange="OnSprintDropdownChanged">
                <option value="0">— Load a saved sprint —</option>
                @foreach (var p in _savedPlans)
                {
                    <option value="@p.Id" selected="@(p.Id == _currentPlanId)">
                        @p.Name &nbsp;(@p.SprintStart.ToString("dd-MMM") → @p.SprintEnd.ToString("dd-MMM"))
                    </option>
                }
            </select>
            <button class="btn small" @onclick="NewSprint" disabled="@_isSaving" title="Clear the board and start a new sprint">
                + New
            </button>
        </div>
        <div class="plan-bar-right">
            @if (IsDirty)
            {
                <span class="plan-dirty-badge" title="You have unsaved changes">● Unsaved changes</span>
            }
            else if (_currentPlanId.HasValue)
            {
                <span class="plan-current-badge">@SprintName</span>
            }
            else
            {
                <span class="plan-unsaved-badge">Unsaved</span>
            }
            <button class="btn primary small" @onclick="SavePlanAsync" disabled="@(_isSaving || string.IsNullOrWhiteSpace(SprintName))">
                @(_isSaving ? "Saving…" : "💾 Save Sprint")
            </button>
            @if (_currentPlanId.HasValue)
            {
                <button class="btn small toggle-btn @(_showVersionsPanel ? "toggle-on" : "")"
                        @onclick="() => _showVersionsPanel = !_showVersionsPanel"
                        title="View version history">
                    📋 History@(_planVersions.Count > 0 ? $" ({_planVersions.Count})" : "")
                </button>
                <button class="btn small" @onclick="OpenRemovalLogsAsync" title="View removal log">
                    📝 Removal Log
                </button>
                <button class="btn danger small" @onclick="DeletePlanAsync" disabled="@_isSaving" title="Delete this sprint plan">
                    🗑 Delete
                </button>
            }
        </div>
    </div>

    @if (_showVersionsPanel && _currentPlanId.HasValue)
    {
        <div class="spd-versions-panel">
            <div class="versions-panel-header">
                <span class="versions-panel-title">Version History — @SprintName</span>
                <button class="btn small" @onclick="() => _showVersionsPanel = false">✕ Close</button>
            </div>
            @if (_planVersions.Count == 0)
            {
                <p class="versions-empty">No versions yet — versions are created automatically each time you save an existing plan.</p>
            }
            else
            {
                <div class="versions-list">
                    @foreach (var v in _planVersions)
                    {
                        var ver = v;
                        <div class="version-item">
                            <span class="version-badge">@ver.VersionNumber</span>
                            <span class="version-date">@ver.SavedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</span>
                            <button class="btn small" @onclick="() => RestoreVersionAsync(ver)" disabled="@_isSaving">
                                Restore
                            </button>
                        </div>
                    }
                </div>
            }
        </div>
    }

    <!-- ═══ TEAM FILTER + ACTIONS ══════════════════════════════════════ -->
    <div class="spd-actions-bar">
        <div class="filter-groups">
            <div class="team-filters">
                <span class="filter-label">Team:</span>
                <button class="team-pill @(ActiveTeamFilter == null ? "active" : "")" @onclick="ClearTeamFilter">
                    All <span class="pill-count">@TeamMembers.Count</span>
                </button>
                @foreach (var team in GetAllTeams())
                {
                    var teamName = team;
                    <button class="team-pill @(ActiveTeamFilter == teamName ? "active" : "")" @onclick="() => SetTeamFilter(teamName)">
                        @teamName <span class="pill-count">@GetTeamMemberCount(teamName)</span>
                    </button>
                }
            </div>
            @if (LoadedEpics.Count > 0)
            {
                <div class="team-filters">
                    <span class="filter-label">Epic:</span>
                    <button class="team-pill @(ActiveEpicFilters.Count == 0 ? "active" : "")" @onclick="ClearEpicFilter">All</button>
                    @foreach (var ek in LoadedEpics.Keys)
                    {
                        var epicKey = ek;
                        <button class="team-pill @(ActiveEpicFilters.Contains(epicKey) ? "active" : "")"
                                @onclick="() => ToggleEpicFilter(epicKey)">@epicKey</button>
                    }
                </div>
            }
        </div>
        <div class="actions-right">
            <div class="action-buttons">
                <button class="btn primary" @onclick="AutoAssignAllUnassigned" disabled="@(UnassignedCount == 0)"
                        title="Assign unassigned tasks — keeping each task's Jira assignee when they're on the roster, else least-loaded member">
                    ⚡ Auto-Assign
                </button>
                <button class="btn" @onclick="ImportJiraAssignees" disabled="@(UnassignedCount == 0)"
                        title="Schedule unassigned tasks onto the team member matching their current Jira assignee">
                    👤 Import Assignees
                </button>
                <span class="action-divider"></span>
                <button class="btn danger" @onclick="ClearAllAllocations" disabled="@(Allocations.Count == 0)">
                    Clear All
                </button>
            </div>
            <div class="view-toggle-group">
                <button class="view-toggle-btn @(ViewMode == "calendar" ? "active" : "")" @onclick="SetCalendarView">Calendar</button>
                <button class="view-toggle-btn @(ViewMode == "report" ? "active" : "")" @onclick="SetReportView">Report</button>
                <button class="view-toggle-btn @(ViewMode == "daily" ? "active" : "")" @onclick="SetDailyView">Daily</button>
                <button class="view-toggle-btn @(ViewMode == "summary" ? "active" : "")" @onclick="SetSummaryView">📊 Summary</button>
                <button class="view-toggle-btn @(ViewMode == "bugs" ? "active" : "")" @onclick="SetBugsView">🐛 Support Bugs</button>
            </div>
        </div>
    </div>

    <!-- ═══ MAIN LAYOUT ════════════════════════════════════════════════ -->
    <div class="spd-main @(_calendarFullPage ? "cal-fullpage" : "")">

        <!-- LEFT: Multi-Epic Task Panel -->
        <div class="spd-task-panel">
            @if (HasActiveSelection)
            {
                <div class="selected-task-bar">
                    <span>@GetActivePlacementLabel()</span>
                    <button class="btn small" @onclick="CancelSelection">✕</button>
                </div>
            }

            @if (LoadedEpics.Count == 0 && LoadedTasks.Count == 0)
            {
                <div class="empty-state">
                    <div class="empty-icon">📋</div>
                    <p>Load an <strong>Epic</strong> or individual <strong>Tasks</strong> from the bar above.</p>
                    <p class="empty-sub">Multiple epics and task batches can be loaded together.</p>
                </div>
            }
            else
            {
                @foreach (var kvp in LoadedEpics)
                {
                    var epicKey = kvp.Key;
                    var epicState = kvp.Value;
                    <div class="epic-section">
                        <div class="epic-section-header" @onclick="() => ToggleEpic(epicKey)">
                            <span class="epic-toggle">@(epicState.IsExpanded ? "▾" : "▸")</span>
                            <span class="epic-key-badge">@epicKey</span>
                            @if (epicState.IsLoading)
                            {
                                <span class="epic-loading">Loading...</span>
                            }
                            else
                            {
                                <span class="epic-count">@epicState.Tasks.Count tasks</span>
                            }
                            <button class="epic-remove-btn" @onclick="() => RemoveEpic(epicKey)" @onclick:stopPropagation="true" title="Remove epic">✕</button>
                        </div>

                        @if (epicState.IsExpanded && !epicState.IsLoading)
                        {
                            @foreach (var group in GetTasksGroupedByStatus(epicState.Tasks))
                            {
                                <div class="task-group-header status-@group.Key">
                                    @GetStatusGroupLabel(group.Key)
                                    <span class="task-group-count">@group.Count()</span>
                                </div>
                                <ul class="task-list">
                                    @foreach (var t in group.OrderBy(x => x.Status))
                                    {
                                        var task = t;
                                        var isSelected = SelectedTask?.Id == task.Id;
                                        var isAssigned = IsTaskAssigned(task.Id);
                                        var assignee   = isAssigned ? GetTaskAssigneeName(task.Id) : null;
                                        <li class="task-item @(isSelected ? "selected" : "") @(isAssigned ? "assigned" : "")"
                                            @onclick="() => SelectTask(task)">
                                            <div class="task-item-top">
                                                <span class="task-key-label">@task.Key</span>
                                                @if (isAssigned)
                                                {
                                                    <span class="badge-assigned">✓</span>
                                                    @* @if (assignee is not null)
                                                    {
                                                        <span class="badge-assignee-name" title="@assignee">@assignee</span>
                                                    } *@
                                                }
                                                <span class="task-est-label">@FormatTaskHours(task)</span>
                                            </div>
                                            <div class="task-summary-text">@task.Summary</div>
                                            <div class="task-meta-row">
                                                <span class="meta-chip meta-status @GetStatusType(task.IssueType)">@task.IssueType</span>
                                                <span class="meta-chip meta-status @GetStatusClass(task.Status)">
                                                    @task.Status
                                                </span>
                                            </div>
                                        </li>
                                    }
                                </ul>
                            }
                        }
                    </div>
                }
            }
            <!-- Individually Loaded Tasks Section -->
            @if (LoadedTasks.Count > 0)
            {
                <div class="epic-section">
                    <div class="epic-section-header" @onclick="ToggleManualTasks">
                        <span class="epic-toggle">@(_manualTasksExpanded ? "▾" : "▸")</span>
                        <span class="epic-key-badge epic-key-badge-tasks">📌 Tasks</span>
                        <span class="epic-count">@LoadedTasks.Count loaded</span>
                    </div>
                    @if (_manualTasksExpanded)
                    {
                        <ul class="task-list">
                            @foreach (var t in LoadedTasks.Values.OrderBy(x => x.Key))
                            {
                                var task       = t;
                                var isSelected = SelectedTask?.Id == task.Id;
                                var isAssigned = IsTaskAssigned(task.Id);
                                <li class="task-item @(isSelected ? "selected" : "") @(isAssigned ? "assigned" : "")"
                                    @onclick="() => SelectTask(task)">
                                    <div class="task-item-top">
                                        <span class="task-key-label">@task.Key</span>
                                        @if (isAssigned)
                                        {
                                            <span class="badge-assigned">✓</span>
                                        }
                                        <span class="task-est-label">@FormatTaskHours(task)</span>
                                        <button class="epic-remove-btn" @onclick="() => RemoveLoadedTask(task.Key)" @onclick:stopPropagation="true" title="Remove task">✕</button>
                                    </div>
                                    <div class="task-summary-text">@task.Summary</div>
                                    <div class="task-meta-row">
                                        <span class="meta-chip meta-status @GetStatusType(task.IssueType)">@task.IssueType</span>
                                        <span class="meta-chip meta-status @GetStatusClass(task.Status)">@task.Status</span>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                </div>
            }

            <!-- Custom Tasks Section -->
            <div class="custom-section">
                <div class="custom-section-header" @onclick="ToggleCustomTaskForm">
                    <span class="custom-section-title">+ Custom Tasks</span>
                    <span class="custom-section-count">@_customTasks.Count</span>
                </div>

                @if (ShowCustomTaskForm)
                {
                    <div class="custom-task-form">
                        @if (_customTaskTemplates.Count == 0)
                        {
                            <div class="custom-empty-hint">
                                No custom tasks configured yet. Add them in
                                <a href="team-roster">Sprint Planning Config</a>.
                            </div>
                        }
                        else
                        {
                            var selTpl = _customTaskTemplates.FirstOrDefault(t => t.Id == SelectedTemplateId);
                            <input class="input custom-input" placeholder="Name (e.g. Daily Standup)"
                                   @bind="NewCustomTaskName" @bind:event="oninput" />
                            <select class="input custom-input" value="@SelectedTemplateId" @onchange="OnTemplateChanged">
                                <option value="0">Select a category…</option>
                                @foreach (var tpl in _customTaskTemplates)
                                {
                                    <option value="@tpl.Id">@tpl.Category</option>
                                }
                            </select>
                            @if (selTpl?.Category == "Feature Bug")
                            {
                                <input class="input custom-input" placeholder="Epic key (e.g. PROJ-456)"
                                       @bind="NewFeatureBugEpicKey" @bind:event="oninput" />
                            }
                            <div class="custom-form-row">
                                <input class="input custom-input" type="number" min="0.5" step="0.5"
                                       placeholder="Hours" @bind="NewCustomTaskHours" />
                                <button class="btn primary small" @onclick="AddCustomTask">Add</button>
                            </div>
                        }
                    </div>
                }

                @if (_customTasks.Count > 0)
                {
                    <ul class="task-list custom-task-list">
                        @foreach (var kvp in _customTasks)
                        {
                            var ct = kvp.Value;
                            var isSelCt = SelectedCustomTaskId == ct.Id;
                            var isAssignedCt = IsTaskAssigned(ct.Id);
                            var ctAssignee = isAssignedCt ? GetTaskAssigneeName(ct.Id) : null;
                            var ctColor = string.IsNullOrWhiteSpace(ct.Color) ? GetCategoryColor(ct.Category) : ct.Color;
                            <li class="task-item custom-task-item @(isSelCt ? "selected" : "") @(isAssignedCt ? "assigned" : "")"
                                style="border-left-color: @ctColor"
                                @onclick="() => SelectCustomTask(ct.Id)">
                                <div class="task-item-top">
                                    <span class="custom-cat-badge" style="background: @ctColor">@ct.Category</span>
                                    @if (isAssignedCt)
                                    {
                                        <span class="badge-assigned">✓</span>
                                        @if (ctAssignee is not null)
                                        {
                                            <span class="badge-assignee-name" title="@ctAssignee">@ctAssignee</span>
                                        }
                                    }
                                    <span class="task-est-label">@ct.Hours h</span>
                                    <button class="epic-remove-btn" @onclick="() => RemoveCustomTask(ct.Id)" @onclick:stopPropagation="true" title="Remove">✕</button>
                                </div>
                                <div class="task-summary-text">@ct.Name</div>
                            </li>
                        }
                    </ul>
                }
            </div>

            <div class="task-panel-hint">
                Select a task → click a calendar cell to schedule.
                Each member's daily capacity comes from the roster — tasks split automatically.
            </div>
        </div>

        <!-- RIGHT: View Area -->
        <div class="spd-view-area">

            <!-- Placement Bar -->
            @if (PendingPlacement is not null)
            {
                <div class="placement-bar">
                    <span class="pl-pending">
                        Placing <strong>@GetActivePlacementLabel()</strong>
                        — Start: @PendingPlacement.Start.ToString("dd-MMM")
                        — click same row to confirm
                    </span>
                    <button class="btn small" @onclick="CancelPlacement">Cancel</button>
                </div>
            }

            @if (ViewMode == "report")
            {
                <!-- ═ REPORT VIEW ════════════════════════════════════════════ -->
                <div class="rpt-container">
                    @if (_isRefreshingReport)
                    {
                        <div class="rpt-loading"><div class="rpt-spinner"></div><span>Fetching latest data from Jira…</span></div>
                    }
                    @if (Allocations.Count == 0)
                    {
                        <div class="empty-state">No tasks assigned yet — schedule tasks on the calendar first.</div>
                    }
                    else
                    {
                        <table class="rpt-table">
                            <thead>
                                <tr>
                                    <th class="rpt-th rpt-th-assignee">Assignee</th>
                                    <th class="rpt-th rpt-th-key">Key</th>
                                    <th class="rpt-th rpt-th-title">Title</th>
                                    <th class="rpt-th rpt-th-status">Status</th>
                                    <th class="rpt-th rpt-th-est">Original Est.</th>
                                    <th class="rpt-th rpt-th-est">Remaining</th>
                                    <th class="rpt-th rpt-th-logged">Time Logged</th>
                                    <th class="rpt-th rpt-th-pct">% Done</th>
                                    <th class="rpt-th rpt-th-feasible">Feasible</th>
                                    <th class="rpt-th rpt-th-activity">Last Activity</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var teamGroup in GetFilteredMembersByTeam())
                                {
                                    var rptTeamName = teamGroup.Key;
                                    <tr class="rpt-team-row">
                                        <td colspan="10" class="rpt-team-cell">@rptTeamName</td>
                                    </tr>
                                    @foreach (var mem in teamGroup)
                                    {
                                        var rptMem = mem;
                                        var memberRows = GetReportRowsForMember(rptMem.Id);
                                        @if (memberRows.Count == 0)
                                        {
                                            <tr class="rpt-row">
                                                <td class="rpt-td rpt-td-assignee">@rptMem.Name</td>
                                                <td class="rpt-td" colspan="9" style="color:#9ca3af;font-style:italic;">No tasks assigned</td>
                                            </tr>
                                        }
                                        else
                                        {
                                            @foreach (var (row, idx) in memberRows.Select((r, i) => (r, i)))
                                            {
                                                <tr class="rpt-row">
                                                    <td class="rpt-td rpt-td-assignee">@(idx == 0 ? rptMem.Name : "")</td>
                                                    @if (row.IsCustom)
                                                    {
                                                        <td class="rpt-td rpt-td-key">
                                                            <span class="rpt-custom-badge" style="background:@row.CustomColor">@row.CustomCategory</span>
                                                        </td>
                                                        <td class="rpt-td rpt-td-title">@row.Title</td>
                                                        <td class="rpt-td rpt-td-dash">—</td>
                                                        <td class="rpt-td rpt-td-dash">@($"{row.CustomHours:0.#}h")</td>
                                                        <td class="rpt-td rpt-td-dash">—</td>
                                                        @if (row.CustomCategory == "Support Bug" || (row.CustomCategory == "Feature Bug" && !string.IsNullOrEmpty(row.FeatureBugEpicKey)))
                                                        {
                                                            <td class="rpt-td rpt-td-est">@(row.SupportBugLoggedSeconds > 0 ? FormatEstimate("", row.SupportBugLoggedSeconds) : "—")</td>
                                                        }
                                                        else
                                                        {
                                                            <td class="rpt-td rpt-td-dash">—</td>
                                                        }
                                                        @if ((row.CustomCategory == "Support Bug" || row.CustomCategory == "Feature Bug") && row.CustomHours > 0)
                                                        {
                                                            <td class="rpt-td rpt-td-pct">
                                                                <span class="risk-badge @GetCompletionBadgeClass(row)" title="@FormatEstimate("", row.SupportBugLoggedSeconds) logged / @($"{row.CustomHours:0.#}h") planned">@GetCompletionPct(row)</span>
                                                            </td>
                                                        }
                                                        else
                                                        {
                                                            <td class="rpt-td rpt-td-dash">—</td>
                                                        }
                                                        <td class="rpt-td rpt-td-dash">—</td>
                                                        @if ((row.CustomCategory == "Support Bug" || (row.CustomCategory == "Feature Bug" && !string.IsNullOrEmpty(row.FeatureBugEpicKey))) && row.SupportBugLastActivity.HasValue)
                                                        {
                                                            <td class="rpt-td rpt-td-activity"><span>@row.SupportBugLastActivity.Value.ToString("dd MMM, HH:mm")</span></td>
                                                        }
                                                        else
                                                        {
                                                            <td class="rpt-td rpt-td-dash">—</td>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        var isInProgress = string.Equals(row.Status, "in progress", StringComparison.OrdinalIgnoreCase);
                                                        var isStaleActivity = isInProgress &&
                                                            (!row.LastActivityDate.HasValue ||
                                                             (DateTime.Now - row.LastActivityDate.Value).TotalHours > 24);
                                                        <td class="rpt-td rpt-td-key">
                                                            <span class="rpt-jira-key">@row.Key</span>
                                                        </td>
                                                        <td class="rpt-td rpt-td-title">@row.Title</td>
                                                        <td class="rpt-td">
                                                            <span class="rpt-status-chip @GetStatusClass(row.Status)">@(string.IsNullOrEmpty(row.Status) ? "—" : row.Status)</span>
                                                        </td>
                                                        <td class="rpt-td rpt-td-est">@FormatEstimate(row.OriginalEstimate, row.OriginalEstimateSeconds)</td>
                                                        <td class="rpt-td rpt-td-est">@FormatEstimate(row.RemainingEstimate, row.ComputedRemainingSeconds)</td>
                                                        <td class="rpt-td rpt-td-est">@FormatEstimate(row.TimeSpent, row.TimeSpentSeconds)</td>
                                                        <td class="rpt-td rpt-td-pct">
                                                            <span class="risk-badge @GetCompletionBadgeClass(row)">@GetCompletionPct(row)</span>
                                                        </td>
                                                        <td class="rpt-td rpt-td-feasible">
                                                            <span class="feas-badge @GetFeasibilityClass(row)">@GetFeasibilityLabel(row)</span>
                                                        </td>
                                                        <td class="rpt-td rpt-td-activity @(isStaleActivity ? "rpt-activity-stale" : "")"
                                                            title="@(isStaleActivity ? "In Progress — no activity in the last 24h" : "")">
                                                            @if (row.LastActivityDate.HasValue)
                                                            {
                                                                <span>@row.LastActivityDate.Value.ToString("dd MMM, HH:mm")</span>
                                                            }
                                                            else
                                                            {
                                                                <span class="rpt-activity-never">Never</span>
                                                            }
                                                        </td>
                                                    }
                                                </tr>
                                            }
                                        }
                                    }
                                }
                            </tbody>
                        </table>
                    }
                </div>
            }
            else if (ViewMode == "daily")
            {
                <!-- ═ DAILY VIEW ══════════════════════════════════════════════ -->
                <div class="daily-container">
                    @if (_isRefreshingReport)
                    {
                        <div class="rpt-loading"><div class="rpt-spinner"></div><span>Fetching latest data from Jira…</span></div>
                    }
                    @{
                        var dm = GetDailyMetrics();
                    }

                    <!-- Top KPI row -->
                    <div class="daily-kpi-row">
                        <div class="daily-kpi-card">
                            <div class="daily-kpi-value @(dm.TaskPct >= 80 ? "kpi-green" : dm.TaskPct >= 40 ? "kpi-amber" : "kpi-red")">
                                @($"{dm.TaskPct:0}%")
                            </div>
                            <div class="daily-kpi-label">Tasks Completed</div>
                            <div class="daily-kpi-sub">@dm.DoneCount of @dm.TotalCount tasks</div>
                        </div>
                        <div class="daily-kpi-card">
                            <div class="daily-kpi-value @(dm.HoursPct >= 80 ? "kpi-green" : dm.HoursPct >= 40 ? "kpi-amber" : "kpi-red")">
                                @($"{dm.HoursPct:0}%")
                            </div>
                            <div class="daily-kpi-label">Estimated Work Done</div>
                            <div class="daily-kpi-sub">Hours-based · custom tasks excluded</div>
                        </div>
                        <div class="daily-kpi-card">
                            <div class="daily-kpi-value kpi-neutral">@dm.NoRemainingCount</div>
                            <div class="daily-kpi-label">Missing Remaining Est.</div>
                            <div class="daily-kpi-sub">In progress / to do with no remaining est.</div>
                        </div>
                        <div class="daily-kpi-card">
                            <div class="daily-kpi-value @(dm.BlockedCount > 0 ? "kpi-red" : "kpi-green")">@dm.BlockedCount</div>
                            <div class="daily-kpi-label">On Hold</div>
                            <div class="daily-kpi-sub">Status = "On Hold"</div>
                        </div>
                    </div>

                    <!-- Today's Activity -->
                    @{
                        var todayActivity = GetTodayActivity();
                        var todayAuthors = todayActivity.Select(x => x.Author).ToHashSet(StringComparer.OrdinalIgnoreCase);
                        var noActivityToday = Allocations
                            .Where(a => a.TaskId > 0)
                            .Select(a => TeamMembers.FirstOrDefault(m => m.Id == a.TeamMemberId)?.Name)
                            .Where(n => n != null)
                            .Distinct()
                            .Where(name => !todayAuthors.Any(a => AuthorMatchesMember(a, name!)))
                            .OrderBy(n => n)
                            .ToList();
                    }
                    <div class="daily-section">
                        <div class="daily-section-title">
                            Today's Activity
                            <span class="daily-section-sub">— worklogs from @DateTime.Today.ToString("dd MMM")</span>
                        </div>
                        @if (_reportIssues.Count == 0)
                        {
                            <div class="daily-empty-note">No Jira data loaded — switch to Report view first to refresh.</div>
                        }
                        else if (!todayActivity.Any())
                        {
                            <div class="daily-empty-note">No worklogs found for today.</div>
                        }
                        else
                        {
                            <table class="rpt-table">
                                <thead>
                                    <tr>
                                        <th class="rpt-th rpt-th-assignee">Author</th>
                                        <th class="rpt-th rpt-th-est">Logged Today</th>
                                        <th class="rpt-th rpt-th-key">Task</th>
                                        <th class="rpt-th rpt-th-title">Summary</th>
                                        <th class="rpt-th" style="width:80px;text-align:center">In Calendar</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var (author, totalSec, lines) in todayActivity)
                                    {
                                        @foreach (var (line, idx) in lines.Select((l, i) => (l, i)))
                                        {
                                            <tr class="rpt-row">
                                                <td class="rpt-td rpt-td-assignee">@(idx == 0 ? author : "")</td>
                                                <td class="rpt-td rpt-td-est">
                                                    @if (idx == 0)
                                                    {
                                                        <span class="risk-badge risk-green">@FmtSec(totalSec)</span>
                                                    }
                                                </td>
                                                <td class="rpt-td rpt-td-key"><span class="rpt-jira-key">@line.IssueKey</span></td>
                                                <td class="rpt-td rpt-td-title">@line.IssueSummary</td>
                                                <td class="rpt-td" style="text-align:center;font-size:14px;color:@(line.IsInCalendar ? "#16a34a" : "#9ca3af")">
                                                    @(line.IsInCalendar ? "✓" : "—")
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        }
                        @if (noActivityToday.Any())
                        {
                            <div class="daily-no-activity">No activity today: @string.Join(" · ", noActivityToday)</div>
                        }
                    </div>

                    <!-- Status breakdown -->
                    <div class="daily-section">
                        <div class="daily-section-title">Tasks by Status</div>
                        <div class="daily-status-grid">
                            @foreach (var (status, count) in dm.ByStatus.OrderByDescending(x => x.Value))
                            {
                                var sBadgeClass = GetStatusClass(status);
                                <div class="daily-status-item">
                                    <span class="rpt-status-chip @sBadgeClass">@status</span>
                                    <span class="daily-status-count">@count</span>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Untouched tasks -->
                    @if (dm.UntouchedTasks.Count > 0)
                    {
                        <div class="daily-section">
                            <div class="daily-section-title">Untouched Tasks <span class="daily-section-sub">(remaining = original, not Done)</span></div>
                            <table class="rpt-table">
                                <thead>
                                    <tr>
                                        <th class="rpt-th rpt-th-key">Key</th>
                                        <th class="rpt-th rpt-th-title">Title</th>
                                        <th class="rpt-th rpt-th-status">Status</th>
                                        <th class="rpt-th rpt-th-assignee">Assignee</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var t in dm.UntouchedTasks)
                                    {
                                        <tr class="rpt-row">
                                            <td class="rpt-td rpt-td-key"><span class="rpt-jira-key">@t.Key</span></td>
                                            <td class="rpt-td rpt-td-title">@t.Summary</td>
                                            <td class="rpt-td"><span class="rpt-status-chip @GetStatusClass(t.Status)">@t.Status</span></td>
                                            <td class="rpt-td rpt-td-assignee">@t.Assignee</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

                    <!-- Missing remaining estimate -->
                    @if (dm.NoRemainingTasks.Count > 0)
                    {
                        <div class="daily-section">
                            <div class="daily-section-title">Missing Remaining Estimate <span class="daily-section-sub">(active tasks — need attention)</span></div>
                            <table class="rpt-table">
                                <thead>
                                    <tr>
                                        <th class="rpt-th rpt-th-key">Key</th>
                                        <th class="rpt-th rpt-th-title">Title</th>
                                        <th class="rpt-th rpt-th-status">Status</th>
                                        <th class="rpt-th rpt-th-assignee">Assignee</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var t in dm.NoRemainingTasks)
                                    {
                                        <tr class="rpt-row">
                                            <td class="rpt-td rpt-td-key"><span class="rpt-jira-key">@t.Key</span></td>
                                            <td class="rpt-td rpt-td-title">@t.Summary</td>
                                            <td class="rpt-td"><span class="rpt-status-chip @GetStatusClass(t.Status)">@t.Status</span></td>
                                            <td class="rpt-td rpt-td-assignee">@t.Assignee</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

                    <!-- On Hold tasks -->
                    @if (dm.BlockedTasks.Count > 0)
                    {
                        <div class="daily-section">
                            <div class="daily-section-title daily-section-title-danger">On Hold Tasks</div>
                            <table class="rpt-table">
                                <thead>
                                    <tr>
                                        <th class="rpt-th rpt-th-key">Key</th>
                                        <th class="rpt-th rpt-th-title">Title</th>
                                        <th class="rpt-th rpt-th-status">Status</th>
                                        <th class="rpt-th rpt-th-assignee">Assignee</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var t in dm.BlockedTasks)
                                    {
                                        <tr class="rpt-row">
                                            <td class="rpt-td rpt-td-key"><span class="rpt-jira-key">@t.Key</span></td>
                                            <td class="rpt-td rpt-td-title">@t.Summary</td>
                                            <td class="rpt-td"><span class="rpt-status-chip status-on-hold">@t.Status</span></td>
                                            <td class="rpt-td rpt-td-assignee">@t.Assignee</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            }
            else if (ViewMode == "summary")
            {
                <!-- ═ SPRINT SUMMARY VIEW (commitment vs completion) ══════════════ -->
                <div class="daily-container">
                    @if (_isRefreshingReport)
                    {
                        <div class="rpt-loading"><div class="rpt-spinner"></div><span>Fetching latest data from Jira…</span></div>
                    }
                    @{
                        var sm = GetSummaryMetrics();
                        var taskPct  = Pct(sm.DoneTasks, sm.CommittedTasks);
                        var hoursPct = Pct(sm.DoneSeconds, sm.CommittedSeconds);
                        var logPct   = Pct(sm.LoggedSeconds, sm.CommittedSeconds);
                    }
                    @if (sm.CommittedTasks == 0)
                    {
                        <div class="empty-state">No Jira tasks scheduled yet — assign tasks on the calendar to see the summary.</div>
                    }
                    else
                    {
                        <div class="daily-kpi-row">
                            <div class="daily-kpi-card">
                                <div class="daily-kpi-value @PctClass(taskPct)">@($"{taskPct:0}%")</div>
                                <div class="daily-kpi-label">Tasks Completed</div>
                                <div class="daily-kpi-sub">@sm.DoneTasks of @sm.CommittedTasks committed</div>
                            </div>
                            <div class="daily-kpi-card">
                                <div class="daily-kpi-value @PctClass(hoursPct)">@($"{hoursPct:0}%")</div>
                                <div class="daily-kpi-label">Estimated Work Done</div>
                                <div class="daily-kpi-sub">@FmtSec((int)sm.DoneSeconds) of @FmtSec((int)sm.CommittedSeconds) committed</div>
                            </div>
                            <div class="daily-kpi-card">
                                <div class="daily-kpi-value kpi-neutral">@($"{logPct:0}%")</div>
                                <div class="daily-kpi-label">Time Logged vs Commit</div>
                                <div class="daily-kpi-sub">@FmtSec((int)sm.LoggedSeconds) logged</div>
                            </div>
                            <div class="daily-kpi-card">
                                <div class="daily-kpi-value @(sm.AtRisk > 0 ? "kpi-red" : "kpi-green")">@sm.AtRisk</div>
                                <div class="daily-kpi-label">At Risk</div>
                                <div class="daily-kpi-sub">@RemainingWorkingDays working days left</div>
                            </div>
                        </div>

                        <div class="daily-section">
                            <div class="daily-section-title">Commitment vs Completion</div>
                            <div class="sum-bar-row">
                                <span class="sum-bar-label">Tasks</span>
                                <div class="sum-bar-track">
                                    <div class="sum-bar-fill @PctClass(taskPct)" style="width:@(Math.Min(taskPct,100).ToString("F1", CultureInfo.InvariantCulture))%;"></div>
                                </div>
                                <span class="sum-bar-pct">@sm.DoneTasks / @sm.CommittedTasks</span>
                            </div>
                            <div class="sum-bar-row">
                                <span class="sum-bar-label">Effort</span>
                                <div class="sum-bar-track">
                                    <div class="sum-bar-fill @PctClass(hoursPct)" style="width:@(Math.Min(hoursPct,100).ToString("F1", CultureInfo.InvariantCulture))%;"></div>
                                </div>
                                <span class="sum-bar-pct">@FmtSec((int)sm.DoneSeconds) / @FmtSec((int)sm.CommittedSeconds)</span>
                            </div>
                            <div class="sum-status-line">
                                <span class="sum-chip status-done">@sm.DoneTasks Done</span>
                                <span class="sum-chip status-in-progress">@sm.InProgressTasks In Progress</span>
                                <span class="sum-chip status-todo">@sm.NotStartedTasks Not Started</span>
                            </div>
                        </div>

                        <div class="daily-section">
                            <div class="daily-section-title">By Team</div>
                            <table class="rpt-table">
                                <thead>
                                    <tr>
                                        <th class="rpt-th">Team</th>
                                        <th class="rpt-th" style="text-align:center;">Tasks Done</th>
                                        <th class="rpt-th" style="text-align:center;">Task %</th>
                                        <th class="rpt-th" style="text-align:center;">Effort Done</th>
                                        <th class="rpt-th" style="text-align:center;">Effort %</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var tr in GetTeamSummaryRows())
                                    {
                                        var tPct = Pct(tr.Done, tr.Committed);
                                        var ePct = Pct((double)tr.DoneHours, (double)tr.CommittedHours);
                                        <tr class="rpt-row">
                                            <td class="rpt-td" style="font-weight:600;">@tr.Team</td>
                                            <td class="rpt-td" style="text-align:center;">@tr.Done / @tr.Committed</td>
                                            <td class="rpt-td" style="text-align:center;"><span class="risk-badge @GetPctBadge(tPct)">@($"{tPct:0}%")</span></td>
                                            <td class="rpt-td" style="text-align:center;">@($"{tr.DoneHours:0.#}h / {tr.CommittedHours:0.#}h")</td>
                                            <td class="rpt-td" style="text-align:center;"><span class="risk-badge @GetPctBadge(ePct)">@($"{ePct:0}%")</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            }
            else if (ViewMode == "bugs")
            {
                <!-- ═ SUPPORT BUGS VIEW ══════════════════════════════════════════ -->
                <div class="bugs-container">
                    @if (_isRefreshingReport)
                    {
                        <div class="rpt-loading"><div class="rpt-spinner"></div><span>Fetching latest data from Jira…</span></div>
                    }
                    @{
                        var bugWeeks   = GetWeekRanges();
                        var bugMembers = GetMembersWithSupportBugActivity();
                        var hasBugData = _customTasks.Values.Any(ct => ct.Category == "Support Bug")
                                      || LoadedSupportBugEpics.Count > 0;
                    }
                    @if (!hasBugData)
                    {
                        <div class="bugs-no-data">
                            <p>No Support Bug data yet.</p>
                            <p>Assign <strong>Support Bug</strong> custom tasks in the calendar, and/or load a Bug Epic in the config bar above.</p>
                        </div>
                    }
                    else if (bugWeeks.Count == 0)
                    {
                        <div class="bugs-no-data">Apply a sprint date range first.</div>
                    }
                    else
                    {
                        <table class="bugs-table">
                            <thead>
                                <tr>
                                    <th class="bugs-th bugs-th-member">Member</th>
                                    @foreach (var wk in bugWeeks)
                                    {
                                        <th class="bugs-th bugs-th-week">
                                            @wk.Label
                                            <span class="bugs-th-sub">@wk.Start.ToString("dd-MMM") – @wk.End.ToString("dd-MMM")</span>
                                            <span class="bugs-th-sub">Planned / Logged</span>
                                        </th>
                                    }
                                    <th class="bugs-th bugs-th-week bugs-th-total">
                                        Sprint Total
                                        <span class="bugs-th-sub">Planned / Logged</span>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (bugMembers.Count == 0)
                                {
                                    <tr>
                                        <td colspan="@(bugWeeks.Count + 2)" class="bugs-no-data">No members have Support Bug allocations or logged hours yet.</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var grp in bugMembers.GroupBy(m => m.Team))
                                    {
                                        <tr class="bugs-team-row">
                                            <td colspan="@(bugWeeks.Count + 2)" class="bugs-team-cell">@grp.Key</td>
                                        </tr>
                                        @foreach (var mem in grp)
                                        {
                                            var bMem        = mem;
                                            var totalPlanned = GetSupportBugPlannedHoursInRange(bMem.Id, SprintStart, SprintEnd);
                                            var totalLogged  = GetSupportBugLoggedSecondsInRange(bMem.Name, SprintStart, SprintEnd);
                                            var bugIsExpanded = _expandedBugMembers.Contains(bMem.Id);
                                            <tr class="bugs-tr">
                                                <td class="bugs-td bugs-td-member">
                                                    <button class="bugs-member-toggle" @onclick="() => ToggleBugMemberDetail(bMem.Id)" title="Show which support bugs were logged">
                                                        <span class="bugs-caret">@(bugIsExpanded ? "▾" : "▸")</span>
                                                        @bMem.Name
                                                    </button>
                                                </td>
                                                @foreach (var wk in bugWeeks)
                                                {
                                                    var wkPlanned = GetSupportBugPlannedHoursInRange(bMem.Id, wk.Start, wk.End);
                                                    var wkLogged  = GetSupportBugLoggedSecondsInRange(bMem.Name, wk.Start, wk.End);
                                                    var wkLoggedH = wkLogged / 3600m;
                                                    var wkBadge   = BugPctBadgeClass(wkPlanned, wkLoggedH);
                                                    var wkPctStr  = BugPctLabel(wkPlanned, wkLoggedH);
                                                    <td class="bugs-td bugs-td-cell">
                                                        <div class="bugs-cell">
                                                            <span class="bugs-planned">@($"{wkPlanned:0.#}h")</span>
                                                            <span class="bugs-logged">@($"{wkLoggedH:0.#}h logged")</span>
                                                            <span class="bugs-pct @wkBadge">@wkPctStr</span>
                                                        </div>
                                                    </td>
                                                }
                                                @{
                                                    var totLoggedH = totalLogged / 3600m;
                                                    var totBadge   = BugPctBadgeClass(totalPlanned, totLoggedH);
                                                    var totPctStr  = BugPctLabel(totalPlanned, totLoggedH);
                                                }
                                                <td class="bugs-td bugs-td-cell bugs-td-total">
                                                    <div class="bugs-cell">
                                                        <span class="bugs-planned">@($"{totalPlanned:0.#}h")</span>
                                                        <span class="bugs-logged">@($"{totLoggedH:0.#}h logged")</span>
                                                        <span class="bugs-pct @totBadge">@totPctStr</span>
                                                    </div>
                                                </td>
                                            </tr>
                                            @if (bugIsExpanded)
                                            {
                                                var bugLog = GetSupportBugLogBreakdown(bMem.Name, SprintStart, SprintEnd);
                                                <tr class="bugs-detail-row">
                                                    <td colspan="@(bugWeeks.Count + 2)" class="bugs-detail-cell">
                                                        @if (bugLog.Count == 0)
                                                        {
                                                            <div class="bugs-detail-empty">No support-bug worklogs matched <strong>@bMem.Name</strong> in this sprint window. If Jira shows hours, the worklog author name may not match the roster name.</div>
                                                        }
                                                        else
                                                        {
                                                            <table class="bugs-detail-table">
                                                                <thead>
                                                                    <tr>
                                                                        <th>Issue</th>
                                                                        <th>Summary</th>
                                                                        <th class="bugs-detail-num">Worklogs</th>
                                                                        <th class="bugs-detail-num">Logged</th>
                                                                        <th class="bugs-detail-num">Last activity</th>
                                                                    </tr>
                                                                </thead>
                                                                <tbody>
                                                                    @foreach (var bl in bugLog)
                                                                    {
                                                                        <tr>
                                                                            <td><a href="@JiraBrowseUrl(bl.Key)" target="_blank">@bl.Key ↗</a></td>
                                                                            <td class="bugs-detail-summary">@bl.Summary</td>
                                                                            <td class="bugs-detail-num">@bl.Worklogs</td>
                                                                            <td class="bugs-detail-num">@FmtSec(bl.Seconds)</td>
                                                                            <td class="bugs-detail-num">@bl.LastActivity.ToString("dd MMM, HH:mm")</td>
                                                                        </tr>
                                                                    }
                                                                </tbody>
                                                                <tfoot>
                                                                    <tr>
                                                                        <td colspan="2">@bugLog.Count issue(s)</td>
                                                                        <td class="bugs-detail-num">@bugLog.Sum(b => b.Worklogs)</td>
                                                                        <td class="bugs-detail-num">@FmtSec(bugLog.Sum(b => b.Seconds))</td>
                                                                        <td></td>
                                                                    </tr>
                                                                </tfoot>
                                                            </table>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    }
                                }
                                @{
                                    var unassignedTotalSec = GetSupportBugUnmatchedSecondsInRange(bugMembers, SprintStart, SprintEnd);
                                }
                                @if (unassignedTotalSec > 0)
                                {
                                    <tr class="bugs-tr bugs-tr-unassigned">
                                        <td class="bugs-td bugs-td-member">
                                            <button class="bugs-member-toggle" @onclick="() => _unassignedBugRowExpanded = !_unassignedBugRowExpanded" title="Worklogs whose author doesn't match any roster member">
                                                <span class="bugs-caret">@(_unassignedBugRowExpanded ? "▾" : "▸")</span>
                                                Unassigned
                                            </button>
                                        </td>
                                        @foreach (var wk in bugWeeks)
                                        {
                                            var wkUnSec = GetSupportBugUnmatchedSecondsInRange(bugMembers, wk.Start, wk.End);
                                            <td class="bugs-td bugs-td-cell">
                                                <div class="bugs-cell">
                                                    <span class="bugs-planned">—</span>
                                                    <span class="bugs-logged">@($"{wkUnSec / 3600m:0.#}h logged")</span>
                                                    <span class="bugs-pct bugs-pct-gray">unmatched</span>
                                                </div>
                                            </td>
                                        }
                                        <td class="bugs-td bugs-td-cell bugs-td-total">
                                            <div class="bugs-cell">
                                                <span class="bugs-planned">—</span>
                                                <span class="bugs-logged">@($"{unassignedTotalSec / 3600m:0.#}h logged")</span>
                                                <span class="bugs-pct bugs-pct-gray">unmatched</span>
                                            </div>
                                        </td>
                                    </tr>
                                    @if (_unassignedBugRowExpanded)
                                    {
                                        var byAuthor = GetSupportBugUnmatchedByAuthor(bugMembers, SprintStart, SprintEnd);
                                        <tr class="bugs-detail-row">
                                            <td colspan="@(bugWeeks.Count + 2)" class="bugs-detail-cell">
                                                <table class="bugs-detail-table">
                                                    <thead><tr><th>Worklog author</th><th class="bugs-detail-num">Logged</th></tr></thead>
                                                    <tbody>
                                                        @foreach (var a in byAuthor)
                                                        {
                                                            <tr><td>@a.Author</td><td class="bugs-detail-num">@FmtSec(a.Seconds)</td></tr>
                                                        }
                                                    </tbody>
                                                    <tfoot><tr><td>@byAuthor.Count author(s) · not in roster</td><td class="bugs-detail-num">@FmtSec(unassignedTotalSec)</td></tr></tfoot>
                                                </table>
                                                <div class="bugs-detail-empty" style="margin-top:6px">These authors don't match a roster member. Add them — or set their Jira account/email — on the Team Roster page to attribute their hours.</div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                            <tfoot>
                                <tr class="bugs-total-row">
                                    <td class="bugs-td bugs-td-member">TOTAL</td>
                                    @foreach (var wk in bugWeeks)
                                    {
                                        var wkTotalPlanned = bugMembers.Sum(m => GetSupportBugPlannedHoursInRange(m.Id, wk.Start, wk.End));
                                        var wkTotalLoggedSec = GetSupportBugLoggedSecondsAllInRange(wk.Start, wk.End);
                                        var wkTotalLoggedH   = wkTotalLoggedSec / 3600m;
                                        <td class="bugs-td bugs-td-cell">
                                            <div class="bugs-cell">
                                                <span class="bugs-planned">@($"{wkTotalPlanned:0.#}h")</span>
                                                <span class="bugs-logged">@($"{wkTotalLoggedH:0.#}h logged")</span>
                                                <span class="bugs-pct @BugPctBadgeClass(wkTotalPlanned, wkTotalLoggedH)">@BugPctLabel(wkTotalPlanned, wkTotalLoggedH)</span>
                                            </div>
                                        </td>
                                    }
                                    @{
                                        var grandPlanned    = bugMembers.Sum(m => GetSupportBugPlannedHoursInRange(m.Id, SprintStart, SprintEnd));
                                        var grandLoggedSec  = GetSupportBugLoggedSecondsAllInRange(SprintStart, SprintEnd);
                                        var grandLoggedH    = grandLoggedSec / 3600m;
                                    }
                                    <td class="bugs-td bugs-td-cell bugs-td-total">
                                        <div class="bugs-cell">
                                            <span class="bugs-planned">@($"{grandPlanned:0.#}h")</span>
                                            <span class="bugs-logged">@($"{grandLoggedH:0.#}h logged")</span>
                                            <span class="bugs-pct @BugPctBadgeClass(grandPlanned, grandLoggedH)">@BugPctLabel(grandPlanned, grandLoggedH)</span>
                                        </div>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                    }
                </div>
            }
            else
            {
                <!-- ═ CALENDAR VIEW ════════════════════════════════════════════ -->
                @if (VisibleDates.Count == 0)
                {
                    <div class="empty-state">Apply a sprint date range to see the calendar.</div>
                }
                else
                {
                    <div class="cal-toolbar">
                        <div class="cal-legend">
                            @if (_colorMode == "type")
                            {
                                <span class="lg-item"><span class="lg-dot" style="background:#2563eb"></span>Story</span>
                                <span class="lg-item"><span class="lg-dot" style="background:#0d9488"></span>Task</span>
                                <span class="lg-item"><span class="lg-dot" style="background:#7c3aed"></span>Bug</span>
                                <span class="lg-item"><span class="lg-dot" style="background:#64748b"></span>Custom</span>
                            }
                            else
                            {
                                <span class="lg-item">Coloured by epic</span>
                            }
                            <span class="lg-sep"></span>
                            <span class="lg-item"><span class="lg-dot lg-over"></span>Over capacity</span>
                        </div>
                        <div class="cal-toolbar-controls">
                            <div class="seg-toggle" title="Colour calendar blocks by">
                                <button class="seg-btn @(_colorMode == "type" ? "seg-on" : "")" @onclick='() => _colorMode = "type"'>Type</button>
                                <button class="seg-btn @(_colorMode == "epic" ? "seg-on" : "")" @onclick='() => _colorMode = "epic"'>Epic</button>
                            </div>
                            <div class="seg-toggle" title="Row density">
                                <button class="seg-btn @(_density == "comfortable" ? "seg-on" : "")" @onclick='() => _density = "comfortable"'>Comfortable</button>
                                <button class="seg-btn @(_density == "compact" ? "seg-on" : "")" @onclick='() => _density = "compact"'>Compact</button>
                            </div>
                            <button class="btn small cal-fullpage-btn"
                                    @onclick="() => _calendarFullPage = !_calendarFullPage"
                                    title="@(_calendarFullPage ? "Exit full page" : "Expand calendar to full page")">
                                @(_calendarFullPage ? "⊡ Exit Full Page" : "⛶ Full Page")
                            </button>
                        </div>
                    </div>
                    <div class="cal-scroll">
                        <table class="cal-table">
                            <colgroup>
                                <col class="col-member" />
                                @foreach (var d in VisibleDates)
                                {
                                    <col class="col-date" />
                                }
                            </colgroup>
                            <thead>
                                <tr>
                                    <th class="cal-sticky-col cal-head-member">
                                        <div>Team Member</div>
                                        <div class="cal-head-sub">Sprint capacity</div>
                                    </th>
                                    @foreach (var d in VisibleDates)
                                    {
                                        var dateCol = d;
                                        var isToday = dateCol == DateOnly.FromDateTime(DateTime.Today);
                                        var isHolCol = IsHoliday(dateCol);
                                        var isWeCol = IsWeekend(dateCol);
                                        <th class="cal-date-th @(isToday ? "col-today" : "") @(isWeCol ? "col-we" : "") @(isHolCol ? "col-holiday" : "")"
                                            title="@GetDateColTitle(dateCol)"
                                            @onclick="() => OnDateHeaderClicked(dateCol)">
                                            <div class="cal-th-day">@dateCol.ToString("ddd", CultureInfo.InvariantCulture)</div>
                                            <div class="cal-th-date">@dateCol.ToString("dd", CultureInfo.InvariantCulture)</div>
                                            <div class="cal-th-mon">@dateCol.ToString("MMM", CultureInfo.InvariantCulture)</div>
                                            @if (isToday) { <div class="today-dot"></div> }
                                            @if (isHolCol) { <div class="hol-badge">H</div> }
                                        </th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var teamGroup in GetFilteredMembersByTeam())
                                {
                                    var teamName = teamGroup.Key;
                                    var teamAllocated = GetTeamAllocatedHours(teamName);
                                    var teamCapacity = GetTeamCapacityHours(teamName);
                                    <tr class="cal-team-row">
                                        <td class="cal-sticky-col cal-team-label" colspan="@(VisibleDates.Count + 1)">
                                            @teamName
                                            <span class="cal-team-stat">@($"{teamAllocated:0.#}h / {teamCapacity:0.#}h")</span>
                                        </td>
                                    </tr>

                                    @foreach (var member in teamGroup)
                                    {
                                        var mem = member;
                                        var lanedBlocks = GetLanedBlocks(mem.Id);
                                        var maxLanes = GetMaxLanes(mem.Id);
                                        var laneH    = _density == "compact" ? 24 : 34;
                                        var topBase  = _density == "compact" ? 18 : 24;
                                        var rowBase  = _density == "compact" ? 50 : 72;
                                        var rowExtra = _density == "compact" ? 28 : 38;
                                        var rowHeight = Math.Max(rowBase, maxLanes * laneH + rowExtra);
                                        var mCap = GetMemberSprintCapacity(mem.Id);
                                        var mAlloc = GetMemberSprintAllocated(mem.Id);
                                        var mPct = mCap > 0m ? (double)(mAlloc / mCap * 100m) : 0.0;
                                        var loadCls = GetCapacityLoadClass(mPct);
                                        var isFormer = IsFormerMember(mem.Id);

                                        <tr style="height:@(rowHeight)px;">
                                            <td class="cal-sticky-col cal-member-cell">
                                                <div class="cal-member-name">
                                                    @mem.Name
                                                    @if (isFormer) { <span class="former-tag" title="Not in the active roster — kept for this plan">former</span> }
                                                </div>
                                                <div class="cal-member-alloc">
                                                    @($"{mAlloc:0.#}h / {mCap:0.#}h")
                                                    <span class="cal-member-pct @loadCls">@($"{mPct:0}%")</span>
                                                </div>
                                                <div class="cal-member-bar-wrap">
                                                    <div class="cal-member-bar @loadCls" style="width:@(Math.Min(mPct, 100).ToString("F1", CultureInfo.InvariantCulture))%;"></div>
                                                </div>
                                            </td>

                                            @for (int ci = 0; ci < VisibleDates.Count; ci++)
                                            {
                                                var currentDate = VisibleDates[ci];
                                                var cellBlocks = lanedBlocks
                                                    .Where(lb => GetBlockFirstVisibleDate(lb.Block) == currentDate)
                                                    .ToList();
                                                var allocated = GetAllocatedHours(mem.Id, currentDate);
                                                var isWe = IsWeekend(currentDate);
                                                var isMemberOff = IsMemberTimeOff(mem.Id, currentDate);
                                                var isHolDay = IsHoliday(currentDate);
                                                var isDayOff = isMemberOff || isHolDay;
                                                var isToday = currentDate == DateOnly.FromDateTime(DateTime.Today);
                                                var dailyCap = GetMemberDailyHours(mem.Id);
                                                var cellCls = BuildCellClass(mem.Id, allocated, isDayOff, isWe, isToday);
                                                var usagePct = dailyCap > 0m ? (allocated / dailyCap) * 100m : 0m;

                                                <td class="@cellCls"
                                                    title="@BuildCellTitle(mem.Id, currentDate, allocated, isDayOff, isHolDay)"
                                                    @onclick="() => OnCalendarCellClicked(mem.Id, currentDate)"
                                                    @ondragover:preventDefault="true"
                                                    @ondrop="() => OnCellDrop(mem.Id, currentDate)">

                                                    @if (isDayOff && !isWe)
                                                    {
                                                        <div class="cell-off-label">@(isHolDay ? "hol" : "off")</div>
                                                    }
                                                    @if (allocated > 0m && !isDayOff)
                                                    {
                                                        <div class="cell-usage-bar" style="height:@(Math.Min(usagePct,100m).ToString("F1", CultureInfo.InvariantCulture))%;"></div>
                                                        <div class="cell-hours-label @(allocated > dailyCap ? "over" : "")">@($"{allocated:0.#}h")</div>
                                                    }

                                                    @foreach (var (block, lane) in cellBlocks)
                                                    {
                                                        var blk = block;
                                                        var blkLane = lane;
                                                        var span = GetBlockVisibleSpanSprint(blk);
                                                        var topOff = blkLane * laneH + topBase;
                                                        var wPct = span * 100;
                                                        var blkHours = GetBlockHoursOnDate(blk, currentDate);

                                                        <div class="stacked-block @(_density == "compact" ? "block-compact" : "")"
                                                             draggable="true"
                                                             @ondragstart="() => OnBlockDragStart(blk.GroupId)"
                                                             style="top:@(topOff)px; width:calc(@(wPct)% - 6px); background:@GetBlockColor(blk.TaskId);"
                                                             title="@GetBlockTooltip(blk) — click for details, drag to move"
                                                             @onclick="() => ShowTaskDetails(blk.TaskId)"
                                                             @onclick:stopPropagation="true">
                                                            <div class="stacked-block-content">
                                                                <span class="stacked-block-title">@GetTaskShortLabel(blk.TaskId)</span>
                                                            </div>
                                                            <button class="btn-remove" @onclick="() => RemoveBlock(blk.GroupId)" @onclick:stopPropagation="true">✕</button>
                                                        </div>
                                                    }
                                                </td>
                                            }
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                }
            }
        </div>
    </div>

    @if (_showOverCapacityDialog && _overCapacityPending is not null)
    {
        <div class="modal-backdrop" @onclick="CancelOverCapacity"></div>
        <div class="modal-dialog">
            <div class="modal-title">Over Capacity Warning</div>
            <p class="modal-body">
                Adding <strong>@_overCapacityPending.TaskLabel</strong> to
                <strong>@_overCapacityPending.MemberName</strong> exceeds the
                @GetMemberDailyHours(_overCapacityPending.MemberId).ToString("0.#") h/day limit — not enough free capacity from
                @($"{_overCapacityPending.StartDate:dd-MMM}").
                <br />Schedule anyway (days may exceed the limit)?
            </p>
            <div class="modal-actions">
                <button class="btn primary" @onclick="ConfirmOverCapacity">Yes, schedule anyway</button>
                <button class="btn" @onclick="CancelOverCapacity">No, cancel</button>
            </div>
        </div>
    }

    @if (_showNoEstimateDialog && _noEstimatePending is not null)
    {
        <div class="modal-backdrop" @onclick="CancelNoEstimate"></div>
        <div class="modal-dialog">
            <div class="modal-title">No Estimate — Enter Hours</div>
            <p class="modal-body">
                <strong>@_noEstimatePending.TaskLabel</strong> has no estimate.
                How many hours should be scheduled for <strong>@_noEstimatePending.MemberName</strong>
                from <strong>@($"{_noEstimatePending.StartDate:dd-MMM}")</strong>?
            </p>
            <input class="modal-hours-input"
                   type="number" min="0.5" step="0.5"
                   placeholder="e.g. 4"
                   @bind="_noEstimateHoursInput"
                   @onkeydown="@(async e => { if (e.Key == "Enter") ConfirmNoEstimate(); })" />
            @if (_noEstimateError is not null)
            {
                <p class="modal-error">@_noEstimateError</p>
            }
            <div class="modal-actions">
                <button class="btn primary" @onclick="ConfirmNoEstimate">Schedule</button>
                <button class="btn" @onclick="CancelNoEstimate">Cancel</button>
            </div>
        </div>
    }

    @if (_showRemovalDialog)
    {
        <div class="modal-backdrop" @onclick="CancelRemoval"></div>
        <div class="modal-dialog">
            <div class="modal-title">Remove Assignment</div>
            <p class="modal-body">
                Remove <strong>@_removalPendingTaskLabel</strong> from
                <strong>@_removalPendingMemberName</strong>?
            </p>
            <textarea class="modal-reason-input"
                      placeholder="Reason for removal (optional)"
                      @bind="_removalReason"
                      rows="3"></textarea>
            <div class="modal-actions">
                <button class="btn danger" @onclick="ConfirmRemovalAsync">Remove</button>
                <button class="btn" @onclick="CancelRemoval">Cancel</button>
            </div>
        </div>
    }

    @if (_showRemovalLogsDialog)
    {
        <div class="modal-backdrop" @onclick="CloseRemovalLogs"></div>
        <div class="modal-dialog modal-dialog-lg">
            <div class="modal-header-row">
                <span class="modal-title">Removal Log — @SprintName</span>
                <button class="modal-close-btn" @onclick="CloseRemovalLogs">✕</button>
            </div>
            @if (_isLoadingLogs)
            {
                <p class="modal-body">Loading…</p>
            }
            else if (_removalLogs.Count == 0)
            {
                <p class="modal-body">No removals logged for this sprint plan.</p>
            }
            else
            {
                <div class="removal-logs-wrap">
                    <table class="removal-logs-table">
                        <thead>
                            <tr>
                                <th>Removed At</th>
                                <th>Task</th>
                                <th>Member</th>
                                <th>Reason</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in _removalLogs)
                            {
                                <tr>
                                    <td class="rl-date">@log.RemovedAt.ToString("dd-MMM HH:mm")</td>
                                    <td class="rl-task">@log.TaskLabel</td>
                                    <td class="rl-member">@log.MemberName</td>
                                    <td class="rl-reason">@(string.IsNullOrWhiteSpace(log.Reason) ? "—" : log.Reason)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            <div class="modal-actions">
                <button class="btn" @onclick="CloseRemovalLogs">Close</button>
            </div>
        </div>
    }

    @if (_teamLoadDetail is not null)
    {
        var tlTeam  = _teamLoadDetail;
        var tlCap   = GetTeamCapacityHours(tlTeam);
        var tlAlloc = GetTeamAllocatedHours(tlTeam);
        var tlPct   = tlCap > 0m ? (double)(tlAlloc / tlCap * 100m) : 0.0;
        var tlRows  = GetTeamTaskBreakdown(tlTeam);
        <div class="modal-backdrop" @onclick="CloseTeamLoadDetail"></div>
        <div class="modal-dialog modal-dialog-lg">
            <div class="modal-header-row">
                <span class="modal-title">@tlTeam — Load Breakdown</span>
                <button class="modal-close-btn" @onclick="CloseTeamLoadDetail">✕</button>
            </div>
            <div class="tld-summary @GetCapacityLoadClass(tlPct)">
                <span class="tld-summary-pct">@($"{tlPct:0}%")</span>
                <span class="tld-summary-hrs">@($"{tlAlloc:0.#}h allocated of {tlCap:0.#}h capacity") · @GetTeamMemberCount(tlTeam) ppl</span>
            </div>
            @if (tlRows.Count == 0)
            {
                <p class="modal-body">No work allocated to this team in the current sprint window.</p>
            }
            else
            {
                <div class="removal-logs-wrap">
                    <table class="removal-logs-table tld-table">
                        <thead>
                            <tr>
                                <th>Task</th>
                                <th class="tld-num">Hours</th>
                                <th class="tld-num">% of capacity</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in tlRows)
                            {
                                var rowPct = tlCap > 0m ? (double)(r.Hours / tlCap * 100m) : 0.0;
                                <tr>
                                    <td class="rl-task">
                                        <span class="tld-type-dot @(r.IsCustom ? "tld-dot-custom" : "tld-dot-jira")"></span>
                                        @r.Label
                                    </td>
                                    <td class="tld-num">@($"{r.Hours:0.#}h")</td>
                                    <td class="tld-num">@($"{rowPct:0.#}%")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            <div class="modal-actions">
                <button class="btn" @onclick="CloseTeamLoadDetail">Close</button>
            </div>
        </div>
    }

    @if (_supportBugDetail)
    {
        var sbTotal = SupportBugAllocatedHours;
        var sbAvg   = _bugAvgHours > 0m ? _bugAvgHours : 5m;
        var sbTeams = GetAllTeams()
            .Select(t => new { Team = t, Hours = GetTeamSupportBugHours(t) })
            .Where(x => x.Hours > 0m)
            .OrderByDescending(x => x.Hours)
            .ToList();
        // QA only validates support bugs — it doesn't fix them — so QA hours are
        // excluded from the "tickets solvable" estimate (still shown as allocated).
        var sbSolvableHours   = sbTeams.Where(x => !IsQaTeam(x.Team)).Sum(x => x.Hours);
        var sbSolvableTickets = sbAvg > 0m ? sbSolvableHours / sbAvg : 0m;
        <div class="modal-backdrop" @onclick="CloseSupportBugDetail"></div>
        <div class="modal-dialog modal-dialog-lg">
            <div class="modal-header-row">
                <span class="modal-title">Support Bug Allocation — Team Split</span>
                <button class="modal-close-btn" @onclick="CloseSupportBugDetail">✕</button>
            </div>
            <div class="tld-summary">
                <span class="tld-summary-pct">@($"{sbTotal:0.#}h")</span>
                <span class="tld-summary-hrs">allocated to support bugs this sprint · ≈ @($"{sbSolvableTickets:0.#}") solvable tickets at @($"{sbAvg:0.#}h")/bug <span class="sb-qa-note">(QA hours excluded — QA validates, doesn't fix)</span></span>
            </div>
            <div class="sb-avg-row">
                <label class="sb-avg-label">Avg hours per bug</label>
                <input type="number" min="0.5" step="0.5" class="input sb-avg-input"
                       @bind="_bugAvgHours" @bind:event="oninput" />
                <span class="sb-avg-hint">tickets solvable = dev/team hours ÷ avg (QA excluded)</span>
            </div>
            @if (sbTeams.Count == 0)
            {
                <p class="modal-body">No support-bug hours allocated to any team in the current sprint window.</p>
            }
            else
            {
                <div class="removal-logs-wrap">
                    <table class="removal-logs-table tld-table">
                        <thead>
                            <tr>
                                <th>Team</th>
                                <th class="tld-num">Hours</th>
                                <th class="tld-num">% of support bugs</th>
                                <th class="tld-num">Tickets @@ @($"{sbAvg:0.#}h")</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in sbTeams)
                            {
                                var rowPct  = sbTotal > 0m ? (double)(row.Hours / sbTotal * 100m) : 0.0;
                                var tickets = sbAvg > 0m ? row.Hours / sbAvg : 0m;
                                <tr>
                                    <td class="rl-task">
                                        <span class="tld-type-dot tld-dot-custom"></span>
                                        @row.Team
                                    </td>
                                    <td class="tld-num">@($"{row.Hours:0.#}h")</td>
                                    <td class="tld-num">@($"{rowPct:0.#}%")</td>
                                    <td class="tld-num">@(IsQaTeam(row.Team) ? "— validates" : $"{tickets:0.#}")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="sb-total-row">
                                <td>Total</td>
                                <td class="tld-num">@($"{sbTotal:0.#}h")</td>
                                <td class="tld-num">100%</td>
                                <td class="tld-num">@($"{sbSolvableTickets:0.#}")</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }
            <div class="modal-actions">
                <button class="btn" @onclick="CloseSupportBugDetail">Close</button>
            </div>
        </div>
    }

    @if (_detailTaskId.HasValue)
    {
