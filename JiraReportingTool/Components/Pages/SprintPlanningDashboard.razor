    // CSS class builders
    // ───────────────────────────────────────────────────────────
    private string BuildCellClass(decimal allocated, bool isDayOff, bool isWeekend, bool isToday)
    {
        if (isDayOff) return isWeekend ? "cell stacked-cell weekend-cell" : "cell stacked-cell cell-dayoff";
        var baseClass = "cell stacked-cell";
        if (isToday) baseClass += " cell-today";
        else if (allocated >= MaxHoursPerDay) baseClass += " cell-full";
        else if (allocated > 0m) baseClass += " cell-partial";
        return baseClass;
    }

    private string BuildCellTitle(Guid memberId, DateOnly date, decimal allocated, bool isDayOff, bool isHoliday)
    {
        if (TimeOffMode)
        {
            var isOff = IsMemberTimeOff(memberId, date);
            return isOff ? $"Click to remove time off: {date:dd-MMM}" : $"Click to mark time off: {date:dd-MMM}";
        }
        if (isDayOff) return isHoliday ? "Holiday — no capacity" : "Time off — no capacity";
        var remaining = Math.Max(0m, MaxHoursPerDay - allocated);
        return $"{allocated:0.#}h allocated · {remaining:0.#}h remaining";
    }

    private string GetDateColTitle(DateOnly date)
    {
        if (!TimeOffMode) return date.ToString("dddd, dd MMM yyyy");
        return IsHoliday(date) ? $"Click to remove holiday: {date:dd-MMM}" : $"Click to mark as holiday: {date:dd-MMM}";
    }

    private string GetCoverageCardClass()
        => CoveragePercent >= 80 ? "stat-green" : CoveragePercent >= 50 ? "stat-amber" : "stat-red";

    private string GetCapacityBarClass(double pct) => pct switch
    {
        >= 100 => "bar-over",
        >= 80  => "bar-high",
        >= 50  => "bar-mid",
        _      => "bar-low"
    };

    // ───────────────────────────────────────────────────────────
    // Task label helpers
    // ───────────────────────────────────────────────────────────
    private string GetTaskLabel(int taskId)
    {
        if (_customTasks.TryGetValue(taskId, out var ct)) return $"{ct.Category}: {ct.Name} ({ct.Hours}h)";
        if (!_taskCache.TryGetValue(taskId, out var t))
            return _taskLabelFallback.TryGetValue(taskId, out var fb) ? fb : $"Task #{taskId}";
        return $"{t.Key} - {t.Summary} (Est: {t.OriginalEstimate})";
    }

    private string GetTaskShortLabel(int taskId)
    {
        if (_customTasks.TryGetValue(taskId, out var ct))
        {
            var n = ct.Name.Length > 22 ? ct.Name[..22] + "…" : ct.Name;
            return $"{ct.Category}: {n}";
        }
        if (!_taskCache.TryGetValue(taskId, out var t))
        {
            if (!_taskLabelFallback.TryGetValue(taskId, out var fb)) return $"#{taskId}";
            // Stored format: "KEY - SUMMARY (Est: X)" — extract key and summary for short display.
            var sepIdx = fb.IndexOf(" - ", StringComparison.Ordinal);
            if (sepIdx > 0)
            {
                var key  = fb[..sepIdx];
                var rest = fb[(sepIdx + 3)..];
                var estIdx = rest.LastIndexOf(" (Est:", StringComparison.Ordinal);
                var summary = estIdx > 0 ? rest[..estIdx] : rest;
                summary = summary.Length > 28 ? summary[..28] + "…" : summary;
                return $"{key}: {summary}";
            }
            return fb.Length > 28 ? fb[..28] + "…" : fb;
        }
        var s = t.Summary?.Length > 28 ? t.Summary[..28] + "…" : t.Summary ?? "";
        return $"{t.Key}: {s}";
    }

    private string GetTaskKeyFromCache(int taskId)
    {
        if (_customTasks.TryGetValue(taskId, out var ct)) return ct.Category;
        if (_taskCache.TryGetValue(taskId, out var t)) return t.Key;
        if (_taskLabelFallback.TryGetValue(taskId, out var fb))
        {
            var sepIdx = fb.IndexOf(" - ", StringComparison.Ordinal);
            return sepIdx > 0 ? fb[..sepIdx] : fb;
        }
        return $"#{taskId}";
    }

    private string GetTaskSummaryShort(int taskId)
    {
        if (_customTasks.TryGetValue(taskId, out var ct))
            return ct.Name.Length > 40 ? ct.Name[..40] + "…" : ct.Name;
        if (!_taskCache.TryGetValue(taskId, out var t))
        {
            if (!_taskLabelFallback.TryGetValue(taskId, out var fb)) return "Unknown task";
            var sepIdx = fb.IndexOf(" - ", StringComparison.Ordinal);
            if (sepIdx > 0)
            {
                var rest   = fb[(sepIdx + 3)..];
                var estIdx = rest.LastIndexOf(" (Est:", StringComparison.Ordinal);
                var summary = estIdx > 0 ? rest[..estIdx] : rest;
                return summary.Length > 40 ? summary[..40] + "…" : summary;
            }
            return fb.Length > 40 ? fb[..40] + "…" : fb;
        }
        return t.Summary?.Length > 40 ? t.Summary[..40] + "…" : t.Summary ?? "";
    }

    private SprintIssue? FindTask(int taskId)
        => _taskCache.TryGetValue(taskId, out var t) ? t : null;

    // ───────────────────────────────────────────────────────────
    // Task grouping
    // ───────────────────────────────────────────────────────────
    private IEnumerable<IGrouping<string, SprintIssue>> GetTasksGroupedByStatus(List<SprintIssue> tasks)
        => tasks
            .GroupBy(t => (t.StatusCategoryKey ?? "new").ToLower())
            .OrderBy(g => g.Key switch
            {
                "indeterminate" => 0,
                "new"           => 1,
                "done"          => 2,
                _               => 99
            });

    private static string GetStatusGroupLabel(string statusKey) => statusKey switch
    {
        "indeterminate" => "In Progress",
        "new"           => "To Do",
        "done"          => "Done",
        _               => statusKey
    };

    // ───────────────────────────────────────────────────────────
    // Estimate parsing
    // ───────────────────────────────────────────────────────────
    private static string FormatEstimateHours(string? jiraEstimate)
    {
        var h = ParseJiraDurationToHours(jiraEstimate);
        if (h <= 0m) return "-";
        var r = h % 1m == 0m ? decimal.Round(h, 0) : decimal.Round(h, 1);
        return $"{r.ToString(CultureInfo.InvariantCulture)}h";
    }

    /// <summary>
    /// Dev Ready → use original estimate (task not started, full scope counts).
    /// Any other status → use remaining effort (max(0, original − spent)).
    /// </summary>
    private static decimal GetTaskHours(SprintIssue t)
    {
        bool isDevReady = string.Equals(t.Status, "Dev Ready", StringComparison.OrdinalIgnoreCase);
        if (isDevReady)
            return ParseJiraDurationToHours(t.OriginalEstimate);
        var remSec = Math.Max(0, t.OriginalEstimateSeconds - t.TimeSpentSeconds);
        return remSec / 3600m;
    }

    private static string FormatTaskHours(SprintIssue t)
    {
        var h = GetTaskHours(t);
        if (h <= 0m) return "-";
        var r = h % 1m == 0m ? decimal.Round(h, 0) : decimal.Round(h, 1);
        return $"{r.ToString(CultureInfo.InvariantCulture)}h";
    }

private static decimal ParseJiraDurationToHours(string? input)
    {
        if (string.IsNullOrWhiteSpace(input) || input.Trim() == "-") return 0m;
        var matches = Regex.Matches(input, @"(\d+(?:[.,]\d+)?)\s*([wdhm])", RegexOptions.IgnoreCase);
        if (matches.Count == 0) return 0m;
        decimal total = 0m;
        foreach (Match m in matches)
        {
            var num = m.Groups[1].Value.Replace(',', '.');
            if (!decimal.TryParse(num, NumberStyles.Number, CultureInfo.InvariantCulture, out var v)) continue;
            switch (char.ToLowerInvariant(m.Groups[2].Value[0]))
            {
                case 'w': total += v * DaysPerWeek * HoursPerDay; break;
                case 'd': total += v * HoursPerDay; break;
                case 'h': total += v; break;
                case 'm': total += v / 60m; break;
            }
        }
        return total;
    }

    // ───────────────────────────────────────────────────────────
    // Excel Export
    // ───────────────────────────────────────────────────────────
    private async Task ExportToExcel()
    {
        ErrorMessage = null;
        InfoMessage = null;
        try
        {
            using var wb = new XLWorkbook();

            // ── Sheet 1: Sprint Summary ──
            var summary = wb.Worksheets.Add("Sprint Summary");
            summary.Cell(1, 1).Value = "Sprint";          summary.Cell(1, 2).Value = SprintName;
            summary.Cell(2, 1).Value = "Start";           summary.Cell(2, 2).Value = SprintStart.ToString("dd-MMM-yyyy");
            summary.Cell(3, 1).Value = "End";             summary.Cell(3, 2).Value = SprintEnd.ToString("dd-MMM-yyyy");
            summary.Cell(4, 1).Value = "Working Days";    summary.Cell(4, 2).Value = WorkingDaysCount;
            summary.Cell(5, 1).Value = "Total Tasks";     summary.Cell(5, 2).Value = TotalTaskCount;
            summary.Cell(6, 1).Value = "Assigned";        summary.Cell(6, 2).Value = AssignedCount;
            summary.Cell(7, 1).Value = "Unassigned";      summary.Cell(7, 2).Value = UnassignedCount;
            summary.Cell(8, 1).Value = "Scope Hours";     summary.Cell(8, 2).Value = (double)TotalScopeHours;
            summary.Cell(9, 1).Value = "Allocated Hours"; summary.Cell(9, 2).Value = (double)TotalAllocatedHours;
            summary.Cell(10, 1).Value = "Coverage %";    summary.Cell(10, 2).Value = (double)CoveragePercent;
            summary.Columns().AdjustToContents();

            // ── Sheet 2: Assignments ──
            var sheet = wb.Worksheets.Add("Assignments");
            var headers = new[] { "Epic", "Task Key", "Summary", "Team", "Assigned To", "From", "To", "Hours" };
            for (int c = 0; c < headers.Length; c++)
            {
                var cell = sheet.Cell(1, c + 1);
                cell.Value = headers[c];
                cell.Style.Font.Bold = true;
                cell.Style.Fill.BackgroundColor = XLColor.FromHtml("#EEF2FF");
                cell.Style.Font.FontColor = XLColor.FromHtml("#4338CA");
            }

            var groups = Allocations
                .Where(a => a.Date >= SprintStart && a.Date <= SprintEnd)
                .GroupBy(a => (a.TeamMemberId, a.GroupId))
                .Select(g => new
                {
                    TaskId = g.First().TaskId, TeamMemberId = g.Key.TeamMemberId,
                    From = g.Min(a => a.Date), To = g.Max(a => a.Date),
                    TotalHours = g.Sum(a => a.HoursAllocated)
                })
                .OrderBy(a => TeamMembers.FirstOrDefault(x => x.Id == a.TeamMemberId)?.Team ?? "")
                .ThenBy(a => TeamMembers.FirstOrDefault(x => x.Id == a.TeamMemberId)?.Name ?? "")
                .ThenBy(a => a.From)
                .ToList();

            for (int i = 0; i < groups.Count; i++)
            {
                var a      = groups[i];
                var row    = i + 2;
                var task   = FindTask(a.TaskId);
                var member = TeamMembers.FirstOrDefault(x => x.Id == a.TeamMemberId);
                var epicK  = LoadedEpics.Values.FirstOrDefault(e => e.Tasks.Any(t => t.Id == a.TaskId))?.EpicKey ?? "-";
                sheet.Cell(row, 1).Value = epicK;
                sheet.Cell(row, 2).Value = task?.Key ?? "-";
                sheet.Cell(row, 3).Value = task?.Summary ?? "-";
                sheet.Cell(row, 4).Value = member?.Team ?? "-";
                sheet.Cell(row, 5).Value = member?.Name ?? "-";
                sheet.Cell(row, 6).Value = a.From.ToString("dd-MMM-yyyy");
                sheet.Cell(row, 7).Value = a.To.ToString("dd-MMM-yyyy");
                sheet.Cell(row, 8).Value = (double)a.TotalHours;
            }
            sheet.Columns().AdjustToContents();
            sheet.Column(3).Width = 50;

            // ── Sheet 3: Calendar ──
            var cal = wb.Worksheets.Add("Calendar");

            // Header row: "Member" + one column per visible date
            cal.Cell(1, 1).Value = "Member";
            cal.Cell(1, 1).Style.Font.Bold = true;
            for (int d = 0; d < VisibleDates.Count; d++)
            {
                var hdr = cal.Cell(1, d + 2);
                hdr.Value = VisibleDates[d].ToString("ddd dd-MMM");
                hdr.Style.Font.Bold = true;
                hdr.Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;
                if (IsWeekend(VisibleDates[d]))
                    hdr.Style.Fill.BackgroundColor = XLColor.LightGray;
                else
                    hdr.Style.Fill.BackgroundColor = XLColor.FromHtml("#EEF2FF");
            }

            // One row per team member
            var calMembers = string.IsNullOrEmpty(ActiveTeamFilter)
                ? TeamMembers
                : TeamMembers.Where(m => m.Team == ActiveTeamFilter).ToList();

            for (int r = 0; r < calMembers.Count; r++)
            {
                var member = calMembers[r];
                var rowIdx = r + 2;
                var nameCell = cal.Cell(rowIdx, 1);
                nameCell.Value = $"{member.Name} ({member.Team})";
                nameCell.Style.Font.Bold = true;

                for (int d = 0; d < VisibleDates.Count; d++)
                {
                    var date = VisibleDates[d];
                    var cell = cal.Cell(rowIdx, d + 2);

                    if (IsMemberTimeOff(member.Id, date) || IsHoliday(date))
                    {
                        cell.Value = IsHoliday(date) ? "Holiday" : "Time Off";
                        cell.Style.Fill.BackgroundColor = XLColor.LightYellow;
                        cell.Style.Font.Italic = true;
                        continue;
                    }
                    if (IsWeekend(date))
                    {
                        cell.Style.Fill.BackgroundColor = XLColor.LightGray;
                        continue;
                    }

                    var dayAllocs = Allocations
                        .Where(a => a.TeamMemberId == member.Id && a.Date == date)
                        .ToList();

                    if (dayAllocs.Count > 0)
                    {
                        var parts = dayAllocs
                            .GroupBy(a => a.TaskId)
                            .Select(g =>
                            {
                                var lbl = GetTaskShortLabel(g.Key);
                                var hrs = g.Sum(a => a.HoursAllocated);
                                return $"{lbl} ({hrs:0.#}h)";
                            });
                        cell.Value = string.Join(" | ", parts);
                        cell.Style.Fill.BackgroundColor = XLColor.FromHtml("#DBEAFE");
                    }
                }
            }

            cal.Row(1).Height = 30;
            cal.Column(1).Width = 22;
            for (int d = 0; d < VisibleDates.Count; d++)
                cal.Column(d + 2).Width = 28;
            cal.Rows().Style.Alignment.WrapText = false;

            // ── Stream to download ──
            using var ms     = new System.IO.MemoryStream();
            wb.SaveAs(ms);
            var base64   = Convert.ToBase64String(ms.ToArray());
            var fileName = $"SprintPlanning_{(string.IsNullOrWhiteSpace(SprintName) ? "Export" : SprintName.Replace(" ", "_"))}_{DateTime.Now:yyyyMMdd}.xlsx";
            const string mime = "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet";
            await JS.InvokeVoidAsync("downloadBase64File", base64, fileName, mime);
            InfoMessage = $"Exported {groups.Count} assignment(s) to {fileName}.";
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Export failed: {ex.Message}";
        }
    }
    private static string GetStatusType(string? issueType)
    {
        return issueType?.ToLowerInvariant() switch
        {
            "task" => "type-task",
            "bug" => "type-bug",
            _ => "type-default"
        };
    }
    private static string GetStatusClass(string? status)
    {
        return status?.ToLowerInvariant() switch
        {
            "dev ready" => "status-dev-ready",
            "in progress" => "status-in-progress",
            "in review" => "status-in-review",
            "qa ready" => "status-qa-ready",
            "done" => "status-done",
            "on hold" => "status-on-hold",
            _ => "status-default"
        };
    }
}

