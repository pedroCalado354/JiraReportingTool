    private void ToggleTimeOffMode()
    {
        TimeOffMode = !TimeOffMode;
        InfoMessage = TimeOffMode
            ? "Time Off Mode ON — click cells to mark time off; click date headers to mark holidays."
            : "Time Off Mode OFF.";
    }

    // A day is a holiday if it's in this plan's holidays OR the shared (bank) holiday list.
    private bool IsHoliday(DateOnly date) => Holidays.Contains(date) || _sharedHolidaySet.Contains(date);
    private HashSet<DateOnly> _sharedHolidaySet = new();

    private bool IsMemberTimeOff(Guid memberId, DateOnly date)
        => MemberTimeOff.TryGetValue(memberId, out var days) && days.Contains(date);

    private bool IsDayOff(Guid memberId, DateOnly date)
        => IsWeekend(date) || IsHoliday(date) || IsMemberTimeOff(memberId, date);

    private void ToggleHoliday(DateOnly date)
    {
        if (Holidays.Contains(date)) Holidays.Remove(date);
        else Holidays.Add(date);
        InfoMessage = Holidays.Contains(date)
            ? $"{date:dd-MMM} marked as holiday."
            : $"{date:dd-MMM} holiday removed.";
    }

    private void ToggleMemberTimeOff(Guid memberId, DateOnly date)
    {
        if (!MemberTimeOff.ContainsKey(memberId))
            MemberTimeOff[memberId] = new HashSet<DateOnly>();

        var name = TeamMembers.FirstOrDefault(m => m.Id == memberId)?.Name ?? "Member";
        if (MemberTimeOff[memberId].Contains(date))
        {
            MemberTimeOff[memberId].Remove(date);
            InfoMessage = $"Removed time off for {name} on {date:dd-MMM}.";
        }
        else
        {
            MemberTimeOff[memberId].Add(date);
            InfoMessage = $"Marked {name} as off on {date:dd-MMM}.";
        }
    }

    private void OnDateHeaderClicked(DateOnly date)
    {
        if (TimeOffMode) ToggleHoliday(date);
    }

    private static bool IsWeekend(DateOnly date)
        => date.DayOfWeek == DayOfWeek.Saturday || date.DayOfWeek == DayOfWeek.Sunday;

    // ───────────────────────────────────────────────────────────
    // Calendar cell click
    // ───────────────────────────────────────────────────────────
    private void OnCalendarCellClicked(Guid memberId, DateOnly date)
    {
        ErrorMessage = null;
        InfoMessage = null;

        if (TimeOffMode)
        {
            ToggleMemberTimeOff(memberId, date);
            return;
        }

        // Resolve selected task info (Jira task OR custom task)
        int? activeTaskId   = SelectedTask?.Id ?? SelectedCustomTaskId;
        decimal totalHoursResolved;
        string taskLabel;

        if (SelectedTask is not null)
        {
            totalHoursResolved = GetTaskHours(SelectedTask);
            taskLabel = SelectedTask.Key;
        }
        else if (SelectedCustomTaskId.HasValue && _customTasks.TryGetValue(SelectedCustomTaskId.Value, out var selCt))
        {
            totalHoursResolved = selCt.Hours;
            taskLabel = selCt.Name;
        }
        else
        {
            ErrorMessage = "Select a task first.";
            return;
        }

        if (PendingPlacement is null)
        {
            PendingPlacement = new PendingPlacementState { TeamMemberId = memberId, Start = date };
            return;
        }

        if (PendingPlacement.TeamMemberId != memberId)
        {
            ErrorMessage = "Second click must be on the same member row.";
            return;
        }

        var startDate = date < PendingPlacement.Start ? date : PendingPlacement.Start;

        if (totalHoursResolved <= 0m)
        {
            var memberName2 = TeamMembers.First(x => x.Id == memberId).Name;
            _noEstimatePending    = new NoEstimatePending(activeTaskId!.Value, memberId, startDate, taskLabel, memberName2);
            _noEstimateHoursInput = "";
            _noEstimateError      = null;
            _showNoEstimateDialog = true;
            PendingPlacement      = null;
            return;
        }

        // Custom tasks are repeatable work-type templates (e.g. "Planned Issues / 6h"):
        // every drop schedules the full hours as its own independent block, so a member can
        // accumulate as many of them as needed and the same task can go on any number of
        // members. Jira tasks share one fixed estimate across the team, so they stay capped to
        // their remaining estimate (a 30h ticket can't end up as 2×30h on the calendar).
        var isCustomActive = _customTasks.ContainsKey(activeTaskId!.Value);
        decimal alreadyAllocated;
        decimal remainingToSchedule;
        if (isCustomActive)
        {
            alreadyAllocated    = 0m;
            remainingToSchedule = totalHoursResolved;
        }
        else
        {
            alreadyAllocated    = AllocatedForTask(activeTaskId.Value);
            remainingToSchedule = totalHoursResolved - alreadyAllocated;
            if (remainingToSchedule <= 0m)
            {
                ErrorMessage = $"'{taskLabel}' is already fully scheduled ({totalHoursResolved:0.#}h). "
                             + "Remove an existing block before rescheduling it.";
                SelectedTask = null;
                SelectedCustomTaskId = null;
                PendingPlacement = null;
                return;
            }
        }

        var memberName = TeamMembers.First(x => x.Id == memberId).Name;
        var newAllocs  = ScheduleTask(activeTaskId.Value, memberId, remainingToSchedule, startDate);
        var scheduledHours = newAllocs.Sum(a => a.HoursAllocated);

        if (scheduledHours < remainingToSchedule)
        {
            // Capacity insufficient — ask user whether to schedule over the 6h/day limit
            _overCapacityPending = new OverCapacityPending(
                activeTaskId.Value, memberId, remainingToSchedule, startDate, taskLabel, memberName);
            _showOverCapacityDialog = true;
            PendingPlacement = null;
            return;
        }

        Allocations.AddRange(newAllocs);
        var lastDate = newAllocs.Max(a => a.Date);
        var capNote  = alreadyAllocated > 0m
            ? $" (capped to remaining {remainingToSchedule:0.#}h of {totalHoursResolved:0.#}h)"
            : "";
        InfoMessage = $"Scheduled '{taskLabel}' for {memberName}: {remainingToSchedule:0.#}h from {startDate:dd-MMM} → {lastDate:dd-MMM}{capNote}.";
        SelectedTask = null;
        SelectedCustomTaskId = null;
        PendingPlacement = null;
    }

    // ───────────────────────────────────────────────────────────
    // Scheduling engine (6h/day, day-aware, time-off aware)
    // ───────────────────────────────────────────────────────────
    private List<TaskAllocation> ScheduleTask(
        int taskId, Guid memberId, decimal totalHours, DateOnly startDate,
        List<TaskAllocation>? provisional = null, bool forceOverCapacity = false)
    {
        var result    = new List<TaskAllocation>();
        var groupId   = Guid.NewGuid();
        var remaining = totalHours;
        var date      = startDate;
        const int maxDaysForward = 365;

        for (int d = 0; remaining > 0m && d < maxDaysForward; d++)
        {
            if (!IsDayOff(memberId, date))
            {
                var dailyHours = GetMemberDailyHours(memberId);
                decimal capacity;
                if (forceOverCapacity)
                {
                    // Ignore existing allocations — allow day to exceed the member's daily limit
                    capacity = dailyHours;
                }
                else
                {
                    var committed = GetAllocatedHoursFromList(memberId, date, Allocations);
                    var pending   = provisional is not null ? GetAllocatedHoursFromList(memberId, date, provisional) : 0m;
                    capacity = Math.Max(0m, dailyHours - committed - pending);
                }

                if (capacity > 0m)
                {
                    var hours = Math.Min(remaining, capacity);
                    result.Add(new TaskAllocation
                    {
                        GroupId = groupId, TaskId = taskId, TeamMemberId = memberId,
                        Date = date, HoursAllocated = hours
                    });
                    remaining -= hours;
                }
            }
            date = date.AddDays(1);
        }

        return result;
    }

    // ───────────────────────────────────────────────────────────
    // Over-capacity dialog handlers
    // ───────────────────────────────────────────────────────────
    private void ConfirmOverCapacity()
    {
        if (_overCapacityPending is null) return;
        var p = _overCapacityPending;
        var forced = ScheduleTask(p.TaskId, p.MemberId, p.TotalHours, p.StartDate, forceOverCapacity: true);
        if (forced.Count > 0)
        {
            Allocations.AddRange(forced);
            var lastDate = forced.Max(a => a.Date);
            InfoMessage = $"Scheduled '{p.TaskLabel}' for {p.MemberName}: {p.TotalHours:0.#}h from {p.StartDate:dd-MMM} → {lastDate:dd-MMM} (over capacity).";
        }
        else
        {
            ErrorMessage = $"Could not schedule '{p.TaskLabel}' — no working days available.";
        }
        SelectedTask = null;
        SelectedCustomTaskId = null;
        _overCapacityPending    = null;
        _showOverCapacityDialog = false;
    }

    private void CancelOverCapacity()
    {
        _overCapacityPending    = null;
        _showOverCapacityDialog = false;
        InfoMessage = "Scheduling cancelled.";
    }

    // ───────────────────────────────────────────────────────────
    // No-estimate dialog handlers
    // ───────────────────────────────────────────────────────────
    private void ConfirmNoEstimate()
    {
        if (_noEstimatePending is null) return;

        if (!decimal.TryParse(_noEstimateHoursInput, System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture, out var hours) || hours <= 0m)
        {
            _noEstimateError = "Please enter a valid number of hours greater than 0.";
            return;
        }

        var p          = _noEstimatePending;
        var newAllocs  = ScheduleTask(p.TaskId, p.MemberId, hours, p.StartDate);
        var scheduled  = newAllocs.Sum(a => a.HoursAllocated);

        if (scheduled < hours)
        {
            _showNoEstimateDialog = false;
            _showOverCapacityDialog = true;
            _overCapacityPending = new OverCapacityPending(p.TaskId, p.MemberId, hours, p.StartDate, p.TaskLabel, p.MemberName);
            _noEstimatePending   = null;
            return;
        }

        Allocations.AddRange(newAllocs);
        var lastDate = newAllocs.Max(a => a.Date);
        InfoMessage = $"Scheduled '{p.TaskLabel}' for {p.MemberName}: {hours:0.#}h from {p.StartDate:dd-MMM} → {lastDate:dd-MMM}.";
        SelectedTask         = null;
        SelectedCustomTaskId = null;
        _noEstimatePending    = null;
        _showNoEstimateDialog = false;
    }

    private void CancelNoEstimate()
    {
        _noEstimatePending    = null;
        _showNoEstimateDialog = false;
        _noEstimateError      = null;
        InfoMessage = "Scheduling cancelled.";
    }

    // ───────────────────────────────────────────────────────────
    // Auto-Assign: assign all unassigned tasks
    // ───────────────────────────────────────────────────────────

    /// <summary>Finds the active roster member whose name matches a Jira assignee display name.</summary>
    private TeamMemberDto? MatchMemberByAssignee(string? jiraAssignee)
    {
        if (string.IsNullOrWhiteSpace(jiraAssignee) ||
            string.Equals(jiraAssignee, "Unassigned", StringComparison.OrdinalIgnoreCase))
            return null;
        return TeamMembers.FirstOrDefault(m => AuthorMatchesMember(jiraAssignee, m.Name));
    }

    // Auto-assign: keep a task with its existing Jira assignee when that person is on the
    // (filtered) roster; otherwise fall back to the least-loaded member.
    private void AutoAssignAllUnassigned()
    {
        ErrorMessage = null;
        InfoMessage = null;

        var unassigned = GetAllTasks()
            .Where(t => !IsTaskAssigned(t.Id))
            .Select(t => (Task: t, Hours: GetTaskHours(t)))
            .Where(x => x.Hours > 0m)
            .OrderByDescending(x => x.Hours)   // biggest tasks first
            .ToList();

        if (unassigned.Count == 0) { InfoMessage = "No unassigned tasks with estimates."; return; }

        var pool = TeamMembers
            .Where(m => _activeMemberIds.Contains(m.Id))
            .Where(m => string.IsNullOrEmpty(ActiveTeamFilter) || m.Team == ActiveTeamFilter)
            .ToList();

        var provisional = new List<TaskAllocation>();
        var assigned    = 0;
        var keptAssignee = 0;

        foreach (var (task, hours) in unassigned)
        {
            // 1) Prefer the task's current Jira assignee if they're in the pool with capacity left.
            var jiraMember = MatchMemberByAssignee(task.Assignee);
            var inPool     = jiraMember is not null && pool.Any(m => m.Id == jiraMember.Id);

            TeamMemberDto? target = null;
            if (inPool && GetMemberSprintRemaining(jiraMember!.Id, provisional) > 0m)
            {
                target = jiraMember;
                keptAssignee++;
            }
            else
            {
                // 2) Otherwise the member with the most remaining sprint capacity.
                target = pool
                    .OrderByDescending(m => GetMemberSprintRemaining(m.Id, provisional))
                    .FirstOrDefault();
            }

            if (target is null) break;
            if (GetMemberSprintRemaining(target.Id, provisional) <= 0m) continue;

            var startDate = GetNextAvailableDay(target.Id, SprintStart, provisional);
            if (startDate is null) continue;

            var newAllocs = ScheduleTask(task.Id, target.Id, hours, startDate.Value, provisional);
            if (newAllocs.Count > 0) { provisional.AddRange(newAllocs); assigned++; }
        }

        Allocations.AddRange(provisional);
        InfoMessage = assigned > 0
            ? $"Auto-assigned {assigned} task(s)" + (keptAssignee > 0 ? $" — {keptAssignee} kept their Jira assignee." : ".")
            : "Could not assign any tasks — insufficient capacity.";
    }

    // Schedule only the unassigned tasks whose Jira assignee maps to a roster member,
    // each onto that member. Tasks with no matching assignee are left untouched.
    private void ImportJiraAssignees()
    {
        ErrorMessage = null;
        InfoMessage = null;

        var candidates = GetAllTasks()
            .Where(t => !IsTaskAssigned(t.Id) && GetTaskHours(t) > 0m)
            .Select(t => (Task: t, Hours: GetTaskHours(t), Member: MatchMemberByAssignee(t.Assignee)))
            .Where(x => x.Member is not null && _activeMemberIds.Contains(x.Member!.Id))
            .OrderByDescending(x => x.Hours)
            .ToList();

        if (candidates.Count == 0)
        {
            InfoMessage = "No unassigned tasks have a Jira assignee matching the roster.";
            return;
        }

        var provisional = new List<TaskAllocation>();
        var imported    = 0;
        var unmatched   = new List<string>();

        foreach (var (task, hours, member) in candidates)
        {
            var startDate = GetNextAvailableDay(member!.Id, SprintStart, provisional);
            if (startDate is null) { unmatched.Add(task.Key); continue; }

            var newAllocs = ScheduleTask(task.Id, member.Id, hours, startDate.Value, provisional);
            if (newAllocs.Count > 0) { provisional.AddRange(newAllocs); imported++; }
            else unmatched.Add(task.Key);
        }

        Allocations.AddRange(provisional);
        InfoMessage = $"Imported {imported} task(s) onto their Jira assignee"
                    + (unmatched.Count > 0 ? $". No capacity for: {string.Join(", ", unmatched)}." : ".");
    }

    private DateOnly? GetNextAvailableDay(Guid memberId, DateOnly from, List<TaskAllocation>? provisional = null)
    {
        foreach (var date in VisibleDates.Where(d => d >= from))
        {
            if (IsDayOff(memberId, date)) continue;
            var committed = GetAllocatedHoursFromList(memberId, date, Allocations);
            var pending   = provisional is not null ? GetAllocatedHoursFromList(memberId, date, provisional) : 0m;
            if (committed + pending < GetMemberDailyHours(memberId)) return date;
        }
        return null;
    }

