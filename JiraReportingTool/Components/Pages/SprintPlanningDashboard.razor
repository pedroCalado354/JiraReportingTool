    // ── Custom Task management ──
    private void AddCustomTask()
    {
        ErrorMessage = null;
        if (string.IsNullOrWhiteSpace(NewCustomTaskName)) { ErrorMessage = "Enter a task name."; return; }
        var tpl = _customTaskTemplates.FirstOrDefault(t => t.Id == SelectedTemplateId);
        if (tpl is null) { ErrorMessage = "Select a category first."; return; }
        if (NewCustomTaskHours <= 0m) { ErrorMessage = "Hours must be greater than 0."; return; }

        // "Feature Bug" tasks carry a Jira epic key so the report can pull that epic's
        // bugs and reconcile logged time (Support Bug uses the plan-level loader instead).
        var epicKey = "";
        if (tpl.Category == "Feature Bug")
        {
            epicKey = (NewFeatureBugEpicKey ?? "").Trim().ToUpperInvariant();
            if (!System.Text.RegularExpressions.Regex.IsMatch(epicKey, @"^[A-Z]+-\d+$"))
            {
                ErrorMessage = "Enter a valid epic key (e.g. PROJ-456) for this Feature Bug.";
                return;
            }
        }

        var color = string.IsNullOrWhiteSpace(tpl.Color)
            ? GetCategoryColor(tpl.Category)
            : tpl.Color;

        var id = _nextCustomTaskId--;
        _customTasks[id] = new CustomTaskEntry
        {
            Id = id, Name = NewCustomTaskName.Trim(),
            Category = tpl.Category,
            Hours = NewCustomTaskHours,
            Color = color,
            EpicKey = epicKey
        };

        InfoMessage = $"'{NewCustomTaskName.Trim()}' added. Click it to select, then click a calendar cell.";
        SelectedTemplateId = 0;
        NewCustomTaskName = "";
        NewCustomTaskHours = 1m;
        NewFeatureBugEpicKey = "";
    }

    private void OnTemplateChanged(ChangeEventArgs e)
    {
        SelectedTemplateId = int.TryParse(e.Value?.ToString(), out var id) ? id : 0;
        NewFeatureBugEpicKey = "";
    }

    private void RemoveCustomTask(int id)
    {
        if (_customTasks.TryGetValue(id, out var ct))
        {
            Allocations.RemoveAll(a => a.TaskId == id);
            _customTasks.Remove(id);
            if (SelectedCustomTaskId == id) SelectedCustomTaskId = null;
            InfoMessage = $"'{ct.Name}' and all its allocations removed.";
        }
    }

