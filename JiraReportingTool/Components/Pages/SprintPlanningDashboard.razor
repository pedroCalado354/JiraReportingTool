    private class EpicLoadState
    {
        public string EpicKey { get; set; } = "";
        public List<SprintIssue> Tasks { get; set; } = new();
        public bool IsLoading { get; set; }
        public bool IsExpanded { get; set; } = true;
    }

    private class CustomTaskEntry
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string Category { get; set; } = "Meeting";
        public decimal Hours { get; set; }
        public string Color { get; set; } = "#8b5cf6";
        public string EpicKey { get; set; } = "";   // Feature Bug only — epic whose bugs feed the report
    }

    // ───────────────────────────────────────────────────────────
    // State
    // ───────────────────────────────────────────────────────────
    private string SprintName { get; set; } = "";
    private DateTime? SprintStartDateTime { get; set; }
    private DateTime? SprintEndDateTime { get; set; }
    private DateOnly SprintStart { get; set; }
    private DateOnly SprintEnd { get; set; }
    private List<DateOnly> VisibleDates { get; set; } = new();
    private bool ShowWeekends { get; set; } = false;
    private string ViewMode { get; set; } = "calendar";
    private string? ActiveTeamFilter { get; set; }
    private string _colorMode = "type";       // calendar block colouring: "type" or "epic"
    private string _density   = "comfortable"; // "comfortable" or "compact"

    private Dictionary<string, EpicLoadState> LoadedEpics { get; set; } = new();
    private string EpicKeyInput { get; set; } = "";

    // Individually-loaded Jira tasks (not via an epic). Keyed by Jira key.
    private Dictionary<string, SprintIssue> LoadedTasks { get; set; } = new(StringComparer.OrdinalIgnoreCase);
    private string TaskKeysInput { get; set; } = "";
    private bool _isLoadingTasks = false;
    private bool _manualTasksExpanded = true;

    private Dictionary<string, EpicLoadState> LoadedSupportBugEpics { get; set; } = new();
    private string SupportBugEpicKeyInput { get; set; } = "";
    private Dictionary<string, SprintIssue> _supportBugIssues = new(StringComparer.OrdinalIgnoreCase);
    private Dictionary<string, List<SprintIssue>> _featureBugIssuesByEpic = new(StringComparer.OrdinalIgnoreCase);

    // Members expanded in the Support Bugs table to show their per-issue worklog drill-down.
    private HashSet<Guid> _expandedBugMembers = new();
    private void ToggleBugMemberDetail(Guid memberId)
    {
