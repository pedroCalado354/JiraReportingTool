    /* Issue type colors */

    .type-task {
        background-color: #e0f2fe; /* sky-100 */
        color: #0369a1; /* sky-700 */
    }

    .type-bug {
        background-color: #fee2e2; /* red-100 */
        color: #b91c1c; /* red-700 */
    }

    .type-default {
        background-color: #e5e7eb; /* gray-200 */
