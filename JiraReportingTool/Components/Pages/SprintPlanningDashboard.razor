    private void NewSprint()
    {
        _currentPlanId    = null;
        SprintName        = "";
        LoadedEpics.Clear();
        _taskCache.Clear();
        Allocations.Clear();
        _customTasks.Clear();
        Holidays.Clear();
        MemberTimeOff.Clear();
        _nextCustomTaskId = -1;
        SelectedTask      = null;
        SelectedCustomTaskId = null;
        PendingPlacement  = null;
        _planVersions     = new();
