    // Loads the editable roster from the DB and rebuilds the in-memory member list + capacity map.
    // Roster keyed by member name → used to resolve a member's Jira identity (accountId/email)
    // when matching worklog authors. Rebuilt whenever the roster reloads.
    private Dictionary<string, RosterMember> _rosterByName = new(StringComparer.OrdinalIgnoreCase);

    private async Task LoadRosterAsync()
    {
        _allRoster = await RosterService.GetAllAsync();   // includes inactive members
        _rosterByName = _allRoster
            .GroupBy(r => r.Name, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(g => g.Key, g => g.First(), StringComparer.OrdinalIgnoreCase);

        // Capacity is resolved for EVERYONE (active or not) so old plans render correct hours.
        _memberHours = new();
        foreach (var r in _allRoster)
            _memberHours[MemberId(r.Name, r.Team)] = r.HoursPerDay > 0m ? r.HoursPerDay : DefaultHoursPerDay;

        var active = _allRoster.Where(r => r.Active).ToList();
        _activeMemberIds = active.Select(r => MemberId(r.Name, r.Team)).ToHashSet();
        ResetTeamMembersToActive();
    }

    // Rebuilds the rendered member list to just the active roster (used for new/empty plans).
    private void ResetTeamMembersToActive()
        => TeamMembers = _allRoster.Where(r => r.Active)
            .Select(r => new TeamMemberDto(MemberId(r.Name, r.Team), r.Name, r.Team))
            .ToList();

    // Adds any plan-referenced member that isn't in the active roster (deactivated or renamed),
    // so a loaded historical plan still shows their allocations.
    private void MergePlanMembers(SprintPlanHeader plan)
    {
        var known = TeamMembers.Select(m => m.Id).ToHashSet();
        foreach (var a in plan.Allocations)
        {
            if (a.MemberId == default || known.Contains(a.MemberId)) continue;
            var roster = _allRoster.FirstOrDefault(r => MemberId(r.Name, r.Team) == a.MemberId);
            var team   = roster?.Team ?? "Former Members";
            var name   = !string.IsNullOrWhiteSpace(a.MemberName) ? a.MemberName : (roster?.Name ?? "Unknown");
            TeamMembers.Add(new TeamMemberDto(a.MemberId, name, team));
            known.Add(a.MemberId);
            if (!_memberHours.ContainsKey(a.MemberId))
                _memberHours[a.MemberId] = roster?.HoursPerDay > 0m ? roster!.HoursPerDay : DefaultHoursPerDay;
            // Not added to _activeMemberIds → excluded from auto-assign / import targets.
        }
    }

    private bool IsFormerMember(Guid memberId) => !_activeMemberIds.Contains(memberId);

    /// <summary>This member's daily capacity in hours (from the roster), falling back to the default.</summary>
    private decimal GetMemberDailyHours(Guid memberId)
        => _memberHours.TryGetValue(memberId, out var h) && h > 0m ? h : DefaultHoursPerDay;

