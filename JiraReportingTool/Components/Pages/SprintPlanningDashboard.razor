    private int GetBlockVisibleSpanSprint(CalendarBlock block)
    {
        var start = GetBlockFirstVisibleDate(block);
        if (start == default) return 1;
        var count = VisibleDates.Count(d => d >= start && d <= block.To);
        return Math.Max(1, count);
    }

