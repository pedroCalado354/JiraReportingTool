    private DateOnly GetBlockFirstVisibleDate(CalendarBlock block)
        => VisibleDates.FirstOrDefault(d => d >= block.From);

    private int GetBlockVisibleSpanSprint(CalendarBlock block)
    {
        var start = GetBlockFirstVisibleDate(block);
        if (start == default) return 1;
        var count = VisibleDates.Count(d => d >= start && d <= block.To);
        return Math.Max(1, count);
    }

    private decimal GetBlockHoursOnDate(CalendarBlock block, DateOnly date)
        => Allocations.Where(a => a.GroupId == block.GroupId && a.Date == date).Sum(a => a.HoursAllocated);

