    .rpt-td-pct      { text-align: center; }
    .rpt-td-feasible { text-align: center; }
    .rpt-td-activity { font-size: 12px; color: #374151; white-space: nowrap; }
    .rpt-activity-never { color: #9ca3af; font-style: italic; }
    .rpt-activity-stale { background: #fee2e2 !important; color: #991b1b; font-weight: 600; }

    .feas-badge {
