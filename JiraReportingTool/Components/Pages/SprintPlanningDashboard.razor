@page "/sprint-planning"
@using System.Globalization
@rendermode InteractiveServer
@using JiraReportingTool.Models
@using System.Text.RegularExpressions
@inject IJiraService JiraService
@inject IJSRuntime JS
@inject ISprintPlanService PlanService
@using ClosedXML.Excel

<div class="spd-root">

    <!-- ═══ HEADER ════════════════════════════════════════════════════ -->
    <div class="spd-header">
        <div class="spd-title-block">
            <h2 class="spd-page-title">Sprint Planning Dashboard</h2>
            @if (!string.IsNullOrWhiteSpace(SprintName))
            {
                <span class="spd-sprint-badge">@SprintName</span>
            }
            @if (SprintEnd >= SprintStart && SprintStart != default)
            {
                <span class="spd-sprint-dates">
                    @SprintStart.ToString("dd MMM") → @SprintEnd.ToString("dd MMM yyyy")
                    · @WorkingDaysCount working days
                </span>
            }
        </div>
        <input class="spd-sprint-name-input" placeholder="Sprint name (e.g. Sprint 42)..." @bind="SprintName" @bind:event="oninput" />
    </div>

    <!-- ═══ CONFIG BAR ════════════════════════════════════════════════ -->
    <div class="spd-config-bar">
        <div class="cfg-group">
            <label>Sprint Start</label>
            <InputDate @bind-Value="SprintStartDateTime" class="input" />
        </div>
        <div class="cfg-group">
            <label>Sprint End</label>
            <InputDate @bind-Value="SprintEndDateTime" class="input" />
        </div>
        <div class="cfg-group">
            <button class="btn primary" @onclick="ApplySprintRange">Apply Sprint</button>
        </div>
        <div class="cfg-divider"></div>
        <div class="cfg-group cfg-epic-group">
            <label>Load Epic</label>
            <div class="cfg-epic-row">
                <input class="input" placeholder="Epic key (e.g. JM-15977)"
                       @bind="EpicKeyInput" @bind:event="oninput"
                       @onkeypress="OnEpicInputKeyPress" />
                <button class="btn primary" @onclick="LoadEpic">Load</button>
            </div>
        </div>
        <div class="cfg-group">
            <label>Weekends</label>
            <button class="btn toggle-btn @(ShowWeekends ? "toggle-on" : "")" @onclick="ToggleWeekends">
                @(ShowWeekends ? "Shown" : "Hidden")
            </button>
        </div>
        <div class="cfg-group">
            <label>Time Off</label>
            <button class="btn toggle-btn @(TimeOffMode ? "toggle-on" : "")" @onclick="ToggleTimeOffMode">
                @(TimeOffMode ? "Exit Mode" : "Manage")
            </button>
        </div>
        <div class="cfg-group">
            <button class="btn" @onclick="ExportToExcel" disabled="@(Allocations.Count == 0)" title="Export to Excel">
                ↓ Export .xlsx
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(InfoMessage))
    {
        <div class="spd-info">@InfoMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="spd-error">@ErrorMessage</div>
    }

    <!-- ═══ STATS STRIP ═══════════════════════════════════════════════ -->
    <div class="spd-stats">
        <div class="stat-card">
            <div class="stat-value">@ScheduledTotalCount</div>
            <div class="stat-label">Sprint Tasks</div>
            <div class="stat-sub">@ScheduledJiraTaskCount Jira · @ScheduledCustomTaskCount custom</div>
        </div>
        <div class="stat-card @GetDonePctClass()">
            <div class="stat-value">@(ScheduledJiraTaskCount > 0 ? $"{DonePct:0}%" : "—")</div>
            <div class="stat-label">Done</div>
            <div class="stat-sub">@DoneTaskCount of @ScheduledJiraTaskCount tasks</div>
        </div>
        <div class="stat-card @(AtRiskCount > 0 ? "stat-amber" : (ScheduledJiraTaskCount > 0 ? "stat-green" : ""))">
            <div class="stat-value">@AtRiskCount</div>
            <div class="stat-label">At Risk</div>
            <div class="stat-sub">@RemainingWorkingDays working days left</div>
        </div>
        <div class="stat-card @(BlockedStatCount > 0 ? "stat-red" : (ScheduledJiraTaskCount > 0 ? "stat-green" : ""))">
            <div class="stat-value">@BlockedStatCount</div>
            <div class="stat-label">On Hold</div>
            <div class="stat-sub">status = On Hold</div>
        </div>
        <div class="stat-card">
            <div class="stat-value">@InProgressCount</div>
            <div class="stat-label">In Progress</div>
            <div class="stat-sub">actively being worked on</div>
        </div>
        <div class="stat-card @(MissingEstCount > 0 ? "stat-amber" : "")">
            <div class="stat-value">@MissingEstCount</div>
            <div class="stat-label">Missing Est.</div>
            <div class="stat-sub">active, no remaining est.</div>
        </div>
    </div>

    <!-- ═══ PLAN CRUD BAR ═══════════════════════════════════════════════ -->
    <div class="spd-plan-bar">
        <div class="plan-bar-left">
            <span class="plan-bar-label">Sprint:</span>
            <select class="input plan-select" disabled="@_isSaving"
                    @onchange="OnSprintDropdownChanged">
                <option value="0">— Load a saved sprint —</option>
                @foreach (var p in _savedPlans)
                {
                    <option value="@p.Id" selected="@(p.Id == _currentPlanId)">
                        @p.Name &nbsp;(@p.SprintStart.ToString("dd-MMM") → @p.SprintEnd.ToString("dd-MMM"))
                    </option>
                }
            </select>
            <button class="btn small" @onclick="NewSprint" disabled="@_isSaving" title="Clear the board and start a new sprint">
                + New
            </button>
        </div>
        <div class="plan-bar-right">
            @if (_currentPlanId.HasValue)
            {
                <span class="plan-current-badge">@SprintName</span>
            }
            else
            {
                <span class="plan-unsaved-badge">Unsaved</span>
            }
            <button class="btn primary small" @onclick="SavePlanAsync" disabled="@(_isSaving || string.IsNullOrWhiteSpace(SprintName))">
                @(_isSaving ? "Saving…" : "💾 Save Sprint")
            </button>
            @if (_currentPlanId.HasValue)
            {
                <button class="btn small toggle-btn @(_showVersionsPanel ? "toggle-on" : "")"
                        @onclick="() => _showVersionsPanel = !_showVersionsPanel"
                        title="View version history">
                    📋 History@(_planVersions.Count > 0 ? $" ({_planVersions.Count})" : "")
                </button>
                <button class="btn small" @onclick="OpenRemovalLogsAsync" title="View removal log">
                    📝 Removal Log
                </button>
                <button class="btn danger small" @onclick="DeletePlanAsync" disabled="@_isSaving" title="Delete this sprint plan">
                    🗑 Delete
                </button>
            }
        </div>
    </div>

    @if (_showVersionsPanel && _currentPlanId.HasValue)
    {
        <div class="spd-versions-panel">
            <div class="versions-panel-header">
                <span class="versions-panel-title">Version History — @SprintName</span>
                <button class="btn small" @onclick="() => _showVersionsPanel = false">✕ Close</button>
            </div>
            @if (_planVersions.Count == 0)
            {
                <p class="versions-empty">No versions yet — versions are created automatically each time you save an existing plan.</p>
            }
            else
            {
                <div class="versions-list">
                    @foreach (var v in _planVersions)
                    {
                        var ver = v;
                        <div class="version-item">
                            <span class="version-badge">@ver.VersionNumber</span>
                            <span class="version-date">@ver.SavedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</span>
                            <button class="btn small" @onclick="() => RestoreVersionAsync(ver)" disabled="@_isSaving">
                                Restore
                            </button>
                        </div>
                    }
                </div>
            }
        </div>
    }

    <!-- ═══ TEAM FILTER + ACTIONS ══════════════════════════════════════ -->
    <div class="spd-actions-bar">
        <div class="team-filters">
            <span class="filter-label">Team:</span>
            <button class="team-pill @(ActiveTeamFilter == null ? "active" : "")" @onclick="ClearTeamFilter">
                All <span class="pill-count">@TeamMembers.Count</span>
            </button>
            @foreach (var team in GetAllTeams())
            {
                var teamName = team;
                <button class="team-pill @(ActiveTeamFilter == teamName ? "active" : "")" @onclick="() => SetTeamFilter(teamName)">
                    @teamName <span class="pill-count">@GetTeamMemberCount(teamName)</span>
                </button>
            }
        </div>
        <div class="action-buttons">
            <button class="btn primary" @onclick="AutoAssignAllUnassigned" disabled="@(UnassignedCount == 0)">
                ⚡ Auto-Assign
            </button>
            <button class="btn danger" @onclick="ClearAllAllocations" disabled="@(Allocations.Count == 0)">
                Clear All
            </button>
            <div class="view-toggle-group">
                <button class="view-toggle-btn @(ViewMode == "calendar" ? "active" : "")" @onclick="SetCalendarView">
                    Calendar
                </button>
                <button class="view-toggle-btn @(ViewMode == "report" ? "active" : "")" @onclick="SetReportView">
                    Report
                </button>
                <button class="view-toggle-btn @(ViewMode == "daily" ? "active" : "")" @onclick="SetDailyView">
                    Daily
                </button>
            </div>
        </div>
    </div>

    <!-- ═══ MAIN LAYOUT ════════════════════════════════════════════════ -->
    <div class="spd-main">

        <!-- LEFT: Multi-Epic Task Panel -->
        <div class="spd-task-panel">
            @if (HasActiveSelection)
            {
                <div class="selected-task-bar">
                    <span>@GetActivePlacementLabel()</span>
                    <button class="btn small" @onclick="CancelSelection">✕</button>
                </div>
            }

            @if (LoadedEpics.Count == 0)
            {
                <div class="empty-state">
                    <div class="empty-icon">📋</div>
                    <p>Enter an epic key above and click <strong>Load</strong>.</p>
                    <p class="empty-sub">Multiple epics can be loaded simultaneously.</p>
                </div>
            }
            else
            {
                @foreach (var kvp in LoadedEpics)
                {
                    var epicKey = kvp.Key;
                    var epicState = kvp.Value;
                    <div class="epic-section">
                        <div class="epic-section-header" @onclick="() => ToggleEpic(epicKey)">
                            <span class="epic-toggle">@(epicState.IsExpanded ? "▾" : "▸")</span>
                            <span class="epic-key-badge">@epicKey</span>
                            @if (epicState.IsLoading)
                            {
                                <span class="epic-loading">Loading...</span>
                            }
                            else
                            {
                                <span class="epic-count">@epicState.Tasks.Count tasks</span>
                            }
                            <button class="epic-remove-btn" @onclick="() => RemoveEpic(epicKey)" @onclick:stopPropagation="true" title="Remove epic">✕</button>
                        </div>

                        @if (epicState.IsExpanded && !epicState.IsLoading)
                        {
                            @foreach (var group in GetTasksGroupedByStatus(epicState.Tasks))
                            {
                                <div class="task-group-header status-@group.Key">
                                    @GetStatusGroupLabel(group.Key)
                                    <span class="task-group-count">@group.Count()</span>
                                </div>
                                <ul class="task-list">
                                    @foreach (var t in group.OrderBy(x => x.Status))
                                    {
                                        var task = t;
                                        var isSelected = SelectedTask?.Id == task.Id;
                                        var isAssigned = IsTaskAssigned(task.Id);
                                        var assignee   = isAssigned ? GetTaskAssigneeName(task.Id) : null;
                                        <li class="task-item @(isSelected ? "selected" : "") @(isAssigned ? "assigned" : "")"
                                            @onclick="() => SelectTask(task)">
                                            <div class="task-item-top">
                                                <span class="task-key-label">@task.Key</span>
                                                @if (isAssigned)
                                                {
                                                    <span class="badge-assigned">✓</span>
                                                    @* @if (assignee is not null)
                                                    {
                                                        <span class="badge-assignee-name" title="@assignee">@assignee</span>
                                                    } *@
                                                }
                                                <span class="task-est-label">@FormatTaskHours(task)</span>
                                            </div>
                                            <div class="task-summary-text">@task.Summary</div>
                                            <div class="task-meta-row">
                                                <span class="meta-chip meta-status @GetStatusType(task.IssueType)">@task.IssueType</span>
                                                <span class="meta-chip meta-status @GetStatusClass(task.Status)">
                                                    @task.Status
                                                </span>
                                            </div>
                                        </li>
                                    }
                                </ul>
                            }
                        }
                    </div>
                }
            }
            <!-- Custom Tasks Section -->
            <div class="custom-section">
                <div class="custom-section-header" @onclick="ToggleCustomTaskForm">
                    <span class="custom-section-title">+ Custom Tasks</span>
                    <span class="custom-section-count">@_customTasks.Count</span>
                </div>

                @if (ShowCustomTaskForm)
                {
                    <div class="custom-task-form">
                        <input class="input custom-input" placeholder="Name (e.g. Daily Standup)"
                               @bind="NewCustomTaskName" @bind:event="oninput" />
                        <select class="input custom-input" @bind="NewCustomTaskCategory">
                            <option value="Meeting">Meeting</option>
                            <option value="Support Bug">Support Bug</option>
                            <option value="Review">Review</option>
                            <option value="On-Call">On-Call</option>
                            <option value="Other">Other</option>
                        </select>
                        <div class="custom-form-row">
                            <input class="input custom-input" type="number" min="0.5" step="0.5"
                                   placeholder="Hours" @bind="NewCustomTaskHours" />
                            <button class="btn primary small" @onclick="AddCustomTask">Add</button>
                        </div>
                    </div>
                }

                @if (_customTasks.Count > 0)
                {
                    <ul class="task-list custom-task-list">
                        @foreach (var kvp in _customTasks)
                        {
                            var ct = kvp.Value;
                            var isSelCt = SelectedCustomTaskId == ct.Id;
                            var isAssignedCt = IsTaskAssigned(ct.Id);
                            var ctAssignee = isAssignedCt ? GetTaskAssigneeName(ct.Id) : null;
                            <li class="task-item custom-task-item @(isSelCt ? "selected" : "") @(isAssignedCt ? "assigned" : "")"
                                style="border-left-color: @ct.Color"
                                @onclick="() => SelectCustomTask(ct.Id)">
                                <div class="task-item-top">
                                    <span class="custom-cat-badge" style="background: @ct.Color">@ct.Category</span>
                                    @if (isAssignedCt)
                                    {
                                        <span class="badge-assigned">✓</span>
                                        @if (ctAssignee is not null)
                                        {
                                            <span class="badge-assignee-name" title="@ctAssignee">@ctAssignee</span>
                                        }
                                    }
                                    <span class="task-est-label">@ct.Hours h</span>
                                    <button class="epic-remove-btn" @onclick="() => RemoveCustomTask(ct.Id)" @onclick:stopPropagation="true" title="Remove">✕</button>
                                </div>
                                <div class="task-summary-text">@ct.Name</div>
                            </li>
                        }
                    </ul>
                }
            </div>

            <div class="task-panel-hint">
                Select a task → click a calendar cell to schedule.
                Max @(MaxHoursPerDay)h/day — tasks split automatically.
            </div>
        </div>

        <!-- RIGHT: View Area -->
        <div class="spd-view-area">

            <!-- Placement Bar -->
            @if (PendingPlacement is not null)
            {
                <div class="placement-bar">
                    <span class="pl-pending">
                        Placing <strong>@GetActivePlacementLabel()</strong>
                        — Start: @PendingPlacement.Start.ToString("dd-MMM")
                        — click same row to confirm
                    </span>
                    <button class="btn small" @onclick="CancelPlacement">Cancel</button>
                </div>
            }

            @if (ViewMode == "report")
            {
                <!-- ═ REPORT VIEW ════════════════════════════════════════════ -->
                <div class="rpt-container">
                    @if (_isRefreshingReport)
                    {
                        <div class="rpt-loading">Fetching latest data from Jira…</div>
                    }
                    @if (Allocations.Count == 0)
                    {
                        <div class="empty-state">No tasks assigned yet — schedule tasks on the calendar first.</div>
                    }
                    else
                    {
                        <table class="rpt-table">
                            <thead>
                                <tr>
                                    <th class="rpt-th rpt-th-assignee">Assignee</th>
                                    <th class="rpt-th rpt-th-key">Key</th>
                                    <th class="rpt-th rpt-th-title">Title</th>
                                    <th class="rpt-th rpt-th-status">Status</th>
                                    <th class="rpt-th rpt-th-est">Original Est.</th>
                                    <th class="rpt-th rpt-th-est">Remaining</th>
                                    <th class="rpt-th rpt-th-logged">Time Logged</th>
                                    <th class="rpt-th rpt-th-pct">% Done</th>
                                    <th class="rpt-th rpt-th-feasible">Feasible</th>
                                    <th class="rpt-th rpt-th-activity">Last Activity</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var teamGroup in GetFilteredMembersByTeam())
                                {
                                    var rptTeamName = teamGroup.Key;
                                    <tr class="rpt-team-row">
                                        <td colspan="10" class="rpt-team-cell">@rptTeamName</td>
                                    </tr>
                                    @foreach (var mem in teamGroup)
                                    {
                                        var rptMem = mem;
                                        var memberRows = GetReportRowsForMember(rptMem.Id);
                                        @if (memberRows.Count == 0)
                                        {
                                            <tr class="rpt-row">
                                                <td class="rpt-td rpt-td-assignee">@rptMem.Name</td>
                                                <td class="rpt-td" colspan="9" style="color:#9ca3af;font-style:italic;">No tasks assigned</td>
                                            </tr>
                                        }
                                        else
                                        {
                                            @foreach (var (row, idx) in memberRows.Select((r, i) => (r, i)))
                                            {
                                                <tr class="rpt-row">
                                                    <td class="rpt-td rpt-td-assignee">@(idx == 0 ? rptMem.Name : "")</td>
                                                    @if (row.IsCustom)
                                                    {
                                                        <td class="rpt-td rpt-td-key">
                                                            <span class="rpt-custom-badge" style="background:@row.CustomColor">@row.CustomCategory</span>
                                                        </td>
                                                        <td class="rpt-td rpt-td-title">@row.Title</td>
                                                        <td class="rpt-td rpt-td-dash">—</td>
                                                        <td class="rpt-td rpt-td-dash">@($"{row.CustomHours:0.#}h")</td>
                                                        <td class="rpt-td rpt-td-dash">—</td>
                                                        <td class="rpt-td rpt-td-dash">—</td>
                                                        <td class="rpt-td rpt-td-dash">—</td>
                                                        <td class="rpt-td rpt-td-dash">—</td>
                                                        <td class="rpt-td rpt-td-dash">—</td>
                                                    }
                                                    else
                                                    {
                                                        <td class="rpt-td rpt-td-key">
                                                            <span class="rpt-jira-key">@row.Key</span>
                                                        </td>
                                                        <td class="rpt-td rpt-td-title">@row.Title</td>
                                                        <td class="rpt-td">
                                                            <span class="rpt-status-chip @GetStatusClass(row.Status)">@(string.IsNullOrEmpty(row.Status) ? "—" : row.Status)</span>
                                                        </td>
                                                        <td class="rpt-td rpt-td-est">@FormatEstimate(row.OriginalEstimate, row.OriginalEstimateSeconds)</td>
                                                        <td class="rpt-td rpt-td-est">@FormatEstimate(row.RemainingEstimate, row.RemainingEstimateSeconds)</td>
                                                        <td class="rpt-td rpt-td-est">@FormatEstimate(row.TimeSpent, row.TimeSpentSeconds)</td>
                                                        <td class="rpt-td rpt-td-pct">
                                                            <span class="risk-badge @GetCompletionBadgeClass(row)">@GetCompletionPct(row)</span>
                                                        </td>
                                                        <td class="rpt-td rpt-td-feasible">
                                                            <span class="feas-badge @GetFeasibilityClass(row)">@GetFeasibilityLabel(row)</span>
                                                        </td>
                                                        <td class="rpt-td rpt-td-activity">
                                                            @if (row.LastActivityDate.HasValue)
                                                            {
                                                                <span>@row.LastActivityDate.Value.ToString("dd MMM, HH:mm")</span>
                                                            }
                                                            else
                                                            {
                                                                <span class="rpt-activity-never">Never</span>
                                                            }
                                                        </td>
                                                    }
                                                </tr>
                                            }
                                        }
                                    }
                                }
                            </tbody>
                        </table>
                    }
                </div>
            }
            else if (ViewMode == "daily")
            {
                <!-- ═ DAILY VIEW ══════════════════════════════════════════════ -->
                <div class="daily-container">
                    @if (_isRefreshingReport)
                    {
                        <div class="rpt-loading">Fetching latest data from Jira…</div>
                    }
                    @{
                        var dm = GetDailyMetrics();
                    }

                    <!-- Top KPI row -->
                    <div class="daily-kpi-row">
                        <div class="daily-kpi-card">
                            <div class="daily-kpi-value @(dm.TaskPct >= 80 ? "kpi-green" : dm.TaskPct >= 40 ? "kpi-amber" : "kpi-red")">
                                @($"{dm.TaskPct:0}%")
                            </div>
                            <div class="daily-kpi-label">Tasks Completed</div>
                            <div class="daily-kpi-sub">@dm.DoneCount of @dm.TotalCount tasks</div>
                        </div>
                        <div class="daily-kpi-card">
                            <div class="daily-kpi-value @(dm.HoursPct >= 80 ? "kpi-green" : dm.HoursPct >= 40 ? "kpi-amber" : "kpi-red")">
                                @($"{dm.HoursPct:0}%")
                            </div>
                            <div class="daily-kpi-label">Estimated Work Done</div>
                            <div class="daily-kpi-sub">Hours-based · custom tasks excluded</div>
                        </div>
                        <div class="daily-kpi-card">
                            <div class="daily-kpi-value kpi-neutral">@dm.NoRemainingCount</div>
                            <div class="daily-kpi-label">Missing Remaining Est.</div>
                            <div class="daily-kpi-sub">In progress / to do with no remaining est.</div>
                        </div>
                        <div class="daily-kpi-card">
                            <div class="daily-kpi-value @(dm.BlockedCount > 0 ? "kpi-red" : "kpi-green")">@dm.BlockedCount</div>
                            <div class="daily-kpi-label">On Hold</div>
                            <div class="daily-kpi-sub">Status = "On Hold"</div>
                        </div>
                    </div>

                    <!-- Today's Activity -->
                    @{
                        var todayActivity = GetTodayActivity();
                        var todayAuthors = todayActivity.Select(x => x.Author).ToHashSet(StringComparer.OrdinalIgnoreCase);
                        var noActivityToday = Allocations
                            .Where(a => a.TaskId > 0)
                            .Select(a => TeamMembers.FirstOrDefault(m => m.Id == a.TeamMemberId)?.Name)
                            .Where(n => n != null)
                            .Distinct()
                            .Where(name => !todayAuthors.Any(a => a.Contains(name!, StringComparison.OrdinalIgnoreCase)))
                            .OrderBy(n => n)
                            .ToList();
                    }
                    <div class="daily-section">
                        <div class="daily-section-title">
                            Today's Activity
                            <span class="daily-section-sub">— worklogs from @DateTime.Today.ToString("dd MMM")</span>
                        </div>
                        @if (_reportIssues.Count == 0)
                        {
                            <div class="daily-empty-note">No Jira data loaded — switch to Report view first to refresh.</div>
                        }
                        else if (!todayActivity.Any())
                        {
                            <div class="daily-empty-note">No worklogs found for today.</div>
                        }
                        else
                        {
                            <table class="rpt-table">
                                <thead>
                                    <tr>
                                        <th class="rpt-th rpt-th-assignee">Author</th>
                                        <th class="rpt-th rpt-th-est">Logged Today</th>
                                        <th class="rpt-th rpt-th-key">Task</th>
                                        <th class="rpt-th rpt-th-title">Summary</th>
                                        <th class="rpt-th" style="width:80px;text-align:center">In Calendar</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var (author, totalSec, lines) in todayActivity)
                                    {
                                        @foreach (var (line, idx) in lines.Select((l, i) => (l, i)))
                                        {
                                            <tr class="rpt-row">
                                                <td class="rpt-td rpt-td-assignee">@(idx == 0 ? author : "")</td>
                                                <td class="rpt-td rpt-td-est">
                                                    @if (idx == 0)
                                                    {
                                                        <span class="risk-badge risk-green">@FmtSec(totalSec)</span>
                                                    }
                                                </td>
                                                <td class="rpt-td rpt-td-key"><span class="rpt-jira-key">@line.IssueKey</span></td>
                                                <td class="rpt-td rpt-td-title">@line.IssueSummary</td>
                                                <td class="rpt-td" style="text-align:center;font-size:14px;color:@(line.IsInCalendar ? "#16a34a" : "#9ca3af")">
                                                    @(line.IsInCalendar ? "✓" : "—")
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        }
                        @if (noActivityToday.Any())
                        {
                            <div class="daily-no-activity">No activity today: @string.Join(" · ", noActivityToday)</div>
                        }
                    </div>

                    <!-- Status breakdown -->
                    <div class="daily-section">
                        <div class="daily-section-title">Tasks by Status</div>
                        <div class="daily-status-grid">
                            @foreach (var (status, count) in dm.ByStatus.OrderByDescending(x => x.Value))
                            {
                                var sBadgeClass = GetStatusClass(status);
                                <div class="daily-status-item">
                                    <span class="rpt-status-chip @sBadgeClass">@status</span>
                                    <span class="daily-status-count">@count</span>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Untouched tasks -->
                    @if (dm.UntouchedTasks.Count > 0)
                    {
                        <div class="daily-section">
                            <div class="daily-section-title">Untouched Tasks <span class="daily-section-sub">(remaining = original, not Done)</span></div>
                            <table class="rpt-table">
                                <thead>
                                    <tr>
                                        <th class="rpt-th rpt-th-key">Key</th>
                                        <th class="rpt-th rpt-th-title">Title</th>
                                        <th class="rpt-th rpt-th-status">Status</th>
                                        <th class="rpt-th rpt-th-assignee">Assignee</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var t in dm.UntouchedTasks)
                                    {
                                        <tr class="rpt-row">
                                            <td class="rpt-td rpt-td-key"><span class="rpt-jira-key">@t.Key</span></td>
                                            <td class="rpt-td rpt-td-title">@t.Summary</td>
                                            <td class="rpt-td"><span class="rpt-status-chip @GetStatusClass(t.Status)">@t.Status</span></td>
                                            <td class="rpt-td rpt-td-assignee">@t.Assignee</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

                    <!-- Missing remaining estimate -->
                    @if (dm.NoRemainingTasks.Count > 0)
                    {
                        <div class="daily-section">
                            <div class="daily-section-title">Missing Remaining Estimate <span class="daily-section-sub">(active tasks — need attention)</span></div>
                            <table class="rpt-table">
                                <thead>
                                    <tr>
                                        <th class="rpt-th rpt-th-key">Key</th>
                                        <th class="rpt-th rpt-th-title">Title</th>
                                        <th class="rpt-th rpt-th-status">Status</th>
                                        <th class="rpt-th rpt-th-assignee">Assignee</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var t in dm.NoRemainingTasks)
                                    {
                                        <tr class="rpt-row">
                                            <td class="rpt-td rpt-td-key"><span class="rpt-jira-key">@t.Key</span></td>
                                            <td class="rpt-td rpt-td-title">@t.Summary</td>
                                            <td class="rpt-td"><span class="rpt-status-chip @GetStatusClass(t.Status)">@t.Status</span></td>
                                            <td class="rpt-td rpt-td-assignee">@t.Assignee</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

                    <!-- On Hold tasks -->
                    @if (dm.BlockedTasks.Count > 0)
                    {
                        <div class="daily-section">
                            <div class="daily-section-title daily-section-title-danger">On Hold Tasks</div>
                            <table class="rpt-table">
                                <thead>
                                    <tr>
                                        <th class="rpt-th rpt-th-key">Key</th>
                                        <th class="rpt-th rpt-th-title">Title</th>
                                        <th class="rpt-th rpt-th-status">Status</th>
                                        <th class="rpt-th rpt-th-assignee">Assignee</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var t in dm.BlockedTasks)
                                    {
                                        <tr class="rpt-row">
                                            <td class="rpt-td rpt-td-key"><span class="rpt-jira-key">@t.Key</span></td>
                                            <td class="rpt-td rpt-td-title">@t.Summary</td>
                                            <td class="rpt-td"><span class="rpt-status-chip status-on-hold">@t.Status</span></td>
                                            <td class="rpt-td rpt-td-assignee">@t.Assignee</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            }
            else
            {
                <!-- ═ CALENDAR VIEW ════════════════════════════════════════════ -->
                @if (VisibleDates.Count == 0)
                {
                    <div class="empty-state">Apply a sprint date range to see the calendar.</div>
                }
                else
                {
                    <div class="cal-scroll">
                        <table class="cal-table">
                            <colgroup>
                                <col class="col-member" />
                                @foreach (var d in VisibleDates)
                                {
                                    <col class="col-date" />
                                }
                            </colgroup>
                            <thead>
                                <tr>
                                    <th class="cal-sticky-col cal-head-member">
                                        <div>Team Member</div>
                                        <div class="cal-head-sub">Sprint capacity</div>
                                    </th>
                                    @foreach (var d in VisibleDates)
                                    {
                                        var dateCol = d;
                                        var isToday = dateCol == DateOnly.FromDateTime(DateTime.Today);
                                        var isHolCol = IsHoliday(dateCol);
                                        var isWeCol = IsWeekend(dateCol);
                                        <th class="cal-date-th @(isToday ? "col-today" : "") @(isWeCol ? "col-we" : "") @(isHolCol ? "col-holiday" : "")"
                                            title="@GetDateColTitle(dateCol)"
                                            @onclick="() => OnDateHeaderClicked(dateCol)">
                                            <div class="cal-th-day">@dateCol.ToString("ddd", CultureInfo.InvariantCulture)</div>
                                            <div class="cal-th-date">@dateCol.ToString("dd", CultureInfo.InvariantCulture)</div>
                                            <div class="cal-th-mon">@dateCol.ToString("MMM", CultureInfo.InvariantCulture)</div>
                                            @if (isToday) { <div class="today-dot"></div> }
                                            @if (isHolCol) { <div class="hol-badge">H</div> }
                                        </th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var teamGroup in GetFilteredMembersByTeam())
                                {
                                    var teamName = teamGroup.Key;
                                    var teamAllocated = GetTeamAllocatedHours(teamName);
                                    var teamCapacity = GetTeamCapacityHours(teamName);
                                    <tr class="cal-team-row">
                                        <td class="cal-sticky-col cal-team-label" colspan="@(VisibleDates.Count + 1)">
                                            @teamName
                                            <span class="cal-team-stat">@($"{teamAllocated:0.#}h / {teamCapacity:0.#}h")</span>
                                        </td>
                                    </tr>

                                    @foreach (var member in teamGroup)
                                    {
                                        var mem = member;
                                        var lanedBlocks = GetLanedBlocks(mem.Id);
                                        var maxLanes = GetMaxLanes(mem.Id);
                                        var rowHeight = Math.Max(72, maxLanes * 34 + 38);
                                        var mCap = GetMemberSprintCapacity(mem.Id);
                                        var mAlloc = GetMemberSprintAllocated(mem.Id);
                                        var mPct = mCap > 0m ? (double)(mAlloc / mCap * 100m) : 0.0;

                                        <tr style="height:@(rowHeight)px;">
                                            <td class="cal-sticky-col cal-member-cell">
                                                <div class="cal-member-name">@mem.Name</div>
                                                <div class="cal-member-alloc">@($"{mAlloc:0.#}h / {mCap:0.#}h")</div>
                                                <div class="cal-member-bar-wrap">
                                                    <div class="cal-member-bar @GetCapacityBarClass(mPct)" style="width:@(Math.Min(mPct, 100).ToString("F1", CultureInfo.InvariantCulture))%;"></div>
                                                </div>
                                            </td>

                                            @for (int ci = 0; ci < VisibleDates.Count; ci++)
                                            {
                                                var currentDate = VisibleDates[ci];
                                                var cellBlocks = lanedBlocks
                                                    .Where(lb => GetBlockFirstVisibleDate(lb.Block) == currentDate)
                                                    .ToList();
                                                var allocated = GetAllocatedHours(mem.Id, currentDate);
                                                var isWe = IsWeekend(currentDate);
                                                var isMemberOff = IsMemberTimeOff(mem.Id, currentDate);
                                                var isHolDay = IsHoliday(currentDate);
                                                var isDayOff = isMemberOff || isHolDay;
                                                var isToday = currentDate == DateOnly.FromDateTime(DateTime.Today);
                                                var cellCls = BuildCellClass(allocated, isDayOff, isWe, isToday);
                                                var usagePct = MaxHoursPerDay > 0m ? (allocated / MaxHoursPerDay) * 100m : 0m;

                                                <td class="@cellCls"
                                                    title="@BuildCellTitle(mem.Id, currentDate, allocated, isDayOff, isHolDay)"
                                                    @onclick="() => OnCalendarCellClicked(mem.Id, currentDate)">

                                                    @if (isDayOff && !isWe)
                                                    {
                                                        <div class="cell-off-label">@(isHolDay ? "hol" : "off")</div>
                                                    }
                                                    @if (allocated > 0m && !isDayOff)
                                                    {
                                                        <div class="cell-usage-bar" style="height:@(usagePct.ToString("F1", CultureInfo.InvariantCulture))%;"></div>
                                                        <div class="cell-hours-label @(allocated >= MaxHoursPerDay ? "full" : "")">@($"{allocated:0.#}h")</div>
                                                    }

                                                    @foreach (var (block, lane) in cellBlocks)
                                                    {
                                                        var blk = block;
                                                        var blkLane = lane;
                                                        var span = GetBlockVisibleSpanSprint(blk);
                                                        var topOff = blkLane * 34 + 24;
                                                        var wPct = span * 100;
                                                        var blkHours = GetBlockHoursOnDate(blk, currentDate);

                                                        <div class="stacked-block"
                                                             style="top:@(topOff)px; width:calc(@(wPct)% - 6px); background:@GetBlockColor(blk.TaskId);"
                                                             title="@GetTaskLabel(blk.TaskId)"
                                                             @onclick:stopPropagation="true">
                                                            <div class="stacked-block-content">
                                                                <span class="stacked-block-title">@GetTaskShortLabel(blk.TaskId)</span>
                                                            </div>
                                                            <button class="btn-remove" @onclick="() => RemoveBlock(blk.GroupId)" @onclick:stopPropagation="true">✕</button>
                                                        </div>
                                                    }
                                                </td>
                                            }
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                }
            }
        </div>
    </div>

    @if (_showOverCapacityDialog && _overCapacityPending is not null)
    {
        <div class="modal-backdrop" @onclick="CancelOverCapacity"></div>
        <div class="modal-dialog">
            <div class="modal-title">Over Capacity Warning</div>
            <p class="modal-body">
                Adding <strong>@_overCapacityPending.TaskLabel</strong> to
                <strong>@_overCapacityPending.MemberName</strong> exceeds the
                @MaxHoursPerDay h/day limit — not enough free capacity from
                @($"{_overCapacityPending.StartDate:dd-MMM}").
                <br />Schedule anyway (days may exceed @MaxHoursPerDay h)?
            </p>
            <div class="modal-actions">
                <button class="btn primary" @onclick="ConfirmOverCapacity">Yes, schedule anyway</button>
                <button class="btn" @onclick="CancelOverCapacity">No, cancel</button>
            </div>
        </div>
    }

    @if (_showNoEstimateDialog && _noEstimatePending is not null)
    {
        <div class="modal-backdrop" @onclick="CancelNoEstimate"></div>
        <div class="modal-dialog">
            <div class="modal-title">No Estimate — Enter Hours</div>
            <p class="modal-body">
                <strong>@_noEstimatePending.TaskLabel</strong> has no estimate.
                How many hours should be scheduled for <strong>@_noEstimatePending.MemberName</strong>
                from <strong>@($"{_noEstimatePending.StartDate:dd-MMM}")</strong>?
            </p>
            <input class="modal-hours-input"
                   type="number" min="0.5" step="0.5"
                   placeholder="e.g. 4"
                   @bind="_noEstimateHoursInput"
                   @onkeydown="@(async e => { if (e.Key == "Enter") ConfirmNoEstimate(); })" />
            @if (_noEstimateError is not null)
            {
                <p class="modal-error">@_noEstimateError</p>
            }
            <div class="modal-actions">
                <button class="btn primary" @onclick="ConfirmNoEstimate">Schedule</button>
                <button class="btn" @onclick="CancelNoEstimate">Cancel</button>
            </div>
        </div>
    }

    @if (_showRemovalDialog)
    {
        <div class="modal-backdrop" @onclick="CancelRemoval"></div>
        <div class="modal-dialog">
            <div class="modal-title">Remove Assignment</div>
            <p class="modal-body">
                Remove <strong>@_removalPendingTaskLabel</strong> from
                <strong>@_removalPendingMemberName</strong>?
            </p>
            <textarea class="modal-reason-input"
                      placeholder="Reason for removal (optional)"
                      @bind="_removalReason"
                      rows="3"></textarea>
            <div class="modal-actions">
                <button class="btn danger" @onclick="ConfirmRemovalAsync">Remove</button>
                <button class="btn" @onclick="CancelRemoval">Cancel</button>
            </div>
        </div>
    }

    @if (_showRemovalLogsDialog)
    {
        <div class="modal-backdrop" @onclick="CloseRemovalLogs"></div>
        <div class="modal-dialog modal-dialog-lg">
            <div class="modal-header-row">
                <span class="modal-title">Removal Log — @SprintName</span>
                <button class="modal-close-btn" @onclick="CloseRemovalLogs">✕</button>
            </div>
            @if (_isLoadingLogs)
            {
                <p class="modal-body">Loading…</p>
            }
            else if (_removalLogs.Count == 0)
            {
                <p class="modal-body">No removals logged for this sprint plan.</p>
            }
            else
            {
                <div class="removal-logs-wrap">
                    <table class="removal-logs-table">
                        <thead>
                            <tr>
                                <th>Removed At</th>
                                <th>Task</th>
                                <th>Member</th>
                                <th>Reason</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in _removalLogs)
                            {
                                <tr>
                                    <td class="rl-date">@log.RemovedAt.ToString("dd-MMM HH:mm")</td>
                                    <td class="rl-task">@log.TaskLabel</td>
                                    <td class="rl-member">@log.MemberName</td>
                                    <td class="rl-reason">@(string.IsNullOrWhiteSpace(log.Reason) ? "—" : log.Reason)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            <div class="modal-actions">
                <button class="btn" @onclick="CloseRemovalLogs">Close</button>
            </div>
        </div>
    }
</div>

@code {
    // ───────────────────────────────────────────────────────────
    // Types
    // ───────────────────────────────────────────────────────────
    public record TeamMemberDto(Guid Id, string Name, string Team);

    public class TaskAllocation
    {
        public Guid AllocationId { get; set; } = Guid.NewGuid();
        public Guid GroupId { get; set; }
        public int TaskId { get; set; }
        public Guid TeamMemberId { get; set; }
        public DateOnly Date { get; set; }
        public decimal HoursAllocated { get; set; }
    }

    private sealed class CalendarBlock
    {
        public Guid GroupId { get; init; }
        public int TaskId { get; init; }
        public Guid TeamMemberId { get; init; }
        public DateOnly From { get; init; }
        public DateOnly To { get; init; }
    }

    private class PendingPlacementState
    {
        public Guid TeamMemberId { get; set; }
        public DateOnly Start { get; set; }
    }

    private class EpicLoadState
    {
        public string EpicKey { get; set; } = "";
        public List<SprintIssue> Tasks { get; set; } = new();
        public bool IsLoading { get; set; }
        public bool IsExpanded { get; set; } = true;
    }

    private class CustomTaskEntry
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string Category { get; set; } = "Meeting";
        public decimal Hours { get; set; }
        public string Color { get; set; } = "#8b5cf6";
    }

    // ───────────────────────────────────────────────────────────
    // State
    // ───────────────────────────────────────────────────────────
    private string SprintName { get; set; } = "";
    private DateTime? SprintStartDateTime { get; set; }
    private DateTime? SprintEndDateTime { get; set; }
    private DateOnly SprintStart { get; set; }
    private DateOnly SprintEnd { get; set; }
    private List<DateOnly> VisibleDates { get; set; } = new();
    private bool ShowWeekends { get; set; } = false;
    private string ViewMode { get; set; } = "calendar";
    private string? ActiveTeamFilter { get; set; }

    private Dictionary<string, EpicLoadState> LoadedEpics { get; set; } = new();
    private string EpicKeyInput { get; set; } = "";

    private List<TaskAllocation> Allocations { get; set; } = new();
    private Dictionary<int, SprintIssue> _taskCache = new();
    // Fallback labels loaded from persisted SprintPlanAllocation.TaskLabel when _taskCache misses.
    private Dictionary<int, string> _taskLabelFallback = new();
    private HashSet<DateOnly> Holidays { get; set; } = new();
    private Dictionary<Guid, HashSet<DateOnly>> MemberTimeOff { get; set; } = new();
    private bool TimeOffMode { get; set; } = false;

    private SprintIssue? SelectedTask { get; set; }
    private int? SelectedCustomTaskId { get; set; }
    private PendingPlacementState? PendingPlacement { get; set; }

    // ── Custom Tasks ──
    private Dictionary<int, CustomTaskEntry> _customTasks = new();
    private int _nextCustomTaskId = -1;
    private bool ShowCustomTaskForm { get; set; } = false;
    private string NewCustomTaskName { get; set; } = "";
    private string NewCustomTaskCategory { get; set; } = "Meeting";
    private decimal NewCustomTaskHours { get; set; } = 1m;

    private List<TeamMemberDto> TeamMembers { get; set; } = new();
    private string? ErrorMessage { get; set; }
    private string? InfoMessage  { get; set; }

    // ── Plan CRUD ──
    private int?                  _currentPlanId;
    private List<SprintPlanHeader> _savedPlans = new();
    private bool                  _isSaving   = false;
    private int                   _loadPlanId = 0;

    // ── Plan versions ──
    private List<SprintPlanVersion> _planVersions    = new();
    private bool                    _showVersionsPanel = false;

    // ── Over-capacity dialog ──
    private bool _showOverCapacityDialog = false;
    private record OverCapacityPending(
        int TaskId, Guid MemberId, decimal TotalHours, DateOnly StartDate, string TaskLabel, string MemberName);
    private OverCapacityPending? _overCapacityPending;

    // ── Removal dialog ──
    private bool             _showRemovalDialog      = false;
    private Guid             _removalPendingGroupId;
    private string           _removalPendingTaskLabel  = "";
    private string           _removalPendingMemberName = "";
    private string _removalReason = "";

    // ── No-estimate dialog ──
    private bool   _showNoEstimateDialog = false;
    private record NoEstimatePending(int TaskId, Guid MemberId, DateOnly StartDate, string TaskLabel, string MemberName);
    private NoEstimatePending? _noEstimatePending;
    private string  _noEstimateHoursInput = "";
    private string? _noEstimateError      = null;

    // ── Removal logs dialog ──
    private bool                       _showRemovalLogsDialog = false;
    private bool                       _isLoadingLogs         = false;
    private List<SprintPlanRemovalLog> _removalLogs           = new();

    private const decimal MaxHoursPerDay = 6m;
    private const decimal HoursPerDay = 6m;
    private const decimal DaysPerWeek = 5m;

    // ───────────────────────────────────────────────────────────
    // Computed properties
    // ───────────────────────────────────────────────────────────
    private List<SprintIssue> GetAllTasks()
        => LoadedEpics.Values.SelectMany(e => e.Tasks).ToList();

    private bool IsTaskAssigned(int taskId)
        => Allocations.Any(a => a.TaskId == taskId);

    private string? GetTaskAssigneeName(int taskId)
    {
        var memberId = Allocations.FirstOrDefault(a => a.TaskId == taskId)?.TeamMemberId;
        if (memberId is null) return null;
        return TeamMembers.FirstOrDefault(m => m.Id == memberId.Value)?.Name;
    }

    private int TotalTaskCount => LoadedEpics.Values.Sum(e => e.Tasks.Count);
    private int AssignedCount => GetAllTasks().Count(t => IsTaskAssigned(t.Id));
    private int UnassignedCount => TotalTaskCount - AssignedCount;
    private decimal TotalScopeHours => GetAllTasks().Sum(t => GetTaskHours(t));
    private decimal TotalAllocatedHours => Allocations
        .Where(a => a.Date >= SprintStart && a.Date <= SprintEnd)
        .Sum(a => a.HoursAllocated);
    private decimal CoveragePercent => TotalTaskCount == 0 ? 0m : (AssignedCount * 100m / TotalTaskCount);

    private int WorkingDaysCount => SprintEnd >= SprintStart && SprintStart != default
        ? Enumerable.Range(0, SprintEnd.DayNumber - SprintStart.DayNumber + 1)
            .Select(i => SprintStart.AddDays(i))
            .Count(d => !IsWeekend(d) && !IsHoliday(d))
        : 0;

    // ── Sprint stats strip ──
    private int ScheduledJiraTaskCount
        => Allocations.Where(a => a.TaskId > 0).Select(a => a.TaskId).Distinct().Count();

    private int ScheduledCustomTaskCount
        => Allocations.Where(a => a.TaskId < 0).Select(a => a.TaskId).Distinct().Count();

    private int ScheduledTotalCount => ScheduledJiraTaskCount + ScheduledCustomTaskCount;

    private IReadOnlyList<SprintIssue> GetScheduledIssues()
        => Allocations
            .Where(a => a.TaskId > 0)
            .Select(a => a.TaskId)
            .Distinct()
            .Select(id =>
            {
                var key = GetJiraKeyForTaskId(id);
                if (key != null && _reportIssues.TryGetValue(key, out var ri)) return ri;
                return _taskCache.TryGetValue(id, out var ci) ? ci : null;
            })
            .Where(t => t != null)
            .Select(t => t!)
            .ToList();

    private int DoneTaskCount      => GetScheduledIssues().Count(t => t.StatusCategoryKey == "done");
    private int InProgressCount    => GetScheduledIssues().Count(t => t.StatusCategoryKey == "indeterminate");
    private int BlockedStatCount   => GetScheduledIssues().Count(t => string.Equals(t.Status, "On Hold", StringComparison.OrdinalIgnoreCase));
    private int MissingEstCount    => GetScheduledIssues().Count(t =>
        t.StatusCategoryKey != "done" && t.OriginalEstimateSeconds > 0 && t.RemainingEstimateSeconds == 0);

    private double DonePct => ScheduledJiraTaskCount == 0 ? 0
        : (double)DoneTaskCount / ScheduledJiraTaskCount * 100;

    private string GetDonePctClass() => ScheduledJiraTaskCount == 0 ? ""
        : DonePct >= 80 ? "stat-green" : DonePct >= 40 ? "stat-amber" : "stat-red";

    private int RemainingWorkingDays
    {
        get
        {
            var today = DateOnly.FromDateTime(DateTime.Today);
            if (SprintEnd == default || SprintEnd < today) return 0;
            var from = today > SprintStart ? today : SprintStart;
            return Enumerable.Range(0, SprintEnd.DayNumber - from.DayNumber + 1)
                .Select(i => from.AddDays(i))
                .Count(d => !IsWeekend(d) && !IsHoliday(d));
        }
    }

    private int AtRiskCount
    {
        get
        {
            var remainingSec = (long)RemainingWorkingDays * 6 * 3600;
            return GetScheduledIssues()
                .Count(t => t.StatusCategoryKey != "done"
                          && t.RemainingEstimateSeconds > 0
                          && t.RemainingEstimateSeconds > remainingSec);
        }
    }

    // ── Report completion badge ──
    private static string GetCompletionPct(ReportRow row)
    {
        if (row.IsCustom) return "—";
        if (string.Equals(row.StatusCategoryKey, "done", StringComparison.OrdinalIgnoreCase)) return "100%";
        var total = row.TimeSpentSeconds + row.RemainingEstimateSeconds;
        if (total == 0) return "—";
        return $"{(double)row.TimeSpentSeconds / total * 100:0}%";
    }

    private static string GetCompletionBadgeClass(ReportRow row)
    {
        if (row.IsCustom) return "risk-gray";
        if (string.Equals(row.StatusCategoryKey, "done", StringComparison.OrdinalIgnoreCase)) return "risk-green";
        var total = row.TimeSpentSeconds + row.RemainingEstimateSeconds;
        if (total == 0) return "risk-amber";
        var pct = (double)row.TimeSpentSeconds / total * 100;
        if (pct >= 80) return "risk-green";
        if (pct >= 40) return "risk-amber";
        return row.TimeSpentSeconds > 0 ? "risk-red" : "risk-gray";
    }

    // ── Feasibility ──
    private string GetFeasibilityLabel(ReportRow row)
    {
        if (row.IsCustom) return "—";
        if (string.Equals(row.StatusCategoryKey, "done", StringComparison.OrdinalIgnoreCase)) return "✓ Done";
        if (row.RemainingEstimateSeconds == 0) return "No Estimate";
        return row.RemainingEstimateSeconds <= (long)RemainingWorkingDays * 6 * 3600
            ? "✓ Feasible" : "✗ Not Feasible";
    }

    private string GetFeasibilityClass(ReportRow row)
    {
        if (row.IsCustom) return "feas-na";
        if (string.Equals(row.StatusCategoryKey, "done", StringComparison.OrdinalIgnoreCase)) return "feas-done";
        if (row.RemainingEstimateSeconds == 0) return "feas-unknown";
        return row.RemainingEstimateSeconds <= (long)RemainingWorkingDays * 6 * 3600
            ? "feas-ok" : "feas-fail";
    }

    // ── Today's Activity ──
    private record TodayLogLine(string IssueKey, string IssueSummary, int SecondsLogged, bool IsInCalendar);

    private List<(string Author, int TotalSec, List<TodayLogLine> Lines)> GetTodayActivity()
    {
        if (_reportIssues.Count == 0) return [];
        var today = DateTime.Today;
        var calendarKeys = Allocations
            .Where(a => a.TaskId > 0)
            .Select(a => GetJiraKeyForTaskId(a.TaskId))
            .Where(k => k != null)
            .Select(k => k!)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        return _reportIssues.Values
            .SelectMany(issue => issue.Worklogs
                .Where(w => w.Started.Date == today)
                .Select(w => (w.Author, Line: new TodayLogLine(
                    issue.Key, issue.Summary, w.TimeSpentSeconds, calendarKeys.Contains(issue.Key)))))
            .GroupBy(x => x.Author, StringComparer.OrdinalIgnoreCase)
            .Select(g => (
                g.Key,
                g.Sum(x => x.Line.SecondsLogged),
                g.Select(x => x.Line).OrderByDescending(l => l.SecondsLogged).ToList()))
            .OrderByDescending(x => x.Item2)
            .ToList();
    }

    private static string FmtSec(int seconds)
    {
        if (seconds <= 0) return "0h";
        var h = seconds / 3600;
        var m = (seconds % 3600) / 60;
        return h > 0 && m > 0 ? $"{h}h {m}m" : h > 0 ? $"{h}h" : $"{m}m";
    }

