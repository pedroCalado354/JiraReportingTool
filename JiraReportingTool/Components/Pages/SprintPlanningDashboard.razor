    // ───────────────────────────────────────────────────────────
    // Estimate parsing
    // ───────────────────────────────────────────────────────────
    private static string FormatEstimateHours(string? jiraEstimate)
    {
        var h = ParseJiraDurationToHours(jiraEstimate);
        if (h <= 0m) return "-";
        var r = h % 1m == 0m ? decimal.Round(h, 0) : decimal.Round(h, 1);
        return $"{r.ToString(CultureInfo.InvariantCulture)}h";
    }

    /// <summary>
    /// Dev Ready → use original estimate (task not started, full scope counts).
    /// Any other status → use remaining effort (max(0, original − spent)).
    /// </summary>
    private static decimal GetTaskHours(SprintIssue t)
    {
        bool isDevReady = string.Equals(t.Status, "Dev Ready", StringComparison.OrdinalIgnoreCase);
        if (isDevReady)
            return t.OriginalEstimateSeconds / 3600m;
        var remSec = Math.Max(0, t.OriginalEstimateSeconds - t.TimeSpentSeconds);
        return remSec / 3600m;
    }

    private static string FormatTaskHours(SprintIssue t)
    {
        var h = GetTaskHours(t);
        if (h <= 0m) return "-";
        var r = h % 1m == 0m ? decimal.Round(h, 0) : decimal.Round(h, 1);
        return $"{r.ToString(CultureInfo.InvariantCulture)}h";
    }

private static decimal ParseJiraDurationToHours(string? input)
    {
        if (string.IsNullOrWhiteSpace(input) || input.Trim() == "-") return 0m;
        var matches = Regex.Matches(input, @"(\d+(?:[.,]\d+)?)\s*([wdhm])", RegexOptions.IgnoreCase);
        if (matches.Count == 0) return 0m;
        decimal total = 0m;
        foreach (Match m in matches)
        {
            var num = m.Groups[1].Value.Replace(',', '.');
            if (!decimal.TryParse(num, NumberStyles.Number, CultureInfo.InvariantCulture, out var v)) continue;
            switch (char.ToLowerInvariant(m.Groups[2].Value[0]))
            {
                case 'w': total += v * DaysPerWeek * HoursPerDay; break;
                case 'd': total += v * HoursPerDay; break;
                case 'h': total += v; break;
                case 'm': total += v / 60m; break;
            }
        }
        return total;
    }

    // ───────────────────────────────────────────────────────────
    // Excel Export
    // ───────────────────────────────────────────────────────────
    private async Task ExportToExcel()
    {
        ErrorMessage = null;
        InfoMessage = null;
        try
        {
            // Ensure _reportIssues is populated (needed to resolve task → epic mapping).
            // This is a no-op if the user has already visited Report/Daily view.
            if (_reportIssues.Count == 0)
                await RefreshReportDataAsync();

            using var wb = new XLWorkbook();

            var calMembers = string.IsNullOrEmpty(ActiveTeamFilter)
                ? TeamMembers
                : TeamMembers.Where(m => m.Team == ActiveTeamFilter).ToList();

            // ── Build task-key → epic-key map from freshly-fetched _reportIssues ─────
            // _reportIssues was just populated by RefreshReportDataAsync() so every
            // issue has EpicKey and EpicName set from the Jira API response.
            var taskKeyToEpicKey = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
            var epicNameMap      = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
            foreach (var issue in _reportIssues.Values)
            {
                if (!string.IsNullOrEmpty(issue.Key) && !string.IsNullOrEmpty(issue.EpicKey))
                    taskKeyToEpicKey[issue.Key] = issue.EpicKey;
                if (!string.IsNullOrEmpty(issue.EpicKey) &&
                    !string.IsNullOrEmpty(issue.EpicName) && issue.EpicName != "No Epic")
                    epicNameMap.TryAdd(issue.EpicKey, issue.EpicName);
            }
            // Supplement epic names from LoadedEpics task list
            foreach (var (ek, state) in LoadedEpics)
                foreach (var t in state.Tasks)
                    if (!string.IsNullOrEmpty(t.EpicName) && t.EpicName != "No Epic")
                        epicNameMap.TryAdd(ek, t.EpicName);

            // ── Epic → color map ──────────────────────────────────────────────────
            var epicPalette = new[]
            {
                "#DBEAFE", "#D1FAE5", "#FEF3C7", "#FCE7F3",
                "#EDE9FE", "#FFEDD5", "#CFFAFE", "#E0F2FE",
            };
            // Include epics discovered via _reportIssues (covers the case where LoadedEpics is empty)
            var epicKeys = LoadedEpics.Keys
                .Concat(_reportIssues.Values
                    .Select(i => i.EpicKey)
                    .Where(k => !string.IsNullOrEmpty(k)))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToList();

            // Fetch names for any epic keys not already covered by _reportIssues / LoadedEpics
            var missingNameKeys = epicKeys.Where(k => !epicNameMap.ContainsKey(k)).ToList();
            if (missingNameKeys.Count > 0)
            {
                try
                {
                    var fetchedNames = await JiraService.FetchEpicNamesAsync(missingNameKeys);
                    foreach (var kvp in fetchedNames)
                        epicNameMap.TryAdd(kvp.Key, kvp.Value);
                }
                catch { }
            }

            var epicColorMap = epicKeys
                .Select((k, i) => (k, epicPalette[i % epicPalette.Length]))
                .ToDictionary(x => x.k, x => x.Item2, StringComparer.OrdinalIgnoreCase);

            // ── Shared: write date header row ────────────────────────────────────
            void WriteCalendarHeader(IXLWorksheet ws)
            {
                var h = ws.Cell(1, 1);
                h.Value = "Member"; h.Style.Font.Bold = true;
                for (int d = 0; d < VisibleDates.Count; d++)
                {
                    var hdr = ws.Cell(1, d + 2);
                    hdr.Value = VisibleDates[d].ToString("ddd dd-MMM");
                    hdr.Style.Font.Bold = true;
                    hdr.Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;
                    hdr.Style.Fill.BackgroundColor = IsWeekend(VisibleDates[d])
                        ? XLColor.LightGray : XLColor.FromHtml("#EEF2FF");
                }
            }

            // ── Sheet 1: Calendar ────────────────────────────────────────────────
            // For Jira tasks: show "EPIC-KEY - Epic Summary"
            // For custom tasks: show category (e.g. "Support Bug", "Review")
            // Merge consecutive days with the same task set into one cell.
            string GetEpicLabel(int taskId)
            {
                if (_customTasks.TryGetValue(taskId, out var ct))
                    return string.IsNullOrWhiteSpace(ct.Name) ? ct.Category : $"{ct.Category}: {ct.Name}";
                var jk = GetJiraKeyForTaskId(taskId);
                if (jk != null && taskKeyToEpicKey.TryGetValue(jk, out var ek))
                {
                    return epicNameMap.TryGetValue(ek, out var en) && !string.IsNullOrWhiteSpace(en)
                        ? $"{ek} - {en}"
                        : ek;
                }
                return jk ?? $"#{taskId}";
            }

            var cal = wb.Worksheets.Add("Calendar");
            WriteCalendarHeader(cal);

            for (int r = 0; r < calMembers.Count; r++)
            {
                var member = calMembers[r];
                var rowIdx = r + 2;
                var nc = cal.Cell(rowIdx, 1);
                nc.Value = $"{member.Name} ({member.Team})";
                nc.Style.Font.Bold = true;

                int d = 0;
                while (d < VisibleDates.Count)
                {
                    var date = VisibleDates[d];
                    var cell = cal.Cell(rowIdx, d + 2);

                    if (IsMemberTimeOff(member.Id, date) || IsHoliday(date))
                    {
                        cell.Value = IsHoliday(date) ? "Holiday" : "Time Off";
                        cell.Style.Fill.BackgroundColor = XLColor.LightYellow;
                        cell.Style.Font.Italic = true;
                        d++; continue;
                    }
                    if (IsWeekend(date))
                    {
                        cell.Style.Fill.BackgroundColor = XLColor.LightGray;
                        d++; continue;
                    }

                    var dayAllocs = Allocations.Where(a => a.TeamMemberId == member.Id && a.Date == date).ToList();
                    if (dayAllocs.Count == 0) { d++; continue; }

                    // Fingerprint = distinct epic labels for this day (sub-tasks under the same epic collapse)
                    string Fingerprint(IEnumerable<TaskAllocation> allocs) =>
                        string.Join("§", allocs.Select(a => GetEpicLabel(a.TaskId)).Distinct().OrderBy(s => s));

                    var fp = Fingerprint(dayAllocs);

                    // Find run end: walk forward while next day has the same epic-label set
                    int endD = d;
                    while (endD + 1 < VisibleDates.Count)
                    {
                        var nextDate = VisibleDates[endD + 1];
                        if (IsWeekend(nextDate) || IsMemberTimeOff(member.Id, nextDate) || IsHoliday(nextDate)) break;
                        var nextAllocs = Allocations.Where(a => a.TeamMemberId == member.Id && a.Date == nextDate).ToList();
                        if (nextAllocs.Count == 0 || Fingerprint(nextAllocs) != fp) break;
                        endD++;
                    }

                    // Cell value: distinct epic labels only (no hours)
                    var runAllocs = Allocations.Where(a => a.TeamMemberId == member.Id
                                                        && a.Date >= VisibleDates[d]
                                                        && a.Date <= VisibleDates[endD]).ToList();
                    cell.Value = string.Join(" | ", runAllocs
                        .Select(a => GetEpicLabel(a.TaskId))
                        .Distinct()
                        .OrderBy(s => s));

                    if (endD > d)
                    {
                        var range = cal.Range(rowIdx, d + 2, rowIdx, endD + 2);
                        range.Merge();
                        range.Style.Fill.BackgroundColor = XLColor.FromHtml("#DBEAFE");
                        range.Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;
                        range.Style.Alignment.Vertical   = XLAlignmentVerticalValues.Center;
                        range.Style.Border.OutsideBorder = XLBorderStyleValues.Thin;
                        range.Style.Border.OutsideBorderColor = XLColor.FromHtml("#93C5FD");
                    }
                    else
                    {
                        cell.Style.Fill.BackgroundColor = XLColor.FromHtml("#DBEAFE");
                    }
                    d = endD + 1;
                }
            }
            cal.Row(1).Height = 30;
            cal.Column(1).Width = 22;
            for (int d = 0; d < VisibleDates.Count; d++) cal.Column(d + 2).Width = 28;
            cal.Rows().Style.Alignment.WrapText = false;

            // ── Sheet 2: Calendar V2 ─────────────────────────────────────────────
            // One row per member-task pair. Columns: Member | Task | Total | date…
            // ─────────────────────────────────────────────────────────────────────
            var cal2 = wb.Worksheets.Add("Calendar V2");

            // Header
            void StyleV2Header(IXLCell c, bool weekend)
            {
                c.Style.Font.Bold = true;
                c.Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;
                c.Style.Fill.BackgroundColor = weekend ? XLColor.LightGray : XLColor.FromHtml("#1e40af");
                if (!weekend) c.Style.Font.FontColor = XLColor.White;
            }
            var hMember = cal2.Cell(1, 1); hMember.Value = "Member";
            hMember.Style.Font.Bold = true;
            hMember.Style.Fill.BackgroundColor = XLColor.FromHtml("#1e40af");
            hMember.Style.Font.FontColor = XLColor.White;
            var hTask = cal2.Cell(1, 2); hTask.Value = "Task";
            hTask.Style.Font.Bold = true;
            hTask.Style.Fill.BackgroundColor = XLColor.FromHtml("#1e40af");
            hTask.Style.Font.FontColor = XLColor.White;
            var hTotal = cal2.Cell(1, 3); hTotal.Value = "Total";
            hTotal.Style.Font.Bold = true;
            hTotal.Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;
            hTotal.Style.Fill.BackgroundColor = XLColor.FromHtml("#1e40af");
            hTotal.Style.Font.FontColor = XLColor.White;
            for (int d = 0; d < VisibleDates.Count; d++)
            {
                var dh = cal2.Cell(1, d + 4);
                dh.Value = VisibleDates[d].ToString("ddd dd-MMM");
                StyleV2Header(dh, IsWeekend(VisibleDates[d]));
            }

            // Cell fill color per task category
            XLColor V2TaskColor(int taskId)
            {
                if (_customTasks.TryGetValue(taskId, out var ctc))
                    return ctc.Category switch
                    {
                        "Support Bug" or "Feature Bug" => XLColor.FromHtml("#FEE2E2"),
                        "Review"  => XLColor.FromHtml("#FEF3C7"),
                        "On-Call" => XLColor.FromHtml("#FFEDD5"),
                        _         => XLColor.FromHtml("#EDE9FE"),
                    };
                // Jira task → epic color (pastel)
                var jk = GetJiraKeyForTaskId(taskId);
                if (jk != null && taskKeyToEpicKey.TryGetValue(jk, out var ek) && epicColorMap.TryGetValue(ek, out var col))
                    return XLColor.FromHtml(col);
                return XLColor.FromHtml("#DBEAFE");
            }

            // Column B label: "KEY - Summary" for Jira tasks, "Category: Name" for custom
            string V2TaskLabel(int taskId)
            {
                if (_customTasks.TryGetValue(taskId, out var ctc))
                    return $"{ctc.Category}: {ctc.Name}";

                // Prefer live cache (Summary field populated by API)
                if (_taskCache.TryGetValue(taskId, out var cached) && !string.IsNullOrEmpty(cached.Key))
                    return string.IsNullOrEmpty(cached.Summary)
                        ? cached.Key
                        : $"{cached.Key} - {cached.Summary}";

                // Fall back to persisted label "KEY - SUMMARY (Est: X)"
                if (_taskLabelFallback.TryGetValue(taskId, out var fb))
                {
                    var sepIdx = fb.IndexOf(" - ", StringComparison.Ordinal);
                    if (sepIdx > 0)
                    {
                        var key     = fb[..sepIdx].Trim();
                        var rest    = fb[(sepIdx + 3)..];
                        var estIdx  = rest.LastIndexOf(" (Est:", StringComparison.Ordinal);
                        var summary = estIdx > 0 ? rest[..estIdx] : rest;
                        return $"{key} - {summary}";
                    }
                    return fb;
                }

                var jk = GetJiraKeyForTaskId(taskId);
                return jk ?? $"#{taskId}";
            }

            int v2Row = 2;
            string? prevTeam = null;
            foreach (var member in calMembers)
            {
                // Team banner row
                if (member.Team != prevTeam)
                {
                    prevTeam = member.Team;
                    var teamCell = cal2.Cell(v2Row, 1);
                    teamCell.Value = member.Team.ToUpperInvariant();
                    teamCell.Style.Font.Bold = true;
                    teamCell.Style.Font.FontColor = XLColor.FromHtml("#1e40af");
                    teamCell.Style.Fill.BackgroundColor = XLColor.FromHtml("#EEF2FF");
                    cal2.Range(v2Row, 1, v2Row, 3 + VisibleDates.Count).Merge();
                    v2Row++;
                }

                // Gather unique tasks for this member, ordered by first allocation date
                var memberTasks = Allocations
                    .Where(a => a.TeamMemberId == member.Id
                        && a.Date >= SprintStart && a.Date <= SprintEnd)
                    .GroupBy(a => a.TaskId)
                    .OrderBy(g => g.Min(a => a.Date))
                    .ToList();

                int memberFirstRow = v2Row;

                if (memberTasks.Count == 0)
                {
                    // No allocations — one placeholder row
                    cal2.Cell(v2Row, 1).Value = $"{member.Name}";
                    cal2.Cell(v2Row, 1).Style.Font.Bold = true;
                    cal2.Cell(v2Row, 1).Style.Fill.BackgroundColor = XLColor.FromHtml("#EEF2FF");
                    for (int d = 0; d < VisibleDates.Count; d++)
                    {
                        var date = VisibleDates[d];
                        var ec = cal2.Cell(v2Row, d + 4);
                        if (IsWeekend(date)) ec.Style.Fill.BackgroundColor = XLColor.LightGray;
                        else if (IsMemberTimeOff(member.Id, date) || IsHoliday(date))
                        {
                            ec.Value = IsHoliday(date) ? "Holiday" : "Time Off";
                            ec.Style.Fill.BackgroundColor = XLColor.LightYellow;
                            ec.Style.Font.Italic = true;
                        }
                    }
                    v2Row++;
                }
                else
                {
                    foreach (var taskGrp in memberTasks)
                    {
                        int taskId = taskGrp.Key;
                        var taskColor = V2TaskColor(taskId);
                        bool isFirst = taskGrp == memberTasks[0];

                        // Col A — member name (populated on every row; merge later)
                        var memberCell = cal2.Cell(v2Row, 1);
                        if (isFirst) { memberCell.Value = member.Name; memberCell.Style.Font.Bold = true; }
                        memberCell.Style.Fill.BackgroundColor = XLColor.FromHtml("#EEF2FF");
                        memberCell.Style.Alignment.Vertical = XLAlignmentVerticalValues.Top;

                        // Col B — task key / name
                        var taskCell2 = cal2.Cell(v2Row, 2);
                        taskCell2.Value = V2TaskLabel(taskId);
                        taskCell2.Style.Fill.BackgroundColor = taskColor;

                        // Col C — sprint total for this task
                        var sprintTotal = taskGrp.Sum(a => a.HoursAllocated);
                        var totalCell = cal2.Cell(v2Row, 3);
                        totalCell.Value = $"{sprintTotal:0.#}h";
                        totalCell.Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;
                        totalCell.Style.Fill.BackgroundColor = taskColor;
                        totalCell.Style.Font.Bold = true;

                        // Date columns
                        for (int d = 0; d < VisibleDates.Count; d++)
                        {
                            var date = VisibleDates[d];
                            var dc = cal2.Cell(v2Row, d + 4);
                            if (IsWeekend(date))
                            {
                                dc.Style.Fill.BackgroundColor = XLColor.LightGray;
                                continue;
                            }
                            if (IsMemberTimeOff(member.Id, date) || IsHoliday(date))
                            {
                                dc.Value = IsHoliday(date) ? "Holiday" : "Time Off";
                                dc.Style.Fill.BackgroundColor = XLColor.LightYellow;
                                dc.Style.Font.Italic = true;
                                dc.Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;
                                continue;
                            }
                            var dayHours = taskGrp.Where(a => a.Date == date).Sum(a => a.HoursAllocated);
                            if (dayHours > 0)
                            {
                                dc.Value = $"{dayHours:0.#}h";
                                dc.Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;
                                dc.Style.Fill.BackgroundColor = taskColor;
                            }
                        }

                        v2Row++;
                    }

                    // Per-member totals row
                    cal2.Cell(v2Row, 1).Style.Fill.BackgroundColor = XLColor.FromHtml("#EEF2FF");
                    var mTotalB = cal2.Cell(v2Row, 2);
                    mTotalB.Value = "Total";
                    mTotalB.Style.Font.Bold = true;
                    mTotalB.Style.Font.FontColor = XLColor.FromHtml("#1e40af");
                    mTotalB.Style.Fill.BackgroundColor = XLColor.FromHtml("#DBEAFE");
                    var mGrandTotal = memberTasks.Sum(g => g.Sum(a => a.HoursAllocated));
                    var mTotalC = cal2.Cell(v2Row, 3);
                    mTotalC.Value = $"{mGrandTotal:0.#}h";
                    mTotalC.Style.Font.Bold = true;
                    mTotalC.Style.Font.FontColor = XLColor.FromHtml("#1e40af");
                    mTotalC.Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;
                    mTotalC.Style.Fill.BackgroundColor = XLColor.FromHtml("#DBEAFE");
                    for (int d = 0; d < VisibleDates.Count; d++)
                    {
                        var date = VisibleDates[d];
                        var tc = cal2.Cell(v2Row, d + 4);
                        if (IsWeekend(date)) { tc.Style.Fill.BackgroundColor = XLColor.LightGray; continue; }
                        if (IsMemberTimeOff(member.Id, date) || IsHoliday(date)) { tc.Style.Fill.BackgroundColor = XLColor.LightYellow; continue; }
                        var daySum = memberTasks.Sum(g => g.Where(a => a.Date == date).Sum(a => a.HoursAllocated));
                        tc.Style.Fill.BackgroundColor = XLColor.FromHtml("#DBEAFE");
                        if (daySum > 0)
                        {
                            tc.Value = $"{daySum:0.#}h";
                            tc.Style.Font.Bold = true;
                            tc.Style.Font.FontColor = XLColor.FromHtml("#1e40af");
                            tc.Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;
                        }
                    }
                    v2Row++;

                    // Merge column A across all task rows + totals row for this member
                    if (v2Row - memberFirstRow > 1)
                        cal2.Range(memberFirstRow, 1, v2Row - 1, 1).Merge();
                }

                // Thin separator row between members
                var sepRange = cal2.Range(v2Row, 1, v2Row, 3 + VisibleDates.Count);
                sepRange.Style.Fill.BackgroundColor = XLColor.FromHtml("#F3F4F6");
                v2Row++;
            }

            cal2.Row(1).Height = 28;
            cal2.Column(1).Width = 20;
            cal2.Column(2).Width = 48;
            cal2.Column(3).Width = 9;
            for (int d = 0; d < VisibleDates.Count; d++) cal2.Column(d + 4).Width = 13;
            cal2.Rows().Style.Alignment.WrapText = false;
            cal2.SheetView.FreezeRows(1);
            cal2.SheetView.FreezeColumns(2);

            // ── Sheet 3: Report ──────────────────────────────────────────────────
            var rpt = wb.Worksheets.Add("Report");
            var rptHeaders = new[]
            {
                "Member", "Key / Type", "Title", "Status",
                "Original Est", "Remaining", "Time Logged", "%", "Feasible", "Last Activity"
            };
            for (int c = 0; c < rptHeaders.Length; c++)
            {
                var hc = rpt.Cell(1, c + 1);
                hc.Value = rptHeaders[c];
                hc.Style.Font.Bold = true;
                hc.Style.Fill.BackgroundColor = XLColor.FromHtml("#EEF2FF");
                hc.Style.Font.FontColor = XLColor.FromHtml("#1e40af");
            }

            int rptRow = 2;
            foreach (var member in calMembers)
            {
                var rows = GetReportRowsForMember(member.Id);
                if (rows.Count == 0) continue;

                for (int i = 0; i < rows.Count; i++)
                {
                    var row = rows[i];
                    rpt.Cell(rptRow, 1).Value = i == 0 ? $"{member.Name} ({member.Team})" : "";
                    if (i == 0) rpt.Cell(rptRow, 1).Style.Font.Bold = true;

                    if (row.IsCustom)
                    {
                        rpt.Cell(rptRow, 2).Value = row.CustomCategory;
                        rpt.Cell(rptRow, 3).Value = row.Title;
                        rpt.Cell(rptRow, 4).Value = "";
                        rpt.Cell(rptRow, 5).Value = $"{row.CustomHours:0.#}h";
                        rpt.Cell(rptRow, 6).Value = "—";
                        rpt.Cell(rptRow, 7).Value = row.SupportBugLoggedSeconds > 0
                            ? FormatEstimate("", row.SupportBugLoggedSeconds) : "—";
                        rpt.Cell(rptRow, 8).Value = GetCompletionPct(row);
                        rpt.Cell(rptRow, 9).Value = "—";
                        rpt.Cell(rptRow, 10).Value = row.SupportBugLastActivity.HasValue
                            ? row.SupportBugLastActivity.Value.ToString("dd MMM, HH:mm") : "—";
                    }
                    else
                    {
                        rpt.Cell(rptRow, 2).Value = row.Key;
                        rpt.Cell(rptRow, 3).Value = row.Title;
                        rpt.Cell(rptRow, 4).Value = row.Status;
                        rpt.Cell(rptRow, 5).Value = FormatEstimate(row.OriginalEstimate, row.OriginalEstimateSeconds);
                        rpt.Cell(rptRow, 6).Value = FormatEstimate(row.RemainingEstimate, row.ComputedRemainingSeconds);
                        rpt.Cell(rptRow, 7).Value = FormatEstimate(row.TimeSpent, row.TimeSpentSeconds);
                        rpt.Cell(rptRow, 8).Value = GetCompletionPct(row);
                        rpt.Cell(rptRow, 9).Value = GetFeasibilityLabel(row);
                        rpt.Cell(rptRow, 10).Value = row.LastActivityDate.HasValue
                            ? row.LastActivityDate.Value.ToString("dd MMM, HH:mm") : "Never";
                    }

                    // Shade custom rows faintly
                    if (row.IsCustom)
                        rpt.Row(rptRow).Style.Fill.BackgroundColor = XLColor.FromHtml("#F9FAFB");

                    rptRow++;
                }

                // Blank separator row between members
                rptRow++;
            }

            rpt.Row(1).Height = 22;
            rpt.Column(1).Width = 24;
            rpt.Column(2).Width = 14;
            rpt.Column(3).Width = 52;
            rpt.Column(4).Width = 16;
            for (int c = 5; c <= 10; c++) rpt.Column(c).Width = 14;
            rpt.Rows().Style.Alignment.WrapText = false;

            // ── Stream to download ────────────────────────────────────────────────
            using var ms = new System.IO.MemoryStream();
            wb.SaveAs(ms);
            var base64   = Convert.ToBase64String(ms.ToArray());
            var fileName = $"SprintPlanning_{(string.IsNullOrWhiteSpace(SprintName) ? "Export" : SprintName.Replace(" ", "_"))}_{DateTime.Now:yyyyMMdd}.xlsx";
            const string mime = "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet";
            await JS.InvokeVoidAsync("downloadBase64File", base64, fileName, mime);
            InfoMessage = $"Exported to {fileName}.";
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Export failed: {ex.Message}";
        }
    }
    // ───────────────────────────────────────────────────────────
    // Support Bugs View helpers
    // ───────────────────────────────────────────────────────────
    private record WeekRange(string Label, DateOnly Start, DateOnly End);

    private List<WeekRange> GetWeekRanges()
    {
        if (SprintStart == default || SprintEnd < SprintStart) return [];
        var weeks = new List<WeekRange>();
        var weekStart = SprintStart;
        while (weekStart.DayOfWeek != DayOfWeek.Monday)
            weekStart = weekStart.AddDays(-1);
        int weekNum = 1;
        while (weekStart <= SprintEnd)
        {
            var weekEnd        = weekStart.AddDays(6);
            var effectiveStart = weekStart < SprintStart ? SprintStart : weekStart;
            var effectiveEnd   = weekEnd   > SprintEnd   ? SprintEnd   : weekEnd;
            weeks.Add(new WeekRange($"Week {weekNum}", effectiveStart, effectiveEnd));
            weekNum++;
            weekStart = weekStart.AddDays(7);
        }
        return weeks;
    }

    private decimal GetSupportBugPlannedHoursInRange(Guid memberId, DateOnly from, DateOnly to)
    {
        var supportBugTaskIds = _customTasks.Values
            .Where(ct => ct.Category == "Support Bug")
            .Select(ct => ct.Id)
            .ToHashSet();
        return Allocations
            .Where(a => a.TeamMemberId == memberId
                     && supportBugTaskIds.Contains(a.TaskId)
                     && a.Date >= from && a.Date <= to)
            .Sum(a => a.HoursAllocated);
    }

    private int GetSupportBugLoggedSecondsInRange(string memberName, DateOnly from, DateOnly to)
    {
        if (_supportBugIssues.Count == 0 || string.IsNullOrEmpty(memberName)) return 0;
        var fromDt = from.ToDateTime(TimeOnly.MinValue);
        var toDt   = to.ToDateTime(TimeOnly.MaxValue);
        return _supportBugIssues.Values
            .SelectMany(i => i.Worklogs)
            .Where(w => w.Started >= fromDt && w.Started <= toDt
                     && WorklogByMember(w, memberName))
            .Sum(w => w.TimeSpentSeconds);
    }

    // Per-issue worklog breakdown for a member in [from, to] — drives the Support Bugs
    // drill-down and lets totals be reconciled against a Jira "parent = EPIC,
    // worklogAuthor = X" report issue-by-issue.
    private List<BugLogRow> GetSupportBugLogBreakdown(string memberName, DateOnly from, DateOnly to)
    {
        if (_supportBugIssues.Count == 0 || string.IsNullOrEmpty(memberName)) return new();
        var fromDt = from.ToDateTime(TimeOnly.MinValue);
        var toDt   = to.ToDateTime(TimeOnly.MaxValue);
        return _supportBugIssues.Values
            .Select(i =>
            {
                var mine = i.Worklogs
                    .Where(w => w.Started >= fromDt && w.Started <= toDt
                             && WorklogByMember(w, memberName))
                    .ToList();
                return new BugLogRow(
                    i.Key,
                    i.Summary,
                    mine.Sum(w => w.TimeSpentSeconds),
                    mine.Count,
                    mine.Count > 0 ? mine.Max(w => w.Started) : default);
            })
            .Where(r => r.Worklogs > 0)
            .OrderByDescending(r => r.Seconds)
            .ToList();
    }

    // All support-bug worklog seconds in [from,to], regardless of author — matches the
    // Support Bugs dashboard "Sprint Logged" total (which does not filter by roster member).
    private int GetSupportBugLoggedSecondsAllInRange(DateOnly from, DateOnly to)
    {
        if (_supportBugIssues.Count == 0) return 0;
        var fromDt = from.ToDateTime(TimeOnly.MinValue);
        var toDt   = to.ToDateTime(TimeOnly.MaxValue);
        return _supportBugIssues.Values
            .SelectMany(i => i.Worklogs)
            .Where(w => w.Started >= fromDt && w.Started <= toDt)
            .Sum(w => w.TimeSpentSeconds);
    }

    // Support-bug worklog seconds in [from,to] whose author matches none of `members` —
    // the hours that would otherwise be silently dropped from the per-member breakdown.
    private int GetSupportBugUnmatchedSecondsInRange(IReadOnlyList<TeamMemberDto> members, DateOnly from, DateOnly to)
    {
        if (_supportBugIssues.Count == 0) return 0;
        var fromDt = from.ToDateTime(TimeOnly.MinValue);
        var toDt   = to.ToDateTime(TimeOnly.MaxValue);
        return _supportBugIssues.Values
            .SelectMany(i => i.Worklogs)
            .Where(w => w.Started >= fromDt && w.Started <= toDt
                     && !members.Any(m => WorklogByMember(w, m.Name)))
            .Sum(w => w.TimeSpentSeconds);
    }

    // Unmatched worklogs in [from,to] grouped by author — powers the "Unassigned" drill-down
    // so unmatched authors can be spotted and added/aliased in the roster.
    private List<(string Author, int Seconds)> GetSupportBugUnmatchedByAuthor(IReadOnlyList<TeamMemberDto> members, DateOnly from, DateOnly to)
    {
        if (_supportBugIssues.Count == 0) return new();
        var fromDt = from.ToDateTime(TimeOnly.MinValue);
        var toDt   = to.ToDateTime(TimeOnly.MaxValue);
        return _supportBugIssues.Values
            .SelectMany(i => i.Worklogs)
            .Where(w => w.Started >= fromDt && w.Started <= toDt
                     && !members.Any(m => WorklogByMember(w, m.Name)))
            .GroupBy(w => string.IsNullOrWhiteSpace(w.Author) ? "(unknown)" : w.Author, StringComparer.OrdinalIgnoreCase)
            .Select(g => (Author: g.Key, Seconds: g.Sum(w => w.TimeSpentSeconds)))
            .OrderByDescending(x => x.Seconds)
            .ToList();
    }

    private IReadOnlyList<TeamMemberDto> GetMembersWithSupportBugActivity()
    {
        var supportBugTaskIds = _customTasks.Values
            .Where(ct => ct.Category == "Support Bug")
            .Select(ct => ct.Id)
            .ToHashSet();

        var membersWithPlan = Allocations
            .Where(a => supportBugTaskIds.Contains(a.TaskId)
                     && a.Date >= SprintStart && a.Date <= SprintEnd)
            .Select(a => a.TeamMemberId)
            .ToHashSet();

        var sprintStartDt = SprintStart.ToDateTime(TimeOnly.MinValue);
        var sprintEndDt   = SprintEnd.ToDateTime(TimeOnly.MaxValue);
        var worklogsInRange = _supportBugIssues.Values
            .SelectMany(i => i.Worklogs)
            .Where(w => w.Started >= sprintStartDt && w.Started <= sprintEndDt)
            .ToList();

        return TeamMembers
            .Where(m => membersWithPlan.Contains(m.Id)
                     || worklogsInRange.Any(w => WorklogByMember(w, m.Name)))
            .ToList();
    }

    private static string BugPctBadgeClass(decimal planned, decimal loggedHours)
    {
        if (planned <= 0m && loggedHours <= 0m) return "bugs-pct-gray";
        if (planned <= 0m) return "bugs-pct-gray";
        var pct = loggedHours / planned * 100m;
        if (pct > 100m)  return "bugs-pct-red";
        if (pct >= 80m)  return "bugs-pct-green";
        if (pct >= 40m)  return "bugs-pct-amber";
        return "bugs-pct-red";
    }

    private static string BugPctLabel(decimal planned, decimal loggedHours)
    {
        if (planned <= 0m && loggedHours <= 0m) return "—";
        if (planned <= 0m) return "unplanned";
        var pct = loggedHours / planned * 100m;
        return $"{pct:0}%";
    }

    private static string GetStatusType(string? issueType)
    {
        return issueType?.ToLowerInvariant() switch
        {
            "task" => "type-task",
            "bug" => "type-bug",
            _ => "type-default"
        };
    }
    private static string GetStatusClass(string? status)
    {
        return status?.ToLowerInvariant() switch
        {
            "dev ready" => "status-dev-ready",
            "in progress" => "status-in-progress",
            "in review" => "status-in-review",
            "qa ready" => "status-qa-ready",
            "done" => "status-done",
            "on hold" => "status-on-hold",
            _ => "status-default"
        };
    }
}

