    private string GetTaskShortLabel(int taskId)
    {
        if (_customTasks.TryGetValue(taskId, out var ct))
        {
            var n = ct.Name.Length > 22 ? ct.Name[..22] + "…" : ct.Name;
            return $"{ct.Category}: {n}";
        }
        if (!_taskCache.TryGetValue(taskId, out var t))
        {
            if (!_taskLabelFallback.TryGetValue(taskId, out var fb)) return $"#{taskId}";
            // Stored format: "KEY - SUMMARY (Est: X)" — extract key and summary for short display.
            var sepIdx = fb.IndexOf(" - ", StringComparison.Ordinal);
            if (sepIdx > 0)
            {
                var key  = fb[..sepIdx];
                var rest = fb[(sepIdx + 3)..];
                var estIdx = rest.LastIndexOf(" (Est:", StringComparison.Ordinal);
                var summary = estIdx > 0 ? rest[..estIdx] : rest;
                summary = summary.Length > 28 ? summary[..28] + "…" : summary;
                return $"{key}: {summary}";
            }
            return fb.Length > 28 ? fb[..28] + "…" : fb;
        }
        var s = t.Summary?.Length > 28 ? t.Summary[..28] + "…" : t.Summary ?? "";
        return $"{t.Key}: {s}";
    }

    private string GetTaskKeyFromCache(int taskId)
    {
        if (_customTasks.TryGetValue(taskId, out var ct)) return ct.Category;
        if (_taskCache.TryGetValue(taskId, out var t)) return t.Key;
        if (_taskLabelFallback.TryGetValue(taskId, out var fb))
        {
            var sepIdx = fb.IndexOf(" - ", StringComparison.Ordinal);
            return sepIdx > 0 ? fb[..sepIdx] : fb;
        }
        return $"#{taskId}";
    }

    private string GetTaskSummaryShort(int taskId)
    {
        if (_customTasks.TryGetValue(taskId, out var ct))
            return ct.Name.Length > 40 ? ct.Name[..40] + "…" : ct.Name;
        if (!_taskCache.TryGetValue(taskId, out var t))
        {
            if (!_taskLabelFallback.TryGetValue(taskId, out var fb)) return "Unknown task";
            var sepIdx = fb.IndexOf(" - ", StringComparison.Ordinal);
            if (sepIdx > 0)
            {
                var rest   = fb[(sepIdx + 3)..];
                var estIdx = rest.LastIndexOf(" (Est:", StringComparison.Ordinal);
                var summary = estIdx > 0 ? rest[..estIdx] : rest;
                return summary.Length > 40 ? summary[..40] + "…" : summary;
            }
            return fb.Length > 40 ? fb[..40] + "…" : fb;
        }
        return t.Summary?.Length > 40 ? t.Summary[..40] + "…" : t.Summary ?? "";
    }

