    private static decimal GetAllocatedHoursFromList(Guid memberId, DateOnly date, IEnumerable<TaskAllocation> list)
        => list.Where(a => a.TeamMemberId == memberId && a.Date == date).Sum(a => a.HoursAllocated);

    private decimal GetAllocatedHours(Guid memberId, DateOnly date)
        => GetAllocatedHoursFromList(memberId, date, Allocations);

    private decimal GetRemainingHours(Guid memberId, DateOnly date)
    {
        if (IsDayOff(memberId, date)) return 0m;
        return Math.Max(0m, GetMemberDailyHours(memberId) - GetAllocatedHours(memberId, date));
    }

    private decimal GetMemberSprintCapacity(Guid memberId)
    {
        if (SprintEnd < SprintStart || SprintStart == default) return 0m;
        return Enumerable.Range(0, SprintEnd.DayNumber - SprintStart.DayNumber + 1)
            .Select(i => SprintStart.AddDays(i))
            .Count(d => !IsDayOff(memberId, d)) * GetMemberDailyHours(memberId);
    }

    private decimal GetMemberSprintAllocated(Guid memberId)
        => Allocations
            .Where(a => a.TeamMemberId == memberId && a.Date >= SprintStart && a.Date <= SprintEnd)
            .Sum(a => a.HoursAllocated);

    private decimal GetMemberSprintRemaining(Guid memberId, List<TaskAllocation>? provisional = null)
    {
        var capacity  = GetMemberSprintCapacity(memberId);
        var allocated = GetMemberSprintAllocated(memberId);
        var pending   = provisional?
            .Where(a => a.TeamMemberId == memberId && a.Date >= SprintStart && a.Date <= SprintEnd)
            .Sum(a => a.HoursAllocated) ?? 0m;
        return Math.Max(0m, capacity - allocated - pending);
    }

    private decimal GetTeamCapacityHours(string team)
        => TeamMembers.Where(m => m.Team == team).Sum(m => GetMemberSprintCapacity(m.Id));

    private decimal GetTeamAllocatedHours(string team)
        => TeamMembers.Where(m => m.Team == team).Sum(m => GetMemberSprintAllocated(m.Id));

