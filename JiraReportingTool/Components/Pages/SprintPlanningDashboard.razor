    // ── Block colouring (calm work-type palette; red is reserved for over-capacity) ──
    // Calm, muted palette — deliberately no red/amber so those stay meaningful for problems.
    private static readonly string[] WorkPalette =
        { "#2563eb", "#0d9488", "#7c3aed", "#0891b2", "#6366f1", "#db2777", "#ca8a04", "#475569" };

    private static int StableIndex(string s, int mod)
    {
        if (mod <= 0) return 0;
        int h = 0;
        foreach (var c in s) h = (h * 31 + c) & 0x7fffffff;
        return h % mod;
    }

    private static string GetCategoryColor(string category) => category switch
    {
        "Meeting"     => "#64748b",
        "Support Bug" => "#0891b2",
        "Feature Bug" => "#0d9488",
        "Review"      => "#6366f1",
        "On-Call"     => "#7c3aed",
        _             => "#475569"
    };

    private static string GetTypeColor(string? issueType)
    {
        var t = (issueType ?? "").ToLowerInvariant();
        if (t.Contains("sub")) return "#0891b2";
        return t switch
        {
            "story" => "#2563eb",
            "task"  => "#0d9488",
            "bug"   => "#7c3aed",
            "epic"  => "#6366f1",
            _       => "#475569"
        };
    }

    private string GetBlockColor(int taskId)
    {
        if (_customTasks.TryGetValue(taskId, out var ct))
            return string.IsNullOrWhiteSpace(ct.Color) ? GetCategoryColor(ct.Category) : ct.Color;

        if (_colorMode == "epic")
        {
            var epic = GetEpicKeyForAllocation(taskId);
            if (!string.IsNullOrEmpty(epic)) return WorkPalette[StableIndex(epic, WorkPalette.Length)];
        }
        var issue = _taskCache.TryGetValue(taskId, out var ci) ? ci : null;
        return GetTypeColor(issue?.IssueType);
    }

