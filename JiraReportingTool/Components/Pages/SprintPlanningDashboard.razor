    private async Task LoadPlanAsync(int id)
    {
        _isSaving = true;
        ErrorMessage = null;
        try
        {
            var plan = await PlanService.GetAsync(id);
            if (plan is null) { ErrorMessage = $"Plan #{id} not found."; return; }
            await ApplyPlanAsync(plan);
            _planVersions = await PlanService.GetVersionsAsync(id);
            InfoMessage = $"Plan '{plan.Name}' loaded — {plan.Allocations.Count} allocations.";
        }
        catch (Exception ex) { ErrorMessage = $"Load failed: {ex.Message}"; }
        finally { _isSaving = false; }
    }

    // Applies a SprintPlanHeader to the in-memory state. When keepId=true the
    // current _currentPlanId is preserved (used when restoring a version).
    private async Task ApplyPlanAsync(SprintPlanHeader plan, bool keepId = false)
    {
        if (!keepId)
            _currentPlanId = plan.Id > 0 ? plan.Id : _currentPlanId;

        SprintName          = plan.Name;
        SprintStartDateTime = plan.SprintStart.ToDateTime(TimeOnly.MinValue);
        SprintEndDateTime   = plan.SprintEnd.ToDateTime(TimeOnly.MinValue);
        ApplySprintRange();

        // Reload epics from cache/Jira
        LoadedEpics.Clear();
        _taskCache.Clear();
        var epicKeys = plan.LoadedEpicKeys.Split(',', StringSplitOptions.RemoveEmptyEntries);
        foreach (var key in epicKeys)
            await LoadEpicByKey(key);

        // Restore custom tasks
        _customTasks.Clear();
        foreach (var ct in plan.CustomTasks)
            _customTasks[ct.LocalId] = new CustomTaskEntry
            {
                Id = ct.LocalId, Name = ct.Name,
                Category = ct.Category, Hours = ct.Hours, Color = ct.Color
            };
        _nextCustomTaskId = _customTasks.Count > 0 ? _customTasks.Keys.Min() - 1 : -1;

        // Restore allocations (match member by stable Guid, fallback to name lookup)
        Allocations.Clear();
        foreach (var a in plan.Allocations)
        {
            var memberId = TeamMembers.Any(m => m.Id == a.MemberId)
                ? a.MemberId
                : TeamMembers.FirstOrDefault(m => m.Name == a.MemberName)?.Id ?? a.MemberId;
            Allocations.Add(new TaskAllocation
            {
                TaskId = a.TaskId, TeamMemberId = memberId,
                Date = a.Date, HoursAllocated = a.HoursAllocated, GroupId = a.GroupId
            });
        }

        // Restore holidays & time-off
        Holidays = plan.Holidays.Select(h => h.Date).ToHashSet();
        MemberTimeOff.Clear();
        foreach (var to in plan.TimeOffs)
        {
            if (!MemberTimeOff.ContainsKey(to.MemberId))
                MemberTimeOff[to.MemberId] = new HashSet<DateOnly>();
            MemberTimeOff[to.MemberId].Add(to.Date);
        }
    }

    private async Task RestoreVersionAsync(SprintPlanVersion version)
    {
        _isSaving = true;
        ErrorMessage = null;
        try
        {
            var plan = System.Text.Json.JsonSerializer.Deserialize<SprintPlanHeader>(version.DataJson);
            if (plan is null) { ErrorMessage = "Failed to read version data."; return; }
            await ApplyPlanAsync(plan, keepId: true);
            _showVersionsPanel = false;
            InfoMessage = $"Restored version {version.VersionNumber} (saved {version.SavedAt.ToLocalTime():dd-MMM-yyyy HH:mm}). Save to keep this state.";
        }
        catch (Exception ex) { ErrorMessage = $"Restore failed: {ex.Message}"; }
        finally { _isSaving = false; }
    }

    private async Task DeletePlanAsync()
    {
        if (!_currentPlanId.HasValue) return;
        _isSaving = true;
        ErrorMessage = null;
        try
        {
            await PlanService.DeleteAsync(_currentPlanId.Value);
            InfoMessage    = $"Plan #{_currentPlanId} deleted.";
            _currentPlanId = null;
            _savedPlans    = await PlanService.GetAllAsync();
        }
        catch (Exception ex) { ErrorMessage = $"Delete failed: {ex.Message}"; }
        finally { _isSaving = false; }
    }

    // ───────────────────────────────────────────────────────────
    // Task selection
    // ───────────────────────────────────────────────────────────
    private void SelectTask(SprintIssue task)
    {
        ErrorMessage = null;
        InfoMessage = null;
        SelectedTask = task;
        SelectedCustomTaskId = null;
        PendingPlacement = null;
        InfoMessage = $"Selected {task.Key} ({FormatTaskHours(task)}). Click a calendar cell to place.";
    }

    private void SelectCustomTask(int id)
    {
        ErrorMessage = null;
        InfoMessage = null;
        SelectedTask = null;
        SelectedCustomTaskId = id;
        PendingPlacement = null;
        if (_customTasks.TryGetValue(id, out var ct))
            InfoMessage = $"Selected '{ct.Name}' ({ct.Hours}h). Click a calendar cell to place.";
    }

    private void CancelSelection()
    {
        SelectedTask = null;
        SelectedCustomTaskId = null;
        PendingPlacement = null;
        InfoMessage = "Selection cleared.";
    }

    // ── Custom Task management ──
    private void AddCustomTask()
    {
        ErrorMessage = null;
        if (string.IsNullOrWhiteSpace(NewCustomTaskName)) { ErrorMessage = "Enter a task name."; return; }
        if (NewCustomTaskHours <= 0m) { ErrorMessage = "Hours must be greater than 0."; return; }

        var color = NewCustomTaskCategory switch
        {
            "Meeting"     => "#8b5cf6",
            "Support Bug" => "#ef4444",
            "Review"      => "#f59e0b",
            "On-Call"     => "#f97316",
            _             => "#6366f1"
        };

        var id = _nextCustomTaskId--;
        _customTasks[id] = new CustomTaskEntry
        {
            Id = id, Name = NewCustomTaskName,
            Category = NewCustomTaskCategory,
            Hours = NewCustomTaskHours,
            Color = color
        };

        InfoMessage = $"'{NewCustomTaskName}' added. Click it to select, then click a calendar cell.";
        NewCustomTaskName = "";
        NewCustomTaskHours = 1m;
    }

    private void RemoveCustomTask(int id)
    {
        if (_customTasks.TryGetValue(id, out var ct))
        {
            Allocations.RemoveAll(a => a.TaskId == id);
            _customTasks.Remove(id);
            if (SelectedCustomTaskId == id) SelectedCustomTaskId = null;
            InfoMessage = $"'{ct.Name}' and all its allocations removed.";
        }
    }

    private void ToggleCustomTaskForm() => ShowCustomTaskForm = !ShowCustomTaskForm;

    private bool HasActiveSelection => SelectedTask is not null || SelectedCustomTaskId.HasValue;

    private string GetActivePlacementLabel()
    {
        if (SelectedTask is not null)
            return $"{SelectedTask.Key} — {SelectedTask.Summary} ({FormatTaskHours(SelectedTask)})";
        if (SelectedCustomTaskId.HasValue && _customTasks.TryGetValue(SelectedCustomTaskId.Value, out var ct))
            return $"{ct.Category}: {ct.Name} ({ct.Hours}h)";
        return "";
    }

    private string GetBlockColor(int taskId)
    {
        if (_customTasks.TryGetValue(taskId, out var ct)) return ct.Color;
        return "#3b82f6";
    }

    private void CancelPlacement()
    {
        PendingPlacement = null;
        InfoMessage = "Placement cancelled.";
    }

    // ───────────────────────────────────────────────────────────
    // Time Off / Holiday helpers
    // ───────────────────────────────────────────────────────────
    private void ToggleTimeOffMode()
    {
        TimeOffMode = !TimeOffMode;
        InfoMessage = TimeOffMode
            ? "Time Off Mode ON — click cells to mark time off; click date headers to mark holidays."
            : "Time Off Mode OFF.";
    }

    private bool IsHoliday(DateOnly date) => Holidays.Contains(date);

    private bool IsMemberTimeOff(Guid memberId, DateOnly date)
        => MemberTimeOff.TryGetValue(memberId, out var days) && days.Contains(date);

    private bool IsDayOff(Guid memberId, DateOnly date)
        => IsWeekend(date) || IsHoliday(date) || IsMemberTimeOff(memberId, date);

    private void ToggleHoliday(DateOnly date)
    {
        if (Holidays.Contains(date)) Holidays.Remove(date);
        else Holidays.Add(date);
        InfoMessage = Holidays.Contains(date)
            ? $"{date:dd-MMM} marked as holiday."
            : $"{date:dd-MMM} holiday removed.";
    }

    private void ToggleMemberTimeOff(Guid memberId, DateOnly date)
    {
        if (!MemberTimeOff.ContainsKey(memberId))
            MemberTimeOff[memberId] = new HashSet<DateOnly>();

        var name = TeamMembers.FirstOrDefault(m => m.Id == memberId)?.Name ?? "Member";
        if (MemberTimeOff[memberId].Contains(date))
        {
            MemberTimeOff[memberId].Remove(date);
            InfoMessage = $"Removed time off for {name} on {date:dd-MMM}.";
        }
        else
        {
            MemberTimeOff[memberId].Add(date);
            InfoMessage = $"Marked {name} as off on {date:dd-MMM}.";
        }
    }

    private void OnDateHeaderClicked(DateOnly date)
    {
        if (TimeOffMode) ToggleHoliday(date);
    }

    private static bool IsWeekend(DateOnly date)
        => date.DayOfWeek == DayOfWeek.Saturday || date.DayOfWeek == DayOfWeek.Sunday;

    // ───────────────────────────────────────────────────────────
    // Calendar cell click
    // ───────────────────────────────────────────────────────────
    private void OnCalendarCellClicked(Guid memberId, DateOnly date)
    {
        ErrorMessage = null;
        InfoMessage = null;

        if (TimeOffMode)
        {
            ToggleMemberTimeOff(memberId, date);
            return;
        }

        // Resolve selected task info (Jira task OR custom task)
        int? activeTaskId   = SelectedTask?.Id ?? SelectedCustomTaskId;
        decimal totalHoursResolved;
        string taskLabel;

        if (SelectedTask is not null)
        {
            totalHoursResolved = GetTaskHours(SelectedTask);
            taskLabel = SelectedTask.Key;
        }
        else if (SelectedCustomTaskId.HasValue && _customTasks.TryGetValue(SelectedCustomTaskId.Value, out var selCt))
        {
            totalHoursResolved = selCt.Hours;
            taskLabel = selCt.Name;
        }
        else
        {
            ErrorMessage = "Select a task first.";
            return;
        }

        if (PendingPlacement is null)
        {
            PendingPlacement = new PendingPlacementState { TeamMemberId = memberId, Start = date };
            return;
        }

        if (PendingPlacement.TeamMemberId != memberId)
        {
            ErrorMessage = "Second click must be on the same member row.";
            return;
        }

        var startDate = date < PendingPlacement.Start ? date : PendingPlacement.Start;

        if (totalHoursResolved <= 0m)
        {
            ErrorMessage = $"'{taskLabel}' has no estimate — cannot schedule.";
            PendingPlacement = null;
            return;
        }

        var memberName = TeamMembers.First(x => x.Id == memberId).Name;
        var newAllocs  = ScheduleTask(activeTaskId!.Value, memberId, totalHoursResolved, startDate);
        var scheduledHours = newAllocs.Sum(a => a.HoursAllocated);

        if (scheduledHours < totalHoursResolved)
        {
            // Capacity insufficient — ask user whether to schedule over the 6h/day limit
            _overCapacityPending = new OverCapacityPending(
                activeTaskId.Value, memberId, totalHoursResolved, startDate, taskLabel, memberName);
            _showOverCapacityDialog = true;
            PendingPlacement = null;
            return;
        }

        Allocations.AddRange(newAllocs);
        var lastDate = newAllocs.Max(a => a.Date);
        InfoMessage = $"Scheduled '{taskLabel}' for {memberName}: {totalHoursResolved:0.#}h from {startDate:dd-MMM} → {lastDate:dd-MMM}.";
        SelectedTask = null;
        SelectedCustomTaskId = null;
        PendingPlacement = null;
    }

    // ───────────────────────────────────────────────────────────
    // Scheduling engine (6h/day, day-aware, time-off aware)
    // ───────────────────────────────────────────────────────────
    private List<TaskAllocation> ScheduleTask(
        int taskId, Guid memberId, decimal totalHours, DateOnly startDate,
        List<TaskAllocation>? provisional = null, bool forceOverCapacity = false)
    {
        var result    = new List<TaskAllocation>();
        var groupId   = Guid.NewGuid();
        var remaining = totalHours;
        var date      = startDate;
        const int maxDaysForward = 365;

        for (int d = 0; remaining > 0m && d < maxDaysForward; d++)
        {
            if (!IsDayOff(memberId, date))
            {
                decimal capacity;
                if (forceOverCapacity)
                {
                    // Ignore existing allocations — allow day to exceed 6h limit
                    capacity = MaxHoursPerDay;
                }
                else
                {
                    var committed = GetAllocatedHoursFromList(memberId, date, Allocations);
                    var pending   = provisional is not null ? GetAllocatedHoursFromList(memberId, date, provisional) : 0m;
                    capacity = Math.Max(0m, MaxHoursPerDay - committed - pending);
                }

                if (capacity > 0m)
                {
                    var hours = Math.Min(remaining, capacity);
                    result.Add(new TaskAllocation
                    {
                        GroupId = groupId, TaskId = taskId, TeamMemberId = memberId,
                        Date = date, HoursAllocated = hours
                    });
                    remaining -= hours;
                }
            }
            date = date.AddDays(1);
        }

        return result;
    }

    // ───────────────────────────────────────────────────────────
    // Over-capacity dialog handlers
    // ───────────────────────────────────────────────────────────
    private void ConfirmOverCapacity()
    {
        if (_overCapacityPending is null) return;
        var p = _overCapacityPending;
        var forced = ScheduleTask(p.TaskId, p.MemberId, p.TotalHours, p.StartDate, forceOverCapacity: true);
        if (forced.Count > 0)
        {
            Allocations.AddRange(forced);
            var lastDate = forced.Max(a => a.Date);
            InfoMessage = $"Scheduled '{p.TaskLabel}' for {p.MemberName}: {p.TotalHours:0.#}h from {p.StartDate:dd-MMM} → {lastDate:dd-MMM} (over capacity).";
        }
        else
        {
            ErrorMessage = $"Could not schedule '{p.TaskLabel}' — no working days available.";
        }
        SelectedTask = null;
        SelectedCustomTaskId = null;
        _overCapacityPending    = null;
        _showOverCapacityDialog = false;
    }

    private void CancelOverCapacity()
    {
        _overCapacityPending    = null;
        _showOverCapacityDialog = false;
        InfoMessage = "Scheduling cancelled.";
    }

    // ───────────────────────────────────────────────────────────
    // Auto-Assign: assign all unassigned tasks by capacity
    // ───────────────────────────────────────────────────────────
    private void AutoAssignAllUnassigned()
    {
        ErrorMessage = null;
        InfoMessage = null;

        var unassigned = GetAllTasks()
            .Where(t => !IsTaskAssigned(t.Id))
            .Select(t => (Task: t, Hours: GetTaskHours(t)))
            .Where(x => x.Hours > 0m)
            .OrderByDescending(x => x.Hours)   // biggest tasks first
            .ToList();

        if (unassigned.Count == 0) { InfoMessage = "No unassigned tasks with estimates."; return; }

        var provisional = new List<TaskAllocation>();
        var assigned    = 0;

        foreach (var (task, hours) in unassigned)
        {
            // Pick the member with the most remaining sprint capacity
            var bestMember = (string.IsNullOrEmpty(ActiveTeamFilter)
                    ? TeamMembers
                    : TeamMembers.Where(m => m.Team == ActiveTeamFilter))
                .OrderByDescending(m => GetMemberSprintRemaining(m.Id, provisional))
                .FirstOrDefault();

            if (bestMember is null) break;
            if (GetMemberSprintRemaining(bestMember.Id, provisional) <= 0m) continue;

            var startDate = GetNextAvailableDay(bestMember.Id, SprintStart, provisional);
            if (startDate is null) continue;

            var newAllocs = ScheduleTask(task.Id, bestMember.Id, hours, startDate.Value, provisional);
            if (newAllocs.Count > 0) { provisional.AddRange(newAllocs); assigned++; }
        }

        Allocations.AddRange(provisional);
        InfoMessage = assigned > 0
            ? $"Auto-assigned {assigned} task(s) to the team."
            : "Could not assign any tasks — insufficient capacity.";
    }

    private DateOnly? GetNextAvailableDay(Guid memberId, DateOnly from, List<TaskAllocation>? provisional = null)
    {
        foreach (var date in VisibleDates.Where(d => d >= from))
        {
            if (IsDayOff(memberId, date)) continue;
            var committed = GetAllocatedHoursFromList(memberId, date, Allocations);
            var pending   = provisional is not null ? GetAllocatedHoursFromList(memberId, date, provisional) : 0m;
            if (committed + pending < MaxHoursPerDay) return date;
        }
        return null;
    }

