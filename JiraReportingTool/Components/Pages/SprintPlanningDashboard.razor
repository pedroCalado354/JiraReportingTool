    // CSS class builders
    // ───────────────────────────────────────────────────────────
    private string BuildCellClass(Guid memberId, decimal allocated, bool isDayOff, bool isWeekend, bool isToday)
    {
        if (isDayOff) return isWeekend ? "cell stacked-cell weekend-cell" : "cell stacked-cell cell-dayoff";
        var dailyCap = GetMemberDailyHours(memberId);
        var baseClass = "cell stacked-cell";
        if (allocated > dailyCap) baseClass += " cell-over";       // red — genuinely over capacity
        else if (isToday) baseClass += " cell-today";
        else if (allocated >= dailyCap) baseClass += " cell-full"; // at capacity — calm/neutral
        else if (allocated > 0m) baseClass += " cell-partial";
        return baseClass;
    }

    private string BuildCellTitle(Guid memberId, DateOnly date, decimal allocated, bool isDayOff, bool isHoliday)
    {
        if (TimeOffMode)
        {
            var isOff = IsMemberTimeOff(memberId, date);
            return isOff ? $"Click to remove time off: {date:dd-MMM}" : $"Click to mark time off: {date:dd-MMM}";
        }
        if (isDayOff) return isHoliday ? "Holiday — no capacity" : "Time off — no capacity";
        var remaining = Math.Max(0m, GetMemberDailyHours(memberId) - allocated);
        return $"{allocated:0.#}h allocated · {remaining:0.#}h remaining";
    }

    private string GetDateColTitle(DateOnly date)
    {
        if (!TimeOffMode) return date.ToString("dddd, dd MMM yyyy");
        return IsHoliday(date) ? $"Click to remove holiday: {date:dd-MMM}" : $"Click to mark as holiday: {date:dd-MMM}";
    }

