    }

    // The "Unassigned" row (worklogs whose author matches no roster member) drill-down toggle.
    private bool _unassignedBugRowExpanded;

    // One row per support-bug issue a member logged time on, within [from, to].
    private sealed record BugLogRow(string Key, string Summary, int Seconds, int Worklogs, DateTime LastActivity);

    private List<TaskAllocation> Allocations { get; set; } = new();
    private Dictionary<int, SprintIssue> _taskCache = new();
    // Fallback labels loaded from persisted SprintPlanAllocation.TaskLabel when _taskCache misses.
    private Dictionary<int, string> _taskLabelFallback = new();
    private HashSet<DateOnly> Holidays { get; set; } = new();
    private Dictionary<Guid, HashSet<DateOnly>> MemberTimeOff { get; set; } = new();
    private bool TimeOffMode { get; set; } = false;

    private SprintIssue? SelectedTask { get; set; }
    private int? SelectedCustomTaskId { get; set; }
    private PendingPlacementState? PendingPlacement { get; set; }

    // Drag-to-reschedule: the GroupId of the calendar block currently being dragged.
    private Guid? _dragGroupId;

    // ── Custom Tasks ──
    private Dictionary<int, CustomTaskEntry> _customTasks = new();
    private int _nextCustomTaskId = -1;
    private bool ShowCustomTaskForm { get; set; } = false;
    private string NewCustomTaskName { get; set; } = "";
    private decimal NewCustomTaskHours { get; set; } = 1m;

    // Custom-task categories (managed on Sprint Planning Config) + current picker selection.
    private List<CustomTaskTemplate> _customTaskTemplates = new();
    private int SelectedTemplateId { get; set; }
    private string NewFeatureBugEpicKey { get; set; } = "";   // epic key for a picked "Feature Bug" task

    // TeamMembers = the rows the board renders: active roster members, plus any (now-inactive)
    // members still referenced by a loaded plan so historical plans never lose people.
    private List<TeamMemberDto> TeamMembers { get; set; } = new();
    // Per-member daily capacity (hours), keyed by the deterministic member Guid. Falls back to the default.
    private Dictionary<Guid, decimal> _memberHours = new();
    private List<RosterMember> _allRoster = new();           // full roster incl. inactive (for lookups)
    private HashSet<Guid> _activeMemberIds = new();          // assignment pool (auto-assign/import targets)
    private string? ErrorMessage { get; set; }
    private string? InfoMessage  { get; set; }
    private bool _calendarFullPage;

    // ── Plan CRUD ──
    private int?                  _currentPlanId;
    private List<SprintPlanHeader> _savedPlans = new();
    private bool                  _isSaving   = false;
    private int                   _loadPlanId = 0;

    // ── Unsaved-changes tracking ──
    // Hash of the plan state at last save/load; IsDirty compares it to current state.
    private string   _savedStateHash = "";
    private DateTime? _loadedUpdatedAt;          // header timestamp at load, for concurrency detection
    private bool     _forceSaveOverwrite = false; // set when the user confirms overwriting a newer save

    private bool IsDirty => ComputeStateHash() != _savedStateHash;

    private string ComputeStateHash()
    {
        var sb = new System.Text.StringBuilder();
        sb.Append(SprintName).Append('|').Append(SprintStart).Append('|').Append(SprintEnd).Append('|');
        sb.Append(string.Join(",", LoadedEpics.Keys.OrderBy(k => k))).Append('|');
        sb.Append(string.Join(",", LoadedTasks.Keys.OrderBy(k => k))).Append('|');
        sb.Append(string.Join(",", LoadedSupportBugEpics.Keys.OrderBy(k => k))).Append('|');
        foreach (var a in Allocations.OrderBy(a => a.TaskId).ThenBy(a => a.TeamMemberId).ThenBy(a => a.Date))
            sb.Append(a.TaskId).Append(':').Append(a.TeamMemberId).Append(':').Append(a.Date.DayNumber).Append(':').Append(a.HoursAllocated).Append(';');
        sb.Append('|');
        foreach (var ct in _customTasks.Values.OrderBy(c => c.Id))
            sb.Append(ct.Id).Append(':').Append(ct.Name).Append(':').Append(ct.Hours).Append(':').Append(ct.Category).Append(';');
        sb.Append('|');
        foreach (var h in Holidays.OrderBy(d => d)) sb.Append(h.DayNumber).Append(',');
        sb.Append('|');
        foreach (var kvp in MemberTimeOff.OrderBy(k => k.Key))
            foreach (var d in kvp.Value.OrderBy(x => x)) sb.Append(kvp.Key).Append(d.DayNumber).Append(',');
        return sb.ToString();
    }

    private void ResetDirtyBaseline() => _savedStateHash = ComputeStateHash();

    // ── Plan versions ──
    private List<SprintPlanVersion> _planVersions    = new();
    private bool                    _showVersionsPanel = false;

    // ── Over-capacity dialog ──
    private bool _showOverCapacityDialog = false;
    private record OverCapacityPending(
        int TaskId, Guid MemberId, decimal TotalHours, DateOnly StartDate, string TaskLabel, string MemberName);
    private OverCapacityPending? _overCapacityPending;

    // ── Removal dialog ──
    private bool             _showRemovalDialog      = false;
    private Guid             _removalPendingGroupId;
    private string           _removalPendingTaskLabel  = "";
    private string           _removalPendingMemberName = "";
    private string _removalReason = "";

    // ── No-estimate dialog ──
    private bool   _showNoEstimateDialog = false;
    private record NoEstimatePending(int TaskId, Guid MemberId, DateOnly StartDate, string TaskLabel, string MemberName);
    private NoEstimatePending? _noEstimatePending;
    private string  _noEstimateHoursInput = "";
    private string? _noEstimateError      = null;

    // ── Global busy overlay ── (null = idle; otherwise the message shown over a dimmed page)
    private string? _busyMessage = "Loading sprint planner…";

    // Shows the blocking overlay with <message>, paints it, runs <work>, then clears it.
    // The StateHasChanged + Task.Yield pair forces the overlay to render before <work>
    // begins, even when the work is fast/synchronous (cache hits) and wouldn't otherwise yield.
    private async Task RunBusyAsync(string message, Func<Task> work)
    {
        _busyMessage = message;
        StateHasChanged();
        await Task.Yield();
        try { await work(); }
        finally { _busyMessage = null; }
    }

    // ── Team Load breakdown dialog ── (null = closed; otherwise the team name)
    private string? _teamLoadDetail = null;
    private bool _supportBugDetail = false;
    private decimal _bugAvgHours = 5m;

    // ── Removal logs dialog ──
    private bool                       _showRemovalLogsDialog = false;
    private bool                       _isLoadingLogs         = false;
    private List<SprintPlanRemovalLog> _removalLogs           = new();

    private const decimal DefaultHoursPerDay = 6m;   // fallback daily capacity when a member has no roster value
    private const decimal HoursPerDay = 6m;          // Jira-duration parsing: hours in a Jira "day"
    private const decimal DaysPerWeek = 5m;          // Jira-duration parsing: days in a Jira "week"

    // Shared (bank) holidays from the roster admin page — merged into every plan's holiday set.
    private List<SharedHoliday> _sharedHolidays = new();

    // ───────────────────────────────────────────────────────────
    // Computed properties
    // ───────────────────────────────────────────────────────────
    private List<SprintIssue> GetAllTasks()
        => LoadedEpics.Values.SelectMany(e => e.Tasks)
            .Concat(LoadedTasks.Values)
            .GroupBy(t => t.Id)
            .Select(g => g.First())
            .ToList();

    private bool IsTaskAssigned(int taskId)
        => Allocations.Any(a => a.TaskId == taskId);

    private string? GetTaskAssigneeName(int taskId)
    {
        var memberId = Allocations.FirstOrDefault(a => a.TaskId == taskId)?.TeamMemberId;
        if (memberId is null) return null;
        return TeamMembers.FirstOrDefault(m => m.Id == memberId.Value)?.Name;
    }

    private int TotalTaskCount => GetAllTasks().Count;
    private int AssignedCount => GetAllTasks().Count(t => IsTaskAssigned(t.Id));
    private int UnassignedCount => TotalTaskCount - AssignedCount;
    private decimal TotalScopeHours => GetAllTasks().Sum(t => GetTaskHours(t));
    private decimal TotalAllocatedHours => Allocations
        .Where(a => a.Date >= SprintStart && a.Date <= SprintEnd)
        .Sum(a => a.HoursAllocated);
    private decimal CoveragePercent => TotalTaskCount == 0 ? 0m : (AssignedCount * 100m / TotalTaskCount);

    private int WorkingDaysCount => SprintEnd >= SprintStart && SprintStart != default
        ? Enumerable.Range(0, SprintEnd.DayNumber - SprintStart.DayNumber + 1)
            .Select(i => SprintStart.AddDays(i))
            .Count(d => !IsWeekend(d) && !IsHoliday(d))
        : 0;

    // ── Sprint stats strip ──
    private int ScheduledJiraTaskCount
        => Allocations.Where(a => a.TaskId > 0).Select(a => a.TaskId).Distinct().Count();

    private int ScheduledCustomTaskCount
        => Allocations.Where(a => a.TaskId < 0).Select(a => a.TaskId).Distinct().Count();

    private int ScheduledTotalCount => ScheduledJiraTaskCount + ScheduledCustomTaskCount;

    private IReadOnlyList<SprintIssue> GetScheduledIssues()
        => Allocations
            .Where(a => a.TaskId > 0)
            .Select(a => a.TaskId)
            .Distinct()
            .Select(id =>
            {
                var key = GetJiraKeyForTaskId(id);
                if (key != null && _reportIssues.TryGetValue(key, out var ri)) return ri;
                return _taskCache.TryGetValue(id, out var ci) ? ci : null;
            })
            .Where(t => t != null)
            .Select(t => t!)
            .ToList();

    private int DoneTaskCount      => GetScheduledIssues().Count(t => t.StatusCategoryKey == "done");
    private int InProgressCount    => GetScheduledIssues().Count(t => t.StatusCategoryKey == "indeterminate");
    private int BlockedStatCount   => GetScheduledIssues().Count(t => string.Equals(t.Status, "On Hold", StringComparison.OrdinalIgnoreCase));
    private int MissingEstCount    => GetScheduledIssues().Count(t =>
        t.StatusCategoryKey != "done" && t.OriginalEstimateSeconds > 0 && t.ComputedRemainingSeconds == 0);

    private decimal SupportBugAllocatedHours =>
        _customTasks.Values
            .Where(ct => ct.Category == "Support Bug")
            .Sum(ct => Allocations
                .Where(a => a.TaskId == ct.Id && !IsDayOff(a.TeamMemberId, a.Date)
                    && a.Date >= SprintStart && a.Date <= SprintEnd)
                .Sum(a => a.HoursAllocated));

    private double DonePct => ScheduledJiraTaskCount == 0 ? 0
        : (double)DoneTaskCount / ScheduledJiraTaskCount * 100;

    private string GetDonePctClass() => ScheduledJiraTaskCount == 0 ? ""
        : DonePct >= 80 ? "stat-green" : DonePct >= 40 ? "stat-amber" : "stat-red";

    private int RemainingWorkingDays
    {
        get
        {
            var today = DateOnly.FromDateTime(DateTime.Today);
            if (SprintEnd == default || SprintEnd < today) return 0;
            var from = today > SprintStart ? today : SprintStart;
            return Enumerable.Range(0, SprintEnd.DayNumber - from.DayNumber + 1)
                .Select(i => from.AddDays(i))
                .Count(d => !IsWeekend(d) && !IsHoliday(d));
        }
    }

    // At-risk = incomplete tasks belonging to members whose total remaining work
    // exceeds their remaining capacity (i.e. the assignee is collectively overbooked).
    private int AtRiskCount
    {
        get
        {
            var issuesById = GetScheduledIssues()
                .GroupBy(t => t.Id)
                .ToDictionary(g => g.Key, g => g.First());

            var atRisk = 0;
            var memberIds = Allocations
                .Where(a => a.TaskId > 0)
                .Select(a => a.TeamMemberId)
                .Distinct();

            foreach (var memberId in memberIds)
            {
                var memberIssues = Allocations
                    .Where(a => a.TeamMemberId == memberId && a.TaskId > 0)
                    .Select(a => a.TaskId)
                    .Distinct()
                    .Where(id => issuesById.ContainsKey(id))
                    .Select(id => issuesById[id])
                    .Where(t => t.StatusCategoryKey != "done" && t.ComputedRemainingSeconds > 0)
                    .ToList();

                var totalRemaining = memberIssues.Sum(t => (long)t.ComputedRemainingSeconds);
                if (totalRemaining > GetMemberRemainingCapacitySeconds(memberId))
                    atRisk += memberIssues.Count;
            }
            return atRisk;
        }
    }

    // ── Sprint summary / closing metrics (commitment vs completion) ──
    private sealed record SummaryMetrics(
        int CommittedTasks, int DoneTasks, int InProgressTasks, int NotStartedTasks, int AtRisk,
        long CommittedSeconds, long DoneSeconds, long LoggedSeconds);

    private record TeamSummaryRow(string Team, int Committed, int Done, decimal CommittedHours, decimal DoneHours);

    // Maps each scheduled Jira task to the team of the member it's assigned to.
    private string GetTeamForScheduledTask(int taskId)
    {
        var memberId = Allocations.FirstOrDefault(a => a.TaskId == taskId)?.TeamMemberId;
        if (memberId is null) return "Unassigned";
        return TeamMembers.FirstOrDefault(m => m.Id == memberId.Value)?.Team ?? "Unassigned";
    }

    private SummaryMetrics GetSummaryMetrics()
    {
        var issues = GetScheduledIssues();
        var committedSec = issues.Sum(t => (long)t.OriginalEstimateSeconds);
        var doneSec      = issues.Where(t => t.StatusCategoryKey == "done").Sum(t => (long)t.OriginalEstimateSeconds);
        var loggedSec    = issues.Sum(t => (long)t.TimeSpentSeconds);
        return new SummaryMetrics(
            CommittedTasks:  issues.Count,
            DoneTasks:       issues.Count(t => t.StatusCategoryKey == "done"),
            InProgressTasks: issues.Count(t => t.StatusCategoryKey == "indeterminate"),
            NotStartedTasks: issues.Count(t => t.StatusCategoryKey == "new"),
            AtRisk:          AtRiskCount,
            CommittedSeconds: committedSec,
            DoneSeconds:      doneSec,
            LoggedSeconds:    loggedSec);
    }

    private List<TeamSummaryRow> GetTeamSummaryRows()
    {
        var issues = GetScheduledIssues();
        return issues
            .GroupBy(t => GetTeamForScheduledTask(t.Id))
            .Select(g => new TeamSummaryRow(
                g.Key,
                g.Count(),
                g.Count(t => t.StatusCategoryKey == "done"),
                g.Sum(t => t.OriginalEstimateSeconds) / 3600m,
                g.Where(t => t.StatusCategoryKey == "done").Sum(t => t.OriginalEstimateSeconds) / 3600m))
            .OrderBy(r => r.Team)
            .ToList();
    }

    private static double Pct(double part, double whole) => whole <= 0 ? 0 : part / whole * 100;
    private static string PctClass(double pct) => pct >= 80 ? "kpi-green" : pct >= 40 ? "kpi-amber" : "kpi-red";
    private static string GetPctBadge(double pct) => pct >= 80 ? "risk-green" : pct >= 40 ? "risk-amber" : "risk-red";

    // ── Report completion badge ──
    private static string GetCompletionPct(ReportRow row)
    {
        if (row.IsCustom)
        {
            if ((row.CustomCategory == "Support Bug" || row.CustomCategory == "Feature Bug") && row.CustomHours > 0)
                return $"{row.SupportBugLoggedSeconds / (double)(row.CustomHours * 3600) * 100:0}%";
            return "—";
        }
        if (string.Equals(row.StatusCategoryKey, "done", StringComparison.OrdinalIgnoreCase)) return "100%";
        if (row.OriginalEstimateSeconds > 0)
            return $"{(double)row.TimeSpentSeconds / row.OriginalEstimateSeconds * 100:0}%";
        var total = row.TimeSpentSeconds + row.ComputedRemainingSeconds;
        if (total == 0) return "—";
        var pct = (double)row.TimeSpentSeconds / total * 100;
        return $"{Math.Min(pct, 99):0}%";
    }

    private static string GetCompletionBadgeClass(ReportRow row)
    {
        if (row.IsCustom)
        {
            if ((row.CustomCategory == "Support Bug" || row.CustomCategory == "Feature Bug") && row.CustomHours > 0)
            {
                var pct = row.SupportBugLoggedSeconds / (double)(row.CustomHours * 3600) * 100;
                if (pct > 100) return "risk-red";
                if (pct >= 80) return "risk-amber";
                return "risk-green";
            }
            return "risk-gray";
        }
        if (string.Equals(row.StatusCategoryKey, "done", StringComparison.OrdinalIgnoreCase)) return "risk-green";
        double completionPct;
        if (row.OriginalEstimateSeconds > 0)
            completionPct = (double)row.TimeSpentSeconds / row.OriginalEstimateSeconds * 100;
        else
        {
            var total = row.TimeSpentSeconds + row.ComputedRemainingSeconds;
            if (total == 0) return "risk-amber";
            completionPct = (double)row.TimeSpentSeconds / total * 100;
        }
        if (completionPct > 100) return "risk-red";
        if (completionPct >= 80) return "risk-green";
        if (completionPct >= 40) return "risk-amber";
        return row.TimeSpentSeconds > 0 ? "risk-red" : "risk-gray";
    }

    // ── Feasibility ──
    // Feasibility is now assignee-aware: a task is only "Feasible" if it fits within the
    // member's remaining capacity AFTER accounting for all their other assigned work.
    private static bool IsMemberOverbooked(ReportRow row)
        => row.MemberTotalRemainingSeconds > row.MemberRemainingCapacitySeconds;

    private string GetFeasibilityLabel(ReportRow row)
    {
        if (row.IsCustom) return "—";
        if (string.Equals(row.StatusCategoryKey, "done", StringComparison.OrdinalIgnoreCase)) return "✓ Done";
        if (row.ComputedRemainingSeconds == 0) return "No Estimate";
        return IsMemberOverbooked(row) ? "✗ Over Capacity" : "✓ Feasible";
    }

    private string GetFeasibilityClass(ReportRow row)
    {
        if (row.IsCustom) return "feas-na";
        if (string.Equals(row.StatusCategoryKey, "done", StringComparison.OrdinalIgnoreCase)) return "feas-done";
        if (row.ComputedRemainingSeconds == 0) return "feas-unknown";
        return IsMemberOverbooked(row) ? "feas-fail" : "feas-ok";
    }

    // ── Today's Activity ──
    private record TodayLogLine(string IssueKey, string IssueSummary, int SecondsLogged, bool IsInCalendar);

    private List<(string Author, int TotalSec, List<TodayLogLine> Lines)> GetTodayActivity()
    {
        if (_reportIssues.Count == 0) return [];
        var today = DateTime.Today;
        var calendarKeys = Allocations
            .Where(a => a.TaskId > 0)
            .Select(a => GetJiraKeyForTaskId(a.TaskId))
            .Where(k => k != null)
            .Select(k => k!)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        return _reportIssues.Values
            .SelectMany(issue => issue.Worklogs
                .Where(w => w.Started.Date == today)
                .Select(w => (w.Author, Line: new TodayLogLine(
                    issue.Key, issue.Summary, w.TimeSpentSeconds, calendarKeys.Contains(issue.Key)))))
            .GroupBy(x => x.Author, StringComparer.OrdinalIgnoreCase)
            .Select(g => (
                g.Key,
                g.Sum(x => x.Line.SecondsLogged),
                g.Select(x => x.Line).OrderByDescending(l => l.SecondsLogged).ToList()))
            .OrderByDescending(x => x.Item2)
            .ToList();
    }

    // Matches a Jira author/assignee display name to a roster member name on word boundaries,
    // so "Sam" no longer matches "Samuel" and "Rui" no longer matches "Ruiz".
    private static bool AuthorMatchesMember(string? author, string memberName)
    {
        if (string.IsNullOrWhiteSpace(author) || string.IsNullOrWhiteSpace(memberName)) return false;
        var words = author.Split(new[] { ' ', '.', ',', '-', '_', '@', '(', ')', '\t' },
                                 StringSplitOptions.RemoveEmptyEntries);
        return words.Any(w => string.Equals(w, memberName, StringComparison.OrdinalIgnoreCase));
    }

    // Decides whether a worklog belongs to a roster member, in priority order:
    //   1. Jira accountId   — exact, the identifier Jira itself matches on (most reliable)
    //   2. Email            — exact, when the roster and the worklog author both expose it
    //   3. Display-name heuristic — legacy fallback for members with no Jira id configured
    // The strong identifiers only short-circuit when BOTH sides have a value to compare, so a
    // member with an accountId set still matches name-only worklogs (e.g. older index data).
    private bool WorklogByMember(WorklogEntry w, string memberName)
    {
        if (_rosterByName.TryGetValue(memberName, out var r))
        {
            if (!string.IsNullOrWhiteSpace(r.JiraAccountId) && !string.IsNullOrWhiteSpace(w.AuthorAccountId))
                return string.Equals(r.JiraAccountId, w.AuthorAccountId, StringComparison.OrdinalIgnoreCase);
            if (!string.IsNullOrWhiteSpace(r.JiraEmail) && !string.IsNullOrWhiteSpace(w.AuthorEmail))
                return string.Equals(r.JiraEmail, w.AuthorEmail, StringComparison.OrdinalIgnoreCase);
        }
        return AuthorMatchesMember(w.Author, memberName);
    }

    private static string FmtSec(int seconds)
    {
        if (seconds == 0) return "0h";
        var abs = Math.Abs(seconds);
        var h = abs / 3600;
        var m = (abs % 3600) / 60;
        var s = h > 0 && m > 0 ? $"{h}h {m}m" : h > 0 ? $"{h}h" : $"{m}m";
        return seconds < 0 ? $"-{s}" : s;
    }

