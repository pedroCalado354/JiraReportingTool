    // ── Report / Daily shared data ──
    // Keyed by Jira issue key (e.g. "JM-14506") — populated on Report/Daily view switch.
    // Using key instead of DB ID avoids stale ID issues caused by epic cache invalidation.
    private Dictionary<string, SprintIssue> _reportIssues = new(StringComparer.OrdinalIgnoreCase);
    private bool _isRefreshingReport = false;

    private string GetEpicKeyForAllocation(int taskId)
    {
        var jk = GetJiraKeyForTaskId(taskId);
        if (jk == null) return "";
        foreach (var kvp in LoadedEpics)
            if (kvp.Value.Tasks.Any(t => t.Key.Equals(jk, StringComparison.OrdinalIgnoreCase)))
                return kvp.Key;
        return "";
    }

    private string? GetJiraKeyForTaskId(int taskId)
    {
        if (_taskCache.TryGetValue(taskId, out var cached) && !string.IsNullOrEmpty(cached.Key))
            return cached.Key;
        if (_taskLabelFallback.TryGetValue(taskId, out var label))
        {
            // Stored format: "KEY - SUMMARY (Est: X)" — split on " - " to get the key
            var dashIdx = label.IndexOf(" - ", StringComparison.Ordinal);
            if (dashIdx > 0) return label[..dashIdx].Trim();
            // Older format fallback: "KEY: SUMMARY"
            var colonIdx = label.IndexOf(':');
            if (colonIdx > 0) return label[..colonIdx].Trim();
        }
        return null;
    }

    private static string FormatEstimate(string estimateStr, int estimateSeconds)
    {
        if (!string.IsNullOrEmpty(estimateStr) && estimateStr != "-") return estimateStr;
        if (estimateSeconds <= 0) return "—";
        const int sPerMin = 60, sPerHour = 3600, sPerDay = 28800, sPerWeek = 144000;
        var w = estimateSeconds / sPerWeek; estimateSeconds %= sPerWeek;
        var d = estimateSeconds / sPerDay;  estimateSeconds %= sPerDay;
        var h = estimateSeconds / sPerHour; estimateSeconds %= sPerHour;
        var m = estimateSeconds / sPerMin;
        var parts = new List<string>();
        if (w > 0) parts.Add($"{w}w");
        if (d > 0) parts.Add($"{d}d");
        if (h > 0) parts.Add($"{h}h");
        if (m > 0) parts.Add($"{m}m");
        return parts.Count > 0 ? string.Join(" ", parts) : "—";
    }

    private async Task RefreshReportDataAsync()
    {
        _isRefreshingReport = true;
        _reportIssues.Clear();
        StateHasChanged();
        await Task.Yield();   // let the spinner paint before the (possibly cached/fast) fetch
        try
        {
            // Fetch all issues for every loaded epic (broader than GetEpicReportAsync —
            // covers both classic Epic Link and next-gen parent relationships)
            foreach (var epicKey in LoadedEpics.Keys.ToList())
            {
                try
                {
                    var epicReport = await JiraService.GetAllEpicIssuesAsync(epicKey);
                    foreach (var issue in epicReport.Issues)
                        if (!string.IsNullOrEmpty(issue.Key))
                            _reportIssues[issue.Key] = issue;
                }
                catch { }
            }

            // Refresh individually-loaded tasks (not covered by an epic fetch above)
            if (LoadedTasks.Count > 0)
            {
                try
                {
                    var taskReport = await JiraService.GetIssuesByKeysAsync(LoadedTasks.Keys.ToList());
                    foreach (var issue in taskReport.Issues)
                        if (!string.IsNullOrEmpty(issue.Key))
                        {
                            _reportIssues[issue.Key] = issue;
                            LoadedTasks[issue.Key]   = issue;
                            _taskCache[issue.Id]     = issue;
                        }
                }
                catch { }
            }

            // Fallback: any allocated task still not found (moved/orphaned issues)
            var covered = _reportIssues.Keys.ToHashSet(StringComparer.OrdinalIgnoreCase);
            var missingKeys = Allocations
                .Select(a => a.TaskId).Where(id => id > 0).Distinct()
                .Select(GetJiraKeyForTaskId)
                .Where(k => k != null && !covered.Contains(k!))
                .Distinct()
                .Cast<string>().ToList();

            if (missingKeys.Count > 0)
            {
                try
                {
                    var fallbackReport = await JiraService.GetIssuesByKeysAsync(missingKeys);
                    foreach (var issue in fallbackReport.Issues)
                        if (!string.IsNullOrEmpty(issue.Key))
                            _reportIssues[issue.Key] = issue;
                }
                catch { }
            }

            // Refresh support bug issues (with up-to-date worklogs) for Time Logged column.
            // bugsOnly:false — must match the initial load (LoadSupportBugEpic): the epic contains
            // non-Bug types (Redesign, Task, Story) that carry logged work; excluding them here
            // silently dropped their worklogs on every refresh (e.g. Redesign issues → wrong totals).
            _supportBugIssues.Clear();
            foreach (var epicKey in LoadedSupportBugEpics.Keys.ToList())
            {
                try
                {
                    var bugReport = await JiraService.GetEpicBugsAsync(epicKey, bugsOnly: false);
                    LoadedSupportBugEpics[epicKey].Tasks = bugReport.Issues;
                    foreach (var issue in bugReport.Issues)
                        if (!string.IsNullOrEmpty(issue.Key))
                            _supportBugIssues[issue.Key] = issue;
                }
                catch { }
            }

            // Refresh feature bug epic issues — each "Feature Bug" custom task embeds an epic key in its title
            _featureBugIssuesByEpic.Clear();
            var featureBugKeys = _customTasks.Values
                .Where(ct => ct.Category == "Feature Bug")
                .Select(GetCustomTaskEpicKey)
                .Where(k => k != null).Select(k => k!)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToList();
            foreach (var epicKey in featureBugKeys)
            {
                try
                {
                    var bugReport = await JiraService.GetEpicBugsAsync(epicKey);
                    _featureBugIssuesByEpic[epicKey] = bugReport.Issues;
                }
                catch { }
            }
        }
        finally
        {
            _isRefreshingReport = false;
        }
    }

