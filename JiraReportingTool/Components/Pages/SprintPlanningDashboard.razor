                <div class="modal-header-row">
                    <span class="modal-title"><span class="td-cat-badge" style="background:@dtCt.Color">@dtCt.Category</span> @dtCt.Name</span>
                    <button class="modal-close-btn" @onclick="CloseTaskDetails">✕</button>
                </div>
                <div class="td-grid">
                    <div class="td-field"><span class="td-label">Category</span><span class="td-value">@dtCt.Category</span></div>
                    <div class="td-field"><span class="td-label">Planned</span><span class="td-value">@($"{dtCt.Hours:0.#}h")</span></div>
                    <div class="td-field"><span class="td-label">Scheduled</span><span class="td-value">@($"{dtPlanned:0.#}h")</span></div>
                    <div class="td-field"><span class="td-label">Assigned to</span><span class="td-value">@(dtMembers.Count > 0 ? string.Join(", ", dtMembers) : "—")</span></div>
                    @if (!string.IsNullOrEmpty(dtEpic))
                    {
                        <div class="td-field"><span class="td-label">Epic</span><span class="td-value"><a href="@JiraBrowseUrl(dtEpic!)" target="_blank">@dtEpic ↗</a></span></div>
                    }
                </div>
            }
            else
            {
                var dtIssue = GetTaskIssue(dtId);
                var dtKey   = GetJiraKeyForTaskId(dtId);
                @if (dtIssue is null)
                {
                    <div class="modal-header-row">
                        <span class="modal-title">@(dtKey ?? $"#{dtId}")</span>
                        <button class="modal-close-btn" @onclick="CloseTaskDetails">✕</button>
                    </div>
                    <p class="modal-body">No Jira data loaded for this task yet. Open the <strong>Report</strong> tab to refresh, then try again.</p>
                    @if (!string.IsNullOrEmpty(dtKey))
                    {
                        <div class="td-actions"><a class="btn primary small" href="@JiraBrowseUrl(dtKey)" target="_blank">Open in Jira ↗</a></div>
                    }
                }
                else
                {
                    <div class="modal-header-row">
                        <span class="modal-title"><span class="td-key">@dtIssue.Key</span> @dtIssue.Summary</span>
                        <button class="modal-close-btn" @onclick="CloseTaskDetails">✕</button>
                    </div>
                    <div class="td-grid">
                        <div class="td-field"><span class="td-label">Status</span><span class="td-value"><span class="rpt-status-chip @GetStatusClass(dtIssue.Status)">@(string.IsNullOrEmpty(dtIssue.Status) ? "—" : dtIssue.Status)</span></span></div>
                        <div class="td-field"><span class="td-label">Assignee</span><span class="td-value">@dtIssue.Assignee</span></div>
                        <div class="td-field"><span class="td-label">Type</span><span class="td-value">@(string.IsNullOrEmpty(dtIssue.IssueType) ? "—" : dtIssue.IssueType)</span></div>
                        <div class="td-field"><span class="td-label">Priority</span><span class="td-value">@dtIssue.Priority</span></div>
                        <div class="td-field"><span class="td-label">Epic</span>
                            <span class="td-value">
                                @if (string.IsNullOrEmpty(dtIssue.EpicKey))
                                {
                                    <span>—</span>
                                }
                                else
                                {
                                    <a href="@JiraBrowseUrl(dtIssue.EpicKey)" target="_blank">@dtIssue.EpicKey</a>
                                    <span class="td-epic-name">@dtIssue.EpicName</span>
                                }
                            </span>
                        </div>
                        <div class="td-field"><span class="td-label">Original Est.</span><span class="td-value">@FormatEstimate(dtIssue.OriginalEstimate, dtIssue.OriginalEstimateSeconds)</span></div>
                        <div class="td-field"><span class="td-label">Time Logged</span><span class="td-value">@FormatEstimate(dtIssue.TimeSpent, dtIssue.TimeSpentSeconds)</span></div>
                        <div class="td-field"><span class="td-label">Remaining</span><span class="td-value">@FormatEstimate(dtIssue.RemainingEstimate, dtIssue.ComputedRemainingSeconds)</span></div>
                        <div class="td-field"><span class="td-label">Due</span><span class="td-value">@(dtIssue.DueDate?.ToString("dd MMM yyyy") ?? "—")</span></div>
                        <div class="td-field"><span class="td-label">Scheduled</span><span class="td-value">@($"{dtPlanned:0.#}h") · @(dtMembers.Count > 0 ? string.Join(", ", dtMembers) : "—")</span></div>
                    </div>
                    <div class="td-actions">
                        <a class="btn primary small" href="@JiraBrowseUrl(dtIssue.Key)" target="_blank">Open in Jira ↗</a>
                    </div>
                }
            }
        </div>
    }
</div>

@code {
    // ───────────────────────────────────────────────────────────
    // Types
    // ───────────────────────────────────────────────────────────
    public record TeamMemberDto(Guid Id, string Name, string Team);

    public class TaskAllocation
    {
