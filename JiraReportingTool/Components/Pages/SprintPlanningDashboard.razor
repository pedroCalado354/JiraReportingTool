    /* Task list */
    .task-list {
        list-style: none;
        padding: 4px 8px;
        margin: 0;
        display: grid;
        gap: 5px;
    }

    .task-item {
        border: 1px solid #e5e7eb;
        border-left: 3px solid transparent;
        border-radius: 8px;
        padding: 8px 10px;
        background: #fff;
        cursor: pointer;
        transition: all 0.15s;
    }

        .task-item:hover { border-color: #bfdbfe; box-shadow: 0 1px 4px rgba(59,130,246,0.07); }
        .task-item.selected { border-color: #93c5fd; border-left-color: #3b82f6; background: #eff6ff; }
        .task-item.assigned { border-left-color: #10b981; }

    .task-item-top {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-bottom: 3px;
    }

    .task-key-label {
        font-weight: 700;
        font-size: 12px;
        color: #1d4ed8;
    }

    .badge-assigned {
