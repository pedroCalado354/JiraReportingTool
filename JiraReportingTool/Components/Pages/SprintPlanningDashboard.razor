    // ───────────────────────────────────────────────────────────
    // Individual task loading (by Jira key, not via an epic)
    // ───────────────────────────────────────────────────────────
    private static IEnumerable<string> ParseTaskKeys(string input) =>
        input.Split(new[] { ',', ' ', ';', '\n', '\t', '\r' }, StringSplitOptions.RemoveEmptyEntries)
             .Select(k => k.Trim().ToUpperInvariant())
             .Where(k => k.Length > 0)
             .Distinct();

    // Jira issues are fetched with Id == 0 (the EF PK default). The planner keys tasks,
    // allocations and calendar blocks by this int Id, so leaving every loaded task at 0
    // makes them collide — GetAllTasks() collapses them and the calendar shows only the
    // most-recently-loaded one (e.g. JM-12452 "turning into" JM-14513). Stamp each task
    // with its numeric Jira id: unique, positive (custom tasks use negative ids) and stable
    // across reloads so persisted allocations keep matching.
    private static void AssignStableTaskId(SprintIssue t)
    {
        if (t.Id != 0 || string.IsNullOrEmpty(t.JiraId)) return;
        if (long.TryParse(t.JiraId, out var jid) && jid > 0)
            t.Id = jid <= int.MaxValue ? (int)jid : (int)(jid % int.MaxValue) + 1;
    }

    private async Task LoadTasks()
    {
        ErrorMessage = null;
        InfoMessage = null;

        var keys = ParseTaskKeys(TaskKeysInput)
            .Where(k => !LoadedTasks.ContainsKey(k))
            .ToList();
        if (keys.Count == 0) { ErrorMessage = "Enter one or more task keys (e.g. JM-123, JM-456)."; return; }

        _isLoadingTasks = true;
        TaskKeysInput = "";
        StateHasChanged();

        try
        {
            var report = await JiraService.GetIssuesByKeysAsync(keys);
            var found = report?.Issues ?? new List<SprintIssue>();
            foreach (var t in found)
            {
                if (string.IsNullOrEmpty(t.Key)) continue;
                AssignStableTaskId(t);
                _taskCache[t.Id] = t;
                LoadedTasks[t.Key] = t;
            }

            var foundKeys = found.Select(t => t.Key).ToHashSet(StringComparer.OrdinalIgnoreCase);
            var missing   = keys.Where(k => !foundKeys.Contains(k)).ToList();
            InfoMessage = $"Loaded {found.Count} task(s)."
                        + (missing.Count > 0 ? $" Not found: {string.Join(", ", missing)}." : "");
        }
        catch (Exception ex) { ErrorMessage = $"Failed to load tasks: {ex.Message}"; }
        finally { _isLoadingTasks = false; }
    }

